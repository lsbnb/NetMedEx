"], "database": "ncbi_mesh", "normalized_id": "C030985", "biotype": "chemical", "name": "purine", "accession": "@CHEMICAL_purine"}, "role2": {"identifier": "MESH:D029424", "type": "Disease", "valid": true, "normalized": ["D029424"], "database": "ncbi_mesh", "normalized_id": "D029424", "biotype": "disease", "name": "Pulmonary Disease Chronic Obstructive", "accession": "@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, "type": "Association"}, "nodes": [{"refid": "10", "role": "47,50"}]}, {"id": "R12", "infons": {"score": "0.8745", "role1": {"identifier": "MESH:C030985", "type": "Chemical", "valid": true, "normalized": ["C030985"], "database": "ncbi_mesh", "normalized_id": "C030985", "biotype": "chemical", "name": "purine", "accession": "@CHEMICAL_purine"}, "role2": {"identifier": "MESH:D014527", "type": "Chemical", "valid": true, "normalized": ["D014527"], "database": "ncbi_mesh", "normalized_id": "D014527", "biotype": "chemical", "name": "Uric Acid", "accession": "@CHEMICAL_Uric_Acid"}, "type": "Association"}, "nodes": [{"refid": "11", "role": "47,48"}]}], "pmid": 41893329, "pmcid": null, "meta": {}, "date": "2026-03-07T00:00:00Z", "journal": "Metabolites", "authors": ["Casadevall C", "Enríquez-Rodríguez CJ", "Eliassaf A", "Castro-Acosta A", "Faner R", "López-Campos JL", "Monsó E", "Pascual-Guàrdia S", "Camps-Ubach R", "Cosío BG", "Agustí A", "Shalev O", "Gea J", "On Behalf Of The Biomepoc Group"], "relations_display": [{"name": "associate|@CHEMICAL_3_methylhistidine|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_Linoleic_Acids_Conjugated|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_5_nitro_2_toluidine|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_Bile_Acids_and_Salts|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_Creatine|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_Creatinine|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_Uric_Acid|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_purine|@DISEASE_Inflammation"}, {"name": "associate|@CHEMICAL_gallium_arsenide|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_Fructose|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_purine|@DISEASE_Pulmonary_Disease_Chronic_Obstructive"}, {"name": "associate|@CHEMICAL_purine|@CHEMICAL_Uric_Acid"}]}, {"_id": "41893481|None", "id": "41893481", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Safety Assessment of Lemon Myrtle (Backhousia citriodora) Extract: 28-Day Oral Toxicity Study in Rats and In Vitro and In Vivo Genotoxicity Studies.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "39976", "type": "Species", "valid": true, "normalized": [39976], "database": "ncbi_taxonomy", "normalized_id": 39976, "biotype": "species", "name": "39976", "accession": null}, "text": "Backhousia citriodora", "locations": [{"offset": 35, "length": 21}]}, {"id": "5", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mesh", "normalized_id": "D064420", "biotype": "disease", "name": "Drug-Related Side Effects and Adverse Reactions", "accession": "@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions"}, "text": "Toxicity", "locations": [{"offset": 79, "length": 8}]}, {"id": "6", "infons": {"identifier": "10116", "type": "Species", "valid": true, "normalized": [10116], "database": "ncbi_taxonomy", "normalized_id": 10116, "biotype": "species", "name": "10116", "accession": null}, "text": "Rats", "locations": [{"offset": 97, "length": 4}]}, {"id": "7", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "Genotoxicity", "locations": [{"offset": 127, "length": 12}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 149, "text": "The essential oil or extract of Lemon myrtle (Backhousia citriodora F. Muell.), belonging to the family Myrtaceae and the genus Backhousia, exhibits anti-inflammatory and antioxidant properties. However, limited information exists on the safety of water extracts from its leaves. The present study aimed to assess the safety of lemon myrtle water extract as a functional food by performing genotoxicity studies and repeated-dose oral toxicity. Although the bacterial reverse mutation test (Ames test) yielded positive results, in vivo mammalian erythrocyte micronucleus and alkaline comet assays yielded negative results. In a 28-day oral toxicity study, the extract was orally administered to male and female Crl:CD rats at doses of 0, 250, 500, and 1000 mg/kg bw/day. Notably, the extract induced no adverse effects, and the no-observed-adverse-effect level was 1000 mg/kg bw/day in male and female rats. Despite its genotoxicity in vitro, the extract did not exhibit genotoxicity in vivo. Moreover, no signs of toxicity were observed in the general toxicity study. Overall, these results suggest that lemon myrtle water extract does not pose a substantive genotoxic risk at practical oral exposure levels.", "sentences": [], "annotations": [{"id": "23", "infons": {"identifier": "MESH:D009822", "type": "Chemical", "valid": true, "normalized": ["D009822"], "database": "ncbi_mesh", "normalized_id": "D009822", "biotype": "chemical", "name": "Oils Volatile", "accession": "@CHEMICAL_Oils_Volatile"}, "text": "essential oil", "locations": [{"offset": 153, "length": 13}]}, {"id": "24", "infons": {"identifier": "39976", "type": "Species", "valid": true, "normalized": [39976], "database": "ncbi_taxonomy", "normalized_id": 39976, "biotype": "species", "name": "39976", "accession": null}, "text": "Backhousia citriodora F. Muell", "locations": [{"offset": 195, "length": 30}]}, {"id": "25", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 303, "length": 12}]}, {"id": "26", "infons": {"identifier": "MESH:D014867", "type": "Chemical", "valid": true, "normalized": ["D014867"], "database": "ncbi_mesh", "normalized_id": "D014867", "biotype": "chemical", "name": "Water", "accession": "@CHEMICAL_Water"}, "text": "water", "locations": [{"offset": 397, "length": 5}]}, {"id": "27", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "genotoxicity", "locations": [{"offset": 539, "length": 12}]}, {"id": "28", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mesh", "normalized_id": "D064420", "biotype": "disease", "name": "Drug-Related Side Effects and Adverse Reactions", "accession": "@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions"}, "text": "toxicity", "locations": [{"offset": 583, "length": 8}]}, {"id": "29", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "mammalian", "locations": [{"offset": 684, "length": 9}]}, {"id": "30", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mesh", "normalized_id": "D064420", "biotype": "disease", "name": "Drug-Related Side Effects and Adverse Reactions", "accession": "@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions"}, "text": "toxicity", "locations": [{"offset": 788, "length": 8}]}, {"id": "31", "infons": {"identifier": "MESH:D002104", "type": "Chemical", "valid": true, "normalized": ["D002104"], "database": "ncbi_mesh", "normalized_id": "D002104", "biotype": "chemical", "name": "Cadmium", "accession": "@CHEMICAL_Cadmium"}, "text": "CD", "locations": [{"offset": 863, "length": 2}]}, {"id": "32", "infons": {"identifier": "10116", "type": "Species", "valid": true, "normalized": [10116], "database": "ncbi_taxonomy", "normalized_id": 10116, "biotype": "species", "name": "10116", "accession": null}, "text": "rats", "locations": [{"offset": 866, "length": 4}]}, {"id": "33", "infons": {"identifier": "10116", "type": "Species", "valid": true, "normalized": [10116], "database": "ncbi_taxonomy", "normalized_id": 10116, "biotype": "species", "name": "10116", "accession": null}, "text": "rats", "locations": [{"offset": 1050, "length": 4}]}, {"id": "34", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "genotoxicity", "locations": [{"offset": 1068, "length": 12}]}, {"id": "35", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "genotoxicity", "locations": [{"offset": 1119, "length": 12}]}, {"id": "36", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mesh", "normalized_id": "D064420", "biotype": "disease", "name": "Drug-Related Side Effects and Adverse Reactions", "accession": "@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions"}, "text": "toxicity", "locations": [{"offset": 1163, "length": 8}]}, {"id": "37", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mesh", "normalized_id": "D064420", "biotype": "disease", "name": "Drug-Related Side Effects and Adverse Reactions", "accession": "@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions"}, "text": "toxicity", "locations": [{"offset": 1201, "length": 8}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9979", "role1": {"identifier": "MESH:D009822", "type": "Chemical", "valid": true, "normalized": ["D009822"], "database": "ncbi_mesh", "normalized_id": "D009822", "biotype": "chemical", "name": "Oils Volatile", "accession": "@CHEMICAL_Oils_Volatile"}, "role2": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "4,6"}]}], "pmid": 41893481, "pmcid": null, "meta": {}, "date": "2026-02-28T00:00:00Z", "journal": "Toxics", "authors": ["Yamaguchi T", "Honda S", "Fujii T", "Yamamoto A", "Itoh K", "Ueda M", "Masumori S", "Kubo H"], "relations_display": [{"name": "treat|@CHEMICAL_Oils_Volatile|@DISEASE_Inflammation"}]}, {"_id": "41915085|None", "id": "41915085", "infons": {}, "passages": [{"infons": {"journal": "Mol Biomed;2026Mar31; 7 (1) . doi:10.1186/s43556-026-00423-6", "year": "2026", "article-id_pmc": "3836174", "type": "title", "authors": "Liang J, Zang S, Wang Z, Zhang R, "}, "offset": 0, "text": "Cancer and aging: complex associations and therapeutic targets.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "Cancer", "locations": [{"offset": 0, "length": 6}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 64, "text": "The incidence of cancer increases markedly with aging, and the two processes share underlying molecular mechanisms. In the context of global population aging and rising cancer incidence, nine convergent hallmark axes have been identified: genomic instability, epigenetic drift, inflammation-immunity imbalance, microbiome dysbiosis, metabolic reprogramming, telomere attrition, stem cell exhaustion, cellular senescence, and autophagy dysfunction. These hallmarks constitute an integrated regulatory network that operates synergistically, antagonistically, or through bidirectional feedback across molecular, cellular, and microenvironmental levels. Genomic instability, epigenetic remodeling, chronic inflammation, microbiome dysbiosis, and metabolic reprogramming in aging often act synergistically to promote tumorigenesis, whereas telomere attrition and stem cell exhaustion primarily exert antagonistic, tumor-suppressive effects. Cellular senescence and autophagy dysfunction display context-dependent dual roles. Importantly, this network framework has direct relevance to cancer therapeutics. Although chemotherapy, radiotherapy, and immunotherapy effectively suppress tumor progression, they frequently induce therapy-induced senescence, characterized by cell-cycle arrest and a senescence-associated secretory phenotype, thereby accelerating functional decline and increasing long-term toxicities in older patients. The proposed \"synergistic-antagonistic-dual\" framework linking aging and cancer not only helps explain the disproportionate cancer burden in older adults but also supports a \"one drug, two targets\" therapeutic paradigm. Targeting these shared pathways has delayed aging phenotypes and suppressed tumorigenesis in preclinical studies and early clinical trials, highlighting the potential of integrated interventions that concurrently address aging and cancer.", "sentences": [], "annotations": [{"id": "17", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 81, "length": 6}]}, {"id": "18", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 233, "length": 6}]}, {"id": "19", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 342, "length": 12}]}, {"id": "20", "infons": {"identifier": "MESH:D002908", "type": "Disease", "valid": true, "normalized": ["D002908"], "database": "ncbi_mesh", "normalized_id": "D002908", "biotype": "disease", "name": "Chronic Disease", "accession": "@DISEASE_Chronic_Disease"}, "text": "chronic", "locations": [{"offset": 758, "length": 7}]}, {"id": "21", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 766, "length": 12}]}, {"id": "22", "infons": {"identifier": "MESH:D063646", "type": "Disease", "valid": true, "normalized": ["D063646"], "database": "ncbi_mesh", "normalized_id": "D063646", "biotype": "disease", "name": "Carcinogenesis", "accession": "@DISEASE_Carcinogenesis"}, "text": "tumorigenesis", "locations": [{"offset": 876, "length": 13}]}, {"id": "23", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "tumor", "locations": [{"offset": 973, "length": 5}]}, {"id": "24", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 1144, "length": 6}]}, {"id": "25", "infons": {"identifier": "MESH:D009369", "type"