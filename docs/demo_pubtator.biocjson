89], "database": "ncbi_gene", "normalized_id": 100508689, "biotype": "gene", "name": "LOC100508689", "accession": "@GENE_LOC100508689"}, "text": "mucin", "locations": [{"offset": 1196, "length": 5}]}, {"id": "40", "infons": {"identifier": "375288", "type": "Species", "valid": true, "normalized": [375288], "database": "ncbi_taxonomy", "normalized_id": 375288, "biotype": "species", "name": "375288", "accession": null}, "text": "Parabacteroides", "locations": [{"offset": 1255, "length": 15}]}, {"id": "41", "infons": {"identifier": "46503", "type": "Species", "valid": true, "normalized": [46503], "database": "ncbi_taxonomy", "normalized_id": 46503, "biotype": "species", "name": "46503", "accession": null}, "text": "P. merdae", "locations": [{"offset": 1306, "length": 9}]}, {"id": "42", "infons": {"identifier": "MESH:D019158", "type": "Chemical", "valid": true, "normalized": ["D019158"], "database": "ncbi_mesh", "normalized_id": "D019158", "biotype": "chemical", "name": "N-Acetylneuraminic Acid", "accession": "@CHEMICAL_N_Acetylneuraminic_Acid"}, "text": "sialic acid", "locations": [{"offset": 1330, "length": 11}]}, {"id": "43", "infons": {"identifier": "MESH:D019158", "type": "Chemical", "valid": true, "normalized": ["D019158"], "database": "ncbi_mesh", "normalized_id": "D019158", "biotype": "chemical", "name": "N-Acetylneuraminic Acid", "accession": "@CHEMICAL_N_Acetylneuraminic_Acid"}, "text": "sialic acid", "locations": [{"offset": 1432, "length": 11}]}, {"id": "44", "infons": {"identifier": "100508689", "type": "Gene", "valid": true, "normalized": [100508689], "database": "ncbi_gene", "normalized_id": 100508689, "biotype": "gene", "name": "LOC100508689", "accession": "@GENE_LOC100508689"}, "text": "mucin", "locations": [{"offset": 1496, "length": 5}]}, {"id": "45", "infons": {"identifier": "MESH:D019158", "type": "Chemical", "valid": true, "normalized": ["D019158"], "database": "ncbi_mesh", "normalized_id": "D019158", "biotype": "chemical", "name": "N-Acetylneuraminic Acid", "accession": "@CHEMICAL_N_Acetylneuraminic_Acid"}, "text": "sialic acid", "locations": [{"offset": 1510, "length": 11}]}, {"id": "46", "infons": {"identifier": "100508689", "type": "Gene", "valid": true, "normalized": [100508689], "database": "ncbi_gene", "normalized_id": 100508689, "biotype": "gene", "name": "LOC100508689", "accession": "@GENE_LOC100508689"}, "text": "mucin", "locations": [{"offset": 1657, "length": 5}]}, {"id": "47", "infons": {"identifier": "MESH:D019158", "type": "Chemical", "valid": true, "normalized": ["D019158"], "database": "ncbi_mesh", "normalized_id": "D019158", "biotype": "chemical", "name": "N-Acetylneuraminic Acid", "accession": "@CHEMICAL_N_Acetylneuraminic_Acid"}, "text": "sialic acid", "locations": [{"offset": 1674, "length": 11}]}, {"id": "48", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 1929, "length": 12}]}, {"id": "49", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "inflammaging", "locations": [{"offset": 1996, "length": 12}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9992", "role1": {"identifier": "MESH:D019158", "type": "Chemical", "valid": true, "normalized": ["D019158"], "database": "ncbi_mesh", "normalized_id": "D019158", "biotype": "chemical", "name": "N-Acetylneuraminic Acid", "accession": "@CHEMICAL_N_Acetylneuraminic_Acid"}, "role2": {"identifier": "100508689", "type": "Gene", "valid": true, "normalized": [100508689], "database": "ncbi_gene", "normalized_id": 100508689, "biotype": "gene", "name": "LOC100508689", "accession": "@GENE_LOC100508689"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "22,21"}]}], "pmid": 41665182, "pmcid": null, "meta": {}, "date": "2026-12-31T00:00:00Z", "journal": "Gut Microbes", "authors": ["Fujiwara S", "Park J", "Takeda M", "Miyatake T", "Saito Y", "Makino S", "Kim YG"], "relations_display": [{"name": "associate|@CHEMICAL_N_Acetylneuraminic_Acid|@GENE_LOC100508689"}]}, {"_id": "41667791|None", "id": "41667791", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Insulin resistance: mechanisms and therapeutic interventions.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "Insulin resistance", "locations": [{"offset": 0, "length": 18}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 62, "text": "Insulin is an important endocrine peptide hormone with pleiotropic effects on metabolic regulation and cellular growth. Insulin resistance (IR), characterized by insensitivity of metabolic tissues to insulin stimulation, has emerged as a major impediment to overall metabolic health. Triggered by multiple environmental factors and genetic predisposition, IR paves the way for several related diseases, including metabolic associated diseases, cardiovascular diseases and cancer. Of note, the liver plays a central role in whole-body metabolism and is the portal encountering high concentrations of insulin. Excess glucose, lipids and the compensatory hyperinsulinemia resulting from IR may collectively impose a huge burden on the liver, driving the progression of chronic liver diseases and fostering a pro-carcinogenic environment by increasing mutagenic susceptibility and angiogenic dysregulation. Better understanding of this mechanistic link is important to highlight the underestimated role of IR in progressive diseases and may contribute to stratified diagnosis and treatment. This review summarizes the risk factors and molecular mechanisms of IR, with a specific focus on its role in carcinogenesis, taking hepatocellular carcinoma (HCC) as an example. Finally, we discuss the effective lifestyle and pharmacological interventions for IR and emphasize the necessity of incorporating IR management into the prevention, stratified diagnosis and treatment of HCC.", "sentences": [], "annotations": [{"id": "24", "infons": {"identifier": "3630", "type": "Gene", "ncbi_homologene": "173", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "text": "Insulin", "locations": [{"offset": 62, "length": 7}]}, {"id": "25", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "Insulin resistance", "locations": [{"offset": 182, "length": 18}]}, {"id": "26", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 202, "length": 2}]}, {"id": "27", "infons": {"identifier": "3630", "type": "Gene", "ncbi_homologene": "173", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "text": "insulin", "locations": [{"offset": 262, "length": 7}]}, {"id": "28", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 418, "length": 2}]}, {"id": "29", "infons": {"identifier": "MESH: