s": [{"offset": 1441, "length": 4}]}, {"id": "41", "infons": {"identifier": "MESH:D001284", "type": "Disease", "valid": true, "normalized": ["D001284"], "database": "ncbi_mesh", "normalized_id": "D001284", "biotype": "disease", "name": "Atrophy", "accession": "@DISEASE_Atrophy"}, "text": "atrophy", "locations": [{"offset": 1576, "length": 7}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9987", "role1": {"identifier": "MESH:C005958", "type": "Chemical", "valid": true, "normalized": ["C005958"], "database": "ncbi_mesh", "normalized_id": "C005958", "biotype": "chemical", "name": "palmidrol", "accession": "@CHEMICAL_palmidrol"}, "role2": {"identifier": "18033", "type": "Gene", "valid": true, "normalized": [18033], "database": "ncbi_gene", "normalized_id": 18033, "biotype": "gene", "name": "Nfkb1", "accession": "@GENE_NFKB1"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "17,12"}]}, {"id": "R2", "infons": {"score": "0.8716", "role1": {"identifier": "MESH:C005958", "type": "Chemical", "valid": true, "normalized": ["C005958"], "database": "ncbi_mesh", "normalized_id": "C005958", "biotype": "chemical", "name": "palmidrol", "accession": "@CHEMICAL_palmidrol"}, "role2": {"identifier": "MESH:D001284", "type": "Disease", "valid": true, "normalized": ["D001284"], "database": "ncbi_mesh", "normalized_id": "D001284", "biotype": "disease", "name": "Atrophy", "accession": "@DISEASE_Atrophy"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "1", "role": "17,20"}]}, {"id": "R3", "infons": {"score": "0.9921", "role1": {"identifier": "MESH:C005958", "type": "Chemical", "valid": true, "normalized": ["C005958"], "database": "ncbi_mesh", "normalized_id": "C005958", "biotype": "chemical", "name": "palmidrol", "accession": "@CHEMICAL_palmidrol"}, "role2": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "17,18"}]}], "pmid": 41693292, "pmcid": null, "meta": {}, "date": "2026-02-01T00:00:00Z", "journal": "Physiol Rep", "authors": ["Cole PL", "Gillham SH", "Viggars MR", "Close GL", "Owens DJ"], "relations_display": [{"name": "negative_correlate|@CHEMICAL_palmidrol|@GENE_NFKB1"}, {"name": "treat|@CHEMICAL_palmidrol|@DISEASE_Atrophy"}, {"name": "treat|@CHEMICAL_palmidrol|@DISEASE_Inflammation"}]}, {"_id": "41708628|None", "id": "41708628", "infons": {}, "passages": [{"infons": {"journal": "NPJ Aging;2026Feb18. doi:10.1038/s41514-026-00336-2", "year": "2026", "type": "title", "authors": "Anwar M, Kaur P, Gupta D, Chakrawarty A, Dey AB, Dey S, "}, "offset": 0, "text": "Molecular insight into transcriptome profiling of aerobic exercise induced changes in aged skeletal muscle.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 108, "text": "Skeletal muscle aging causes loss of both muscle mss and strength, often leading to sarcopenia. Clinical manifestation of sarcopenia has been found to improve with exercise intervention. The molecular mechanisms in response to exercise intervention in aged skeletal muscles are not fully understood. We performed transcriptomic profiling of aged animal model with exercise intervention for identifying the plausible mechanism leading to enhanced muscle function. Expression levels of 43,629 RNAs were analyzed for the process of aging and exercise intervention. Differentially expressed genes showed 22,196 protein-coding and 21,433 non-coding RNAs that were found to be significantly altered with intervention. Genes associated with extracellular matrix and inflammatory responses exhibited significant change with intervention. Slpi (Secretory Leukocyte Protease Inhibitor)- a vital gene in the intervention group with its role as an inflammatory regulator and tissue repair gene. The activation of quisqualate receptor, neurotransmitter receptors and postsynaptic signal transmission pathways were most relevant for upregulated genes in the intervention group. Downregulated genes in the intervention group were mostly associated with ATP-dependent protein disaggregase activity. Our study provides a comprehensive analysis of the global transcriptome that governs aerobic exercise induced changes in aged muscle leading to compensatory adaptation with exercise in aged model group.", "sentences": [], "annotations": [{"id": "9", "infons": {"identifier": "MESH:D016388", "type": "Disease", "valid": true, "normalized": ["D016388"], "database": "ncbi_mesh", "normalized_id": "D016388", "biotype": "disease", "name": "Tooth Loss", "accession": "@DISEASE_Tooth_Loss"}, "text": "loss of", "locations": [{"offset": 137, "length": 7}]}, {"id": "10", "infons": {"identifier": "MESH:D019042", "type": "Disease", "valid": true, "normalized": ["D019042"], "database": "ncbi_mesh", "normalized_id": "D019042", "biotype": "disease", "name": "Muscle Neoplasms", "accession": "@DISEASE_Muscle_Neoplasms"}, "text": "muscle mss and strength", "locations": [{"offset": 150, "length": 23}]}, {"id": "11", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 192, "length": 10}]}, {"id": "12", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 230, "length": 10}]}, {"id": "13", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 867, "length": 12}]}, {"id": "14", "infons": {"identifier": "6590", "type": "Gene", "ncbi_homologene": "2305", "valid": true, "normalized": [6590], "database": "ncbi_gene", "normalized_id": 6590, "biotype": "gene", "name": "SLPI", "accession": "@GENE_SLPI"}, "text": "Slpi", "locations": [{"offset": 938, "length": 4}]}, {"id": "15", "infons": {"identifier": "6590", "type": "Gene", "ncbi_homologene": "2305", "valid": true, "normalized": [6590], "database": "ncbi_gene", "normalized_id": 6590, "biotype": "gene", "name": "SLPI", "accession": "@GENE_SLPI"}, "text": "Secretory Leukocyte Protease Inhibitor", "locations": [{"offset": 944, "length": 38}]}, {"id": "16", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 1044, "length": 12}]}, {"id": "17", "infons": {"identifier": "MESH:D000255", "type": "Chemical", "valid": true, "normalized": ["D000255"], "database": "ncbi_mesh", "normalized_id": "D000255", "biotype": "chemical", "name": "Adenosine Triphosphate", "accession": "@CHEMICAL_Adenosine_Triphosphate"}, "text": "ATP", "locations": [{"offset": 1346, "length": 3}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9995", "role1": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "6590", "type": "Gene", "valid": true, "normalized": [6590], "database": "ncbi_gene", "normalized_id": 6590, "biotype": "gene", "name": "SLPI", "accession": "@GENE_SLPI"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "7,6"}]}], "pmid": 41708628, "pmcid": null, "meta": {}, "date": "2026-02-18T00:00:00Z", "journal": "NPJ Aging", "authors": ["Anwar M", "Kaur P", "Gupta D", "Chakrawarty A", "Dey AB", "Dey S"], "relations_display": [{"name": "associate|@DISEASE_Inflammation|@GENE_SLPI"}]}, {"_id": "41716280|None", "id": "41716280", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Exploring osteosarcopenia from the gut microbiota perspective: mechanistic insights and therapeutic potentials based on the gut-muscle-bone Axis.", "sentences": [], "annotations": [{"id": "1", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "osteosarcopenia", "locations": [{"offset": 10, "length": 15}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 146, "text": "The aging society presents a growing challenge in the form of osteosarcopenia (OS). This syndrome is marked by the concomitant deterioration of bone (osteoporosis) and muscle (sarcopenia), and significantly elevates the risks of fractures, disability, and mortality. Despite its clinical relevance, the shared pathophysiology and effective interventions for OS remain elusive. Emerging evidence highlights the gut microbiota (GM) as a critical modulator of musculoskeletal health. This review integrates current evidence to delineate \"gut-muscle-bone Axis\" framework, summarizing current evidence on how GM dysbiosis may be involved in OS through multifaceted mechanisms, including intestinal barrier disruption, chronic inflammation, endocrine dysregulation, impaired nutrient absorption, and disrupted muscle-bone crosstalk. GM-derived metabolites, such as short-chain fatty acids (SCFAs), interact with immune, metabolic, and hormonal pathways to influence osteoblast/osteoclast activity and muscle protein synthesis. Furthermore, systemic inflammation triggered by GM imbalance exacerbates bone resorption and muscle atrophy. The axis also highlights bidirectional feedback between muscle and bone, mediated by myokines (e.g., irisin) and osteokines (e.g., osteocalcin), which synergistically regulate musculoskeletal homeostasis. Therapeutic strategies targeting GM modulation-such as dietary optimization (plant-based proteins, high-fiber diets), probiotics/prebiotics, exercise, and fecal microbiota transplantation (FMT)-suggest a potential capacity to modulate gut-muscle-bone interactions, which may be relevant to osteosarcopenia-related pathophysiological processes. This review proposes an integrative conceptual framework for understanding the pathogenesis of OS, synthesizing evidence primarily derived from osteoporosis and sarcopenia research, as well as animal and mechanistic studies. While direct clinical evidence in OS remains limited, emerging findings suggest that microbiota-centered strategies may hold potential for future preventive and therapeutic exploration.", "sentences": [], "annotations": [{"id": "22", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "osteosarcopenia", "locations": [{"offset": 208, "length": 15}]}, {"id": "23", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "OS", "locations": [{"offset": 225, "length": 2}]}, {"id": "24", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "osteoporosis", "locations": [{"offset": 296, "length": 12}]}, {"id": "25", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 322, "length": 10}]}, {"id": "26", "infons": {"identifier": "MESH:D050723", "type": "Disease", "valid": true, "normalized": ["D050723"], "database": "ncbi_mesh", "normalized_id": "D050723", "biotype": "disease", "name": "Fractures Bone", "accession": "@DISEASE_Fractures_Bone"}, "text": "fractures", "locations": [{"offset": 375, "length": 9}]}, {"id": "27", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "OS", "locations": [{"offset": 504, "length": 2}]}, {"id": "28", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "OS", "locations": [{"offset": 782, "length": 2}]}, {"id": "29", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 867, "length": 12}]}, {"id": "30", "infons": {"identifier": "MESH:D004700", "type": "Disease", "valid": true, "normalized": ["D004700"], "database": "ncbi_mesh", "normalized_id": "D004700", "biotype": "disease", "name": "Endocrine System Diseases", "accession": "@DISEASE_Endocrine_System_Diseases"}, "text": "endocrine dysregulation", "locations": [{"offset": 881, "length": 23}]}, {"id": "31", "infons": {"identifier": "MESH:D005232", "type": "Chemical", "valid": true, "normalized": ["D005232"], "database": "ncbi_mesh", "normalized_id": "D005232", "biotype": "chemical", "name": "Fatty Acids Volatile", "accession": "@CHEMICAL_Fatty_Acids_Volatile"}, "text": "short-chain fatty acids", "locations": [{"offset": 1005, "length": 23}]}, {"id": "32", "infons": {"identifier": "MESH:D005232", "type": "Chemical", "valid": true, "normalized": ["D005232"], "database": "ncbi_mesh", "normalized_id": "D005232", "biotype": "chemical", "name": "Fatty Acids Volatile", "accession": "@CHEMICAL_Fatty_Acids_Volatile"}, "text": "SCFAs", "locations": [{"offset": 1030, "length": 5}]}, {"id": "33", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 1189, "length": 12}]}, {"id": "34", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 1260, "length": 14}]}, {"id": "35", "infons": {"identifier": "252995", "type": "Gene", "ncbi_homologene": "17812", "valid": true, "normalized": [252995], "database": "ncbi_gene", "normalized_id": 252995, "biotype": "gene", "name": "FNDC5", "accession": "@GENE_FNDC5"}, "text": "irisin", "locations": [{"offset": 1377, "length": 6}]}, {"id": "36", "infons": {"identifier": "632", "type": "Gene", "ncbi_homologene": "104130", "valid": true, "normalized": [632], "database": "ncbi_gene", "normalized_id": 632, "biotype": "gene", "name": "BGLAP", "accession": "@GENE_BGLAP"}, "text": "osteocalcin", "locations": [{"offset": 1407, "length": 11}]}, {"id": "37", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "osteosarcopenia", "locations": [{"offset": 1771, "length": 15}]}, {"id": "38", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "OS", "locations": [{"offset": 1920, "length": 2}]}, {"id": "39", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "osteoporosis", "locations": [{"offset": 1969, "length": 12}]}, {"id": "40", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 1986, "length": 10}]}, {"id": "41", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "OS", "locations": [{"offset": 2084, "length": 2}]}], "relations": []}], "relations": [], "pmid": 41716280, "pmcid": null, "meta": {}, "date": "2026-02-04T00:00:00Z", "journal": "Front Microbiol", "authors": ["Jiang HB", "Zhang JQ", "Liang H", "Sun LY", "Deng CQ", "Yang SF"], "relations_display": []}, {"_id": "41732548|None", "id": "41732548", "infons": {}, "passages": [{"infons": {"journal": "Toxicol Rep;2026Jun; 16 102225. doi:10.1016/j.toxrep.2026.102225", "year": "2026", "article-id_pmc": "PMC12925566", "type": "title", "authors": "Kassid AA, Mahmood AM, Obaid KA, Philip Rahmani MH, "}, "offset": 0, "text": "Telmisartan protects male reproductive function by modulating biochemical, oxidative stress, apoptosis, and DNA integrity in cyclophosphamide-exposed rats.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:D000077333", "type": "Chemical", "valid": true, "normalized": ["D000077333"], "database": "ncbi_mesh", "normalized_id": "D000077333", "biotype": "chemical", "name": "Telmisartan", "accession": "@CHEMICAL_Telmisartan"}, "text": "Telmisartan", "locations": [{"offset": 0, "length": 11}]}, {"id": "4", "infons": {"identifier": "MESH:D003520", "type": "Chemical", "valid": true, "normalized": ["D003520"], "database": "ncbi_mesh", "normalized_id": "D003520", "biotype": "chemical", "name": "Cyclophosphamide", "accession": "@CHEMICAL_Cyclophosphamide"}, "text": "cyclophosphamide", "locations": [{"offset": 125, "length": 16}]}, {"id": "5", "infons": {"identifier": "10116", "type": "Species", "valid": true, "normalized": [10116], "database": "ncbi_taxonomy", "normalized_id": 10116, "biotype": "species", "name": "10116", "accession": null}, "text": "rats", "locations": [{"offset": 150, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 156, "text": "Background: Cyclophosphamide (CPA) is a common chemotherapy drug known to cause significant damage to testicular health. It induces oxidative stress, inflammation, cell death, and DNA damage. Telmisartan blocks the angiotensin II type 1 receptor and has some activity on PPAR-gamma, a receptor involved in cell regulation. It has been shown to have antioxidant and cell-protecting effects in other organs, but its potential to safeguard reproductive health has not been thoroughly investigated. Objective: This study aimed to evaluate the protection exerted by telmisartan against CPA-induced testicular injury in rats, addressing its anti-inflammatory and anti-apoptotic mechanisms. Methods: 56 adult male Sprague-Dawley rats were randomized into seven groups: control, telmisartan control, CPA induction, three telmisartan treatment groups (3, 5, and 7 mg/kg/day), and a melatonin positive control. Treatments have been given for 8 days; CPA (150 mg/kg, i.p.) on the second day. The serum reproductive hormones, sperm quality, oxidative stress factors, apoptotic genes (Bax, Bcl-2, caspase-3), DNA fragmentation, and histopathology were assessed. Results: CPA inhibited testosterone, LH, and FSH, decreased sperm quality, increased oxidative stress, proapoptotic markers, and induced DNA fragmentation. Telmisartan improved all of these parameters by administration on a dose-dependent basis, and the treatment with higher doses returned hormone levels, sperm quality, antioxidant defenses and apoptotic balance back to near-normal levels. Telmisartan had similar protective actions to those of melatonin, given at high doses. Conclusion: Telmisartan protects from CPA-related testicular toxicity via anti-inflammatory and anti-apoptotic actions.", "sentences": [], "annotations": [{"id": "36", "infons": {"identifier": "MESH:D003520", "type": "Chemical", "valid": true, "normalized": ["D003520"], "database": "ncbi_mesh", "normalized_id": "D003520", "biotype": "chemical", "name": "Cyclophosphamide", "accession": "@CHEMICAL_Cyclophosphamide"}, "text": "Cyclophosphamide", "locations": [{"offset": 168, "length": 16}]}, {"id": "37", "infons": {"identifier": "MESH:D003520", "type": "Chemical", "valid": true, "normalized": ["D003520"], "database": "ncbi_mesh", "normalized_id": "D003520", "biotype": "chemical", "name": "Cyclophosphamide", "accession": "@CHEMICAL_Cyclophosphamide"}, "text": "CPA", "locations": [{"offset": 186, "length": 3}]}, {"id": "38", "infons": {"identifier": "MESH:D013733", "type": "Disease", "valid": true, "normalized": ["D013733"], "database": "ncbi_mesh", "normalized_id": "D013733", "biotype": "disease", "name": "Testicular Diseases", "accession": "@DISEASE_Testicular_Diseases"}, "text": "testicular health", "locations": [{"offset": 258, "length": 17}]}, {"id": "39", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 306, "length": 12}]}, {"id": "40", "infons": {"identifier": "MESH:D000077333", "type": "Chemical", "valid": true, "normalized": ["D000077333"], "database": "ncbi_mesh", "normalized_id": "D000077333", "biotype": "chemical", "name": "Telmisartan", "accession": "@CHEMICAL_Telmisartan"}, "text": "Telmisartan", "locations": [{"offset": 348, "length": 11}]}, {"id": "41", "infons": {"identifier": "81638", "type": "Gene", "ncbi_homologene": "84871", "valid": true, "normalized": [81638], "database": "ncbi_gene", "normalized_id": 81638, "biotype": "gene", "name": "Agtr1b", "accession": "@GENE_AGTR1B"}, "text": "angiotensin II type 1 receptor", "locations": [{"offset": 371, "length": 30}]}, {"id": "42", "infons": {"id