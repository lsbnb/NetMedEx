"biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "23,11"}]}, {"id": "R4", "infons": {"score": "0.999", "role1": {"identifier": "MESH:C511621", "type": "Chemical", "valid": true, "normalized": ["C511621"], "database": "ncbi_mesh", "normalized_id": "C511621", "biotype": "chemical", "name": "2-methyl-2H-pyrazole-3-carboxylic acid (2-methyl-4-o-tolylazophenyl)amide", "accession": "@CHEMICAL_2_methyl_2H_pyrazole_3_carboxylic_acid_(2_methyl_4_o_tolylazophenyl)amide"}, "role2": {"identifier": "11622", "type": "Gene", "valid": true, "normalized": [11622], "database": "ncbi_gene", "normalized_id": 11622, "biotype": "gene", "name": "Ahr", "accession": "@GENE_AHR"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "3", "role": "23,27"}]}], "pmid": 40663393, "pmcid": null, "meta": {}, "date": "2025-07-15T00:00:00Z", "journal": "JCI Insight", "authors": ["Yu K", "Vyavahare S", "Alhamad DW", "Bensreti H", "Ruan L", "Tuladhar A", "Dai C", "Shaver JC", "Tripathi A", "Ding K", "Pacholczyk R", "Cooley MA", "Zhong R", "Johnson MH", "Chen J", "Bollag WB", "Isales CM", "Hill WD", "Hamrick MW", "Fulzele S", "McGee-Lawrence ME"], "relations_display": [{"name": "associate|@CHEMICAL_Kynurenine|@GENE_AHR"}, {"name": "interact|@CHEMICAL_Kynurenine|@CHEMICAL_Tryptophan"}, {"name": "treat|@CHEMICAL_2_methyl_2H_pyrazole_3_carboxylic_acid_(2_methyl_4_o_tolylazophenyl)amide|@DISEASE_Musculoskeletal_Diseases"}, {"name": "negative_correlate|@CHEMICAL_2_methyl_2H_pyrazole_3_carboxylic_acid_(2_methyl_4_o_tolylazophenyl)amide|@GENE_AHR"}]}, {"_id": "40668672|None", "id": "40668672", "infons": {}, "passages": [{"infons": {"journal": "Cell Rep;2025Jul15; 44 (8) 116021. doi:10.1016/j.celrep.2025.116021", "year": "2025", "type": "title", "authors": "Norris AM, Palzkill VR, Appu AB, Fierman KE, Noble CD, Ryan TE, Kopinke D, "}, "offset": 0, "text": "Intramuscular adipose tissue restricts functional muscle recovery.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 67, "text": "With age and disease, skeletal muscle is progressively lost and replaced by fibrotic scar and intramuscular adipose tissue (IMAT). While strongly correlated, it remains unclear whether IMAT has a functional impact on muscle. In the present study, we evaluated the impact of IMAT on muscle regeneration by creating a mouse model where the cellular origin of IMAT, fibro/adipogenic progenitors (FAPs), is prevented from differentiating into adipocytes (mFATBLOCK model). We found that blocking IMAT after an adipogenic injury allowed muscle to regenerate more efficiently, resulting in enhanced functional recovery. Our data explain why acute muscle injuries featuring IMAT infiltration, such as rotator cuff tears and acute denervation injuries, exhibit poor regeneration and lead to a loss of muscle function. It also demonstrates the therapeutic importance of preventing IMAT formation in acute injuries in order to maximize regeneration and minimize loss in muscle mass and function.", "sentences": [], "annotations": [{"id": "7", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 383, "length": 5}]}, {"id": "8", "infons": {"identifier": "MESH:D014947", "type": "Disease", "valid": true, "normalized": ["D014947"], "database": "ncbi_mesh", "normalized_id": "D014947", "biotype": "disease", "name": "Wounds and Injuries", "accession": "@DISEASE_Wounds_and_Injuries"}, "text": "adipogenic injury", "locations": [{"offset": 573, "length": 17}]}, {"id": "9", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle injuries", "locations": [{"offset": 708, "length": 15}]}, {"id": "10", "infons": {"identifier": "MESH:D000070636", "type": "Disease", "valid": true, "normalized": ["D000070636"], "database": "ncbi_mesh", "normalized_id": "D000070636", "biotype": "disease", "name": "Rotator Cuff Injuries", "accession": "@DISEASE_Rotator_Cuff_Injuries"}, "text": "rotator cuff tears", "locations": [{"offset": 761, "length": 18}]}, {"id": "11", "infons": {"identifier": "MESH:D014947", "type": "Disease", "valid": true, "normalized": ["D014947"], "database": "ncbi_mesh", "normalized_id": "D014947", "biotype": "disease", "name": "Wounds and Injuries", "accession": "@DISEASE_Wounds_and_Injuries"}, "text": "denervation injuries", "locations": [{"offset": 790, "length": 20}]}, {"id": "12", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "loss of muscle", "locations": [{"offset": 852, "length": 14}]}, {"id": "13", "infons": {"identifier": "MESH:D019042", "type": "Disease", "valid": true, "normalized": ["D019042"], "database": "ncbi_mesh", "normalized_id": "D019042", "biotype": "disease", "name": "Muscle Neoplasms", "accession": "@DISEASE_Muscle_Neoplasms"}, "text": "in muscle", "locations": [{"offset": 1024, "length": 9}]}], "relations": []}], "relations": [], "pmid": 40668672, "pmcid": null, "meta": {}, "date": "2025-07-15T00:00:00Z", "journal": "Cell Rep", "authors": ["Norris AM", "Palzkill VR", "Appu AB", "Fierman KE", "Noble CD", "Ryan TE", "Kopinke D"], "relations_display": []}, {"_id": "40671046|None", "id": "40671046", "infons": {}, "passages": [{"infons": {"journal": "Cancer Cell Int;2025Jul16; 25 (1) 266. doi:10.1186/s12935-025-03720-2", "year": "2025", "article-id_pmc": "PMC12269176", "type": "title", "authors": "El-Saadony MT, Alkafaas SS, Saad AM, Mohammed DM, Korma SA, Salem HM, Abd El-Mageed TA, Elsalahaty MI, Elkafas SS, Mosa WFA, Ahmed AE, Ibrahim EH, Alnadari F, Mathew BT, Abdelhamid AS, Allaban SF, Loutfy SA, Ghosh S, Assal HY, El-Tarabily MK, AbuQamar SF, El-Tarabily KA, "}, "offset": 0, "text": "Medicinal plants: nutritional, immunological and therapeutic role in treating cancer-related malnutrition: a comprehensive review.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 78, "length": 6}]}, {"id": "3", "infons": {"identifier": "MESH:D044342", "type": "Disease", "valid": true, "normalized": ["D044342"], "database": "ncbi_mesh", "normalized_id": "D044342", "biotype": "disease", "name": "Malnutrition", "accession": "@DISEASE_Malnutrition"}, "text": "malnutrition", "locations": [{"offset": 93, "length": 12}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 131, "text": "Cancer is the second leading cause of death globally, following microbial infection, with an estimated 16 million deaths projected by 2040. However, natural resources can potentially treat up to 60% of cancer cases. Various cancers, including those affecting the breast, prostate, stomach, colon, lung, liver, kidney, bone, skin, and blood, have strong dietary connections regarding their occurrence and prevention. Cancer and its treatments, particularly chemotherapy, are closely associated with malnutrition in humans. The adverse effects of medical therapies and the disease itself often prevent patients with cancer from meeting their nutritional needs through regular food intake. The etiology of malnutrition in patients with cancer is complex and multifactorial, influenced by the type and location of cancer, disease stage, side effects of treatment, economic status, functional capacity, symptoms impacting nutrition, fasting requirements, inadequate dietary therapy, and awareness of the clinical staff regarding the role of dietary habits in diagnosis, treatment, and quality of life. Although there have been advances in drug-targeted therapies, they remain unelucidated, and therefore, this review aims to elucidate the relationship between cancer, chemical treatments, and malnutrition. In addition, it highlights the significant role of medicinal plants in treating various cancers and mitigating the adverse side effects of chemotherapy, offering a comprehensive understanding of their nutritional, immunological, and therapeutic benefits.", "sentences": [], "annotations": [{"id": "22", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "Cancer", "locations": [{"offset": 131, "length": 6}]}, {"id": "23", "infons": {"identifier": "MESH:D003643", "type": "Disease", "valid": true, "normalized": ["D003643"], "database": "ncbi_mesh", "normalized_id": "D003643", "biotype": "disease", "name": "Death", "accession": "@DISEASE_Death"}, "text": "death", "locations": [{"offset": 169, "length": 5}]}, {"id": "24", "infons": {"identifier": "MESH:D015163", "type": "Disease", "valid": true, "normalized": ["D015163"], "database": "ncbi_mesh", "normalized_id": "D015163", "biotype": "disease", "name": "Superinfection", "accession": "@DISEASE_Superinfection"}, "text": "microbial infection", "locations": [{"offset": 195, "length": 19}]}, {"id": "25", "infons": {"identifier": "MESH:D003643", "type": "Disease", "valid": true, "normalized": ["D003643"], "database": "ncbi_mesh", "normalized_id": "D003643", "biotype": "disease", "name": "Death", "accession": "@DISEASE_Death"}, "text": "deaths", "locations": [{"offset": 245, "length": 6}]}, {"id": "26", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 333, "length": 6}]}, {"id": "27", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancers", "locations": [{"offset": 355, "length": 7}]}, {"id": "28", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "Cancer", "locations": [{"offset": 547, "length": 6}]}, {"id": "29", "infons": {"identifier": "MESH:D044342", "type": "Disease", "valid": true, "normalized": ["D044342"], "database": "ncbi_mesh", "normalized_id": "D044342", "biotype": "disease", "name": "Malnutrition", "accession": "@DISEASE_Malnutrition"}, "text": "malnutrition", "locations": [{"offset": 629, "length": 12}]}, {"id": "30", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "humans", "locations": [{"offset": 645, "length": 6}]}, {"id": "31", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 731, "length": 8}]}, {"id": "32", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 745, "length": 6}]}, {"id": "33", "infons": {"identifier": "MESH:D044342", "type": "Disease", "valid": true, "normalized": ["D044342"], "database": "ncbi_mesh", "normalized_id": "D044342", "biotype": "disease", "name": "Malnutrition", "accession": "@DISEASE_Malnutrition"}, "text": "malnutrition", "locations": [{"offset": 834, "length": 12}]}, {"id": "34", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 850, "length": 8}]}, {"id": "35", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 864, "length": 6}]}, {"id": "36", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 941, "length": 6}]}, {"id": "37", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 1386, "length": 6}]}, {"id": "38", "infons": {"identifier": "MESH:D044342", "type": "Disease", "valid": true, "normalized": ["D044342"], "database": "ncbi_mesh", "normalized_id": "D044342", "biotype": "disease", "name": "Malnutrition", "accession": "@DISEASE_Malnutrition"}, "text": "malnutrition", "locations": [{"offset": 1419, "length": 12}]}, {"id": "39", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancers", "locations": [{"offset": 1521, "length": 7}]}], "relations": []}], "relations": [], "pmid": 40671046, "pmcid": null, "meta": {}, "date": "2025-07-16T00:00:00Z", "journal": "Cancer Cell Int", "authors": ["El-Saadony MT", "Alkafaas SS", "Saad AM", "Mohammed DM", "Korma SA", "Salem HM", "Abd El-Mageed TA", "Elsalahaty MI", "Elkafas SS", "Mosa WFA", "Ahmed AE", "Ibrahim EH", "Alnadari F", "Mathew BT", "Abdelhamid AS", "Allaban SF", "Loutfy SA", "Ghosh S", "Assal HY", "El-Tarabily MK", "AbuQamar SF", "El-Tarabily KA"], "relations_display": []}, {"_id": "40683107|None", "id": "40683107", "infons": {}, "passages": [{"infons": {"journal": "Pharmacol Rev;2025Jun26; 77 (5) 100077. doi:10.1016/j.pharmr.2025.100077", "year": "2025", "type": "title", "authors": "Sen CK, Friday AJ, Roy S, "}, "offset": 0, "text": "Cell and tissue reprogramming: Unlocking a new era in medical drug discovery.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 78, "text": "Recent advancements in cell and tissue biology have fundamentally changed our understanding of cellular behavior, revealing that both stem and nonstem cells exhibit remarkable plasticity and adaptability. This discovery has paved the way for revolutionary medical drug therapies that leverage cell and tissue reprogramming to repair or regenerate damaged tissues, offering new hope for conditions that were once considered irreversible. Tissue reprogramming involves the activation of specific molecular pathways to convert the function of residual tissue to compensate for the loss of tissue function to aging, trauma, or disease processes. By targeting these pathways, emerging drugs can promote regenerative processes, enabling the restoration of tissue function lost due to aging, injury, or disease. These therapies have shown promising results in preclinical studies addressing a wide range of diseases. Unlike traditional treatments, which focus primarily on managing symptoms, tissue reprogramming therapies offer a dynamic approach that can fundamentally alter cellular states, leading to functional recovery. This review explores the current state of cell and tissue reprogramming, highlighting its potential applications in regenerative medicine and the challenges that must be addressed for successful clinical translation. As our understanding of cellular plasticity continues to evolve, these innovative therapies stand at the forefront of a new era in medicine, with the potential to transform treatment paradigms and significantly improve patient outcomes across a wide range of conditions. SIGNIFICANCE STATEMENT: Breakthrough technologies have transformed our understanding of cell and tissue biology, uncovering that cells and tissues possess remarkable adaptability and fluidity in their roles. This revelation has opened up exciting possibilities in regenerative medicine, where emerging drug therapies aim to harness and reprogram cells to repair or regenerate damaged tissues. An emerging class of medical drugs will activate the body's natural regenerative abilities, offering the potential to restore tissue function lost due to aging, injury, or disease.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D014947", "type": "Disease", "valid": true, "normalized": ["D014947"], "database": "ncbi_mesh", "normalized_id": "D014947", "biotype": "disease", "name": "Wounds and Injuries", "accession": "@DISEASE_Wounds_and_Injuries"}, "text": "trauma", "locations": [{"offset": 690, "length": 6}]}, {"id": "3", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patient", "locations": [{"offset": 1633, "length": 7}]}], "relations": []}], "relations": [], "pmid": 40683107, "pmcid": null, "meta": {}, "date": "2025-06-26T00:00:00Z", "journal": "Pharmacol Rev", "authors": ["Sen CK", "Friday AJ", "Roy S"], "relations_display": []}, {"_id": "40691076|None", "id": "40691076", "infons": {}, "passages": [{"infons": {"journal": "Exp Anim;2025Jul19. doi:10.1538/expanim.25-0032", "year": "2025", "type": "title", "authors": "Fujimoto M, Iwasaki T, Hosotani Saito M, Takahashi N, Hashimoto M, Takahashi E, Kitamura H, "}, "offset": 0, "text": "Suppression of USP2 in mouse skeletal muscle: a model of oxidative stress in muscle tissue.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "53376", "type": "Gene", "ncbi_homologene": "3098", "valid": true, "normalized": [53376], "database": "ncbi_gene", "normalized_id": 53376, "biotype": "gene", "name": "Usp2", "accession": "@GENE_USP2"}, "text": "USP2", "locations": [{"offset": 15, "length": 4}]}, {"id": "3", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 23, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 92, "text": "Emerging evidence indicates that oxidative stress in skeletal muscle is a prerequisite for sarcopenia in diabetic patients. In this study, we show that ubiquitin-specific protease (USP) 2 mitigates the accumulation of reactive oxygen species (ROS) in mature muscle cells. Treatment with ML364, a canonical USP2 inhibitor, robustly increased mitochondrial ROS in mouse C2C12 myotubes and caused an accompanying increase in the glutathione disulfide (GSSG)/glutathione (GSH) ratio. ML364 also caused mitochondrial damage in C2C12 myotubes, resulting in a reduction in intracellular adenosine triphosphate levels. Correspondingly, under diabetic condition, the muscle-specific Usp2-knockout (msUsp2KO) C57BL/6N mice exhibited a significantly higher lipid peroxide level and GSSG/GSH ratio in skeletal muscle than the control mice. The msUsp2KO mice also exhibited augmented insulin resistance and glucose intolerance, but showed no obvious deterioration in muscle weight or histology relative to the control mice. However, damaged mitochondria in the soleus muscle were more frequently observed in msUsp2KO mice than in the control mice. Together, these data suggest that USP2 mitigates ROS accumulation and subsequent mitochondrial damage in muscle cells in mice.", "sentences": [], "annotations": [{"id": "40", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 183, "length": 10}]}, {"id": "41", "infons": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "text": "diabetic", "locations": [{"offset": 197, "length": 8}]}, {"id": "42", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 206, "length": 8}]}, {"id": "43", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "reactive oxygen species", "locations": [{"offset": 310, "length": 23}]}, {"id": "44", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 335, "length": 3}]}, {"id": "45", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "ML364", "locations": [{"offset": 379, "length": 5}]}, {"id": "46", "infons": {"identifier": "53376", "type": "Gene", "ncbi_homologene": "3098", "valid": true, "normalized": [53376], "database": "ncbi_gene", "normalized_id": 53376, "biotype": "gene", "name": "Usp2", "accession": "@GENE_USP2"}, "text": "USP2", "locations": [{"offset": 398, "length": 4}]}, {"id": "47", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 447, "length": 3}]}, {"id": "48", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 454, "length": 5}]}, {"id": "49", "infons": {"identifier": "CVCL:0188", "type": "CellLine", "valid": true, "normalized": ["0188"], "database": "cvcl", "normalized_id": "0188", "biotype": "cellline", "name": "0188", "accession": null}, "text": "C2C12", "locations": [{"offset": 460, "length": 5}]}, {"id": "50", "infons": {"identifier": "MESH:D019803", "type": "Chemical", "valid": true, "normalized": ["D019803"], "database": "ncbi_mesh", "normalized_id": "D019803", "biotype": "chemical", "name": "Glutathione Disulfide", "accession": "@CHEMICAL_Glutathione_Disulfide"}, "text": "glutathione disulfide", "locations": [{"offset": 518, "length": 21}]}, {"id": "51", "infons": {"identifier": "MESH:D019803", "type": "Chemical", "valid": true, "normalized": ["D019803"], "database": "ncbi_mesh", "normalized_id": "D019803", "biotype": "chemical", "name": "Glutathione Disulfide", "accession": "@CHEMICAL_Glutathione_Disulfide"}, "text": "GSSG", "locations": [{"offset": 541, "length": 4}]}, {"id": "52", "infons": {"identifier": "MESH:D005978", "type": "Chemical", "valid": true, "normalized": ["D005978"], "database": "ncbi_mesh", "normalized_id": "D005978", "biotype": "chemical", "name": "Glutathione", "accession": "@CHEMICAL_Glutathione"}, "text": "glutathione", "locations": [{"offset": 547, "length": 11}]}, {"id": "53", "infons": {"identifier": "MESH:D005978", "type": "Chemical", "valid": true, "normalized": ["D005978"], "database": "ncbi_mesh", "normalized_id": "D005978", "biotype": "chemical", "name": "Glutathione", "accession": "@CHEMICAL_Glutathione"}, "text": "GSH", "locations": [{"offset": 560, "length": 3}]}, {"id": "54", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "ML364", "locations": [{"offset": 572, "length": 5}]}, {"id": "55", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial damage", "locations": [{"offset": 590, "length": 20}]}, {"id": "56", "infons": {"identifier": "CVCL:0188", "type": "CellLine", "valid": true, "normalized": ["0188"], "database": "cvcl", "normalized_id": "0188", "biotype": "cellline", "name": "0188", "accession": null}, "text": "C2C12", "locations": [{"offset": 614, "length": 5}]}, {"id": "57", "infons": {"identifier": "MESH:D000255", "type": "Chemical", "valid": true, "normalized": ["D000255"], "database": "ncbi_mesh", "normalized_id