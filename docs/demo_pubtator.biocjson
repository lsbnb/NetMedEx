dentifier": "5562", "type": "Gene", "valid": true, "normalized": [5562], "database": "ncbi_gene", "normalized_id": 5562, "biotype": "gene", "name": "PRKAA1", "accession": "@GENE_PRKAA1"}, "role2": {"identifier": "8013", "type": "Gene", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "4", "role": "22,38"}]}, {"id": "R6", "infons": {"score": "0.9967", "role1": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "role2": {"identifier": "8013", "type": "Gene", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "type": "Association"}, "nodes": [{"refid": "5", "role": "27,38"}]}, {"id": "R7", "infons": {"score": "0.9993", "role1": {"identifier": "MESH:D001284", "type": "Disease", "valid": true, "normalized": ["D001284"], "database": "ncbi_mesh", "normalized_id": "D001284", "biotype": "disease", "name": "Atrophy", "accession": "@DISEASE_Atrophy"}, "role2": {"identifier": "8013", "type": "Gene", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "type": "Association"}, "nodes": [{"refid": "6", "role": "28,38"}]}], "pmid": 40609830, "pmcid": null, "meta": {}, "date": "2025-07-01T00:00:00Z", "journal": "Mol Metab", "authors": ["Smith JAB", "Gabriel BM", "Brady AJ", "Abdelmoez AM", "Savikj M", "Wright SC", "Koutsilieri S", "Barrès R", "Lauschke VM", "Krook A", "Zierath JR", "Pillon NJ"], "relations_display": [{"name": "associate|@CHEMICAL_Glucose|@GENE_NR4A3"}, {"name": "positive_correlate|@CHEMICAL_Carbonyl_Cyanide_p_Trifluoromethoxyphenylhydrazone|@CHEMICAL_Fatty_Acids"}, {"name": "cause|@CHEMICAL_Dexamethasone|@DISEASE_Atrophy"}, {"name": "associate|@CHEMICAL_Lactic_Acid|@GENE_NR4A3"}, {"name": "negative_correlate|@GENE_PRKAA1|@GENE_NR4A3"}, {"name": "associate|@CHEMICAL_Dexamethasone|@GENE_NR4A3"}, {"name": "associate|@DISEASE_Atrophy|@GENE_NR4A3"}]}, {"_id": "40623060|None", "id": "40623060", "infons": {}, "passages": [{"infons": {"journal": "PLoS One;2025; 20 (7) 0326968. doi:10.1371/journal.pone.0326968", "year": "2025", "article-id_pmc": "PMC12233260", "type": "title", "authors": "Ishii KA, Hashimoto R, Umeda C, Hosoyama T, Watanabe K, "}, "offset": 0, "text": "An in vitro model to study molecular pathogenesis of sarcopenia established by a SASP-dependent human myotube culture.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 53, "length": 10}]}, {"id": "4", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "SASP", "locations": [{"offset": 81, "length": 4}]}, {"id": "5", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 96, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 119, "text": "Sarcopenia is a condition that affects one's activities of daily livingand is rapidly increasing with the ages of the global population. However, the basic molecular mechanisms for prevention and treatment are not fully understood. Although rodent model animals have many valuable aspects for studying sarcopenia, some aspects and mechanisms differ from humans, such as immune response, metabolism, stress response, and myofiber composition. This study established a human cell-based in vitro model to elucidate the molecular mechanism by which SASP from senescence-induced human mesenchymal stem cells led to the narrowing of human myotube diameter, suggesting that this model is useful for studying sarcopenia. Gene expression profiling was performed the molecular mechanisms and devel on the model by RNA sequencing to identify genes whose expression was affected by SASP. Among these, the exposure to SASP upregulated PDK4 expression, and a PDK4 inhibitor, DCA, could increase myotube diameter and reverse SASP-mediated narrowing of the diameter. Pathway analyses suggested that SASP affected energy metabolism by activating OXPHOS and promoting the expression of mitochondrial function-related genes and mitochondrial biosynthesis factors. These results provide insights that contribute to developing new treatments for sarcopenia.", "sentences": [], "annotations": [{"id": "22", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "Sarcopenia", "locations": [{"offset": 119, "length": 10}]}, {"id": "23", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 421, "length": 10}]}, {"id": "24", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "humans", "locations": [{"offset": 473, "length": 6}]}, {"id": "25", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 586, "length": 5}]}, {"id": "26", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "SASP", "locations": [{"offset": 664, "length": 4}]}, {"id": "27", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 693, "length": 5}]}, {"id": "28", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 746, "length": 5}]}, {"id": "29", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 820, "length": 10}]}, {"id": "30", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "SASP", "locations": [{"offset": 989, "length": 4}]}, {"id": "31", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "SASP", "locations": [{"offset": 1024, "length": 4}]}, {"id": "32", "infons": {"identifier": "5166", "type": "Gene", "ncbi_homologene": "129720", "valid": true, "normalized": [5166], "database": "ncbi_gene", "normalized_id": 5166, "biotype": "gene", "name": "PDK4", "accession": "@GENE_PDK4"}, "text": "PDK4", "locations": [{"offset": 1041, "length": 4}]}, {"id": "33", "infons": {"identifier": "5166", "type": "Gene", "ncbi_homologene": "129720", "valid": true, "normalized": [5166], "database": "ncbi_gene", "normalized_id": 5166, "biotype": "gene", "name": "PDK4", "accession": "@GENE_PDK4"}, "text": "PDK4", "locations": [{"offset": 1064, "length": 4}]}, {"id": "34", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "DCA", "locations": [{"offset": 1080, "length": 3}]}, {"id": "35", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "SASP", "locations": [{"offset": 1129, "length": 4}]}, {"id": "36", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "SASP", "locations": [{"offset": 1202, "length": 4}]}, {"id": "37", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 1444, "length": 10}]}], "relations": []}], "relations": [], "pmid": 40623060, "pmcid": null, "meta": {}, "date": "2025-07-07T00:00:00Z", "journal": "PLoS One", "authors": ["Ishii KA", "Hashimoto R", "Umeda C", "Hosoyama T", "Watanabe K"], "relations_display": []}, {"_id": "40626223|None", "id": "40626223", "infons": {}, "passages": [{"infons": {"journal": "Front Nutr;2025; 12 1595316. doi:10.3389/fnut.2025.1595316", "year": "2025", "article-id_pmc": "PMC12231144", "type": "title", "authors": "Almoghrabi YM, Eldakhakhny BM, Bima AI, Sakr H, Ajabnoor GMA, Gad HM, Mohammad FAH, Elsamanoudy SA, Awan AZ, Elsamanoudy AZ, "}, "offset": 0, "text": "The interplay between nutrigenomics and low-carbohydrate ketogenic diets in personalized healthcare.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D002241", "type": "Chemical", "valid": true, "normalized": ["D002241"], "database": "ncbi_mesh", "normalized_id": "D002241", "biotype": "chemical", "name": "Carbohydrates", "accession": "@CHEMICAL_Carbohydrates"}, "text": "carbohydrate", "locations": [{"offset": 44, "length": 12}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 101, "text": "The field of nutrigenomics explores the interaction between diet and gene expression, examining how nutrients function as signaling molecules that influence cellular processes, protein synthesis, and metabolite production. This discipline aims to design diets that promote genomic stability through various genetic mechanisms, including minimizing DNA damage and epigenetic modifications, among others. Nutrigenomic profiling helps identify individual dietary needs and responses to food interventions. Nutrigenetics, a subfield of nutritional genomics, investigates how genetic variations affect nutrient metabolism and health outcomes. It operates on the principle that genetic differences influence nutrient absorption and metabolism, shaping disease susceptibility and treatment responses. Therefore, integrating nutrigenetics into dietary planning enables the development of personalized nutrition strategies to improve health and prevent disease. One key application of nutrigenomics is its impact on various diets, including the Low-Carbohydrate ketogenic diet (LCKD), a high-fat, low-carbohydrate regimen that induces ketosis. In this metabolic state, ketone bodies serve as energy sources and signaling molecules. Research suggests that LCKD may influence gene expression and epigenetic mechanisms, modulating inflammation-related pathways, oxidative stress, and metabolic regulation. Additionally, KD has been associated with improved insulin sensitivity, glucose control, lipid profiles, and weight loss. However, genetic factors affecting LCKD response require further investigation to refine personalized dietary recommendations. This review highlights the significance of nutrigenomics, focusing on the interplay between the LCKD and genetic factors. A comprehensive understanding of these interactions is essential for developing personalized dietary strategies that optimize LCKD benefits while mitigating potential risks, ultimately contributing to individualized nutritional guidance within a precision health framework.", "sentences": [], "annotations": [{"id": "12", "infons": {"identifier": "MESH:D002241", "type": "Chemical", "valid": true, "normalized": ["D002241"], "database": "ncbi_mesh", "normalized_id": "D002241", "biotype": "chemical", "name": "Carbohydrates", "accession": "@CHEMICAL_Carbohydrates"}, "text": "Carbohydrate", "locations": [{"offset": 1141, "length": 12}]}, {"id": "13", "infons": {"identifier": "MESH:D002241", "type": "Chemical", "valid": true, "normalized": ["D002241"], "database": "ncbi_mesh", "normalized_id": "D002241", "biotype": "chemical", "name": "Carbohydrates", "accession": "@CHEMICAL_Carbohydrates"}, "text": "carbohydrate", "locations": [{"offset": 1193, "length": 12}]}, {"id": "14", "infons": {"identifier": "MESH:D007662", "type": "Disease", "valid": true, "normalized": ["D007662"], "database": "ncbi_mesh", "normalized_id": "D007662", "biotype": "disease", "name": "Ketosis", "accession": "@DISEASE_Ketosis"}, "text": "ketosis", "locations": [{"offset": 1227, "length": 7}]}, {"id": "15", "infons": {"identifier": "MESH:D007657", "type": "Chemical", "valid": true, "normalized": ["D007657"], "database": "ncbi_mesh", "normalized_id": "D007657", "biotype": "chemical", "name": "Ketone Bodies", "accession": "@CHEMICAL_Ketone_Bodies"}, "text": "ketone bodies", "locations": [{"offset": 1261, "length": 13}]}, {"id": "16", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 1420, "length": 12}]}, {"id": "17", "infons": {"identifier": "MESH:D009080", "type": "Disease", "valid": true, "normalized": ["D009080"], "database": "ncbi_mesh", "normalized_id": "D009080", "biotype": "disease", "name": "Mucocutaneous Lymph Node Syndrome", "accession": "@DISEASE_Mucocutaneous_Lymph_Node_Syndrome"}, "text": "KD", "locations": [{"offset": 1509, "length": 2}]}, {"id": "18", "infons": {"identifier": "3630", "type": "Gene", "ncbi_homologene": "173", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "text": "insulin", "locations": [{"offset": 1546, "length": 7}]}, {"id": "19", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "glucose", "locations": [{"offset": 1567, "length": 7}]}, {"id": "20", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 1584, "length": 5}]}, {"id": "21", "infons": {"identifier": "MESH:D015431", "type": "Disease", "valid": true, "normalized": ["D015431"], "database": "ncbi_mesh", "normalized_id": "D015431", "biotype": "disease", "name": "Weight Loss", "accession": "@DISEASE_Weight_Loss"}, "text": "weight loss", "locations": [{"offset": 1604, "length": 11}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9803", "role1": {"identifier": "MESH:D002241", "type": "Chemical", "valid": true, "normalized": ["D002241"], "database": "ncbi_mesh", "normalized_id": "D002241", "biotype": "chemical", "name": "Carbohydrates", "accession": "@CHEMICAL_Carbohydrates"}, "role2": {"identifier": "MESH:D007662", "type": "Disease", "valid": true, "normalized": ["D007662"], "database": "ncbi_mesh", "normalized_id": "D007662", "biotype": "disease", "name": "Ketosis", "accession": "@DISEASE_Ketosis"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "0", "role": "2,3"}]}, {"id": "R2", "infons": {"score": "0.4858", "role1": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "role2": {"identifier": "MESH:D009080", "type": "Disease", "valid": true, "normalized": ["D009080"], "database": "ncbi_mesh", "normalized_id": "D009080", "biotype": "disease", "name": "Mucocutaneous Lymph Node Syndrome", "accession": "@DISEASE_Mucocutaneous_Lymph_Node_Syndrome"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "1", "role": "8,6"}]}, {"id": "R3", "infons": {"score": "0.9885", "role1": {"identifier": "MESH:D009080", "type": "Disease", "valid": true, "normalized": ["D009080"], "database": "ncbi_mesh", "normalized_id": "D009080", "biotype": "disease", "name": "Mucocutaneous Lymph Node Syndrome", "accession": "@DISEASE_Mucocutaneous_Lymph_Node_Syndrome"}, "role2": {"identifier": "3630", "type": "Gene", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "6,7"}]}, {"id": "R4", "infons": {"score": "0.735", "role1": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "role2": {"identifier": "MESH:D009080", "type": "Disease", "valid": true, "normalized": ["D009080"], "database": "ncbi_mesh", "normalized_id": "D009080", "biotype": "disease", "name": "Mucocutaneous Lymph Node Syndrome", "accession": "@DISEASE_Mucocutaneous_Lymph_Node_Syndrome"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "3", "role": "9,6"}]}], "pmid": 40626223, "pmcid": null, "meta": {}, "date": "2025-06-23T00:00:00Z", "journal": "Front Nutr", "authors": ["Almoghrabi YM", "Eldakhakhny BM", "Bima AI", "Sakr H", "Ajabnoor GMA", "Gad HM", "Mohammad FAH", "Elsamanoudy SA", "Awan AZ", "Elsamanoudy AZ"], "relations_display": [{"name": "cause|@CHEMICAL_Carbohydrates|@DISEASE_Ketosis"}, {"name": "treat|@CHEMICAL_Glucose|@DISEASE_Mucocutaneous_Lymph_Node_Syndrome"}, {"name": "associate|@DISEASE_Mucocutaneous_Lymph_Node_Syndrome|@GENE_INS"}, {"name": "treat|@CHEMICAL_Lipids|@DISEASE_Mucocutaneous_Lymph_Node_Syndrome"}]}, {"_id": "40628948|None", "id": "40628948", "infons": {}, "passages": [{"infons": {"journal": "Cell Res;2025Aug; 35 (8) 535. doi:10.1038/s41422-025-01138-z", "year": "2025", "article-id_pmc": "PMC12297431", "type": "title", "authors": "Memczak S, Izpisua Belmonte JC, Graepel T, "}, "offset": 0, "text": "Escaping ageing through Cell Annealing-a phenomenological model.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 65, "text": "", "sentences": [], "annotations": [], "relations": []}], "relations": [], "pmid": 40628948, "pmcid": null, "meta": {}, "date": "2025-08-01T00:00:00Z", "journal": "Cell Res", "authors": ["Memczak S", "Izpisua Belmonte JC", "Graepel T"], "relations_display": []}, {"_id": "40630123|None", "id": "40630123", "infons": {}, "passages": [{"infons": {"journal": "Front Pharmacol;2025; 16 1601537. doi:10.3389/fphar.2025.1601537", "year": "2025", "article-id_pmc": "PMC12234569", "type": "title", "authors": "Huang C, Jin H, Zhang Y, Wang D, He Z, Shuai B, "}, "offset": 0, "text": "Eucommia ulmoides Oliv. and its bioactive compounds: therapeutic potential in bone diseases.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "4392", "type": "Species", "valid": true, "normalized": [4392], "database": "ncbi_taxonomy", "normalized_id": 4392, "biotype": "species", "name": "4392", "accession": null}, "text": "Eucommia ulmoides", "locations": [{"offset": 0, "length": 17}]}, {"id": "3", "infons": {"identifier": "MESH:D001847", "type": "Disease", "valid": true, "normalized": ["D001847"], "database": "ncbi_mesh", "normalized_id": "D001847", "biotype": "disease", "name": "Bone Diseases", "accession": "@DISEASE_Bone_Diseases"}, "text": "bone diseases", "locations": [{"offset": 78, "length": 13}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 93, "text": "Background: Aging-related bone diseases encompass a range of conditions that emerge or worsen with advancing age, including osteoporosis and osteoarthritis, and they are placing an increasing burden on society. Although these diseases differ in clinical manifestations and pathological features, they often share common age-associated mechanisms such as impaired bone remodeling, chronic low-grade inflammation, cellular senescence, oxidative stress, and hormonal changes. Current therapies often face limitations in efficacy or long-term safety, highlighting the need for alternative strategies. Phytochemicals derived from Chinese medicine herb have emerged as promising candidates due to their multi-target effects on bone homeostasis. Eucommia ulmoides Oliv. (EU) and its bioactive compounds (e.g., quercetin, aucubin, geniposide, geniposidic acid). may regulate key pathways to restore bone balance, offering potential for treating osteoporosis and other aging-related bone diseases. Objectives: This study aims to assess the therapeutic potential of EU in the treatment of aging-related bone diseases. Methods: A literature search was conducted on the PubMed database up to November 2024 using the search term: \"Eucommia AND (bone OR cartilage OR joint).\" Results: The review indicates that EU formulas, extracts, and bioactive components promote osteogenesis, suppress bone resorption, and exert anti-inflammatory and antioxidant properties. These effects contribute positively to the treatment of aging-related bone diseases. Conclusion: The therapeutic benefits of EU support its development as a promising tool for preventing and treating aging-related bone diseases. These findings provide new research directions to address related health challenges associated with population aging.", "sentences": [], "annotations": [{"id": "21", "infons": {"identifier": "MESH:D001847", "type": "Disease", "valid": true, "normalized": ["D001847"], "database": "ncbi_mesh", "normalized_id": "D001847", "biotype": "disease", "name": "Bone Diseases", "accession": "@DISEASE_Bone_Diseases"}, "text": "bone diseases", "locations": [{"offset": 119, "length": 13}]}, {"id": "22", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "osteoporosis", "locations": [{"offset": 217, "length": 12}]}, {"id": "23", "infons": {"identifier": "MESH:D010003", "type": "Disease", "valid": true, "normalized": ["D010003"], "database": "ncbi_mesh", "normalized_id": "D010003", "biotype": "disease", "name": "Osteoarthritis", "accession": "@DISEASE_Osteoarthritis"}, "text": "osteoarthritis", "locations": [{"offset": 234, "length": 14}]}, {"id": "24", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 491, "length": 12}]}, {"id": "25", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Chinese medicine", "locations": [{"offset": 718, "length": 16}]}, {"id": "26", "infons": {"identifier": "4392", "type": "Species", "valid": true, "normalized": [4392], "database": "ncbi_taxonomy", "normalized_id": 4392, "biotype": "species", "name": "4392", "accession": null}, "text": "Eucommia ulmoides", "locations": [{"offset": 832, "length": 17}]}