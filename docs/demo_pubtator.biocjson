name": "Acod1", "accession": "@GENE_ACOD1"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "25,24"}]}, {"id": "R2", "infons": {"score": "0.9332", "role1": {"identifier": "16365", "type": "Gene", "valid": true, "normalized": [16365], "database": "ncbi_gene", "normalized_id": 16365, "biotype": "gene", "name": "Acod1", "accession": "@GENE_ACOD1"}, "role2": {"identifier": "16819", "type": "Gene", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "24,23"}]}, {"id": "R3", "infons": {"score": "0.9996", "role1": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "role2": {"identifier": "16365", "type": "Gene", "valid": true, "normalized": [16365], "database": "ncbi_gene", "normalized_id": 16365, "biotype": "gene", "name": "Acod1", "accession": "@GENE_ACOD1"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "26,24"}]}, {"id": "R4", "infons": {"score": "0.6174", "role1": {"identifier": "MESH:D014947", "type": "Disease", "valid": true, "normalized": ["D014947"], "database": "ncbi_mesh", "normalized_id": "D014947", "biotype": "disease", "name": "Wounds and Injuries", "accession": "@DISEASE_Wounds_and_Injuries"}, "role2": {"identifier": "16819", "type": "Gene", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "3", "role": "25,23"}]}, {"id": "R5", "infons": {"score": "0.9995", "role1": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "role2": {"identifier": "16819", "type": "Gene", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "26,23"}]}, {"id": "R6", "infons": {"score": "0.9767", "role1": {"identifier": "MESH:C477224", "type": "Chemical", "valid": true, "normalized": ["C477224"], "database": "ncbi_mesh", "normalized_id": "C477224", "biotype": "chemical", "name": "erastin", "accession": "@CHEMICAL_erastin"}, "role2": {"identifier": "16819", "type": "Gene", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "type": "Association"}, "nodes": [{"refid": "5", "role": "14,23"}]}, {"id": "R7", "infons": {"score": "0.9994", "role1": {"identifier": "MESH:D007501", "type": "Chemical", "valid": true, "normalized": ["D007501"], "database": "ncbi_mesh", "normalized_id": "D007501", "biotype": "chemical", "name": "Iron", "accession": "@CHEMICAL_Iron"}, "role2": {"identifier": "16819", "type": "Gene", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "type": "Association"}, "nodes": [{"refid": "6", "role": "8,23"}]}, {"id": "R8", "infons": {"score": "0.9995", "role1": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "role2": {"identifier": "16819", "type": "Gene", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "type": "Association"}, "nodes": [{"refid": "7", "role": "19,23"}]}], "pmid": 40984022, "pmcid": null, "meta": {}, "date": "2025-09-22T00:00:00Z", "journal": "Cell Prolif", "authors": ["Hao X", "Shi H", "Wu D", "Liang R", "Zhao T", "Sun W", "Wang Y", "Yu X", "Luo X", "Yan Y", "Lu J", "Wang H", "Wang J"], "relations_display": [{"name": "associate|@DISEASE_Wounds_and_Injuries|@GENE_ACOD1"}, {"name": "associate|@GENE_ACOD1|@GENE_LCN2"}, {"name": "associate|@DISEASE_Muscular_Diseases|@GENE_ACOD1"}, {"name": "stimulate|@DISEASE_Wounds_and_Injuries|@GENE_LCN2"}, {"name": "associate|@DISEASE_Muscular_Diseases|@GENE_LCN2"}, {"name": "associate|@CHEMICAL_erastin|@GENE_LCN2"}, {"name": "associate|@CHEMICAL_Iron|@GENE_LCN2"}, {"name": "associate|@DISEASE_Mitochondrial_Diseases|@GENE_LCN2"}]}, {"_id": "40984725|None", "id": "40984725", "infons": {}, "passages": [{"infons": {"journal": "J Extracell Vesicles;2025Sep; 14 (9) 70164. doi:10.1002/jev2.70164", "year": "2025", "article-id_pmc": "PMC12454923", "type": "title", "authors": "Hakkar R, Brun CE, Leblanc P, Meugnier E, Berger-Danty E, Blanc-Brude O, Tacconi S, Jalabert A, Reininger L, Pesenti S, Calzada C, Gache V, Vasan SB, Pichon J, Larcher T, Errazuriz-Cerda E, Cassin C, Sung BH, Weaver A, Bongiovanni A, Rouger K, de Barros JP, Bouzakri K, Rome S, "}, "offset": 0, "text": "Sphingolipids in Extracellular Vesicles Released From the Skeletal Muscle Plasma Membrane Control Muscle Stem Cell Fate During Muscle Regeneration.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D013107", "type": "Chemical", "valid": true, "normalized": ["D013107"], "database": "ncbi_mesh", "normalized_id": "D013107", "biotype": "chemical", "name": "Sphingolipids", "accession": "@CHEMICAL_Sphingolipids"}, "text": "Sphingolipids", "locations": [{"offset": 0, "length": 13}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 148, "text": "Extracellular vesicles (EVs) represent a cytokine-independent pathway though which skeletal muscle (SkM) cells influence the fate of neighbouring cells, thereby regulating SkM metabolic homeostasis and regeneration. Although SkM-EVs are increasingly being explored as a therapeutic strategy to enhance muscle regeneration or to induce the myogenic differentiation of induced pluripotent stem cells (iPSCs), the mechanisms governing their release from muscle cells remain poorly described. Moreover, because muscle regeneration involves a tightly regulated inflammatory response it also important to determine how inflammation alters SkM-EV cargo and function in order to design more effective EV-based therapies. To address this knowledge gap, we isolated and characterized the large and small EVs (lEVs, sEVs) released from SkM cells under basal conditions and in response to TNF-alpha, a well-established inflammatory mediator elevated in both acute muscle injury and chronic inflammatory conditions such as type 2 diabetes. We then evaluated the regenerative roles of these EV subtypes in vivo using a mouse model of cardiotoxin-induced muscle injury, with a specific focus on their bioactive sphingolipid content. Using transmission, scanning or cryo-electron microscopy, lipidomic profiling and an adenoviral construct to express labelled CD63 in myotubes, we demonstrated that SkM cells release both sEVs and lEVs primarily from the plasma membrane. Notably, sEVs were generated from specialized membrane folds enriched in the EV markers ALIX (ALG-2 interacting protein X) and TSG101, as well as lipid raft-associated lipids. During regeneration, sEVs promoted M1 macrophage polarization and migration and muscle stem cell (MuSC) differentiation, thereby accelerating muscle repair. In contrast, lEVs inhibited and promoted MuSC proliferation and impaired the transition from the pro-inflammatory to the anti-inflammatory response, an essential step for promoting MuSC differentiation. Treatment of isolated muscle fibres with SkM-EVs revealed that the distinct effects of sEVs and lEVs on MuSC behaviour and macrophage phenotype could be largely explained by differences in their lipid composition, particularly the ratio of sphingosine-1-phosphate (S1P) subspecies. However, TNF-alpha exposure altered these ratios in sEVs and impaired their regenerative functions on MuSC and their effect on macrophage migration and polarization. These results demonstrate for the first time the importance of the sphingolipid content of EVs released by skeletal muscle in their regenerative function within muscle tissue, largely explained by their role as carriers of different subspecies of sphingosine-1-phosphate. This suggests that modulating the sphingolipid composition of EVs could be a viable strategy to enhance the regenerative potential of muscle tissue in addition to therapeutic interventions.", "sentences": [], "annotations": [{"id": "34", "infons": {"identifier": "CVCL:VG48", "type": "CellLine", "valid": true, "normalized": ["VG48"], "database": "cvcl", "normalized_id": "VG48", "biotype": "cellline", "name": "VG48", "accession": null}, "text": "SkM", "locations": [{"offset": 248, "length": 3}]}, {"id": "35", "infons": {"identifier": "CVCL:VG48", "type": "CellLine", "valid": true, "normalized": ["VG48"], "database": "cvcl", "normalized_id": "VG48", "biotype": "cellline", "name": "VG48", "accession": null}, "text": "SkM", "locations": [{"offset": 320, "length": 3}]}, {"id": "36", "infons": {"identifier": "CVCL:VG48", "type": "CellLine", "valid": true, "normalized": ["VG48"], "database": "cvcl", "normalized_id": "VG48", "biotype": "cellline", "name": "VG48", "accession": null}, "text": "SkM", "locations": [{"offset": 373, "length": 3}]}, {"id": "37", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 704, "length": 12}]}, {"id": "38", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "