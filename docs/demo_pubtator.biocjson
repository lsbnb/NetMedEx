id": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "7", "role": "9,12"}]}], "pmid": 40630123, "pmcid": null, "meta": {}, "date": "2025-06-24T00:00:00Z", "journal": "Front Pharmacol", "authors": ["Huang C", "Jin H", "Zhang Y", "Wang D", "He Z", "Shuai B"], "relations_display": [{"name": "treat|@CHEMICAL_geniposidic_acid|@DISEASE_Osteoporosis"}, {"name": "treat|@CHEMICAL_geniposide|@DISEASE_Osteoporosis"}, {"name": "treat|@CHEMICAL_geniposidic_acid|@DISEASE_Bone_Diseases"}, {"name": "treat|@CHEMICAL_Quercetin|@DISEASE_Osteoporosis"}, {"name": "treat|@CHEMICAL_aucubin|@DISEASE_Bone_Diseases"}, {"name": "treat|@CHEMICAL_Quercetin|@DISEASE_Bone_Diseases"}, {"name": "treat|@CHEMICAL_geniposide|@DISEASE_Bone_Diseases"}, {"name": "treat|@CHEMICAL_aucubin|@DISEASE_Osteoporosis"}]}, {"_id": "40632859|None", "id": "40632859", "infons": {}, "passages": [{"infons": {"journal": "Sci Adv;2025Jul11; 11 (28) 4371. doi:10.1126/sciadv.ads4371", "year": "2025", "article-id_pmc": "PMC12239959", "type": "title", "authors": "Sen I, Smith JAB, Caria E, Orlov I, Savikj M, Brady AJ, Lian K, Ellefsen S, Zierath JR, Krook A, "}, "offset": 0, "text": "Down-regulation of human-specific lncRNA TMEM9B-AS1 in skeletal muscle of people with type 2 diabetes affects ribosomal biogenesis.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 19, "length": 5}]}, {"id": "4", "infons": {"identifier": "493900", "type": "Gene", "valid": true, "normalized": [493900], "database": "ncbi_gene", "normalized_id": 493900, "biotype": "gene", "name": "TMEM9B-AS1", "accession": "@GENE_TMEM9B_AS1"}, "text": "TMEM9B-AS1", "locations": [{"offset": 41, "length": 10}]}, {"id": "5", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes", "locations": [{"offset": 86, "length": 15}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 132, "text": "Long noncoding RNAs (lncRNAs) are important regulators of skeletal muscle physiology, with altered expression noted in several human diseases including type 2 diabetes. We report that TMEM9B-AS1, a previously uncharacterized lncRNA, is down-regulated in skeletal muscle of men with type 2 diabetes and skeletal muscle from individuals with sarcopenia. Silencing of TMEM9B-AS1 in primary human myotubes attenuated protein synthesis, concomitant with reduced phosphorylation of ribosomal protein S6. Moreover, we show that TMEM9B-AS1 plays a pivotal role in regulation of ribosomal biogenesis by facilitating messenger RNA stabilization of the transcription factor MYC through direct physical interaction with the RNA binding protein, insulin-like growth factor 2 mRNA binding protein 1 (IGF2BP1). Disrupted ribosomal biogenesis resulting from TMEM9B-AS1 silencing leads to decreased expression of muscle contractile and structural proteins important for maintenance of skeletal muscle mass and function. Collectively, our data reveal a role of TMEM9B-AS1 in skeletal muscle loss associated with metabolic disorders.", "sentences": [], "annotations": [{"id": "23", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 259, "length": 5}]}, {"id": "24", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes", "locations": [{"offset": 284, "length": 15}]}, {"id": "25", "infons": {"identifier": "493900", "type": "Gene", "valid": true, "normalized": [493900], "database": "ncbi_gene", "normalized_id": 493900, "biotype": "gene", "name": "TMEM9B-AS1", "accession": "@GENE_TMEM9B_AS1"}, "text": "TMEM9B-AS1", "locations": [{"offset": 316, "length": 10}]}, {"id": "26", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "men", "locations": [{"offset": 405, "length": 3}]}, {"id": "27", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes", "locations": [{"offset": 414, "length": 15}]}, {"id": "28", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 472, "length": 10}]}, {"id": "29", "infons": {"identifier": "493900", "type": "Gene", "valid": true, "normalized": [493900], "database": "ncbi_gene", "normalized_id": 493900, "biotype": "gene", "name": "TMEM9B-AS1", "accession": "@GENE_TMEM9B_AS1"}, "text": "TMEM9B-AS1", "locations": [{"offset": 497, "length": 10}]}, {"id": "30", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 519, "length": 5}]}, {"id": "31", "infons": {"identifier": "6194", "type": "Gene", "ncbi_homologene": "85949", "valid": true, "normalized": [6194], "database": "ncbi_gene", "normalized_id": 6194, "biotype": "gene", "name": "RPS6", "accession": "@GENE_RPS6"}, "text": "ribosomal protein S6", "locations": [{"offset": 608, "length": 20}]}, {"id": "32", "infons": {"identifier": "493900", "type": "Gene", "valid": true, "normalized": [493900], "database": "ncbi_gene", "normalized_id": 493900, "biotype": "gene", "name": "TMEM9B-AS1", "accession": "@GENE_TMEM9B_AS1"}, "text": "TMEM9B-AS1", "locations": [{"offset": 653, "length": 10}]}, {"id": "33", "infons": {"identifier": "4609", "type": "Gene", "ncbi_homologene": "31092", "valid": true, "normalized": [4609], "database": "ncbi_gene", "normalized_id": 4609, "biotype": "gene", "name": "MYC", "accession": "@GENE_MYC"}, "text": "MYC", "locations": [{"offset": 795, "length": 3}]}, {"id": "34", "infons": {"identifier": "10642", "type": "Gene", "ncbi_homologene": "4772", "valid": true, "normalized": [10642], "database": "ncbi_gene", "normalized_id": 10642, "biotype": "gene", "name": "IGF2BP1", "accession": "@GENE_IGF2BP1"}, "text": "insulin-like growth factor 2 mRNA binding protein 1", "locations": [{"offset": 865, "length": 51}]}, {"id": "35", "infons": {"identifier": "10642", "type": "Gene", "ncbi_homologene": "4772", "valid": true, "normalized": [10642], "database": "ncbi_gene", "normalized_id": 10642, "biotype": "gene", "name": "IGF2BP1", "accession": "@GENE_IGF2BP1"}, "text": "IGF2BP1", "locations": [{"offset": 918, "length": 7}]}, {"id": "36", "infons": {"identifier": "493900", "type": "Gene", "valid": true, "normalized": [493900], "database": "ncbi_gene", "normalized_id": 493900, "biotype": "gene", "name": "TMEM9B-AS1", "accession": "@GENE_TMEM9B_AS1"}, "text": "TMEM9B-AS1", "locations": [{"offset": 974, "length": 10}]}, {"id": "37", "infons": {"identifier": "493900", "type": "Ge