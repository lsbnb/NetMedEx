d": "5", "role": "58,59"}]}, {"id": "R7", "infons": {"score": "0.986", "role1": {"identifier": "MESH:D003401", "type": "Chemical", "valid": true, "normalized": ["D003401"], "database": "ncbi_mesh", "normalized_id": "D003401", "biotype": "chemical", "name": "Creatine", "accession": "@CHEMICAL_Creatine"}, "role2": {"identifier": "MESH:D003404", "type": "Chemical", "valid": true, "normalized": ["D003404"], "database": "ncbi_mesh", "normalized_id": "D003404", "biotype": "chemical", "name": "Creatinine", "accession": "@CHEMICAL_Creatinine"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "6", "role": "58,61"}]}, {"id": "R8", "infons": {"score": "0.9993", "role1": {"identifier": "MESH:D003404", "type": "Chemical", "valid": true, "normalized": ["D003404"], "database": "ncbi_mesh", "normalized_id": "D003404", "biotype": "chemical", "name": "Creatinine", "accession": "@CHEMICAL_Creatinine"}, "role2": {"identifier": "MESH:D010100", "type": "Chemical", "valid": true, "normalized": ["D010100"], "database": "ncbi_mesh", "normalized_id": "D010100", "biotype": "chemical", "name": "Oxygen", "accession": "@CHEMICAL_Oxygen"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "7", "role": "61,44"}]}, {"id": "R9", "infons": {"score": "0.9969", "role1": {"identifier": "MESH:D003404", "type": "Chemical", "valid": true, "normalized": ["D003404"], "database": "ncbi_mesh", "normalized_id": "D003404", "biotype": "chemical", "name": "Creatinine", "accession": "@CHEMICAL_Creatinine"}, "role2": {"identifier": "MESH:D002100", "type": "Disease", "valid": true, "normalized": ["D002100"], "database": "ncbi_mesh", "normalized_id": "D002100", "biotype": "disease", "name": "Cachexia", "accession": "@DISEASE_Cachexia"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "8", "role": "61,62"}]}, {"id": "R10", "infons": {"score": "0.9985", "role1": {"identifier": "MESH:D003401", "type": "Chemical", "valid": true, "normalized": ["D003401"], "database": "ncbi_mesh", "normalized_id": "D003401", "biotype": "chemical", "name": "Creatine", "accession": "@CHEMICAL_Creatine"}, "role2": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "type": "Association"}, "nodes": [{"refid": "9", "role": "58,63"}]}], "pmid": 40543756, "pmcid": null, "meta": {}, "date": "2025-08-01T00:00:00Z", "journal": "Mol Metab", "authors": ["Fang J", "Huang X", "Guo C", "Chen T", "Chen Y", "Yang X", "Zheng M", "Ding H"], "relations_display": [{"name": "negative_correlate|@CHEMICAL_SBI_425|@GENE_ALPL"}, {"name": "associate|@CHEMICAL_Creatinine|@DISEASE_Renal_Insufficiency_Chronic"}, {"name": "associate|@CHEMICAL_Creatine|@CHEMICAL_Oxygen"}, {"name": "cause|@CHEMICAL_Creatinine|@DISEASE_Neoplasms_Adipose_Tissue"}, {"name": "associate|@CHEMICAL_Creatine|@GENE_GYPA"}, {"name": "cause|@CHEMICAL_Creatine|@DISEASE_Neoplasms_Adipose_Tissue"}, {"name": "positive_correlate|@CHEMICAL_Creatine|@CHEMICAL_Creatinine"}, {"name": "positive_correlate|@CHEMICAL_Creatinine|@CHEMICAL_Oxygen"}, {"name": "treat|@CHEMICAL_Creatinine|@DISEASE_Cachexia"}, {"name": "associate|@CHEMICAL_Creatine|@DISEASE_Renal_Insufficiency_Chronic"}]}, {"_id": "40565158|None", "id": "40565158", "infons": {}, "passages": [{"infons": {"journal": "Int J Mol Sci;2025Jun13; 26 (12) . doi:10.3390/ijms26125694", "year": "2025", "article-id_pmc": "PMC12192787", "type": "title", "authors": "Buacheen P, Karinchai J, Inthachat W, Butkinaree C, Wongnoppawich A, Imsumran A, Temviriyanukul P, Inoue YH, Pitchakarn P, "}, "offset": 0, "text": "Anoectochilus burmannicus Extract Rescues Aging-Related Phenotypes in Drosophila Susceptible to Oxidative Stress-Induced Senescence.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "2500812", "type": "Species", "valid": true, "normalized": [2500812], "database": "ncbi_taxonomy", "normalized_id": 2500812, "biotype": "species", "name": "2500812", "accession": null}, "text": "Anoectochilus burmannicus", "locations": [{"offset": 0, "length": 25}]}, {"id": "3", "infons": {"identifier": "7227", "type": "Species", "valid": true, "normalized": [7227], "database": "ncbi_taxonomy", "normalized_id": 7227, "biotype": "species", "name": "7227", "accession": null}, "text": "Drosophila", "locations": [{"offset": 70, "length": 10}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 133, "text": "Aging is a significant risk factor for various conditions, including neurodegeneration, cardiovascular disease, and type 2 diabetes. The accumulation of reactive oxygen species (ROS) and a decline in antioxidant defense are mechanisms that are widely acknowledged as causing the acceleration of both aging and the onset of age-related diseases. To promote longevity and reduce the risk of the development of aging-related disorders, it is essential to prevent or minimize oxidative stress and enhance antioxidant defense. It has been shown that Anoectochilus burmannicus (AB), a jewel orchid rich in phenolic compounds, can impact various biological activities associated with aging prevention. These activities include antioxidant, anti-inflammation, anti-insulin resistance, and anti-obesity effects. The aim of this study was to explore whether AB extract (ABE) could serve as an anti-aging agent using a Sod1-deficient Drosophila model, which accelerates the process of aging through ROS production. The results demonstrated that ABE, at a concentration of 2.5 mg/mL, significantly extended the lifespan of the flies and helped maintain their locomotor activity as they aged. ABE also reduced the age-related accumulation of damaged proteins in the muscle of the flies by inhibiting the expression of Gstd1, a genetic marker for oxidative stress. This finding agrees with those from in vitro experiments, which have shown the potential for ABE to reduce the production of ROS induced by H2O2 in myoblasts. ABE has been shown to attenuate insulin resistance, an age-related disorder, by inhibiting the pro-inflammatory cytokine TNF-alpha, which in turn increased insulin-stimulated glucose uptake in adipocytes. These findings suggest a promising role of ABE as an ingredient in functional foods or nutraceuticals aimed at promoting health, preventing oxidative stress, and potentially managing age-associated diseases.", "sentences": [], "annotations": [{"id": "37", "infons": {"identifier": "MESH:D019636", "type": "Disease", "valid": true, "normalized": ["D019636"], "database": "ncbi_mesh", "normalized_id": "D019636", "biotype": "disease", "name": "Neurodegenerative Diseases", "accession": "@DISEASE_Neurodegenerative_Diseases"}, "text": "neurodegeneration", "locations": [{"offset": 202, "length": 17}]}, {"id": "38", "infons": {"identifier": "MESH:D002318", "type": "Disease", "valid": true, "normalized": ["D002318"], "database": "ncbi_mesh", "normalized_id": "D002318", "biotype": "disease", "name": "Cardiovascular Diseases", "accession": "@DISEASE_Cardiovascular_Diseases"}, "text": "cardiovascular disease", "locations": [{"offset": 221, "length": 22}]}, {"id": "39", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes", "locations": [{"offset": 249, "length": 15}]}, {"id": "40", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "reactive oxygen species", "locations": [{"offset": 286, "length": 23}]}, {"id": "41", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 311, "length": 3}]}, {"id": "42", "infons": {"identifier": "MESH:D019588", "type": "Disease", "valid": true, "normalized": ["D019588"], "database": "ncbi_mesh", "normalized_id": "D019588", "biotype": "disease", "name": "Aging Premature", "accession": "@DISEASE_Aging_Premature"}, "text": "age-", "locations": [{"offset": 456, "length": 4}]}, {"id": "43", "infons": {"identifier": "MESH:D004194", "type": "Disease", "valid": true, "normalized": ["D004194"], "database": "ncbi_mesh", "normalized_id": "D004194", "biotype": "disease", "name": "Disease", "accession": "@DISEASE_Disease"}, "text": "diseases", "locations": [{"offset": 468, "length": 8}]}, {"id": "44", "infons": {"identifier": "2500812", "type": "Species", "valid": true, "normalized": [2500812], "database": "ncbi_taxonomy", "normalized_id": 2500812, "biotype": "species", "name": "2500812", "accession": null}, "text": "Anoectochilus burmannicus", "locations": [{"offset": 678, "length": 25}]}, {"id": "45", "infons": {"identifier": "2500812", "type": "Species", "valid": true, "normalized": [2500812], "database": "ncbi_taxonomy", "normalized_id": 2500812, "biotype": "species", "name": "2500812", "accession": null}, "text": "AB", "locations": [{"offset": 705, "length": 2}]}, {"id": "46", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "phenolic compounds", "locations": [{"offset": 733, "length": 18}]}, {"id": "47", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 871, "length": 12}]}, {"id": "48", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "insulin resistance", "locations": [{"offset": 890, "length": 18}]}, {"id": "49", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 919, "length": 7}]}, {"id": "50", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "AB extract", "locations": [{"offset": 981, "length": 10}]}, {"id": "51", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "ABE", "locations": [{"offset": 993, "length": 3}]}, {"id": "52", "infons": {"identifier": "39251", "type": "Gene", "ncbi_homologene": "392", "valid": true, "normalized": [39251], "database": "ncbi_gene", "normalized_id": 39251, "biotype": "gene", "name": "Sod1", "accession": "@GENE_SOD1"}, "text": "Sod1", "locations": [{"offset": 1041, "length": 4}]}, {"id": "53", "infons": {"identifier": "7227", "type": "Species", "valid": true, "normalized": [7227], "database": "ncbi_taxonomy", "normalized_id": 7227, "biotype": "species", "name": "7227", "accession": null}, "text": "Drosophila", "locations": [{"offset": 1056, "length": 10}]}, {"id": "54", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 1121, "length": 3}]}, {"id": "55", "infons": {"identifier": "-", "type