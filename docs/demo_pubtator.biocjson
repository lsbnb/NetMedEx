D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "role2": {"identifier": "26416", "type": "Gene", "valid": true, "normalized": [26416], "database": "ncbi_gene", "normalized_id": 26416, "biotype": "gene", "name": "Mapk14", "accession": "@GENE_MAPK14"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "3", "role": "30,35"}]}, {"id": "R5", "infons": {"score": "0.8208", "role1": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "role2": {"identifier": "MESH:D009569", "type": "Chemical", "valid": true, "normalized": ["D009569"], "database": "ncbi_mesh", "normalized_id": "D009569", "biotype": "chemical", "name": "Nitric Oxide", "accession": "@CHEMICAL_Nitric_Oxide"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "30,27"}]}], "pmid": 41343580, "pmcid": null, "meta": {}, "date": "2025-12-04T00:00:00Z", "journal": "PLoS One", "authors": ["Jantarawong S", "Khimmaktong W", "Panichayupakaranant P", "Pengjam Y"], "relations_display": [{"name": "treat|@CHEMICAL_Dexamethasone|@DISEASE_Muscle_Neoplasms"}, {"name": "associate|@GENE_CTSB|@GENE_DOCK2"}, {"name": "positive_correlate|@CHEMICAL_Dexamethasone|@GENE_CTNNB1"}, {"name": "positive_correlate|@CHEMICAL_Dexamethasone|@GENE_MAPK14"}, {"name": "associate|@CHEMICAL_Dexamethasone|@CHEMICAL_Nitric_Oxide"}]}, {"_id": "41347804|None", "id": "41347804", "infons": {}, "passages": [{"infons": {"journal": "Int J Mol Med;2026Feb; 57 (2) . doi:10.3892/ijmm.2025.5706", "year": "2026", "article-id_pmc": "PMC12695155", "type": "title", "authors": "Xiao Q, Zeng H, Yang R, Zhan Y, Lin F, Chen B, Chen X, "}, "offset": 0, "text": "Branched-chain amino acid metabolism and bone metabolism: Implications for osteoporosis pathogenesis and therapeutic strategies (Review).", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Branched", "locations": [{"offset": 0, "length": 8}]}, {"id": "4", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "amino acid", "locations": [{"offset": 15, "length": 10}]}, {"id": "5", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "osteoporosis", "locations": [{"offset": 75, "length": 12}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 138, "text": "Branched-chain amino acids (BCAAs) are biologically active amino acids with branched carbon chains, recognized for their diverse biological functions and therapeutic potential. BCAAs have demonstrated promising effects in the prevention and treatment of various conditions, including muscle growth disorders, cardiovascular diseases and cancer. Despite extensive research confirming their targeted therapeutic effects in multiple domains, the mechanisms of action and therapeutic range of BCAAs remain incompletely understood. Osteoporosis, a metabolic bone disease, is a global public health issue characterized by an imbalance between osteoblast-mediated bone formation and osteoclast-induced bone resorption, resulting in fragile bones and an elevated risk of fractures. Given the well-documented therapeutic roles of BCAAs, their potential link to osteoporosis has been explored, emphasizing the influence of BCAA metabolism on bone metabolism. The present review aims to summarize findings on the relationship between BCAA metabolism and osteoporosis, and to investigate the mechanisms by which BCAA metabolism may exert anti-osteoporotic effects. The review first outlines the fundamental processes and key factors influencing bone metabolism, BCAA metabolism and osteoporosis. It then examines the interactions between these processes and the effects of BCAA metabolism on bone health. Finally, it explores the potential of targeting BCAA metabolic pathways as a future therapeutic strategy for osteoporosis, highlighting BCAAs as a promising target for treating this condition.", "sentences": [], "annotations": [{"id": "33", "infons": {"identifier": "MESH:D000597", "type": "Chemical", "valid": true, "normalized": ["D000597"], "database": "ncbi_mesh", "normalized_id": "D000597", "biotype": "chemical", "name": "Amino Acids Branched-Chain", "accession": "@CHEMICAL_Amino_Acids_Branched_Chain"}, "text": "Branched-chain amino acids", "locations": [{"offset": 138, "length": 26}]}, {"id": "34", "infons": {"identifier": "MESH:D000597", "type": "Chemical", "valid": true, "normalized": ["D000597"], "database": "ncbi_mesh", "normalized_id": "D000597", "biotype": "chemical", "name": "Amino Acids Branched-Chain", "accession": "@CHEMICAL_Amino_Acids_Branched_Chain"}, "text": "BCAAs", "locations": [{"offset": 166, "length": 5}]}, {"id": "35", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "amino acids", "locations": [{"offset": 197, "length": 11}]}, {"id": "36", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "branched", "locations": [{"offset": 214, "length": 8}]}, {"id": "37", "infons": {"identifier": "MESH:D002244", "type": "Chemical", "valid": true, "normalized": ["D002244"], "database": "ncbi_mesh", "normalized_id": "D002244", "biotype": "chemic