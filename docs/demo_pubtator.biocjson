", "type": "Chemical", "valid": true, "normalized": ["D015032"], "database": "ncbi_mesh", "normalized_id": "D015032", "biotype": "chemical", "name": "Zinc", "accession": "@CHEMICAL_Zinc"}, "text": "zinc", "locations": [{"offset": 1087, "length": 4}]}, {"id": "51", "infons": {"identifier": "MESH:D008108", "type": "Disease", "valid": true, "normalized": ["D008108"], "database": "ncbi_mesh", "normalized_id": "D008108", "biotype": "disease", "name": "Liver Diseases Alcoholic", "accession": "@DISEASE_Liver_Diseases_Alcoholic"}, "text": "ALD", "locations": [{"offset": 1139, "length": 3}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.8731", "role1": {"identifier": "MESH:D000438", "type": "Chemical", "valid": true, "normalized": ["D000438"], "database": "ncbi_mesh", "normalized_id": "D000438", "biotype": "chemical", "name": "Alcohols", "accession": "@CHEMICAL_Alcohols"}, "role2": {"identifier": "MESH:C564286", "type": "Disease", "valid": true, "normalized": ["C564286"], "database": "ncbi_mesh", "normalized_id": "C564286", "biotype": "disease", "name": "Zinc Deficiency Neonatal due to Low Breast Milk Zinc", "accession": "@DISEASE_Zinc_Deficiency_Neonatal_due_to_Low_Breast_Milk_Zinc"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "23,16"}]}, {"id": "R2", "infons": {"score": "0.9982", "role1": {"identifier": "MESH:D015032", "type": "Chemical", "valid": true, "normalized": ["D015032"], "database": "ncbi_mesh", "normalized_id": "D015032", "biotype": "chemical", "name": "Zinc", "accession": "@CHEMICAL_Zinc"}, "role2": {"identifier": "493829", "type": "Gene", "valid": true, "normalized": [493829], "database": "ncbi_gene", "normalized_id": 493829, "biotype": "gene", "name": "TRIM72", "accession": "@GENE_TRIM72"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "24,9"}]}, {"id": "R3", "infons": {"score": "0.9816", "role1": {"identifier": "MESH:D015032", "type": "Chemical", "valid": true, "normalized": ["D015032"], "database": "ncbi_mesh", "normalized_id": "D015032", "biotype": "chemical", "name": "Zinc", "accession": "@CHEMICAL_Zinc"}, "role2": {"identifier": "MESH:D008108", "type": "Disease", "valid": true, "normalized": ["D008108"], "database": "ncbi_mesh", "normalized_id": "D008108", "biotype": "disease", "name": "Liver Diseases Alcoholic", "accession": "@DISEASE_Liver_Diseases_Alcoholic"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "24,25"}]}, {"id": "R4", "infons": {"score": "0.995", "role1": {"identifier": "MESH:D015032", "type": "Chemical", "valid": true, "normalized": ["D015032"], "database": "ncbi_mesh", "normalized_id": "D015032", "biotype": "chemical", "name": "Zinc", "accession": "@CHEMICAL_Zinc"}, "role2": {"identifier": "217", "type": "Gene", "valid": true, "normalized": [217], "database": "ncbi_gene", "normalized_id": 217, "biotype": "gene", "name": "ALDH2", "accession": "@GENE_ALDH2"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "24,22"}]}, {"id": "R5", "infons": {"score": "0.9993", "role1": {"identifier": "MESH:D000438", "type": "Chemical", "valid": true, "normalized": ["D000438"], "database": "ncbi_mesh", "normalized_id": "D000438", "biotype": "chemical", "name": "Alcohols", "accession": "@CHEMICAL_Alcohols"}, "role2": {"identifier": "MESH:D008108", "type": "Disease", "valid": true, "normalized": ["D008108"], "database": "ncbi_mesh", "normalized_id": "D008108", "biotype": "disease", "name": "Liver Diseases Alcoholic", "accession": "@DISEASE_Liver_Diseases_Alcoholic"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "23,25"}]}, {"id": "R6", "infons": {"score": "0.995", "role1": {"identifier": "MESH:D015032", "type": "Chemical", "valid": true, "normalized": ["D015032"], "database": "ncbi_mesh", "normalized_id": "D015032", "biotype": "chemical", "name": "Zinc", "accession": "@CHEMICAL_Zinc"}, "role2": {"identifier": "10327", "type": "Gene", "valid": true, "normalized": [10327], "database": "ncbi_gene", "normalized_id": 10327, "biotype": "gene", "name": "AKR1A1", "accession": "@GENE_AKR1A1"}, "type": "Association"}, "nodes": [{"refid": "5", "role": "24,21"}]}, {"id": "R7", "infons": {"score": "0.9283", "role1": {"identifier": "MESH:D000438", "type": "Chemical", "valid": true, "normalized": ["D000438"], "database": "ncbi_mesh", "normalized_id": "D000438", "biotype": "chemical", "name": "Alcohols", "accession": "@CHEMICAL_Alcohols"}, "role2": {"identifier": "217", "type": "Gene", "valid": true, "normalized": [217], "database": "ncbi_gene", "normalized_id": 217, "biotype": "gene", "name": "ALDH2", "accession": "@GENE_ALDH2"}, "type": "Association"}, "nodes": [{"refid": "6", "role": "23,22"}]}], "pmid": 41688442, "pmcid": null, "meta": {}, "date": "2026-02-13T00:00:00Z", "journal": "Nat Commun", "authors": ["Shu T", "Zeng X", "Wang J", "Jiang H", "Wang Y", "Zhang M", "Jiang L", "He B", "Yang L", "Liu N", "Tang M", "Jiang Y", "Zhang L", "Chen P", "Xie J", "Fang D", "Lee KE", "Chen Y", "Kim J", "Liu R", "Ye Y", "Han Y", "Ma J", "Zeng C"], "relations_display": [{"name": "associate|@CHEMICAL_Alcohols|@DISEASE_Zinc_Deficiency_Neonatal_due_to_Low_Breast_Milk_Zinc"}, {"name": "associate|@CHEMICAL_Zinc|@GENE_TRIM72"}, {"name": "treat|@CHEMICAL_Zinc|@DISEASE_Liver_Diseases_Alcoholic"}, {"name": "associate|@CHEMICAL_Zinc|@GENE_ALDH2"}, {"name": "associate|@CHEMICAL_Alcohols|@DISEASE_Liver_Diseases_Alcoholic"}, {"name": "associate|@CHEMICAL_Zinc|@GENE_AKR1A1"}, {"name": "associate|@CHEMICAL_Alcohols|@GENE_ALDH2"}]}, {"_id": "41689168|None", "id": "41689168", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "The HIF-1alpha Pathway Regulates Satellite Cell Fate During Aging Through Histone Lactylation.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "15251", "type": "Gene", "ncbi_homologene": "1171", "valid": true, "normalized": [15251], "database": "ncbi_gene", "normalized_id": 15251, "biotype": "gene", "name": "Hif1a", "accession": "@GENE_HIF1A"}, "text": "HIF-1alpha", "locations": [{"offset": 4, "length": 10}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 95, "text": "Aging-associated sarcopenia is driven in part by the progressive loss of type II glycolytic fibers and the functional decline of their resident stem cells, the satellite cells (SCs). We show here that these defects result from attenuation of the hypoxia-inducible factor-1alpha (HIF-1alpha) signaling pathway and can be reversed by pharmacological HIF-1alpha reactivation. In the tibialis anterior muscle of 18-month-old C57BL/6J mice, HIF-1alpha protein abundance decreased by  46% and canonical targets (Vegfa, Egln1) were downregulated in freshly isolated SCs. Treatment of aged SCs with the prolyl hydroxylase inhibitor roxadustat (FG-4592) for 48 h restored HIF signaling, upregulated glycolytic enzymes (HK2, GAPDH, ALDO) and the lactate transporter MCT4, and increased intracellular lactate by 1.9-fold. Increased lactate enhanced global histone lactylation, an epigenetic mark that decreased with age. The effect was attenuated by the LDHA inhibitor oxamate, establishing a link between HIF-driven metabolism and chromatin remodeling. HIF-1alpha activation slowed old SC proliferation (S phase -60%), but decreased the senescence marker p16Ink4a (-54%) and increased the stem cell factor Pax7 (+1.8-fold), indicating a shift from senescence to a quiescent, regenerative state. When differentiation was induced without drugs, pretreated aged SCs formed hypertrophic myotubes (differentiation index +1.7), exhibited higher ATP content (+1.54-fold), and activated the IGF-1/PI3K-Akt-mTOR pathway, leading to an increase in tropomyosin (Tpm1) in fast fibers. These results suggest a HIF-1alpha-lactate-lactylation axis that rejuvenates aged satellite cells and enhances myogenic performance, providing a mechanistic rationale for repurposing roxadustat to alleviate sarcopenia.", "sentences": [], "annotations": [{"id": "33", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 112, "length": 10}]}, {"id": "34", "infons": {"identifier": "15251", "type": "Gene", "ncbi_homologene": "1171", "valid": true, "normalized": [15251], "database": "ncbi_gene", "normalized_id": 15251, "biotype": "gene", "name": "Hif1a", "accession": "@GENE_HIF1A"}, "text": "hypoxia-inducible factor-1alpha", "locations": [{"offset": 341, "length": 31}]}, {"id": "35", "infons": {"identifier": "15251", "type": "Gene", "ncbi_homologene": "1171", "valid": true, "normalized": [15251], "database": "ncbi_gene", "normalized_id": 15251, "biotype": "gene", "name": "Hif1a", "accession": "@GENE_HIF1A"}, "text": "HIF-1alpha", "locations": [{"offset": 374, "length": 10}]}, {"id": "36", "infons": {"identifier": "15251", "type": "Gene", "ncbi_homologene": "1171", "valid": true, "normalized": [15251], "database": "ncbi_gene", "normalized_id": 15251, "biotype": "gene", "name": "Hif1a", "accession": "@GENE_HIF1A"}, "text": "HIF-1alpha", "locations": [{"offset": 443, "length": 10}]}, {"id": "37", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 525, "length": 4}]}, {"id": "38", "infons": {"identifier": "15251", "type": "Gene", "ncbi_homologene": "1171", "valid": true, "normalized": [15251], "database": "ncbi_gene", "normalized_id": 15251, "biotype": "gene", "name": "Hif1a", "accession": "@GENE_HIF1A"}, "text": "HIF-1alpha", "locations": [{"offset": 531, "length": 10}]}, {"id": "39", "infons": {"identifier": "22339", "type": "Gene", "ncbi_homologene": "2534", "valid": true, "normalized": [22339], "database": "ncbi_gene", "normalized_id": 22339, "biotype": "gene",