zed_id": "D005756", "biotype": "disease", "name": "Gastritis", "accession": "@DISEASE_Gastritis"}, "text": "gastritis", "locations": [{"offset": 1702, "length": 9}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9865", "role1": {"identifier": "MESH:D000074263", "type": "Chemical", "valid": true, "normalized": ["D000074263"], "database": "ncbi_mesh", "normalized_id": "D000074263", "biotype": "chemical", "name": "Coconut Oil", "accession": "@CHEMICAL_Coconut_Oil"}, "role2": {"identifier": "MESH:D013274", "type": "Disease", "valid": true, "normalized": ["D013274"], "database": "ncbi_mesh", "normalized_id": "D013274", "biotype": "disease", "name": "Stomach Neoplasms", "accession": "@DISEASE_Stomach_Neoplasms"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "13,21"}]}, {"id": "R2", "infons": {"score": "0.9979", "role1": {"identifier": "MESH:C031492", "type": "Chemical", "valid": true, "normalized": ["C031492"], "database": "ncbi_mesh", "normalized_id": "C031492", "biotype": "chemical", "name": "octanoic acid", "accession": "@CHEMICAL_octanoic_acid"}, "role2": {"identifier": "MESH:D005756", "type": "Disease", "valid": true, "normalized": ["D005756"], "database": "ncbi_mesh", "normalized_id": "D005756", "biotype": "disease", "name": "Gastritis", "accession": "@DISEASE_Gastritis"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "1", "role": "25,27"}]}, {"id": "R3", "infons": {"score": "0.9984", "role1": {"identifier": "MESH:C031492", "type": "Chemical", "valid": true, "normalized": ["C031492"], "database": "ncbi_mesh", "normalized_id": "C031492", "biotype": "chemical", "name": "octanoic acid", "accession": "@CHEMICAL_octanoic_acid"}, "role2": {"identifier": "MESH:D016481", "type": "Disease", "valid": true, "normalized": ["D016481"], "database": "ncbi_mesh", "normalized_id": "D016481", "biotype": "disease", "name": "Helicobacter Infections", "accession": "@DISEASE_Helicobacter_Infections"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "25,23"}]}, {"id": "R4", "infons": {"score": "0.9988", "role1": {"identifier": "MESH:C031492", "type": "Chemical", "valid": true, "normalized": ["C031492"], "database": "ncbi_mesh", "normalized_id": "C031492", "biotype": "chemical", "name": "octanoic acid", "accession": "@CHEMICAL_octanoic_acid"}, "role2": {"identifier": "MESH:D013274", "type": "Disease", "valid": true, "normalized": ["D013274"], "database": "ncbi_mesh", "normalized_id": "D013274", "biotype": "disease", "name": "Stomach Neoplasms", "accession": "@DISEASE_Stomach_Neoplasms"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "3", "role": "25,21"}]}], "pmid": 41003013, "pmcid": null, "meta": {}, "date": "2025-09-22T00:00:00Z", "journal": "Metabolites", "authors": ["Balderrama-Gómez A", "Muñoz-Pérez VM", "Ortiz MI", "Cariño-Cortés R", "Castro-Rosas J", "Betanzos A", "Fernández-Martínez E", "Castillo-Juárez I"], "relations_display": [{"name": "treat|@CHEMICAL_Coconut_Oil|@DISEASE_Stomach_Neoplasms"}, {"name": "treat|@CHEMICAL_octanoic_acid|@DISEASE_Gastritis"}, {"name": "treat|@CHEMICAL_octanoic_acid|@DISEASE_Helicobacter_Infections"}, {"name": "treat|@CHEMICAL_octanoic_acid|@DISEASE_Stomach_Neoplasms"}]}, {"_id": "41017405|None", "id": "41017405", "infons": {}, "passages": [{"infons": {"journal": "Zool Res;2025Sep18; 46 (5) 1219. doi:10.24272/j.issn.2095-8137.2025.127", "year": "2025", "type": "title", "authors": "Zhu YY, Zhao LM, Jia XY, Liao GJ, Wang YP, "}, "offset": 0, "text": "Amphibians as a source of bioactive antioxidant peptides: Emerging insights and therapeutic potential.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "antioxidant peptides", "locations": [{"offset": 36, "length": 20}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 103, "text": "Oxidative stress arises from disruption of the balance between reactive oxygen species (ROS) production and detoxification and constitutes a fundamental driver of diverse pathological diseases. Skin photoaging is a well-recognized example, primarily driven by chronic ultraviolet (UV) exposure and marked by progressive structural and functional deterioration. UV-induced ROS accelerate macromolecular degradation and impair epidermal and dermal barrier integrity, highlighting the urgent need for effective antioxidant interventions. Antioxidant peptides (AOPs), whether naturally occurring or synthetically engineered, have shown considerable potential in mitigating ROS-induced cellular damage. Amphibians, which possess highly permeable skin and are continuously challenged by fluctuating environmental conditions, represent a rich source of bioactive peptides with potent antioxidant properties. In particular, AOPs isolated from amphibian skin secretions demonstrate notable efficacy in ROS scavenging and mitigation of oxidative damage, offering promising candidates for anti-photoaging therapies. This review provides an integrated overview of ROS generation and signaling, the molecular mechanisms linking oxidative stress to skin photoaging, and the emerging biomedical potential of amphibian-derived AOPs. Deeper mechanistic insight into their structure and function is expected to accelerate the development of novel peptide-based interventions for photoaging and other oxidative stress-associated dermatological disorders.", "sentences": [], "annotations": [{"id": "13", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "reactive oxygen species", "locations": [{"offset": 166, "length": 23}]}, {"id": "14", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 191, "length": 3}]}, {"id": "15", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 475, "length": 3}]}, {"id": "16", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Antioxidant peptides", "locations": [{"offset": 638, "length": 20}]}, {"id": "17", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "AOPs", "locations": [{"offset": 660, "length": 4}]}, {"id": "18", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 772, "length": 3}]}, {"id": "19", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "AOPs", "locations": [{"offset": 1019, "length": 4}]}, {"id": "20", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 1096, "length": 3}]}, {"id": "21", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 1255, "length": 3}]}, {"id": "22", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "AOPs", "locations": [{"offset": 1414, "length": 4}]}, {"id": "23", "infons": {"identifier": "MESH:D000168", "type": "Disease", "valid": true, "normalized": ["D000168"], "database": "ncbi_mesh", "normalized_id": "D000168", "biotype": "disease", "name": "Acrocephalosyndactylia", "accession": "@DISEASE_Acrocephalosyndactylia"}, "text": "dermatological disorders", "locations": [{"offset": 1613, "length": 24}]}], "relations": []}], "relations": [], "pmid": 41017405, "pmcid": null, "meta": {}, "date": "2025-09-18T00:00:00Z", "journal": "Zool Res", "authors": ["Zhu YY", "Zhao LM", "Jia XY", "Liao GJ", "Wang YP"], "relations_display": []}, {"_id": "41024483|None", "id": "41024483", "infons": {}, "passages": [{"infons": {"journal": "Ann Clin Transl Neurol;2025Sep29. doi:10.1002/acn3.70209", "year": "2025", "type": "title", "authors": "Hagemann TL, Sonsalla MM, Luzinski C, Zacahua F, Harris DA, Lamming DW, Messing A, "}, "offset": 0, "text": "Growth Differentiation Factor 15 Elevation in the Central Nervous System Is Associated With Failure to Thrive in Alexander Disease.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "29455", "type": "Gene", "ncbi_homologene": "3576", "valid": true, "normalized": [29455], "database": "ncbi_gene", "normalized_id": 29455, "biotype": "gene", "name": "Gdf15", "accession": "@GENE_GDF15"}, "text": "Growth Differentiation Factor 15", "locations": [{"offset": 0, "length": 32}]}, {"id": "4", "infons": {"identifier": "MESH:D005183", "type": "Disease", "valid": true, "normalized": ["D005183"], "database": "ncbi_mesh", "normalized_id": "D005183", "biotype": "disease", "name": "Failure to Thrive", "accession": "@DISEASE_Failure_to_Thrive"}, "text": "Failure to Thrive", "locations": [{"offset": 92, "length": 17}]}, {"id": "5", "infons": {"identifier": "MESH:D038261", "type": "Disease", "valid": true, "normalized": ["D038261"], "database": "ncbi_mesh", "normalized_id": "D038261", "biotype": "disease", "name": "Alexander Disease", "accession": "@DISEASE_Alexander_Disease"}, "text": "Alexander Disease", "locations": [{"offset": 113, "length": 17}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 132, "text": "OBJECTIVE: Alexander disease (AxD) is a severe neurodegenerative disorder caused by gain-of-function mutations in the gene for GFAP, which lead to protein aggregation and a primary astrocytopathy. Symptoms vary, but failure to thrive (FTT) and frequent emesis are common and cause significant morbidity. Here we investigate GDF15, a member of the TGFbeta superfamily, which regulates energy balance and appetite, as a potential mediator of FTT in AxD. METHODS: In this study, we use the Gfap+/R237H rat model (R237H), in which pups fail to gain weight after weaning and become frail and impaired as they mature, to assess muscle atrophy, energy expenditure, and feeding behavior in AxD. We measure GDF15 in brain and cerebrospinal fluid (CSF), assess activation of its receptor GFRAL in area postrema neurons, and use GFAP suppression to correlate FTT phenotypes with GDF15 expression. Finally, we measure GDF15 in patients with AxD. RESULTS: R237H rats show reduced lean and fat mass and muscle atrophy despite reduced energy expenditure, and at an early age exhibit pica and anorexia. GDF15 is expressed by R237H rat astrocytes and is elevated in brainstem and CSF, but not in plasma. Neurons expressing GFRAL, a mediator of GDF15-induced appetite suppression, are activated in the area postrema. Suppression of GFAP using antisense oligonucleotides normalizes weight gain and GDF15 levels in brainstem and CSF. In human AxD, GDF15 is elevated in CSF, but not in blood. INTERPRETATION: GDF15 is associated with FTT in AxD and provides both a target and useful biomarker for the development of future therapeutics.", "sentences": [], "annotations": [{"id": "55", "infons": {"identifier": "MESH:D038261", "type": "Disease", "valid": true, "normalized": ["D038261"], "database": "ncbi_mesh", "normalized_id": "D038261", "biotype": "disease", "name": "Alexander Disease", "accession": "@DISEASE_Alexander_Disease"}, "text": "Alexander disease", "locations": [{"offset": 143, "length": 17}]}, {"id": "56", "infons": {"identifier": "MESH:D038261", "type": "Disease", "valid": true, "normalized": ["D038261"], "database": "ncbi_mesh", "normalized_id": "D038261", "biotype": "disease", "name": "Alexander Disease", "accession": "@DISEASE_Alexander_Disease"}, "text": "AxD", "locations": [{"offset": 162, "length": 3}]}, {"id": "57", "infons": {"identifier": "MESH:D019636", "type": "Disease", "valid": true, "normalized": ["D019636"], "database": "ncbi_mesh", "normalized_id": "D019636", "biotype": "disease", "name": "Neurodegenerative Diseases", "accession": "@DISEASE_Neurodegenerative_Diseases"}, "text": "neurodegenerative disorder", "locations": [{"offset": 179, "length": 26}]}, {"id": "58", "infons": {"identifier": "24387", "type": "Gene", "ncbi_homologene": "1554", "valid": true, "normalized": [24387], "database": "ncbi_gene", "normalized_id": 24387, "biotype": "gene", "name": "Gfap", "accession": "@GENE_GFAP"}, "text": "GFAP", "locations": [{"offset": 259, "length": 4}]}, {"id": "59", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "astrocytopathy", "locations": [{"offset": 313, "length": 14}]}, {"id": "60", "infons": {"identifier": "MESH:D005183", "type": "Disease", "valid": true, "normalized": ["D005183"], "database": "ncbi_mesh", "normalized_id": "D005183", "biotype": "disease", "name": "Failure to Thrive", "accession": "@DISEASE_Failure_to_Thrive"}, "text": "failure to thrive", "locations": [{"offset": 348, "length": 17}]}, {"id": "61", "infons": {"identifier": "MESH:D005183", "type": "Disease", "valid": true, "normalized": ["D005183"], "database": "ncbi_mesh", "normalized_id": "D005183", "biotype": "disease", "name": "Failure to Thrive", "accession": "@DISEASE_Failure_to_Thrive"}, "text": "FTT", "locations": [{"offset": 367, "length": 3}]}, {"id": "62", "infons": {"identifier": "MESH:D014839", "type": "Disease", "valid": true, "normalized": ["D014839"], "database": "ncbi_mesh", "normalized_id": "D014839", "biotype": "disease", "name": "Vomiting", "accession": "@DISEASE_Vomiting"}, "text": "emesis", "locations": [{"offset": 385, "length": 6}]}, {"id": "63", "infons": {"identifier": "29455", "type": "Gene", "ncbi_homologene": "3576", "valid": true, "normalized": [29455], "database": "ncbi_gene", "normalized_id": 29455, "biotype": "gene", "name": "Gdf15", "accession": "@GENE_GDF15"}, "text": "GDF15", "locations": [{"offset": 456, "length": 5}]}, {"id": "64", "infons": {"identifier": "59086", "type": "Gene", "ncbi_homologene": "540", "valid": true, "normalized": [59086], "database": "ncbi_gene", "normalized_id": 59086, "biotype": "gene", "name": "Tgfb1", "accession": "@GENE_TGFB1"}, "text": "TGFbeta", "locations": [{"offset": 479, "length": 7}]}, {"id": "65", "infons": {"identifier": "MESH:D001068", "type": "Disease", "valid": true, "normalized": ["D001068"], "database": "ncbi_mesh", "normalized_id": "D001068", "biotype": "disease", "name": "Feeding and Eating Disorders", "accession": "@DISEASE_Feeding_and_Eating_Disorders"}, "text": "appetite", "locations": [{"offset": 535, "length": 8}]}, {"id": "66", "infons": {"identifier": "MESH:D005183", "type": "Disease", "valid": true, "normalized": ["D005183"], "database": "ncbi_mesh", "normalized_id": "D005183", "biotype": "disease", "name": "Failure to Thrive", "accession": "@DISEASE_Failure_to_Thrive"}, "text": "FTT", "locations": [{"offset": 572, "length": 3}]}, {"id": "67", "infons": {"identifier": "MESH:D038261", "type": "Disease", "valid": true, "normalized": ["D038261"], "data