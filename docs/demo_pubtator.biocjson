e": "ncbi_gene", "normalized_id": 2641, "biotype": "gene", "name": "GCG", "accession": "@GENE_GCG"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "21,5"}]}, {"id": "R6", "infons": {"score": "0.5519", "role1": {"identifier": "MESH:C015516", "type": "Chemical", "valid": true, "normalized": ["C015516"], "database": "ncbi_mesh", "normalized_id": "C015516", "biotype": "chemical", "name": "succinyl-trialanine-4-nitroanilide", "accession": "@CHEMICAL_succinyl_trialanine_4_nitroanilide"}, "role2": {"identifier": "MESH:D015431", "type": "Disease", "valid": true, "normalized": ["D015431"], "database": "ncbi_mesh", "normalized_id": "D015431", "biotype": "disease", "name": "Weight Loss", "accession": "@DISEASE_Weight_Loss"}, "type": "Negative_Correlation"}, "nodes": []}, {"id": "R7", "infons": {"score": "0.983", "role1": {"identifier": "MESH:D012459", "type": "Chemical", "valid": true, "normalized": ["D012459"], "database": "ncbi_mesh", "normalized_id": "D012459", "biotype": "chemical", "name": "Salicylates", "accession": "@CHEMICAL_Salicylates"}, "role2": {"identifier": "MESH:D015431", "type": "Disease", "valid": true, "normalized": ["D015431"], "database": "ncbi_mesh", "normalized_id": "D015431", "biotype": "disease", "name": "Weight Loss", "accession": "@DISEASE_Weight_Loss"}, "type": "Negative_Correlation"}, "nodes": []}, {"id": "R8", "infons": {"score": "0.9804", "role1": {"identifier": "MESH:C015516", "type": "Chemical", "valid": true, "normalized": ["C015516"], "database": "ncbi_mesh", "normalized_id": "C015516", "biotype": "chemical", "name": "succinyl-trialanine-4-nitroanilide", "accession": "@CHEMICAL_succinyl_trialanine_4_nitroanilide"}, "role2": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "5", "role": "24,23"}]}], "pmid": 40527924, "pmcid": null, "meta": {}, "date": "2025-06-17T00:00:00Z", "journal": "Nat Metab", "authors": ["Cal K", "Leyva A", "Rodríguez-Duarte J", "Ruiz S", "Santos L", "Garat MP", "Colella L", "Ingold M", "Benitez-Rosendo A", "Pérez-Torrado V", "Vilaseca C", "Galliussi G", "Ziegler L", "Peclat TR", "Bresque M", "Handy RM", "King R", "Menezes Dos Reis L", "Alves JM", "Espasandín C", "de la Sovera V", "Breining P", "Dapueto R", "Lopez A", "Thompson KL", "Lino CA", "França JV", "Vieira TS", "Rattan R", "Agorrody G", "DeVallance E", "Haag J", "Meadows E", "Lewis SE", "Santana Barbosa GC", "Lai de Souza LO", "Chichierchio MS", "Valez V", "Aicardo A", "Contreras P", "Vendelbo MH", "Jakobsen S", "Kamaid A", "Porcal W", "Calliari A", "Verdes JM", "Du J", "Wang Y", "Hollander JM", "White TA", "Radi R", "Moyna G", "Quijano C", "O'Doherty R", "Moraes-Vieira P", "Giri S", "Holloway GP", "Festuccia WT", "Leiria LO", "Leonardi R", "Mori MA", "Camacho-Pereira J", "Kelley EE", "Duran R", "López GV", "Chini EN", "Batthyány C", "Escande C"], "relations_display": [{"name": "treat|@CHEMICAL_succinyl_trialanine_4_nitroanilide|@DISEASE_Fatty_Liver"}, {"name": "treat|@CHEMICAL_succinyl_trialanine_4_nitroanilide|@DISEASE_Obesity"}, {"name": "positive_correlate|@CHEMICAL_succinyl_trialanine_4_nitroanilide|@CHEMICAL_Creatine"}, {"name": "treat|@CHEMICAL_succinyl_trialanine_4_nitroanilide|@DISEASE_Insulin_Resistance"}, {"name": "associate|@DISEASE_Obesity|@GENE_GCG"}, {"name": "treat|@CHEMICAL_succinyl_trialanine_4_nitroanilide|@DISEASE_Weight_Loss"}, {"name": "treat|@CHEMICAL_Salicylates|@DISEASE_Weight_Loss"}, {"name": "negative_correlate|@CHEMICAL_succinyl_trialanine_4_nitroanilide|@CHEMICAL_Glucose"}]}, {"_id": "40528233|None", "id": "40528233", "infons": {}, "passages": [{"infons": {"journal": "Stem Cell Res Ther;2025Jun17; 16 (1) 308. doi:10.1186/s13287-025-04431-1", "year": "2025", "article-id_pmc": "PMC12175325", "type": "title", "authors": "Wang C, Wu Y, Jiang J, "}, "offset": 0, "text": "The role and mechanism of mesenchymal stem cells in immunomodulation of type 1 diabetes mellitus and its complications: recent research progress and challenges: a review.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D003922", "type": "Disease", "valid": true, "normalized": ["D003922"], "database": "ncbi_mesh", "normalized_id": "D003922", "biotype": "disease", "name": "Diabetes Mellitus Type 1", "accession": "@DISEASE_Diabetes_Mellitus_Type_1"}, "text": "type 1 diabetes mellitus", "locations": [{"offset": 72, "length": 24}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 171, "text": "BACKGROUND: Mesenchymal stem cells are of great interest because of their multipotency, immune modulation capacity, and tissue and vascular regeneration effects. They are used in treating type 1 diabetes mellitus, helping improve the pancreatic environment and insulin secretion. Type 1 diabetes mellitus predominantly affects children and adolescents, with early onset and a prolonged course that can lead to multiorgan complications and related disorders. Studies using mesenchymal stem cells to treat type 1 diabetes mellitus have yielded promising results. This review discusses the common animal models of type 1 diabetes mellitus, mesenchymal stem cell immunotherapy mechanisms, and combined diabetes treatments. Its purpose is to summarize the current evidence on mesenchymal stem cell use in type 1 diabetes, providing insights for further research directions. MAIN FINDINGS: Current studies show that mesenchymal stem cells play an active role in the treatment of type 1 diabetes; however, clinical trials remain rare, necessitating more basic and preclinical research to identify optimal treatments. CONCLUSIONS: Mesenchymal stem cells can treat type 1 diabetes through a variety of immune mechanisms and also play a positive role in the treatment of type 1 diabetes complications. At the same time, it can be combined with other therapies to play a better therapeutic role.", "sentences": [], "annotations": [{"id": "12", "infons": {"identifier": "MESH:D003922", "type": "Disease", "valid": true, "normalized": ["D003922"], "database": "ncbi_mesh", "normalized_id": "D003922", "biotype": "disease", "name": "Diabetes Mellitus Type 1", "accession": "@DISEASE_Diabetes_Mellitus_Type_1"}, "text": "type 1 diabetes mellitus", "locations": [{"offset": 359, "length": 24}]}, {"id": "13", "infons": {"identifier": "3630", "type": "Gene", "ncbi_homologene": "173", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "text": "insulin", "locations": [{"offset": 432, "length": 7}]}, {"id": "14", "infons": {"identifier": "MESH:D003922", "type": "Disease", "valid": true, "normalized": ["D003922"], "database": "ncbi_mesh", "normalized_id": "D003922", "biotype": "disease", "name": "Diabetes Mellitus Type 1", "accession": "@DISEASE_Diabetes_Mellitus_Type_1"}, "text": "Type 1 diabetes mellitus", "locations": [{"offset": 451, "length": 24}]}, {"id": "15", "infons": {"identifier": "MESH:D003922", "type": "Disease", "valid": true, "normalized": ["D003922"], "database": "ncbi_mesh", "normalized_id": "D003922", "biotype": "disease", "name": "Diabetes Mellitus Type 1", "accession": "@DISEASE_Diabetes_Mellitus_Type_1"}, "text": "type 1 diabetes mellitus", "locations": [{"offset": 675, "length": 24}]}, {"id": "16", "infons": {"identifier": "MESH:D003922", "type": "Disease", "valid": true, "normalized": ["D003922"], "database": "ncbi_mesh", "normalized_id": "D003922", "biotype": "disease", "name": "Diabetes Mellitus Type 1", "accession": "@DISEASE_Diabetes_Mellitus_Type_1"}, "text": "type 1 diabetes mellitus", "locations": [{"offset": 782, "length": 24}]}, {"id": "17", "infons": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "text": "diabetes", "locations": [{"offset": 869, "length": 8}]}, {"id": "18", "infons": {"identifier": "MESH:D003922", "type": "Disease", "valid": true, "normalized": ["D003922"], "database": "ncbi_mesh", "normalized_id": "D003922", "biotype": "disease", "name": "Diabetes Mellitus Type 1", "accession": "@DISEASE_Diabetes_Mellitus_Type_1"}, "text": "type 1 diabetes", "locations": [{"offset": 971, "length": 15}]}, {"id": "19", "infons": {"identifier": "MESH:D003922", "type": "Disease", "valid": true, "normalized": ["D003922"], "database": "ncbi_mesh", "normalized_id": "D003922", "biotype": "disease", "name": "Diabetes Mellitus Type 1", "accession": "@DISEASE_Diabetes_Mellitus_Type_1"}, "text": "type 1 diabetes", "locations": [{"offset": 1144, "length": 15}]}, {"id": "20", "infons": {"identifier": "MESH:D003922", "type": "Disease", "valid": true, "normalized": ["D003922"], "database": "ncbi_mesh", "normalized_id": "D003922", "biotype": "disease", "name": "Diabetes Mellitus Type 1", "accession": "@DISEASE_Diabetes_Mellitus_Type_1"}, "text": "type 1 diabetes", "locations": [{"offset": 1327, "length": 15}]}, {"id": "21", "infons": {"identifier": "MESH:D048909", "type": "Disease", "valid": true, "normalized": ["D048909"], "database": "ncbi_mesh", "normalized_id": "D048909", "biotype": "disease", "name": "Diabetes Complications", "accession": "@DISEASE_Diabetes_Complications"}, "text": "type 1 diabetes complications", "locations": [{"offset": 1432, "length": 29}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.8446", "role1": {"identifier": "MESH:D003922", "type": "Disease", "valid": true, "normalized": ["D003922"], "database": "ncbi_mesh", "normalized_id": "D003922", "biotype": "disease", "name": "Diabetes Mellitus Type 1", "accession": "@DISEASE_Diabetes_Mellitus_Type_1"}, "role2": {"identifier": "3630", "type": "Gene", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "9,2"}]}], "pmid": 40528233, "pmcid": null, "meta": {}, "date": "2025-06-17T00:00:00Z", "journal": "Stem Cell Res Ther", "authors": ["Wang C", "Wu Y", "Jiang J"], "relations_display": [{"name": "associate|@DISEASE_Diabetes_Mellitus_Type_1|@GENE_INS"}]}, {"_id": "40531264|None", "id": "40531264", "infons": {}, "passages": [{"infons": {"journal": "Biogerontology;2025Jun18; 26 (4) 120. doi:10.1007/s10522-025-10262-7", "year": "2025", "article-id_pmc": "PMC12176917", "type": "title", "authors": "He X, Li Y, Chen J, Huang Y, Zhou Y, Li Y, Quan J, "}, "offset": 0, "text": "beta-hydroxy-beta-methylbutyrate supplementation mitigates muscle atrophy induced by inactivity and protein deprivation.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:C004961", "type": "Chemical", "valid": true, "normalized": ["C004961"], "database": "ncbi_mesh", "normalized_id": "C004961", "biotype": "chemical", "name": "beta-hydroxyisovaleric acid", "accession": "@CHEMICAL_beta_hydroxyisovaleric_acid"}, "text": "beta-hydroxy-beta-methylbutyrate", "locations": [{"offset": 0, "length": 32}]}, {"id": "4", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 59, "length": 14}]}, {"id": "5", "infons": {"identifier": "MESH:C564765", "type": "Disease", "valid": true, "normalized": ["C564765"], "database": "ncbi_mesh", "normalized_id": "C564765", "biotype": "disease", "name": "Thyrotropin Biologically Inactive", "accession": "@DISEASE_Thyrotropin_Biologically_Inactive"}, "text": "inactivity", "locations": [{"offset": 85, "length": 10}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 121, "text": "Muscle atrophy, resulting from physical inactivity or protein deficiency, is a significant health concern. beta-hydroxy-beta-methylbutyrate (HMB) has potential in preserving muscle mass, but its mechanisms in various atrophy-inducing conditions are not fully understood. This study aimed to investigate HMB's effects on muscle atrophy induced by inactivity and protein deprivation, and to elucidate the underlying molecular mechanisms. Rats were subjected to inactivity or protein-deficient diets with or without HMB supplementation. Muscle morphology, strength, and biochemical parameters were assessed. In vitro studies using C2C12 myoblasts and mouse skeletal muscle satellite cells exposed to interleukin-6 (IL-6) explored molecular pathways involved in HMB's protective effects. Inactivity and protein deprivation led to muscle atrophy, reduced strength, and altered biochemical markers. HMB supplementation partially mitigated these effects, preserving muscle mass and function. HMB attenuated atrophy markers (Muscle Atrophy F-box and Muscle RING Finger 1 (MuRF1)) and maintained myogenic factor (Myogenin (MyoG)) levels. In vitro studies revealed that HMB's protective effects were mediated through the AKT/mTOR pathway, with concurrent regulation of autophagy pathways and preservation of mitochondrial function in both myoblasts and satellite cells. HMB specifically protected satellite cell viability and function through AKT-dependent mechanisms, maintaining protein synthesis and reducing apoptosis under IL-6-induced stress conditions. HMB supplementation shows protective effects against muscle atrophy induced by inactivity and protein deprivation, through multiple mechanisms including AKT/mTOR pathway activation, autophagy regulation, and maintenance of mitochondrial function in both myoblasts and satellite cells. These findings suggest HMB as a potential therapeutic strategy for preventing muscle atrophy in various clinical scenarios.", "sentences": [], "annotations": [{"id": "46", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "Muscle atrophy", "locations": [{"offset": 121, "length": 14}]}, {"id": "47", "infons": {"identifier": "MESH:C564765", "type": "Disease", "valid": true, "normalized": ["C564765"], "database": "ncbi_mesh", "normalized_id": "C564765", "biotype": "disease", "name": "Thyrotropin Biologically Inactive", "accession": "@DISEASE_Thyrotropin_Biologically_Inactive"}, "text": "inactivity", "locations": [{"offset": 161, "length": 10}]}, {"id": "48", "infons": {"identifier": "MESH:D011488", "type": "Disease", "valid": true, "normalized": ["D011488"], "database": "ncbi_mesh", "normalized_id": "D011488", "biotype": "disease", "name": "Protein Deficiency", "accession": "@DISEASE_Protein_Deficiency"}, "text": "protein deficiency", "locations": [{"offset": 175, "length": 18}]}, {"id": "49", "infons": {"identifier": "MESH:C004961", "type": "Chemical", "valid": true, "normalized": ["C004961"], "database": "ncbi_mesh", "normalized_id": "C004961", "biotype": "chemical", "name": "beta-hydroxyisovaleric acid", "accession": "@CHEMICAL_beta_hydroxyisovaleric_acid"}, "text": "beta-hydroxy-beta-methylbutyrate", "locations": [{"offset": 228, "length": 32}]}, {"id": "50", "infons": {"identifier": "MESH:C004961", "type": "Chemical", "valid": true, "normalized": ["C004961"], "database": "ncbi_mesh", "normalized_id": "C004961", "biotype": "chemical", "name": "beta-hydroxyisovaleric acid", "accession": "@CHEMICAL_beta_hydroxyisovaleric_acid"}, "text": "HMB", "locations": [{"offset": 262, "length": 3}]}, {"id": "51", "infons": {"identifier": "MESH:D001284", "type": "Disease", "valid": true, "normalized": ["D001284"], "database": "ncbi_mesh", "normalized_id": "D001284", "biotype": "disease", "name": "Atrophy", "accession": "@DISEA