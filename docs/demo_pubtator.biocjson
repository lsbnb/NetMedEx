ions": [{"id": "R1", "infons": {"score": "0.9749", "role1": {"identifier": "MESH:D000077143", "type": "Chemical", "valid": true, "normalized": ["D000077143"], "database": "ncbi_mesh", "normalized_id": "D000077143", "biotype": "chemical", "name": "Docetaxel", "accession": "@CHEMICAL_Docetaxel"}, "role2": {"identifier": "MESH:D011471", "type": "Disease", "valid": true, "normalized": ["D011471"], "database": "ncbi_mesh", "normalized_id": "D011471", "biotype": "disease", "name": "Prostatic Neoplasms", "accession": "@DISEASE_Prostatic_Neoplasms"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "17,2"}]}, {"id": "R2", "infons": {"score": "0.9103", "role1": {"identifier": "MESH:D000077143", "type": "Chemical", "valid": true, "normalized": ["D000077143"], "database": "ncbi_mesh", "normalized_id": "D000077143", "biotype": "chemical", "name": "Docetaxel", "accession": "@CHEMICAL_Docetaxel"}, "role2": {"identifier": "MESH:D064129", "type": "Disease", "valid": true, "normalized": ["D064129"], "database": "ncbi_mesh", "normalized_id": "D064129", "biotype": "disease", "name": "Prostatic Neoplasms Castration-Resistant", "accession": "@DISEASE_Prostatic_Neoplasms_Castration_Resistant"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "1", "role": "17,3"}]}], "pmid": 40542935, "pmcid": null, "meta": {}, "date": "2025-06-21T00:00:00Z", "journal": "Curr Urol Rep", "authors": ["Troy SP", "Jakubowski CD", "Gartrell BA"], "relations_display": [{"name": "treat|@CHEMICAL_Docetaxel|@DISEASE_Prostatic_Neoplasms"}, {"name": "treat|@CHEMICAL_Docetaxel|@DISEASE_Prostatic_Neoplasms_Castration_Resistant"}]}, {"_id": "40543756|None", "id": "40543756", "infons": {}, "passages": [{"infons": {"journal": "Mol Metab;2025Jun19; 98 102191. doi:10.1016/j.molmet.2025.102191", "year": "2025", "type": "title", "authors": "Fang J, Huang X, Guo C, Chen T, Chen Y, Yang X, Zheng M, Ding H, "}, "offset": 0, "text": "Creatinine promotes adipose tissue wasting in chronic kidney disease via creatine and futile creatine cycle.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "MESH:D003404", "type": "Chemical", "valid": true, "normalized": ["D003404"], "database": "ncbi_mesh", "normalized_id": "D003404", "biotype": "chemical", "name": "Creatinine", "accession": "@CHEMICAL_Creatinine"}, "text": "Creatinine", "locations": [{"offset": 0, "length": 10}]}, {"id": "6", "infons": {"identifier": "MESH:D018205", "type": "Disease", "valid": true, "normalized": ["D018205"], "database": "ncbi_mesh", "normalized_id": "D018205", "biotype": "disease", "name": "Neoplasms Adipose Tissue", "accession": "@DISEASE_Neoplasms_Adipose_Tissue"}, "text": "adipose tissue wasting", "locations": [{"offset": 20, "length": 22}]}, {"id": "7", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "chronic kidney disease", "locations": [{"offset": 46, "length": 22}]}, {"id": "8", "infons": {"identifier": "MESH:D003401", "type": "Chemical", "valid": true, "normalized": ["D003401"], "database": "ncbi_mesh", "normalized_id": "D003401", "biotype": "chemical", "name": "Creatine", "accession": "@CHEMICAL_Creatine"}, "text": "creatine", "locations": [{"offset": 73, "length": 8}]}, {"id": "9", "infons": {"identifier": "MESH:D003401", "type": "Chemical", "valid": true, "normalized": ["D003401"], "database": "ncbi_mesh", "normalized_id": "D003401", "biotype": "chemical", "name": "Creatine", "accession": "@CHEMICAL_Creatine"}, "text": "creatine", "locations": [{"offset": 93, "length": 8}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 109, "text": "OBJECTIVE: Cachexia in chronic kidney disease (CKD) is a wasting syndrome. The futile creatine cycle (FCC) contributes to energy waste in adipocytes. Creatinine is metabolite of creatine. Whether creatinine involves in adipose wasting in CKD remains elusive. METHODS: Cachexia were assessed in unilateral ureteral obstruction induced CKD mice model. Cellular oxygen consumption and FCC-related genes expression were analyzed in adipocytes treated with creatinine in the presence of FCC inhibitor (SBI-425, inhibitor of TNAP) or creatine disruption (b-GPA, a creatine analogue that inhibits creatine transport into cells). The fate of labeled deuterated creatinine (D-3 creatinine) were traced by mass spectrometer. To determine creatinine drives adipose tissue wasting in vivo, two mice models of CKD were established by unilateral ureteral obstruction or renal ischemia and reperfusion injury. 206 patients diagnosed CKD were collected to analyze correlationship between creatinine in serum and adiposity. RESULTS: Adipose tissue wasting presented in CKD mice with serumal creatinine retention. In vitro, creatinine treatment at the concentration relevant of CKD elevated cellular oxygen consumption and FCC-related genes expression by converting into intracellular creatine. In the established CKD mice models, intraperitoneal injection of creatinine enhanced adipose tissue wasting, through increasing creatine accumulation. In contrast, disruption of creatine accumulation by b-GPA ameliorated tissue wasting. In patients with CKD, creatinine in serum negatively correlated with adiposity. CONCLUSIONS: Our results show that elevated serumal creatinine induces creatine accumulation, FCC activation and adipose tissue wasting in CKD, targeting creatinine-induced tissue wasting providing a promising therapeutic to ameliorate cachexia in CKD.", "sentences": [], "annotations": [{"id": "69", "infons": {"identifier": "MESH:D002100", "type": "Disease", "valid": true, "normalized": ["D002100"], "database": "ncbi_mesh", "normalized_id": "D002100", "biotype": "disease", "name": "Cachexia", "accession": "@DISEASE_Cachexia"}, "text": "Cachexia", "locations": [{"offset": 120, "length": 8}]}, {"id": "70", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "chronic kidney disease", "locations": [{"offset": 132, "length": 22}]}, {"id": "71", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 156, "length": 3}]}, {"id": "72", "infons": {"identifier": "MESH:D019282", "type": "Disease", "valid": true, "normalized": ["D019282"], "database": "ncbi_mesh", "normalized_id": "D019282", "biotype": "disease", "name": "Wasting Syndrome", "accession": "@DISEASE_Wasting_Syndrome"}, "text": "wasting syndrome", "locations": [{"offset": 166, "length": 16}]}, {"id": "73", "infons": {"identifier": "MESH:D003401", "type": "Chemical", "valid": true, "normalized": ["D003401"], "database": "ncbi_mesh", "normalized_id": "D003401", "biotype": "chemical", "name": "Creatine", "accession": "@CHEMICAL_Creatine"}, "text": "creatine", "locations": [{"offset": 195, "length": 8}]}, {"id": "74", "infons": {"identifier": "MESH:D003404", "type": "Chemical", "valid": true, "normalized": ["D003404"], "database": "ncbi_mesh", "normalized_id": "D003404", "biotype": "chemical", "name": "Creatinine", "accession": "@CHEMICAL_Creatinine"}, "text": "Creatinine", "locations": [{"offset": 259, "length": 10}]}, {"id": "75", "infons": {"identifier": "MESH:D003401", "type": "Chemical", "valid": true, "normalized": ["D003401"], "database": "ncbi_mesh", "normalized_id": "D003401", "biotype": "chemical", "name": "Creatine", "accession": "@CHEMICAL_Creatine"}, "text": "creatine", "locations": [{"offset": 287, "length": 8}]}, {"id": "