database": "ncbi_gene", "normalized_id": 9734, "biotype": "gene", "name": "HDAC9", "accession": "@GENE_HDAC9"}, "text": "HDAC", "locations": [{"offset": 17, "length": 4}]}, {"id": "5", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 46, "length": 5}]}, {"id": "6", "infons": {"identifier": "7350", "type": "Gene", "ncbi_homologene": "22524", "valid": true, "normalized": [7350], "database": "ncbi_gene", "normalized_id": 7350, "biotype": "gene", "name": "UCP1", "accession": "@GENE_UCP1"}, "text": "UCP1", "locations": [{"offset": 62, "length": 4}]}, {"id": "7", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 80, "length": 12}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 104, "text": "", "sentences": [], "annotations": [], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9993", "role1": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "9734", "type": "Gene", "valid": true, "normalized": [9734], "database": "ncbi_gene", "normalized_id": 9734, "biotype": "gene", "name": "HDAC9", "accession": "@GENE_HDAC9"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "3,0"}]}, {"id": "R2", "infons": {"score": "0.9804", "role1": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "7350", "type": "Gene", "valid": true, "normalized": [7350], "database": "ncbi_gene", "normalized_id": 7350, "biotype": "gene", "name": "UCP1", "accession": "@GENE_UCP1"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "3,2"}]}, {"id": "R3", "infons": {"score": "0.981", "role1": {"identifier": "7350", "type": "Gene", "valid": true, "normalized": [7350], "database": "ncbi_gene", "normalized_id": 7350, "biotype": "gene", "name": "UCP1", "accession": "@GENE_UCP1"}, "role2": {"identifier": "9734", "type": "Gene", "valid": true, "normalized": [9734], "database": "ncbi_gene", "normalized_id": 9734, "biotype": "gene", "name": "HDAC9", "accession": "@GENE_HDAC9"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "2", "role": "2,0"}]}], "pmid": 41787480, "pmcid": null, "meta": {}, "date": "2026-03-05T00:00:00Z", "journal": "J Transl Med", "authors": ["Rammah M", "Romero AR", "Halabi N", "Abuaqel S", "Guennoun A", "Dömling A", "Shan J", "Chouchane L"], "relations_display": [{"name": "associate|@DISEASE_Inflammation|@GENE_HDAC9"}, {"name": "associate|@DISEASE_Inflammation|@GENE_UCP1"}, {"name": "positive_correlate|@GENE_UCP1|@GENE_HDAC9"}]}, {"_id": "41790324|None", "id": "41790324", "infons": {}, "passages": [{"infons": {"journal": "Metabolomics;2026Mar06; 22 (2) . doi:10.1007/s11306-026-02414-8", "year": "2026", "article-id_pmc": "7691330", "type": "title", "authors": "Pandey A, Datta A, Verma R, Jaiswal AK, Kumar R, Das KK, Baishya B, "}, "offset": 0, "text": "Exploring metabolic signatures in urine using NMR for improved prognosis of gliomas.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D005910", "type": "Disease", "valid": true, "normalized": ["D005910"], "database": "ncbi_mesh", "normalized_id": "D005910", "biotype": "disease", "name": "Glioma", "accession": "@DISEASE_Glioma"}, "text": "gliomas", "locations": [{"offset": 76, "length": 7}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 85, "text": "INTRODUCTION: Gliomas represent the tumors of the central nervous system that originate from glial cells. Overall survival predictions and treatment regimen selection are based on accurate tumor diagnosis and grading. However, the diagnosis of glioma remains critically dependent on either invasive biopsies or advanced imaging. OBJECTIVE: This exploratory study aims to assess the diagnostic potential of urine specimens for discriminating gliomas from controls and identify the dysregulated pathways in a North Indian cohort. Urine is an ideal non-invasive candidate, requires no prior preparation, and considerably increases patient compliance. METHOD: Urine samples from 50 glioma patients were analysed with 1H NMR (Nuclear Magnetic Resonance) spectroscopy and compared with those of healthy controls. Statistical analysis was performed in MetaboAnalyst 6.0 to identify significantly perturbed metabolites. Diagnostic performance was assessed using the Receiver Operating Characteristic (ROC) curve, and the Random Forest model was used to evaluate classification accuracy. Pathway enrichment and topology analysis based on the KEGG (Kyoto Encyclopedia of Genes and Genomes) database were performed to identify dysregulated pathways. RESULTS: 1H NMR metabolic analysis of urine samples revealed seven statistically significant (p < 0.05) metabolites namely acetate, pyruvate, creatinine, dimethylamine, glutamine, alanine and carnitine. This panel of metabolites displayed excellent diagnostic capability with an Area Under the Curve of 0.90 as measured by a multivariate ROC curve. The random forest model efficiently differentiated glioma from control samples using significant metabolites. Disruption in the primary energy pathways of the body and in the metabolism of major amino acids was observed in the pathway analysis. CONCLUSION: Integration of these urinary signatures into current clinical practice can serve as an additional diagnostic tool and a non-invasive screening method for populations at risk. They can also be monitored in real time, thus aiding in adaptive treatment strategies and therapy assessment.", "sentences": [], "annotations": [{"id": "21", "infons": {"identifier": "MESH:D005910", "type": "Disease", "valid": true, "normalized": ["D005910"], "database": "ncbi_mesh", "normalized_id": "D005910", "biotype": "disease", "name": "Glioma", "accession": "@DISEASE_Glioma"}, "text": "Gliomas", "locations": [{"offset": 99, "length": 7}]}, {"id": "22", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "tumors", "locations": [{"offset": 121, "length": 6}]}, {"id": "23", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "tumor", "locations": [{"offset": 274, "length": 5}]}, {"id": "24", "infons": {"identifier": "MESH:D005910", "type": "Disease", "valid": true, "normalized": ["D005910"], "database": "ncbi_mesh", "normalized_id": "D005910", "biotype": "disease", "name": "Glioma", "accession": "@DISEASE_Glioma"}, "text": "glioma", "locations": [{"offset": 329, "length": 6}]}, {"id": "25", "infons": {"identifier": "MESH:D005910", "type": "Disease", "valid": true, "normalized": ["D005910"], "database": "ncbi_mesh", "normalized_id": "D005910", "biotype": "disease", "name": "Glioma", "accession": "@DISEASE_Glioma"}, "text": "gliomas", "locations": [{"offset": 526, "length": 7}]}, {"id": "26", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patient", "locations": [{"offset": 713, "length": 7}]}, {"id": "27", "infons": {"identifier": "MESH:D005910", "type": "Disease", "valid": true, "normalized": ["D005910"], "database": "ncbi_mesh", "normalized_id": "D005910", "biotype": "disease", "name": "Glioma", "accession": "@DISEASE_Glioma"}, "text": "glioma", "locations": [{"offset": 763, "length": 6}]}, {"id": "28", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 770, "length": 8}]}, {"id": "29", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "1H", "locations": [{"offset": 798, "length": 2}]}, {"id": "30", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "1H", "locations": [{"offset": 1333, "length": 2}]}, {"id": "31", "infons": {"identifier": "MESH:D000085", "type": "Chemical", "valid": true, "normalized": ["D000085"], "database": "ncbi_mesh", "normalized_id": "D000085", "biotype": "chemical", "name": "Acetates", "accession": "@CHEMICAL_Acetates"}, "text": "acetate", "locations": [{"offset": 1447, "length": 7}]}, {"id": "32", "infons": {"identifier": "MESH:D019289", "type": "Chemical", "valid": true, "normalized": ["D019289"], "database": "ncbi_mesh", "normalized_id": "D019289", "biotype": "chemical", "name": "Pyruvic Acid", "accession": "@CHEMICAL_Pyruvic_Acid"}, "text": "pyruvate", "locations": [{"offset": 1456, "length": 8}]}, {"id": "33", "infons": {"identifier": "MESH:D003404", "type": "Chemical", "valid": true, "normalized": ["D003404"], "database": "ncbi_mesh", "normalized_id": "D003404", "biotype": "chemical", "name": "Creatinine", "accession": "@CHEMICAL_Creatinine"}, "text": "creatinine", "locations": [{"offset": 1466, "length": 10}]}, {"id": "34", "infons": {"identifier": "MESH:C034516", "type": "Chemical", "valid": true, "normalized": ["C034516"], "database": "ncbi_mesh", "normalized_id": "C034516", "biotype": "chemical", "name": "dimethylamine", "accession": "@CHEMICAL_dimethylamine"}, "text": "dimethylamine", "locations": [{"offset": 1478, "length": 13}]}, {"id": "35", "infons": {"identifier": "MESH:D005973", "type": "Chemical", "valid": true, "normalized": ["D005973"], "database": "ncbi_mesh", "normalized_id": "D005973", "biotype": "chemical", "name": "Glutamine", "accession": "@CHEMICAL_Glutamine"}, "text": "glutamine", "locations": [{"offset": 1493, "length": 9}]}, {"id": "36", "infons": {"identifier": "MESH:D000409", "type": "Chemical", "valid": true, "normalized": ["D000409"], "database": "ncbi_mesh", "normalized_id": "D000409", "biotype": "chemical", "name": "Alanine", "accession": "@CHEMICAL_Alanine"}, "text": "alanine", "locations": [{"offset": 1504, "length": 7}]}, {"id": "37", "infons": {"identifier": "MESH:D002331", "type": "Chemical", "valid": true, "normalized": ["D002331"], "database": "ncbi_mesh", "normalized_id": "D002331", "biotype": "chemical", "name": "Carnitine", "accession": "@CHEMICAL_Carnitine"}, "text": "carnitine", "locations": [{"offset": 1516, "length": 9}]}, {"id": "38", "infons": {"identifier": "MESH:D005910", "type": "Disease", "valid": true, "normalized": ["D005910"], "database": "ncbi_mesh", "normalized_id": "D005910", "biotype": "disease", "name": "Glioma", "accession": "@DISEASE_Glioma"}, "text": "glioma", "locations": [{"offset": 1724, "length": 6}]}, {"id": "39", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "amino", "locations": [{"offset": 1868, "length": 5}]}], "relations": []}], "relations": [], "pmid": 41790324, "pmcid": null, "meta": {}, "date": "2026-03-06T00:00:00Z", "journal": "Metabolomics", "authors": ["Pandey A", "Datta A", "Verma R", "Jaiswal AK", "Kumar R", "Das KK", "Baishya B"], "relations_display": []}, {"_id": "41790377|None", "id": "41790377", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Tu-Si-Zi-Wan reduces D-galactose-induced hepatic and cerebral oxidative damage in aging mice via the Nrf2/ARE pathway.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Si-Zi-Wan", "locations": [{"offset": 3, "length": 9}]}, {"id": "5", "infons": {"identifier": "MESH:D005690", "type": "Chemical", "valid": true, "normalized": ["D005690"], "database": "ncbi_mesh", "normalized_id": "D005690", "biotype": "chemical", "name": "Galactose", "accession": "@CHEMICAL_Galactose"}, "text": "D-galactose", "locations": [{"offset": 21, "length": 11}]}, {"id": "6", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 88, "length": 4}]}, {"id": "7", "infons": {"identifier": "18024", "type": "Gene", "ncbi_homologene": "2412", "valid": true, "normalized": [18024], "database": "ncbi_gene", "normalized_id": 18024, "biotype": "gene", "name": "Nfe2l2", "accession": "@GENE_NFE2L2"}, "text": "Nrf2", "locations": [{"offset": 101, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 119, "text": "The global aging population necessitates safe, multi-target strategies to combat age-related functional decline. Tu-Si-Zi-Wan (TSZW), a classical medicinal-dietary formula documented in ancient Chinese medical texts and composed of Cuscuta chinensis and Dioscorea opposita, demonstrates multitargeted potential, yet its systemic antiaging mechanisms remain unclear. This study investigated the protective effects of TSZW on hepatic and neurological aging through the Nrf2/ARE pathway while exploring its systemic impact on metabolic and immune homeostasis. Firstly, network pharmacology predicted the targets and pathways of TSZW, identifying 113 shared TSZW-aging targets, with Nrf2, IL-6, and HIF-1alpha as core nodes enriched in oxidative stress-related pathways. Secondly, a D-galactose-induced aging mouse model was established, followed by 4 months of TSZW intervention (low, medium, and high doses). Behavioral tests (open field, novel object recognition, and grip strength), metabolic and inflammatory marker detection, histopathology, and molecular analyses (western blot, quantitative PCR, and immunofluorescence) were used to assess systemic aging phenotypes, oxidative damage, and Nrf2/ARE pathway activity. TSZW dose-dependently improved motor activity, cognition, and muscle strength; restored liver/kidney function (ALT, AST, Cr, and urea); reduced the serum levels of tumor necrosis factor-alpha, interleukin 6, and interleukin-1beta; and attenuated hepatic/neuronal damage. It suppressed the expression of senescence markers (p16, p21, and p53) while increasing the expression of antioxidant enzymes (SOD and GSH-Px) and reducing oxidative damage (MDA and ROS). Mechanistically, TSZW promoted Nrf2 nuclear translocation; upregulated Hmox1, Nqo1, and Gclm expression; and inhibited Keap1. Notably, high-dose TSZW outperformed vitamin E in reversing immune organ atrophy (thymus and spleen indices) and preserving hippocampal neurons. Collectively, TSZW alleviates hepatic and neurological aging via Nrf2/ARE-mediated antioxidant signaling, with concurrent mitigation of systemic aging phenotypes, including immune organ atrophy and chronic inflammation. Its multicomponent synergy highlights Traditional Chinese medicinal cuisine's potential for systemic anti-aging intervention by targeting oxidative stress-inflammation-metabolic signaling crosstalk.", "sentences": [], "annotations": [{"id": "44", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Si-Zi-Wan", "locations": [{"offset": 235, "length": 9}]}, {"id": "45", "infons": {"identifier": "267557", "type": "Species", "valid": true, "normalized": [267557], "database": "ncbi_taxonomy", "normalized_id": 267557, "biotype": "species", "name": "267557", "accession": null}, "text": "Cuscuta chinensis", "locations": [{"offset": 351, "length": 17}]}, {"id": "46", "infons": {"identifier": "569628", "type": "Species", "valid": true, "normalized": [569628], "database": "ncbi_taxonomy", "normalized_id": 569628, "biotype": "species", "name": "569628", "accession": null}, "text": "Dioscorea opposita", "locations": [{"offset": 373, "length": 18}]}, {"id": "47", "infons": {"identifier": "18024", "type": "Gene", "ncbi_homologene": "2412", "valid": true, "normalized": [18024], "database": "ncbi_gene", "normalized_id": 18024, "biotype": "gene", "name": "Nfe2l2", "accession": "@GENE_NFE2L2"}, "text": "Nrf2", "locations": [{"offset": 586, "length": 4}]}, {"id": "48", "infons": {"identifier": "18024", "type": "Gene", "ncbi_homologene": "2412", "valid": true, "normalized": [18024], "database": "ncbi_gene", "normalized_id": 18024, "biotype": "gene", "name": "Nfe2l2", "accession": "@GENE_NFE2L2"}, "text": "Nrf2", "locations": [{"offset": 798, "length": 4}]}, {"id": "49", "infons": {"identifier": "16193", "type": "Gene", "ncbi_homologene": "502", "valid": true, "normalized": [16193], "database": "ncbi_gene", "normalized_id": 16193, "biotype": "gene", "name": "Il6", "accession": "@GENE_IL6"}, "text": "IL-6", "locations": [{"offset": 804, "length": 4}]}, {"id": "50", "infons": {"identifier": "15251", "type": "Gene", "ncbi_homologene": "1171", "valid": true, "normalized": [15251], "database": "ncbi_gene", "normalized_id": 15251, "biotype": "gene", "name": "Hif1a", "accession": "@GENE_HIF1A"}, "text": "HIF-1alpha", "locations": [{"offset": 814, "length": 10}]}, {"id": "51", "infons": {"identifier": "MESH:D005690", "type": "Chemical", "valid": true, "normalized": ["D005690"], "database": "ncbi_mesh", "normalized_id": "