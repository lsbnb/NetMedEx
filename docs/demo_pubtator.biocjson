"D006349", "biotype": "disease", "name": "Heart Valve Diseases", "accession": "@DISEASE_Heart_Valve_Diseases"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "3", "role": "11,13"}]}, {"id": "R5", "infons": {"score": "0.9988", "role1": {"identifier": "MESH:D000077403", "type": "Chemical", "valid": true, "normalized": ["D000077403"], "database": "ncbi_mesh", "normalized_id": "D000077403", "biotype": "chemical", "name": "Orlistat", "accession": "@CHEMICAL_Orlistat"}, "role2": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "4", "role": "12,23"}]}, {"id": "R6", "infons": {"score": "0.9988", "role1": {"identifier": "MESH:D005277", "type": "Chemical", "valid": true, "normalized": ["D005277"], "database": "ncbi_mesh", "normalized_id": "D005277", "biotype": "chemical", "name": "Fenfluramine", "accession": "@CHEMICAL_Fenfluramine"}, "role2": {"identifier": "MESH:D006349", "type": "Disease", "valid": true, "normalized": ["D006349"], "database": "ncbi_mesh", "normalized_id": "D006349", "biotype": "disease", "name": "Heart Valve Diseases", "accession": "@DISEASE_Heart_Valve_Diseases"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "5", "role": "10,13"}]}], "pmid": 40843857, "pmcid": null, "meta": {}, "date": "2025-07-28T00:00:00Z", "journal": "Medicines (Basel)", "authors": ["Ullah MI", "Tamanna S"], "relations_display": [{"name": "treat|@CHEMICAL_sibutramine|@DISEASE_Obesity"}, {"name": "cause|@CHEMICAL_Orlistat|@DISEASE_Heart_Valve_Diseases"}, {"name": "treat|@CHEMICAL_Fenfluramine|@DISEASE_Obesity"}, {"name": "cause|@CHEMICAL_sibutramine|@DISEASE_Heart_Valve_Diseases"}, {"name": "treat|@CHEMICAL_Orlistat|@DISEASE_Obesity"}, {"name": "cause|@CHEMICAL_Fenfluramine|@DISEASE_Heart_Valve_Diseases"}]}, {"_id": "40858733|None", "id": "40858733", "infons": {}, "passages": [{"infons": {"journal": "Sci Rep;2025Aug26; 15 (1) 31411. doi:10.1038/s41598-025-15232-0", "year": "2025", "article-id_pmc": "PMC12381184", "type": "title", "authors": "Liu D, Yu L, Cao ML, Wang S, Zhou N, Ren YR, "}, "offset": 0, "text": "Screening of SGLT2 inhibitors based on virtual screening and cellular experiments.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "6524", "type": "Gene", "ncbi_homologene": "2289", "valid": true, "normalized": [6524], "database": "ncbi_gene", "normalized_id": 6524, "biotype": "gene", "name": "SLC5A2", "accession": "@GENE_SLC5A2"}, "text": "SGLT2", "locations": [{"offset": 13, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 83, "text": "This study aims at find hit compounds as SGLT2 inhibitors through the methods of virtual screening, biological experiment, Structural similarity search and molecular docking. Computer-aided drug design techniques were used to build modelling of quantitative construct validity relationships. Three-dimensional pharmacophore model and the principle of drug properties were used to screen the compounds. The effects of lead compounds on glucose uptake were observed in 293 T cells. Further, structural similarity searches were conducted on 13 hit compounds, then molecular docking the compounds with proteins was performed. Based on virtual screening, 20 highly rated compounds as potential lead candidates for diabetes treatment were selected. Combining the results in glucose uptake assays, 13 hit compounds were identified with strong inhibitory properties against SGLT2, especially, compound 2 had the lowest glucose uptake and the best inhibition of SGLT2. The compounds were classified into 5 classes and each class has the same core skeleton. Molecular docking cleared and definite that the hit compounds had stable and efficient hydrogen-bonding interactions with SGLT2, and their binding to SGLT2 was specific. 13 hit compounds were identified with strong inhibitory properties against SGLT2, and they are likely to become new SGLT2 inhibitors to treat diabetes.", "sentences": [], "annotations": [{"id": "25", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "compounds", "locations": [{"offset": 111, "length": 9}]}, {"id": "26", "infons": {"identifier": "6524", "type": "Gene", "ncbi_homologene": "2289", "valid": true, "normalized": [6524], "database": "ncbi_gene", "normalized_id": 6524, "biotype": "gene", "name": "SLC5A2", "accession": "@GENE_SLC5A2"}, "text": "SGLT2", "locations": [{"offset": 124, "length": 5}]}, {"id": "27", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "compounds", "locations": [{"offset": 474, "length": 9}]}, {"id": "28", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "compounds", "locations": [{"offset": 505, "length": 9}]}, {"id": "29", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "glucose", "locations": [{"offset": 518, "length": 7}]}, {"id": "30", "infons": {"identifier": "CVCL:0063", "type": "CellLine", "valid": true, "normalized": ["0063"], "database": "cvcl", "normalized_id": "0063", "biotype": "cellline", "name": "0063", "accession": null}, "text": "293 T", "locations": [{"offset": 550, "length": 5}]}, {"id": "31", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "compounds", "locations": [{"offset": 628, "length": 9}]}, {"id": "32", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "compounds", "locations": [{"offset":