", "normalized_id": 8756, "biotype": "gene", "name": "ADAM7", "accession": "@GENE_ADAM7"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "16,15"}]}, {"id": "R3", "infons": {"score": "0.9992", "role1": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "role2": {"identifier": "8756", "type": "Gene", "valid": true, "normalized": [8756], "database": "ncbi_gene", "normalized_id": 8756, "biotype": "gene", "name": "ADAM7", "accession": "@GENE_ADAM7"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "17,15"}]}, {"id": "R4", "infons": {"score": "0.6338", "role1": {"identifier": "MESH:D015741", "type": "Chemical", "valid": true, "normalized": ["D015741"], "database": "ncbi_mesh", "normalized_id": "D015741", "biotype": "chemical", "name": "Metribolone", "accession": "@CHEMICAL_Metribolone"}, "role2": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "3", "role": "12,17"}]}], "pmid": 41391160, "pmcid": null, "meta": {}, "date": "2025-12-14T00:00:00Z", "journal": "Kidney Blood Press Res", "authors": ["Deng X", "Luo Y", "Mei L", "Wu J", "He M", "Ma L", "Lin Y"], "relations_display": [{"name": "treat|@CHEMICAL_Arbutin|@DISEASE_Sarcopenia"}, {"name": "associate|@DISEASE_Kidney_Failure_Chronic|@GENE_ADAM7"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_ADAM7"}, {"name": "treat|@CHEMICAL_Metribolone|@DISEASE_Sarcopenia"}]}, {"_id": "41398907|None", "id": "41398907", "infons": {}, "passages": [{"infons": {"journal": "BMC Geriatr;2025Dec15; 25 (1) 1018. doi:10.1186/s12877-025-06564-7", "year": "2025", "article-id_pmc": "PMC12706993", "type": "title", "authors": "Wang Z, Shi Z, Song Q, Lu W, Sun Z, Zang J, Shao C, "}, "offset": 0, "text": "Altered serum short-chain fatty acids in sarcopenia among Chinese elderly women: a case-control study.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:D005232", "type": "Chemical", "valid": true, "normalized": ["D005232"], "database": "ncbi_mesh", "normalized_id": "D005232", "biotype": "chemical", "name": "Fatty Acids Volatile", "accession": "@CHEMICAL_Fatty_Acids_Volatile"}, "text": "short-chain fatty acids", "locations": [{"offset": 14, "length": 23}]}, {"id": "4", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 41, "length": 10}]}, {"id": "5", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "women", "locations": [{"offset": 74, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 103, "text": "BACKGROUND: Sarcopenia, characterized by the progressive loss of muscle mass and function, is increasingly prevalent among the elderly in China and globally. Emerging evidence suggests that short-chain fatty acids, key metabolites produced by gut microbiota, may influence muscle health. This study aimed to investigate the association between serum short-chain fatty acids and sarcopenia in elderly Chinese women, and to explore potential metabolic biomarkers using a targeted metabolomics approach. METHODS: A case-control study was conducted involving 100 community-dwelling women aged 65 to 75 years in Shanghai, with 50 diagnosed with sarcopenia and 50 age-matched healthy controls. Sarcopenia was defined according to the Asian Working Group for Sarcopenia 2019 criteria. Fasting blood samples were collected, and serum short-chain fatty acid levels were measured using Gas Chromatography-Mass Spectrometry. Dietary intake and demographic data were obtained through structured questionnaires and food frequency assessments. Statistical analyses, including independent sample t-tests and partial correlation analysis, were performed using SPSS version 21.0. Metabolic pathway enrichment was analyzed using MetaboAnalyst. RESULTS: Compared to the control group, the sarcopenia group exhibited significantly lower serum levels of propionic acid (P = 0.004) and isovaleric acid (P = 0.001). Pathway analysis identified 19 significantly enriched metabolic pathways, three of which, carbohydrate digestion and absorption, protein digestion and absorption, and degradation of aromatic compounds, were highly associated with propionic and isovaleric acids. Dietary assessment revealed that individuals with sarcopenia had lower intake of energy, total protein, and high-quality protein, but higher sodium intake (all P < 0.05). CONCLUSIONS: Altered profiles of serum short-chain fatty acids, particularly reduced propionic acid and isovaleric acid, are associated with sarcopenia in elderly women. These metabolites may serve as potential biomarkers for early identification and risk assessment. The findings highlight the relevance of gut microbiota-derived metabolites and dietary factors in sarcopenia pathophysiology and support future development of nutritional and metabolic interventions for prevention. TRIAL REGISTRATION: The trial protocol was filed with the Chinese Clinical Trial Registry (registration number ChiCTR2100048874) on July 19, 2021.", "sentences": [], "annotations": [{"id": "31", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "Sarcopenia", "locations": [{"offset": 115, "length": 10}]}, {"id": "32", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "loss of muscle mass and function", "locations": [{"offset": 160, "length": 32}]}, {"id": "33", "infons": {"identifier": "MESH:D005232", "type": "Chemical", "valid": true, "normalized": ["D005232"], "database": "ncbi_mesh", "normalized_id": "D005232", "biotype": "chemical", "name": "Fatty Acids Volatile", "accession": "@CHEMICAL_Fatty_Acids_Volatile"}, "text": "short-chain fatty acids", "locations": [{"offset": 293, "length": 23}]}, {"id": "34", "infons": {"identifier": "MESH:D005232", "type": "Chemical", "valid": true, "normalized": ["D005232"], "database": "ncbi_mesh", "normalized_id": "D005232", "biotype": "chemical", "name": "Fatty Acids Volatile", "accession": "@CHEMICAL_Fatty_Acids_Volatile"}, "text": "short-chain fatty acids", "locations": [{"offset": 453, "length": 23}]}, {"id": "35", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 481, "length": 10}]}, {"id": "36", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "women", "locations": [{"offset": 511, "length": 5}]}, {"id": "37", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "women", "locations": [{"offset": 681, "length": 5}]}, {"id": "38", "infons": {"identifi