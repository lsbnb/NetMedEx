": {"score": "0.8858", "role1": {"identifier": "MESH:D005221", "type": "Disease", "valid": true, "normalized": ["D005221"], "database": "ncbi_mesh", "normalized_id": "D005221", "biotype": "disease", "name": "Fatigue", "accession": "@DISEASE_Fatigue"}, "role2": {"identifier": "60525", "type": "Gene", "valid": true, "normalized": [60525], "database": "ncbi_gene", "normalized_id": 60525, "biotype": "gene", "name": "Acss2", "accession": "@GENE_ACSS2"}, "type": "Association"}, "nodes": [{"refid": "14", "role": "17,35"}]}], "pmid": 40936396, "pmcid": null, "meta": {}, "date": "2025-09-12T00:00:00Z", "journal": "FEBS Lett", "authors": ["Gunasekaran M", "Campos G", "Wells NM", "Lambuu K", "Draper I", "Pacak CA", "Kang PB"], "relations_display": [{"name": "associate|@CHEMICAL_Cholesterol|@GENE_ACSS2"}, {"name": "interact|@CHEMICAL_Acetates|@CHEMICAL_Acetyl_Coenzyme_A"}, {"name": "associate|@GENE_ACLY|@GENE_ACSS2"}, {"name": "associate|@CHEMICAL_Cholesterol|@DISEASE_Muscular_Dystrophies"}, {"name": "associate|@DISEASE_Muscular_Dystrophies|@GENE_HMGCR"}, {"name": "associate|@CHEMICAL_Acetates|@GENE_ACSS2"}, {"name": "positive_correlate|@CHEMICAL_NAD|@GENE_ACSS2"}, {"name": "associate|@CHEMICAL_Acetyl_Coenzyme_A|@GENE_ACSS2"}, {"name": "associate|@DISEASE_Muscular_Diseases|@GENE_ACSS2"}, {"name": "associate|@CHEMICAL_Acetates|@CHEMICAL_Cholesterol"}, {"name": "associate|@DISEASE_Fatigue|@GENE_ACLY"}, {"name": "associate|@CHEMICAL_Cholesterol|@GENE_HMGCR"}, {"name": "associate|@CHEMICAL_Cholesterol|@DISEASE_Muscular_Diseases"}, {"name": "associate|@CHEMICAL_Acetyl_Coenzyme_A|@CHEMICAL_Cholesterol"}, {"name": "associate|@DISEASE_Fatigue|@GENE_ACSS2"}]}, {"_id": "40947308|None", "id": "40947308", "infons": {}, "passages": [{"infons": {"journal": "Aging Cell;2025Sep14 70236. doi:10.1111/acel.70236", "year": "2025", "type": "title", "authors": "Murach KA, Dungan CM, Chambers TL, Horvath S, Nandakumar J, Gladyshev VN, Pletcher SD, Dai X, Guo L, "}, "offset": 0, "text": "Regenerate to \"Rejuvenate\": Insights From Adult Resident Stem Cells of Aged Flatworms and Mice.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "6157", "type": "Species", "valid": true, "normalized": [6157], "database": "ncbi_taxonomy", "normalized_id": 6157, "biotype": "species", "name": "6157", "accession": null}, "text": "Flatworms", "locations": [{"offset": 76, "length": 9}]}, {"id": "3", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "Mice", "locations": [{"offset": 90, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 96, "text": "Adult resident stem cells are capable of regenerating tissues that manifest signs of \"rejuvenation\" in flatworms and mice of older ages. These findings suggest potentially conserved regulatory mechanisms of adult resident stem cells from worms to mammals. Regenerative capacities are more limited in specific tissues and stem cell types of larger mammals. Understanding and harnessing the rejuvenating properties of resident adult stem cells in flatworms and mice could have broad therapeutic implications for improving stem cell function and tissue plasticity across organ systems of humans in advanced age.", "sentences": [], "annotations": [{"id": "9", "infons": {"identifier": "6157", "type": "Species", "valid": true, "normalized": [6157], "database": "ncbi_taxonomy", "normalized_id": 6157, "biotype": "species", "name": "6157", "accession": null}, "text": "flatworms", "locations": [{"offset": 199, "length": 9}]}, {"id": "10", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 213, "length": 4}]}, {"id": "11", "infons": {"identifier": "6157", "type": "Species", "valid": true, "normalized": [6157], "database": "ncbi_taxonomy", "normalized_id": 6157, "biotype": "species", "name": "6157", "accession": null}, "text": "flatworms", "locations": [{"offset": 541, "length": 9}]}, {"id": "12", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 555, "length": 4}]}, {"id": "13", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "humans", "locations": [{"offset": 681, "length": 6}]}], "relations": []}], "relations": [], "pmid": 40947308, "pmcid": null, "meta": {}, "date": "2025-09-14T00:00:00Z", "journal": "Aging Cell", "authors": ["Murach KA", "Dungan CM", "Chambers TL", "Horvath S", "Nandakumar J", "Gladyshev VN", "Pletcher SD", "Dai X", "Guo L"], "relations_display": []}, {"_id": "40984022|None", "id": "40984022", "infons": {}, "passages": [{"infons": {"journal": "Cell Prolif;2025Sep22 70130. doi:10.1111/cpr.70130", "year": "2025", "type": "title", "authors": "Hao X, Shi H, Wu D, Liang R, Zhao T, Sun W, Wang Y, Yu X, Luo X, Yan Y, Lu J, Wang H, Wang J, "}, "offset": 0, "text": "LCN2-ACOD1 Signalling Affects the Post-Injury Regeneration of Skeletal Muscle Through Mediating Ferroptosis.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "16819", "type": "Gene", "ncbi_homologene": "4064", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "text": "LCN2", "locations": [{"offset": 0, "length": 4}]}, {"id": "5", "infons": {"identifier": "16365", "type": "Gene", "ncbi_homologene": "35405", "valid": true, "normalized": [16365], "database": "ncbi_gene", "normalized_id": 16365, "biotype": "gene", "name": "Acod1", "accession": "@GENE_ACOD1"}, "text": "ACOD1", "locations": [{"offset": 5, "length": 5}]}, {"id": "6", "infons": {"identifier": "MESH:D014947", "type": "Disease", "valid": true, "normalized": ["D014947"], "database": "ncbi_mesh", "normalized_id": "D014947", "biotype": "disease", "name": "Wounds and Injuries", "accession": "@DISEASE_Wounds_and_Injuries"}, "text": "Injury", "locations": [{"offset": 39, "length": 6}]}, {"id": "7", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "Ferroptosis", "locations": [{"offset": 96, "length": 11}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 109, "text": "The normal growth and development of skeletal muscle are crucial for the proper function of organisms. During myoblast development, cell death is a fundamental physiological process, and skeletal muscle damage involves various types of cell death, including ferroptosis. However, ferroptosis-related biomarkers in skeletal muscle damage remain unclear. This study aimed to investigate the mechanisms by which lipocalin-2 (LCN2), a key protein of iron metabolism, regulates skeletal muscle regeneration post damage by mediating ferroptosis. When the gastrocnemius muscle (GAS) of mice is acutely injured, LCN2 is significantly upregulated early in the injury. In vitro, LCN2 participates in the inhibition of proliferation and differentiation of C2C12 cells via erastin-induced ferroptosis. Transcriptomic analysis after the overexpression of LCN2 revealed that the one with the most significant difference among all of the differentially expressed genes (DEGs) was aconitate decarboxylase 1 (Acod1). The inhibition of myogenic factors' expression by LCN2 was associated with the activation of the ferroptosis signalling pathway, partly attributed to the mitochondrial dysfunction. The ACOD1 inhibitor attenuated mitochondria-associated ferroptosis induced by LCN2 and alleviated the inhibitory effect of LCN2 on cell viability. These findings highlight the therapeutic potential of targeting the LCN2-ACOD1 signalling to promote myogenesis, providing promising strategies for facilitating the regeneration of skeletal muscle after injury and the treatment of muscle-related diseases.", "sentences": [], "annotations": [{"id": "31", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle damage", "locations": [{"offset": 305, "length": 13}]}, {"id": "32", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle damage", "locations": [{"offset": 432, "length": 13}]}, {"id": "33", "infons": {"identifier": "16819", "type": "Gene", "ncbi_homologene": "4064", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "text": "lipocalin-2", "locations": [{"offset": 518, "length": 11}]}, {"id": "34", "infons": {"identifier": "16819", "type": "Gene", "ncbi_homologene": "4064", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "text": "LCN2", "locations": [{"offset": 531, "length": 4}]}, {"id": "35", "infons": {"identifier": "MESH:D007501", "type": "Chemical", "valid": true, "normalized": ["D007501"], "database": "ncbi_mesh", "normalized_id": "D007501", "biotype": "chemical", "name": "Iron", "accession": "@CHEMICAL_Iron"}, "text": "iron", "locations": [{"offset": 555, "length": 4}]}, {"id": "36", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 688, "length": 4}]}, {"id": "37", "infons": {"identifier": "16819", "type": "Gene", "ncbi_homologene": "4064", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "text": "LCN2", "locations": [{"offset": 713, "length": 4}]}, {"id": "38", "infons": {"identifier": "MESH:D014947", "type": "Disease", "valid": true, "normalized": ["D014947"], "database": "ncbi_mesh", "normalized_id": "D014947", "biotype": "disease", "name": "Wounds and Injuries", "accession": "@DISEASE_Wounds_and_Injuries"}, "text": "injury", "locations": [{"offset": 760, "length": 6}]}, {"id": "39", "infons": {"identifier": "16819", "type": "Gene", "ncbi_homologene": "4064", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "text": "LCN2", "locations": [{"offset": 778, "length": 4}]}, {"id": "40", "infons": {"identifier": "CVCL:0188", "type": "CellLine", "valid": true, "normalized": ["0188"], "database": "cvcl", "normalized_id": "0188", "biotype": "cellline", "name": "0188", "accession": null}, "text": "C2C12", "locations": [{"offset": 854, "length": 5}]}, {"id": "41", "infons": {"identifier": "MESH:C477224", "type": "Chemical", "valid": true, "normalized": ["C477224"], "database": "ncbi_mesh", "normalized_id": "C477224", "biotype": "chemical", "name": "erastin", "accession": "@CHEMICAL_erastin"}, "text": "erastin", "locations": [{"offset": 870, "length": 7}]}, {"id": "42", "infons": {"identifier": "16819", "type": "Gene", "ncbi_homologene": "4064", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "text": "LCN2", "locations": [{"offset": 951, "length": 4}]}, {"id": "43", "infons": {"identifier": "16365", "type": "Gene", "ncbi_homologene": "35405", "valid": true, "normalized": [16365], "database": "ncbi_gene", "normalized_id": 16365, "biotype": "gene", "name": "Acod1", "accession": "@GENE_ACOD1"}, "text": "aconitate decarboxylase 1", "locations": [{"offset": 1074, "length": 25}]}, {"id": "44", "infons": {"identifier": "16365", "type": "Gene", "ncbi_homologene": "35405", "valid": true, "normalized": [16365], "database": "ncbi_gene", "normalized_id": 16365, "biotype": "gene", "name": "Acod1", "accession": "@GENE_ACOD1"}, "text": "Acod1", "locations": [{"offset": 1101, "length": 5}]}, {"id": "45", "infons": {"identifier": "16819", "type": "Gene", "ncbi_homologene": "4064", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "text": "LCN2", "locations": [{"offset": 1159, "length": 4}]}, {"id": "46", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial dysfunction", "locations": [{"offset": 1263, "length": 25}]}, {"id": "47", "infons": {"identifier": "16365", "type": "Gene", "ncbi_homologene": "35405", "valid": true, "normalized": [16365], "database": "ncbi_gene", "normalized_id": 16365, "biotype": "gene", "name": "Acod1", "accession": "@GENE_ACOD1"}, "text": "ACOD1", "locations": [{"offset": 1294, "length": 5}]}, {"id": "48", "infons": {"identifier": "16819", "type": "Gene", "ncbi_homologene": "4064", "valid": true, "normalized": [16819], "database": "ncbi_gene", "normalized_id": 16819, "biotype": "gene", "name": "Lcn2", "accession": "@GENE_LCN2"}, "text": "LCN2", "locations": [{"offset": 1368, "length": 4}]}, {"id": "49", "infons": {"identifier": "16819", "type": "Gene", "ncbi_homolog