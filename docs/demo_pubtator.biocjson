Chemical", "valid": true, "normalized": ["D006861"], "database": "ncbi_mesh", "normalized_id": "D006861", "biotype": "chemical", "name": "Hydrogen Peroxide", "accession": "@CHEMICAL_Hydrogen_Peroxide"}, "role2": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "3", "role": "25,24"}]}, {"id": "R5", "infons": {"score": "0.8781", "role1": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "role2": {"identifier": "42549", "type": "Gene", "valid": true, "normalized": [42549], "database": "ncbi_gene", "normalized_id": 42549, "biotype": "gene", "name": "InR", "accession": "@GENE_INR"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "4", "role": "32,31"}]}], "pmid": 40565158, "pmcid": null, "meta": {}, "date": "2025-06-13T00:00:00Z", "journal": "Int J Mol Sci", "authors": ["Buacheen P", "Karinchai J", "Inthachat W", "Butkinaree C", "Wongnoppawich A", "Imsumran A", "Temviriyanukul P", "Inoue YH", "Pitchakarn P"], "relations_display": [{"name": "associate|@DISEASE_Inflammation|@GENE_EGR"}, {"name": "cause|@CHEMICAL_Reactive_Oxygen_Species|@DISEASE_Disease"}, {"name": "cause|@CHEMICAL_Reactive_Oxygen_Species|@DISEASE_Aging_Premature"}, {"name": "positive_correlate|@CHEMICAL_Hydrogen_Peroxide|@CHEMICAL_Reactive_Oxygen_Species"}, {"name": "positive_correlate|@CHEMICAL_Glucose|@GENE_INR"}]}, {"_id": "40578028|None", "id": "40578028", "infons": {}, "passages": [{"infons": {"journal": "EBioMedicine;2025Jun26; 118 105825. doi:10.1016/j.ebiom.2025.105825", "year": "2025", "article-id_pmc": "PMC12266574", "type": "title", "authors": "Yang JL, Qian SY, Cheng ML, Wang LX, Wang Y, Liu JJ, Xi CS, Yang YX, Li Y, Gao C, Zheng GQ, "}, "offset": 0, "text": "Skeletal muscle, neuromuscular organoids and assembloids: a scoping review.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "assembloids", "locations": [{"offset": 45, "length": 11}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 76, "text": "Skeletal muscle organoids (SKMOs), neuromuscular organoids (NMOs), and assembloids have emerged as powerful in vitro models that simulate the intricate cellular interactions between muscle and nerve, offering a promising approach to study function, development, and disease at the neuromuscular junction (NMJ). Given the relevance of NMJ dysfunction in diseases such as amyotrophic lateral sclerosis (ALS), these models provide insights into disease modelling. Scoping reviews are particularly valuable when exploring broad or emerging areas, as they help identify key concepts and evolving methodologies. Here, we conducted a scoping review by searching five databases, ultimately including 17 studies focussing on the development and application of SKMOs, NMOs, and assembloids in muscle function modelling. We highlight recent advancements and summarise various differentiation protocols, primarily utilising the Wnt signalling pathway agonist CHIR99021 and basic fibroblast growth factor (bFGF) to induce pluripotent stem cells into 2D neuromesodermal progenitors, further differentiated into SKMOs, NMOs, and assembloids. We also reviewed their cellular compositions, including motor neurons, neural stem cells, terminal Schwann cells, and astrocytes, alongside related research outcomes. Additionally, we discuss key challenges such as iPSC donor selection, standardisation, vascularisation, and 3D organoid imaging. This scoping review provides a foundation for future research on muscle function modelling.", "sentences": [], "annotations": [{"id": "11", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "assembloids", "locations": [{"offset": 147, "length": 11}]}, {"id": "12", "infons": {"identifier": "MESH:D020511", "type": "Disease", "valid": true, "normalized": ["D020511"], "database": "ncbi_mesh", "normalized_id": "D020511", "biotype": "disease", "name": "Neuromuscular Junction Diseases", "accession": "@DISEASE_Neuromuscular_Junction_Diseases"}, "text": "NMJ dysfunction", "locations": [{"offset": 410, "length": 15}]}, {"id": "13", "infons": {"identifier": "MESH:D000690", "type": "Disease", "valid": true, "normalized": ["D000690"], "database": "ncbi_mesh", "normalized_id": "D000690", "biotype": "disease", "name": "Amyotrophic Lateral Sclerosis", "accession": "@DISEASE_Amyotrophic_Lateral_Sclerosis"}, "text": "amyotrophic lateral sclerosis", "locations": [{"offset": 446, "length": 29}]}, {"id": "14", "infons": {"identifier": "MESH:D000690", "type": "Disease", "valid": true, "normalized": ["D000690"], "database": "ncbi_mesh", "normalized_id": "D000690", "biotype": "disease", "name": "Amyotrophic Lateral Sclerosis", "accession": "@DISEASE_Amyotrophic_Lateral_Sclerosis"}, "text": "ALS", "locations": [{"offset": 477, "length": 3}]}, {"id": "15", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "assembloids", "locations": [{"offset": 844, "length": 11}]}, {"id": "16", "infons": {"identifier": "MESH:C473711", "type": "Chemical", "valid": true, "normalized": ["C473711"], "database": "ncbi_mesh", "normalized_id": "C473711", "biotype": "chemical", "name": "Chir 99021", "accession": "@CHEMICAL_Chir_99021"}, "text": "CHIR99021", "locations": [{"offset": 1023, "length": 9}]}, {"id": "17", "infons": {"identifier": "2247", "type": "Gene", "ncbi_homologene": "1521", "valid": true, "normalized": [2247], "database": "ncbi_gene", "normalized_id": 2247, "biotype": "gene", "name": "FGF2", "accession": "@GENE_FGF2"}, "text": "basic fibroblast growth factor", "locations": [{"offset": 1037, "length": 30}]}, {"id": "18", "infons": {"identifier": "2247", "type": "Gene", "ncbi_homologene": "1521", "valid": true, "normalized": [2247], "database": "ncbi_gene", "normalized_id": 2247, "biotype": "gene", "name": "FGF2", "accession": "@GENE_FGF2"}, "text": "bFGF", "locations": [{"offset": 1069, "length": 4}]}, {"id": "19", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "assembloids", "locations": [{"offset": 1190, "length": 11}]}], "relations": []}], "relations": [], "pmid": 40578028, "pmcid": null, "meta": {}, "date": "2025-06-26T00:00:00Z", "journal": "EBioMedicine", "authors": ["Yang JL", "Qian SY", "Cheng ML", "Wang LX", "Wang Y", "Liu JJ", "Xi CS", "Yang YX", "Li Y", "Gao C", "Zheng GQ"], "relations_display": []}, {"_id": "40578352|None", "id": "40578352", "infons": {}, "passages": [{"infons": {"journal": "Stem Cell Reports;2025Jul08; 20 (7) 102550. doi:10.1016/j.stemcr.2025.102550", "year": "2025", "article-id_pmc": "PMC12277833", "type": "title", "authors": "Parafati M, Thwin Z, Malany LK, Coen PM, Malany S, "}, "offset": 0, "text": "Microgravity accelerates skeletal muscle degeneration: Functional and transcriptomic insights from an ISS muscle lab-on-chip model.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D009410", "type": "Disease", "valid": true, "normalized": ["D009410"], "database": "ncbi_mesh", "normalized_id": "D009410", "biotype": "disease", "name": "Nerve Degeneration", "accession": "@DISEASE_Nerve_Degeneration"}, "text": "muscle degeneration", "locations": [{"offset": 34, "length": 19}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 132, "text": "Microgravity accelerates skeletal muscle degeneration, mimicking aspects of aging, yet its effects on muscle cell function remain underexplored. Using a muscle lab-on-chip model onboard the International Space Station (ISS), we examined 3D-bioengineered myobundles derived from young and older adult donors under microgravity. Electrical stimulation applied intermittently to the myobundles revealed reduced contraction magnitude in microgravity and decreased protein levels of myosin heavy chain 7, a main isoform in slow-twitch muscle fibers. Transcriptomic profiling revealed active myogenesis across ground and spaceflight samples, but younger electrically stimulated myobundles displayed enhanced mitochondrial-related gene expression in microgravity, while older and non-electrically stimulated myobundles were less responsive. Comparative analysis between young and older derived myobundles identified 86 muscle-specific age-associated genes altered in microgravity, linked to inflammation, mitochondrial dysfunction, and cellular stress. These findings highlight a unique age-related molecular response in microgravity and underscores electrical stimulation as a potential countermeasure. These insights advance our understanding of muscle aging and degeneration in microgravity, guiding future therapeutic strategies.", "sentences": [], "annotations": [{"id": "6", "infons": {"identifier": "MESH:D009410", "type": "Disease", "valid": true, "normalized": ["D009410"], "database": "ncbi_mesh", "normalized_id": "D009410", "biotype": "disease", "name": "Nerve Degeneration", "accession": "@DISEASE_Nerve_Degeneration"}, "text": "muscle degeneration", "locations": [{"offset": 166, "length": 19}]}, {"id": "7", "infons": {"identifier": "4625", "type": "Gene", "ncbi_homologene": "68044", "valid": true, "normalized": [4625], "database": "ncbi_gene", "normalized_id": 4625, "biotype": "gene", "name": "MYH7", "accession": "@GENE_MYH7"}, "text": "myosin heavy chain 7", "locations": [{"offset": 610, "length": 20}]}, {"id": "8", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 1116, "length": 12}]}, {"id": "9", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial dysfunction", "locations": [{"offset": 1130, "length": 25}]}], "relations": []}], "relations": [], "pmid": 40578352, "pmcid": null, "meta": {}, "date": "2025-07-08T00:00:00Z", "journal": "Stem Cell Reports", "authors": ["Parafati M", "Thwin Z", "Malany LK", "Coen PM", "Malany S"], "relations_display": []}, {"_id": "40591405|None", "id": "40591405", "infons": {}, "passages": [{"infons": {"journal": "J Clin Invest;2025Jul01. doi:10.1172/JCI181881", "year": "2025", "type": "title", "authors": "Nakamura K, Ortuste-Quiroga HP, Horii N, Fujimaki S, Moroishi T, Nakayama KI, Hino S, Saito Y, Nishino I, Ono Y, "}, "offset": 0, "text": "Iron supplementation alleviates pathologies in a mouse model of facioscapulohumeral muscular dystrophy.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:D007501", "type": "Chemical", "valid": true, "normalized": ["D007501"], "database": "ncbi_mesh", "normalized_id": "D007501", "biotype": "chemical", "name": "Iron", "accession": "@CHEMICAL_Iron"}, "text": "Iron", "locations": [{"offset": 0, "length": 4}]}, {"id": "4", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 49, "length": 5}]}, {"id": "5", "infons": {"identifier": "MESH:D020391", "type": "Disease", "valid": true, "normalized": ["D020391"], "database": "ncbi_mesh", "normalized_id": "D020391", "biotype": "disease", "name": "Muscular Dystrophy Facioscapulohumeral", "accession": "@DISEASE_Muscular_Dystrophy_Facioscapulohumeral"}, "text": "facioscapulohumeral muscular dystrophy", "locations": [{"offset": 64, "length": 38}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 104, "text": "Facioscapulohumeral muscular dystrophy (FSHD) is a genetic muscle disease caused by ectopic expression of the toxic protein DUX4, resulting in muscle weakness. However, the mechanism by which DUX4 exerts its toxicity remains unclear. In this study, we observed abnormal iron accumulation in muscles of patients with FSHD and in muscle-specific DUX4-expressing (DUX4-Tg) mice. Treatment with iron chelators, an iron-deficient diet, and genetic modifications inhibiting intracellular uptake of iron did not improve but rather exacerbated FSHD pathology in DUX4-Tg mice. Unexpectedly, however, iron supplementation, either from a high-iron diet or intravenous iron administration, resulted in remarkable improvement in grip strength and running performance in DUX4-Tg mice. Iron supplementation suppressed abnormal iron accumulation and the ferroptosis-related pathway involving increased lipid peroxidation in DUX4-Tg muscle. Muscle-specific DUX4 expression led to retinal vasculopathy, a part of FSHD pathology, which was prevented by iron administration. Furthermore, high-throughput compound screening of the ferroptosis pathway identified drug candidates including Ferrostatin-1 (Fer-1), a potent inhibitor of lipid peroxidation. Treatment with Fer-1 dramatically improved physical function in DUX4-Tg mice. Our findings demonstrate that DUX4-provoked toxicity is involved in the activation of the ferroptosis-related pathway and that supplementary iron could be a promising and readily available therapeutic option for FSHD.", "sentences": [], "annotations": [{"id": "48", "infons": {"identifier": "MESH:D020391", "type": "Disease", "valid": true, "normalized": ["D020391"], "database": "ncbi_mesh", "normalized_id": "D020391", "biotype": "disease", "name": "Muscular Dystrophy Facioscapulohumeral", "accession": "@DISEASE_Muscular_Dystrophy_Facioscapulohumeral"}, "text": "Facioscapulohumeral muscular dystrophy", "locations": [{"offset": 104, "length": 38}]}, {"id": "49", "infons": {"identifier": "MESH:D020391", "type": "Disease", "valid": true, "normalized": ["D020391"], "database": "ncbi_mesh", "normalized_id": "D020391", "biotype": "disease", "name": "Muscular Dystrophy Facioscapulohumeral", "accession": "@DISEASE_Muscular_Dystrophy_Facioscapulohumeral"}, "text": "FSHD", "locations": [{"offset": 144, "length": 4}]}, {"id": "50", "infons": {"identifier": "MESH:D009128", "type": "Disease", "valid": true, "normalized": ["D009128"], "database": "ncbi_mesh", "normalized_id": "D009128", "biotype": "disease", "name": "Muscle Spasticity", "accession": "@DISEASE_Muscle_Spasticity"}, "text": "genetic muscle disease", "locations": [{"offset": 155, "length": 22}]}, {"id": "51", "infons": {"identifier": "664783", "type": "Gene", "valid": true, "normalized": [664783], "database": "ncbi_gene", "normalized_id": 664783, "biotype": "gene", "name": "Dux", "accession": "@GENE_DUX"}, "text": "DUX4", "locations": [{"offset": 228, "length": 4}]}, {"id": "52", "infons": {"identifier": "MESH:D018908", "type": "Disease", "valid": true, "normalized": ["D018908"], "database": "ncbi_mesh", "normalized_id": "D018908", "biotype": "disease", "name": "Muscle Weakness", "accession": "@DISEASE_Muscle_Weakness"}, "text": "muscle weakness", "locations": [{"offset": 247, "length": 15}]}, {"id": "53", "infons": {"identifier": "664783", "type": "Gene", "valid": true, "normalized": [664783], "database": "ncbi_gene", "normalized_id": 664783, "biotype": "gene", "name": "Dux", "accession": "@GENE_DUX"}, "text": "DUX4", "locations": [{"offset": 296, "length": 4}]}, {"id": "54", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "da