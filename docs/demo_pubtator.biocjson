ologene": "3525", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "text": "adiponectin", "locations": [{"offset": 2699, "length": 11}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.5439", "role1": {"identifier": "MESH:D002956", "type": "Chemical", "valid": true, "normalized": ["D002956"], "database": "ncbi_mesh", "normalized_id": "D002956", "biotype": "chemical", "name": "Citrulline", "accession": "@CHEMICAL_Citrulline"}, "role2": {"identifier": "3479", "type": "Gene", "valid": true, "normalized": [3479], "database": "ncbi_gene", "normalized_id": 3479, "biotype": "gene", "name": "IGF1", "accession": "@GENE_IGF1"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "12,13"}]}, {"id": "R2", "infons": {"score": "0.9865", "role1": {"identifier": "3630", "type": "Gene", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "role2": {"identifier": "3952", "type": "Gene", "valid": true, "normalized": [3952], "database": "ncbi_gene", "normalized_id": 3952, "biotype": "gene", "name": "LEP", "accession": "@GENE_LEP"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "15,17"}]}, {"id": "R3", "infons": {"score": "0.9916", "role1": {"identifier": "3630", "type": "Gene", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "role2": {"identifier": "9370", "type": "Gene", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "15,18"}]}, {"id": "R4", "infons": {"score": "0.9972", "role1": {"identifier": "3952", "type": "Gene", "valid": true, "normalized": [3952], "database": "ncbi_gene", "normalized_id": 3952, "biotype": "gene", "name": "LEP", "accession": "@GENE_LEP"}, "role2": {"identifier": "9370", "type": "Gene", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "17,18"}]}, {"id": "R5", "infons": {"score": "0.9986", "role1": {"identifier": "MESH:D002956", "type": "Chemical", "valid": true, "normalized": ["D002956"], "database": "ncbi_mesh", "normalized_id": "D002956", "biotype": "chemical", "name": "Citrulline", "accession": "@CHEMICAL_Citrulline"}, "role2": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "4", "role": "12,5"}]}], "pmid": 41933456, "pmcid": null, "meta": {}, "date": "2026-04-01T00:00:00Z", "journal": "J Cachexia Sarcopenia Muscle", "authors": ["Mercier-Guery A", "Millet M", "Croset M", "Marcangeli V", "Dulac M", "Carvalho LP", "Hajj-Boutros G", "Gaudreau P", "Morais JA", "Gouspillou G", "Noirez P", "Rousseau JC", "Chapurlat R", "Aubertin-Leheudre M"], "relations_display": [{"name": "associate|@CHEMICAL_Citrulline|@GENE_IGF1"}, {"name": "associate|@GENE_INS|@GENE_LEP"}, {"name": "associate|@GENE_INS|@GENE_ADIPOQ"}, {"name": "associate|@GENE_LEP|@GENE_ADIPOQ"}, {"name": "treat|@CHEMICAL_Citrulline|@DISEASE_Obesity"}]}, {"_id": "41934491|None", "id": "41934491", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "SIRT1 Activators as Geroprotective Agents in Brain Aging: Mechanisms and Therapeutic Potential.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "23411", "type": "Gene", "ncbi_homologene": "56556", "valid": true, "normalized": [23411], "database": "ncbi_gene", "normalized_id": 23411, "biotype": "gene", "name": "SIRT1", "accession": "@GENE_SIRT1"}, "text": "SIRT1", "locations": [{"offset": 0, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 96, "text": "The brain undergoes profound molecular and structural changes during the aging process, resulting in the development of neurodegeneration, cognitive impairment, and increased vulnerability to chronic diseases. At the cellular level, brain aging is characterized by oxidative damage, genomic instability, and chronic low-grade inflammation known as inflammaging. Central to this process is Sirtuin 1 (SIRT1), a NAD+-dependent class III histone deacetylase, known for its regulatory role in chromatin remodeling, oxidative stress responses, mitochondrial biogenesis, and neuroplasticity. Recent research has identified SIRT1 as a molecular target capable of reversing or attenuating several hallmarks of aging, particularly within the central nervous system (CNS). This narrative review critically evaluates the emerging evidence surrounding the geroprotective effects of SIRT1 activators, which exert dual actions, senomorphic and senolytic, via modulation of signaling pathways, thereby reducing neuronal senescence, enhancing autophagy, and mitigating inflammatory responses. The discussion also addresses the region-specific role of SIRT1 across the brain, particularly in the hippocampus and hypothalamus, which are essential for memory, energy homeostasis, and resilience to stress. Additionally, this review explores how SIRT1 depletion during aging contributes to the development of synaptic dysfunction, impaired cognitive function, and susceptibility to neurodegenerative diseases such as Alzheimer's disease (AD) and Parkinson's disease (PD). The therapeutic potential of SIRT1 activators is supported by preclinical and early clinical studies, suggesting their value in preventing or delaying brain aging. Thus, SIRT1 could be a promising pharmacological target for age-associated brain disorders, warranting more robust translational studies to validate these findings in humans.", "sentences": [], "annotations": [{"id": "25", "infons": {"identifier": "MESH:D019636", "type": "Disease", "valid": true, "normalized": ["D019636"], "database": "ncbi_mesh", "normalized_id": "D019636", "biotype": "disease", "name": "Neurodegenerative Diseases", "accession": "@DISEASE_Neurodegenerative_Diseases"}, "text": "neurodegeneration", "locations": [{"offset": 216, "length": 17}]}, {"id": "26", "infons": {"identifier": "MESH:D003072", "type": "Disease", "valid": true, "normalized": ["D003072"], "database": "ncbi_mesh", "normalized_id": "D003072", "biotype": "disease", "name": "Cognition Disorders", "accession": "@DISEASE_Cognition_Disorders"}, "text": "cognitive impairment", "locations": [{"offset": 235, "length": 20}]}, {"id": "27", "infons": {"identifier": "MESH:D002908", "type": "Disease", "valid": true, "normalized": ["D002908"], "database": "ncbi_mesh", "normalized_id": "D002908", "biotype": "disease", "name": "Chronic Disease", "accession": "@DISEASE_Chronic_Disease"}, "text": "chronic diseases", "locations": [{"offset": 288, "length": 16}]}, {"id": "28", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 422, "length": 12}]}, {"id": "29", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "inflammaging", "locations": [{"offset": 444, "length": 12}]}, {"id": "30", "infons": {"identifier": "23411", "type": "Gene", "ncbi_homologene": "56556", "valid": true, "normalized": [23411], "database": "ncbi_gene", "normalized_id": 23411, "biotype": "gene", "name": "SIRT1", "accession": "@GENE_SIRT1"}, "text": "Sirtuin 1", "locations": [{"offset": 485, "length": 9}]}, {"id": "31", "infons": {"identifier": "23411", "type": "Gene