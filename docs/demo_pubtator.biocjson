: "Chemical", "valid": true, "normalized": ["C547106"], "database": "ncbi_mesh", "normalized_id": "C547106", "biotype": "chemical", "name": "ostarine", "accession": "@CHEMICAL_ostarine"}, "role2": {"identifier": "MESH:D002100", "type": "Disease", "valid": true, "normalized": ["D002100"], "database": "ncbi_mesh", "normalized_id": "D002100", "biotype": "disease", "name": "Cachexia", "accession": "@DISEASE_Cachexia"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "14,17"}]}, {"id": "R4", "infons": {"score": "0.7255", "role1": {"identifier": "MESH:C536030", "type": "Disease", "valid": true, "normalized": ["C536030"], "database": "ncbi_mesh", "normalized_id": "C536030", "biotype": "disease", "name": "MASS syndrome", "accession": "@DISEASE_MASS_syndrome"}, "role2": {"identifier": "2740", "type": "Gene", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "27,26"}]}, {"id": "R5", "infons": {"score": "0.9656", "role1": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "role2": {"identifier": "2740", "type": "Gene", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "24,26"}]}, {"id": "R6", "infons": {"score": "0.8732", "role1": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "role2": {"identifier": "2740", "type": "Gene", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "type": "Association"}, "nodes": [{"refid": "5", "role": "8,26"}]}, {"id": "R7", "infons": {"score": "0.955", "role1": {"identifier": "MESH:C547106", "type": "Chemical", "valid": true, "normalized": ["C547106"], "database": "ncbi_mesh", "normalized_id": "C547106", "biotype": "chemical", "name": "ostarine", "accession": "@CHEMICAL_ostarine"}, "role2": {"identifier": "MESH:D002908", "type": "Disease", "valid": true, "normalized": ["D002908"], "database": "ncbi_mesh", "normalized_id": "D002908", "biotype": "disease", "name": "Chronic Disease", "accession": "@DISEASE_Chronic_Disease"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "6", "role": "14,19"}]}], "pmid": 40739991, "pmcid": null, "meta": {}, "date": "2025-08-01T00:00:00Z", "journal": "J Diabetes", "authors": ["Wen J", "Ansari U", "Shehabat M", "Ansari Z", "Syed B", "Razick A", "Razick D", "Akhtar M", "Frezza E"], "relations_display": [{"name": "stimulate|@DISEASE_Weight_Loss|@GENE_GLP1R"}, {"name": "treat|@CHEMICAL_ostarine|@DISEASE_Sarcopenia"}, {"name": "treat|@CHEMICAL_ostarine|@DISEASE_Cachexia"}, {"name": "associate|@DISEASE_MASS_syndrome|@GENE_GLP1R"}, {"name": "associate|@DISEASE_Diabetes_Mellitus|@GENE_GLP1R"}, {"name": "associate|@DISEASE_Obesity|@GENE_GLP1R"}, {"name": "treat|@CHEMICAL_ostarine|@DISEASE_Chronic_Disease"}]}, {"_id": "40747292|None", "id": "40747292", "infons": {}, "passages": [{"infons": {"journal": "Curr Res Food Sci;2025; 11 101153. doi:10.1016/j.crfs.2025.101153", "year": "2025", "article-id_pmc": "PMC12311957", "type": "title", "authors": "Ke Y, Dai Z, Zhao Y, Yang Y, Wu H, Shang H, Cholewa J, Zanchi NE, Xia Z, "}, "offset": 0, "text": "Potential of edible insects as alternative protein source for the older adults.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 80, "text": "With global population growth and aging, the demand for high-quality protein continues to increase. It is therefore important to find new and sustainable sources of protein. Compared to traditional animal-derived proteins, insect-derived proteins have higher sustainability and a smaller ecological footprint. In addition, considering that older adults have an anabolic resistance and that protein intake strongly stimulates skeletal muscle protein synthesis, insect-derived proteins may play a potential role in promoting healthy aging. Based on this, this review systematically analyzes the essential amino acid profile, nutritional value, protein digestibility and absorption, health benefits and potential risks, as well as the acceptability and environmental impact of edible insects. Overall, adding insect-derived protein to the diet helps maintain skeletal muscle mass and function in aging, improves gut health, and lowers the risk of age-related diseases. In future research, it is still necessary to improve processing and preparation techniques and establish explicit legal provisions to ensure the safety and acceptability of insect-derived proteins.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D000601", "type": "Chemical", "valid": true, "normalized": ["D000601"], "database": "ncbi_mesh", "normalized_id": "D000601", "biotype": "chemical", "name": "Amino Acids Essential", "accession": "@CHEMICAL_Amino_Acids_Essential"}, "text": "essential amino acid", "locations": [{"offset": 673, "length": 20}]}, {"id": "3", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "age-related diseases", "locations": [{"offset": 1024, "length": 20}]}], "relations": []}], "relations": [], "pmid": 40747292, "pmcid": null, "meta": {}, "date": "2025-07-21T00:00:00Z", "journal": "Curr Res Food Sci", "authors": ["Ke Y", "Dai Z", "Zhao Y", "Yang Y", "Wu H", "Shang H", "Cholewa J", "Zanchi NE", "Xia Z"], "relations_display": []}, {"_id": "40751170|None", "id": "40751170", "infons": {}, "passages": [{"infons": {"journal": "J Health Popul Nutr;2025Aug01; 44 (1) 272. doi:10.1186/s41043-025-01031-w", "year": "2025", "article-id_pmc": "PMC12317481", "type": "title", "authors": "Chen W, "}, "offset": 0, "text": "Nutritional interventions in muscle hypertrophy research: a scientometric analysis within the context of resistance training (1992-2025).", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:C536106", "type": "Disease", "valid": true, "normalized": ["C536106"], "database": "ncbi_mesh", "normalized_id": "C536106", "biotype": "disease", "name": "Myostatin-related muscle hypertrophy", "accession": "@DISEASE_Myostatin_related_muscle_hypertrophy"}, "text": "muscle hypertrophy", "locations": [{"offset": 29, "length": 18}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 138, "text": "BACKGROUND: Muscle hypertrophy, as a central goal in sports training, rehabilitation interventions, and health promotion, relies on scientifically designed resistance training and appropriate nutritional strategies. However, research on the synergistic effects of nutritional interventions and resistance training in promoting muscle hypertrophy is characterized by thematic fragmentation, insufficient integration between mechanistic and applied research, and imbalances across different regions and population groups. METHODS: To systematically delineate the developmental trajectory and emerging trends in this field, a comprehensive search was conducted in the Web of Science Core Collection, initially retrieving 456 publications. After rigorous screening and data cleaning, 411 English-language articles published between 1992 and 2025 were retained for analysis. Scientometric techniques were applied to construct knowledge maps using three major tools: Bibliometrix (R 4.4.3), VOSviewer (1.6.20), and CiteSpace (6.2.6). Bibliometrix was used to analyze publication trends and thematic evolution; VOSviewer to map keyword co-occurrence and collaboration networks; and CiteSpace to detect citation bursts and visualize knowledge structures. Collectively, these methods facilitated the identification of high-frequency keywords, hotspot transitions, collaborative patterns, and underexplored thematic gaps. RESULTS: The results indicate that: (1) the combination of protein supplementation and resistance training represents the most prominent intervention strategy; (2) a stable tripartite research model has emerged, centering on the interaction among training, nutrition, and structural adaptation; (3) the thematic focus has gradually shifted from molecular mechanisms toward practical applications, emphasizing issues such as aging and functional improvement; and (4) notable research gaps remain, particularly the underrepresentation of women and Asian populations, insufficient attention to recovery, metabolism, and periodized nutrition, and the lack of a systematic framework for individualized interventions. CONCLUSION: This study delineates the developmental trajectory, structural characteristics, and future directions of research in this field over the past three decades, providing empirical evidence and a theoretical foundation for the scientific formulation of muscle health enhancement strategies.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "MESH:C536106", "type": "Disease", "valid": true, "normalized": ["C536106"], "database": "ncbi_mesh", "normalized_id": "C536106", "biotype": "disease", "name": "Myostatin-related muscle hypertrophy", "accession": "@DISEASE_Myostatin_related_muscle_hypertrophy"}, "text": "Muscle hypertrophy", "locations": [{"offset": 150, "length": 18}]}, {"id": "6", "infons": {"identifier": "MESH:C536106", "type": "Disease", "valid": true, "normalized": ["C536106"], "database": "ncbi_mesh", "normalized_id": "C536106", "biotype": "disease", "name": "Myostatin-related muscle hypertrophy", "accession": "@DISEASE_Myostatin_related_muscle_hypertrophy"}, "text": "muscle hypertrophy", "locations": [{"offset": 465, "length": 18}]}, {"id": "7", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "women", "locations": [{"offset": 2086, "length": 5}]}], "relations": []}], "relations": [], "pmid": 40751170, "pmcid": null, "meta": {}, "date": "2025-08-01T00:00:00Z", "journal": "J Health Popul Nutr", "authors": ["Chen W"], "relations_display": []}, {"_id": "40760703|None", "id": "40760703", "infons": {}, "passages": [{"infons": {"journal": "Cardiovasc Diabetol;2025Aug04; 24 (1) 319. doi:10.1186/s12933-025-02763-z", "year": "2025", "article-id_pmc": "PMC12323123", "type": "title", "authors": "Liu D, Chen W, Guo Z, Gao Q, Wang B, Wang J, Hu W, Wang C, Wang S, Wu X, Xu M, Lan G, "}, "offset": 0, "text": "Advances and challenges of targeting epicardial adipose tissue (EAT) and perivascular adipose tissue (PVAT).", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 109, "text": "Clinical consensus statements have been issued for various adipose tissues (ATs), particularly regarding the diagnostic value of epicardial AT (EAT) and perivascular AT (PVAT) in cardiovascular disease. PVAT and EAT are promising targets for drug development and many drugs were also investigated, including DPP4 inhibitors, GLP-1R agonists, and SGLT-2i. Notably, DPP4 was the only gene that highly expressed in EAT and PVAT. DPP4 also reduced GLP-1 and its receptor GLP-1R expression, suggesting that DDP4 is a promising target for targeting EAT and PVAT. However, these preparations have poor specificity for PVAT and EAT. AT delivery strategies or specific AT genes, such as ADIPOQ and PHB1, may solve these problems. ADIPOQ is only expressed in AT and encodes adiponectin (ADPN). PHB1 is an AT vascular biomarker. Many ADPN and PHB1 agents have also been developed in preclinical and clinical trials. However, these agents have serious off-target effects. SaRNA, an RNA activation technology, may reduce off-target effects. Several saRNA agents were also developed in preclinical and clinical trials. Direct overexpression of ADIPOQ and PHB1 through saRNA in combination with extrahepatic delivery materials may be beneficial for drug development. This review focuses on recent advances targeting EAT and PVAT agents and identifies new therapeutic targets.", "sentences": [], "annotations": [{"id": "20", "infons": {"identifier": "MESH:D002318", "type": "Disease", "valid": true, "normalized": ["D002318"], "database": "ncbi_mesh", "normalized_id": "D002318", "biotype": "disease", "name": "Cardiovascular Diseases", "accession": "@DISEASE_Cardiovascular_Diseases"}, "text": "cardiovascular disease", "locations": [{"offset": 288, "length": 22}]}, {"id": "21", "infons": {"identifier": "1803", "type": "Gene", "ncbi_homologene": "3279", "valid": true, "normalized": [1803], "database": "ncbi_gene", "normalized_id": 1803, "biotype": "gene", "name": "DPP4", "accession": "@GENE_DPP4"}, "text": "DPP4", "locations": [{"offset": 417, "length": 4}]}, {"id": "22", "infons": {"identifier": "2740", "type": "Gene", "ncbi_homologene": "1558", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "text": "GLP-1R", "locations": [{"offset": 434, "length": 6}]}, {"id": "23", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "SGLT-2i", "locations": [{"offset": 455, "length": 7}]}, {"id": "24", "infons": {"identifier": "1803", "type": "Gene", "ncbi_homologene": "3279", "valid": true, "normalized": [1803], "database": "ncbi_gene", "normalized_id": 1803, "biotype": "gene", "name": "DPP4", "accession": "@GENE_DPP4"}, "text": "DPP4", "locations": [{"offset": 473, "length": 4}]}, {"id": "25", "infons": {"identifier": "1803", "type": "Gene", "ncbi_homologene": "3279", "valid": true, "normalized": [1803], "database": "ncbi_gene", "normalized_id": 1803, "biotype": "gene", "name": "DPP4", "accession": "@GENE_DPP4"}, "text": "DPP4", "locations": [{"offset": 535, "length": 4}]}, {"id": "26", "infons": {"identifier": "2740", "type": "Gene", "ncbi_homologene": "1558", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "text": "GLP-1", "locations": [{"offset": 553, "length": 5}]}, {"id": "27", "infons": {"identifier": "2740", "type": "Gene", "ncbi_homologene": "1558", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "text": "GLP-1R", "locations": [{"offset": 576, "length": 6}]}, {"id": "28", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "DDP4", "locations": [{"offset": 611, "length": 4}]}, {"id": "29", "infons": {"identifier": "9370", "type": "Gene", "ncbi_homologene": "3525", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "text": "ADIPOQ", "locations": [{"offset": 787, "length": 6}]}, {"id": "30", "infons": {"identifier": "5245", "type": "Gene", "ncbi_homologene": "1980", "valid": true, "normalized": [5245], "database": "ncbi_gene", "normalized_id": 5245, "biotype": "gene", "name": "PHB", "accession": "@GENE_PHB"}, "text": "PHB1", "locations": [{"offset": 798, "length": 4}]}, {"id": "31", "infons": {"identifier": "9370", "type": "Gene", "ncbi_homologene": "3525", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "text": "ADIPOQ", "locations": [{"offset": 830, "length": 6}]}, {"id": "32", "infons": {"identifier": "9370", "type": "Gene", "ncbi_homologene": "3525", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "text": "adiponectin", "locations": [{"offset": 873, "length": 11}]}, {"id": "33", "infons": {"identifier": "9370", "type": "Gene", "ncbi_homologene": "3525", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "text": "ADPN", "locations": [{"offset": 886, "length": 4}]}, {"id": "34", "infons": {"identifier": "5245", "type": "Gene", "ncbi_homologene": "1980", "valid": true, "normalized": [5245], "database": "ncbi_gene", "normalized_id": 5245, "biotype": "gene", "name": "PHB", "accession": "@GENE_PHB"}, "text": "PHB1", "locations": [{"offset": 893, "length": 4}]}, {"id": "35", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "AT", "locations": [{"offset": 904, "length": 2}]}, {"id": "36", "infons": {"identifier": "9370", "type": "Gene", "ncbi_homologene": "3525", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "text": "ADPN", "locations": [{"offset": 932, "length": 4}]}, {"id": "37", "infons": {"identifier": "5245", "type": "Gene", "ncbi_homologene": "1980", "valid": true, "normalized": [5245], "database": "ncbi_gene", "normalized_id": 5245, "biotype": "gene", "name": "PHB", "accession": "@GENE_PHB"}, "text": "PHB1", "locations": [{"offset": 941, "length": 4}]}, {"id": "38", "infons": {"identifier": "9370", "type": "Gene", "ncbi_homologene": "3525", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "text": "ADIPOQ", "locations": [{"offset": 1239, "length": 6}]}, {"id": "39", "infons": {"identifier": "5245", "type": "Gene", "ncbi_homologene": "1980", "valid": true, "normalized": [5245], "database": "ncbi_gene", "normalized_id": 5245, "biotype": "gene", "name": "PHB", "accession": "@GENE_PHB"}, "text": "PHB1", "locations": [{"offset": 1250, "length": 4}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.5152", "role1": {"identifier": "2740", "type": "Gene", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "role2": {"identifier": "5245", "type": "Gene", "valid": true, "normalized": [5245], "database": "ncbi_gene", "normalized_id": 5245, "biotype": "gene", "name": "PHB", "accession": "@GENE_PHB"}, "type": "Bind"}, "nodes": [{"refid": "0", "role": "7,19"}]}, {"id": "R2", "infons": {"score": "0.9583", "role1": {"identifier": "2740", "type": "Gene", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "role2": {"identifier": "9370", "type": "Gene", "valid": true, "normalized": [9370], "database": "ncbi_gene", "normalized_id": 9370, "biotype": "gene", "name": "ADIPOQ", "accession": "@GENE_ADIPOQ"}, "type": "Bind"}, "nodes": [{"refid": "1", "role": "7,18"}]}, {"id": "R3", "infons": {"score": "0.9974", "role1": {"identifier": "1803", "type": "Gene", "valid": true, "normalized": [1803], "database": "ncbi_gene", "normalized_id": 1803, "biotype": "gene", "name": "DPP4", "accession": "@GENE_DPP4"}, "role2": {"identifier": "2740", "type": "Gene", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "5,7"}]}], "pmid": 40760703, "pmcid": null, "meta": {}, "date": "2025-08-04T00:00:00Z", "journal": "Cardiovasc Diabetol", "authors": ["Liu D", "Chen W", "Guo Z", "Gao Q", "Wang B", "Wang J", "Hu W", "Wang C", "Wang S", "Wu X", "Xu M", "Lan G"], "relations_display": [{"name": "interact|@GENE_GLP1R|@GENE_PHB"}, {"name": "interact|@GENE_GLP1R|@GENE_ADIPOQ"}, {"name": "negative_correlate|@GENE_DPP4|@GENE_GLP1R"}]}, {"_id": "40774144|None", "id": "40774144", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Age-related declines in mitochondrial Prdx6 contribute to dysregulated muscle bioenergetics.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "9588", "type": "Gene", "ncbi_homologene": "3606", "valid": true, "normalized": [9588], "database": "ncbi_gene", "normalized_id": 9588, "biotype": "gene", "name": "PRDX6", "accession": "@GENE_PRDX6"}, "text": "Prdx6", "locations": [{"offset": 38, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 93, "text": "An age-related decline in mitochondrial function is a multi-factorial hallmark of aging, driven partly by increased lipid hydroperoxide levels that impair mitochondrial respiration in skeletal muscle, leading to atrophy. Although pharmacological and genetic manipulations to counteract increased lipid hydroperoxide levels represent a promising strategy to treat sarcopenia, the mechanisms driving such phenotypes remain understudied. Peroxiredoxin 6 (Prdx6) is a multifunctional enzyme that contributes to peroxidized membrane repair via its phospholipid hydroperoxidase and phospholipase A2 activities. Here, we show decreased mitochondrial Prdx6 levels, increased mitochondrial lipid peroxidation, and dysregulated muscle bioenergetics in aged mice and muscle cells derived from older humans. Mechanistically, we found that Prdx6 supports optimal mitochondrial function and prevents mitochondrial fragmentation by limiting mitochondrial lipid peroxidation via its membrane remodeling activities. Our results suggest that age-related declines in mitochondrial Prdx6 contribute to dysregulated muscle bioenergetics, thereby opening the door to therapeutic modulation of Prdx6 to counteract diminished mitochondrial function in aging.", "sentences": [], "annotations": [{"id": "18", "infons": {"identifier": "MESH:D008054", "type": "Chemical", "valid": true, "normalized": ["D008054"], "database": "ncbi_mesh", "normalized_id": "D008054", "biotype": "chemical", "name": "Lipid Peroxides", "accession": "@CHEMICAL_Lipid_Peroxides"}, "text": "lipid hydroperoxide", "locations": [{"offset": 209, "length": 19}]}, {"id": "19", "infons": {"identifier": "MESH:D001284", "type": "Disease", "valid": true, "normalized": ["D001284"], "database": "ncbi_mesh", "normalized_id": "D001284", "biotype": "disease", "name": "Atrophy", "accession": "@DISEASE_Atrophy"}, "text": "atrophy", "locations": [{"offset": 305, "length": 7}]}, {"id": "20", "infons": {"identifier": "MESH:D008054", "type": "Chemical", "valid": true, "normalized": ["D008054"], "database": "ncbi_mesh", "normalized_id": "D008054", "biotype": "chemical", "name": "Lipid Peroxides", "accession": "@CHEMICAL_Lipid_Peroxides"}, "text": "lipid hydroperoxide", "locations": [{"offset": 389, "length": 19}]}, {"id": "21", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 456, "length": 10}]}, {"id": "22", "infons": {"identifier": "9588", "type": "Gene", "ncbi_homologene": "3606", "valid": true, "normalized": [9588], "database": "ncbi_gene", "normalized_id": 9588, "biotype": "gene", "name": "PRDX6", "accession": "@GENE_PRDX6"}, "text": "Peroxiredoxin 6", "locations": [{"offset": 528, "length": 15}]}, {"id": "23", "infons": {"identifier": "9588", "type": "Gene", "ncbi_homologene": "3606", "valid": true, "normalized": [9588], "database": "ncbi_gene", "normalized_id": 9588, "biotype": "gene", "name": "PRDX6", "accession": "@GENE_PRDX6"}, "text": "Prdx6", "locations": [{"offset": 545, "length": 5}]}, {"id": "24", "infons": {"identifier": "2879", "type": "Gene", "ncbi_homologene": "134384", "valid": true, "normalized": [2879], "database": "ncbi_gene", "normalized_id": 2879, "biotype": "gene", "name": "GPX4", "accession": "@GENE_GPX4"}, "text": "phospholipid hydroperoxidase", "locations": [{"offset": 636, "length": 28}]}, {"id": "25", "infons": {"identifier": "5319", "type": "Gene", "ncbi_homologene": "715", "valid": true, "normalized": [5319], "database": "ncbi_gene", "normalized_id": 5319, "biotype": "gene", "name": "PLA2G1B", "accession": "@GENE_PLA2G1B"}, "text": "phospholipase A2", "locations": [{"offset": 669, "length": 16}]}, {"id": "26", "infons": {"identifier": "9588", "type": "Gene", "ncbi_homologene": "3606", "valid": true, "normalized": [9588], "database": "ncbi_gene", "normalized_id": 9588, "biotype": "gene", "name": "PRDX6", "accession": "@GENE_PRDX6"}, "text": "Prdx6", "locations": [{"offset": 736, "length": 5}]}, {"id": "27", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 774, "length": 5}]}, {"id": "28", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 840, "length": 4}]}, {"id": "29", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "humans", "locations": [{"offset": 881, "length": 6}]}, {"id": "30", "infons": {"identifier": "9588", "type": "Gene", "ncbi_homologene": "3606", "valid": true, "normalized": [9588], "database": "ncbi_gene", "normalized_id": 9588, "biotype": "gene", "name": "PRDX6", "accession": "@GENE_PRDX6"}, "text": "Prdx6", "locations": [{"offset": 920, "length": 5}]}, {"id": "31", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 1033, "length": 5}]}, {"id": "32", "infons": {"identifier": "9588", "type": "Gene", "ncbi_homologene": "3606", "valid": true, "normalized": [9588], "database": "ncbi_gene", "normalized_id": 9588, "biotype": "gene", "name": "PRDX6", "accession": "@GENE_PRDX6"}, "text": "Prdx6", "locations": [{"offset": 1155, "length": 5}]}, {"id": "33", "infons": {"identifier": "9588", "type": "Gene", "ncbi_homologene": "3606", "valid": true, "normalized": [9588], "database": "ncbi_gene", "normalized_id": 9588, "biotype": "gene", "name": "PRDX6", "accession": "@GENE_PRDX6"}, "text": "Prdx6", "locations": [{"offset": 1264, "length": 5}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9866", "role1": {"identifier": "2879", "type": "Gene", "valid": true, "normalized": [2879], "database": "ncbi_gene", "normalized_id": 2879, "biotype": "gene", "name": "GPX4", "accession": "@GENE_GPX4"}, "role2": {"identifier": "9588", "type": "Gene", "valid": true, "normalized": [9588], "database": "ncbi_gene", "normalized_id": 9588, "biotype": "gene", "name": "PRDX6", "accession": "@GENE_PRDX6"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "7,16"}]}, {"id": "R2", "infons": {"score": "0.9985", "role1": {"identifier": "5319", "type": "Gene", "valid": true, "normalized": [5319], "database": "ncbi_gene", "normalized_id": 5319, "biotype": "gene", "name": "PLA2G1B", "accession": "@GENE_PLA2G1B"}, "role2": {"identifier": "9588", "type": "Gene", "valid": true, "normalized": [9588], "database": "ncbi_gene", "normalized_id": 9588, "biotype": "gene", "name": "PRDX6", "accession": "@GENE_PRDX6"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "8,16"}]}, {"id": "R3", "infons": {"score": "0.7942", "role1": {"identifier": "MESH:D008054", "type": "Chemical", "valid": true, "normalized": ["D008054"], "database": "ncbi_mesh", "normalized_id": "D008054", "biotype": "chemical", "name": "Lipid Peroxides", "accession": "@CHEMICAL_Lipid_Peroxides"}, "role2": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "3,4"}]}, {"id": "R4", "infons": {"score": "0.9987", "role1": {"identifier": "MESH:D008054", "type": "Chemical", "valid": true, "normalized": ["D008054"], "database": "ncbi_mesh", "normalized_id": "D008054", "biotype": "chemical", "name": "Lipid Peroxides", "accession": "@CHEMICAL_Lipid_Peroxides"}, "role2": {"identifier": "MESH:D001284", "type": "Disease", "valid": true, "normalized": ["D001284"], "database": "ncbi_mesh", "normalized_id": "D001284", "biotype": "disease", "name": "Atrophy", "accession": "@DISEASE_Atrophy"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "3", "role": "3,2"}]}], "pmid": 40774144, "pmcid": null, "meta": {}, "date": "2025-08-05T00:00:00Z", "journal": "Redox Biol", "authors": ["Arevalo JA", "Xing D", "Leija RG", "Thorwald MA", "Moreno-Santillán DD", "Allen KN", "Selleghin-Veiga G", "Avalos HC", "Utke E", "Conner JL", "Brooks GA", "Vázquez-Medina JP"], "relations_display": [{"name": "associate|@GENE_GPX4|@GENE_PRDX6"}, {"name": "associate|@GENE_PLA2G1B|@GENE_PRDX6"}, {"name": "associate|@CHEMICAL_Lipid_Peroxides|@DISEASE_Sarcopenia"}, {"name": "cause|@CHEMICAL_Lipid_Peroxides|@DISEASE_Atrophy"}]}, {"_id": "40785039|None", "id": "40785039", "infons": {}, "passages": [{"infons": {"journal": "J Cell Mol Med;2025Aug; 29 (15) 70769. doi:10.1111/jcmm.70769", "year": "2025", "article-id_pmc": "PMC12336052", "type": "title", "authors": "Zhang S, Hu C, Wang X, Huang Z, Xia Q, Deng L, "}, "offset": 0, "text": "Identification of Biomarkers and Immune-Metabolic Regulators in Acute Pancreatitis and Sarcopenia: A Multi-Modal Transcriptomics Study.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D010195", "type": "Disease", "valid": true, "normalized": ["D010195"], "database": "ncbi_mesh", "normalized_id": "D010195", "biotype": "disease", "name": "Pancreatitis", "accession": "@DISEASE_Pancreatitis"}, "text": "Acute Pancreatitis", "locations": [{"offset": 64, "length": 18}]}, {"id": "3", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "Sarcopenia", "locations": [{"offset": 87, "length": 10}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 136, "text": "Studies suggest a clinically significant association between acute pancreatitis and sarcopenia. However, the molecular mechanisms behind this association have not been fully elucidated. Here, we systematically investigated gene expression profiles by differentially expressed gene (DEG) analysis, weighted gene co-expression network analysis (WGCNA) and functional enrichment analysis, and identified a total of 36 genes as shared genes between acute pancreatitis and sarcopenia. Functional enrichment analysis revealed that these genes were enriched in immune-inflammatory processes and pathways. Furthermore, we evaluated relevant hub genes in a random forest model and investigated their expression, diagnostic performance and immune cell relationships. Random forest modelling prioritised chloride intracellular channel 5 (CLIC5), solute carrier family 38 member 1 (SLC38A1) and complement C1q B chain (C1QB) as key candidate biomarkers. Immune infiltration analysis linked these genes to dysregulated T cells, monocytes and mast cells in both diseases. Finally, we constructed a regulatory network involving miRNAs, mRNAs and transcription factors to illustrate further the regulations of three genes' transcription in acute pancreatitis and sarcopenia. The diagnostic value of CLIC5, SLC38A1 and C1QB was performed by receiver operating characteristic curves and the area under the curve in the datasets, and the validation results confirmed a consistent trend of downregulation of CLIC5 and SLC38A1 in AP and sarcopenia. This study revealed for the first time that CLIC5 and SLC38A1 were shared biomarkers for AP and sarcopenia. Their association with immune-metabolic dysregulation highlights their potential as therapeutic targets.", "sentences": [], "annotations": [{"id": "28", "infons": {"identifier": "MESH:D010195", "type": "Disease", "valid": true, "normalized": ["D010195"], "database": "ncbi_mesh", "normalized_id": "D010195", "biotype": "disease", "name": "Pancreatitis", "accession": "@DISEASE_Pancreatitis"}, "text": "acute pancreatitis", "locations": [{"offset": 197, "length": 18}]}, {"id": "29", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 220, "length": 10}]}, {"id": "30", "infons": {"identifier": "MESH:D010195", "type": "Disease", "valid": true, "normalized": ["D010195"], "database": "ncbi_mesh", "normalized_id": "D010195", "biotype": "disease", "name": "Pancreatitis", "accession": "@DISEASE_Pancreatitis"}, "text": "acute pancreatitis", "locations": [{"offset": 581, "length": 18}]}, {"id": "31", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 604, "length": 10}]}, {"id": "32", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 697, "length": 12}]}, {"id": "33", "infons": {"identifier": "53405", "type": "Gene", "ncbi_homologene": "987", "valid": true, "normalized": [53405], "database": "ncbi_gene", "normalized_id": 53405, "biotype": "gene", "name": "CLIC5", "accession": "@GENE_CLIC5"}, "text": "chloride intracellular channel 5", "locations": [{"offset": 929, "length": 32}]}, {"id": "34", "infons": {"identifier": "53405", "type": "Gene", "ncbi_homologene": "987", "valid": true, "normalized": [53405], "database": "ncbi_gene", "normalized_id": 53405, "biotype": "gene", "name": "CLIC5", "accession": "@GENE_CLIC5"}, "text": "CLIC5", "locations": [{"offset": 963, "length": 5}]}, {"id": "35", "infons": {"identifier": "81539", "type": "Gene", "ncbi_homologene": "12745", "valid": true, "normalized": [81539], "database": "ncbi_gene", "normalized_id": 81539, "biotype": "gene", "name": "SLC38A1", "accession": "@GENE_SLC38A1"}, "text": "solute carrier family 38 member 1", "locations": [{"offset": 971, "length": 33}]}, {"id": "36", "infons": {"identifier": "81539", "type": "Gene", "ncbi_homologene": "12745", "valid": true, "normalized": [81539], "database": "ncbi_gene", "normalized_id": 81539, "biotype": "gene", "name": "SLC38A1", "accession": "@GENE_SLC38A1"}, "text": "SLC38A1", "locations": [{"offset": 1006, "length": 7}]}, {"id": "37", "infons": {"identifier": "713", "type": "Gene", "ncbi_homologene": "418", "valid": true, "normalized": [713], "database": "ncbi_gene", "normalized_id": 713, "biotype": "gene", "name": "C1QB", "accession": "@GENE_C1QB"}, "text": "complement C1q B chain", "locations": [{"offset": 1019, "length": 22}]}, {"id": "38", "infons": {"identifier": "713", "type": "Gene", "ncbi_homologene": "418", "valid": true, "normalized": [713], "database": "ncbi_gene", "normalized_id": 713, "biotype": "gene", "name": "C1QB", "accession": "@GENE_C1QB"}, "text": "C1QB", "locations": [{"offset": 1043, "length": 4}]}, {"id": "39", "infons": {"identifier": "MESH:D010195", "type": "Disease", "valid": true, "normalized": ["D010195"], "database": "ncbi_mesh", "normalized_id": "D010195", "biotype": "disease", "name": "Pancreatitis", "accession": "@DISEASE_Pancreatitis"}, "text": "acute pancreatitis", "locations": [{"offset": 1360, "length": 18}]}, {"id": "40", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 1383, "length": 10}]}, {"id": "41", "infons": {"identifier": "53405", "type": "Gene", "ncbi_homologene": "987", "valid": true, "normalized": [53405], "database": "ncbi_gene", "normalized_id": 53405, "biotype": "gene", "name": "CLIC5", "accession": "@GENE_CLIC5"}, "text": "CLIC5", "locations": [{"offset": 1419, "length": 5}]}, {"id": "42", "infons": {"identifier": "81539", "type": "Gene", "ncbi_homologene": "12745", "valid": true, "normalized": [81539], "database": "ncbi_gene", "normalized_id": 81539, "biotype": "gene", "name": "SLC38A1", "accession": "@GENE_SLC38A1"}, "text": "SLC38A1", "locations": [{"offset": 1426, "length": 7}]}, {"id": "43", "infons": {"identifier": "713", "type": "Gene", "ncbi_homologene": "418", "valid": true, "normalized": [713], "database": "ncbi_gene", "normalized_id": 713, "biotype": "gene", "name": "C1QB", "accession": "@GENE_C1QB"}, "text": "C1QB", "locations": [{"offset": 1438, "length