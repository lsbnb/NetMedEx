": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 746, "length": 2}]}, {"id": "36", "infons": {"identifier": "MESH:D008107", "type": "Disease", "valid": true, "normalized": ["D008107"], "database": "ncbi_mesh", "normalized_id": "D008107", "biotype": "disease", "name": "Liver Diseases", "accession": "@DISEASE_Liver_Diseases"}, "text": "liver diseases", "locations": [{"offset": 836, "length": 14}]}, {"id": "37", "infons": {"identifier": "MESH:D011230", "type": "Disease", "valid": true, "normalized": ["D011230"], "database": "ncbi_mesh", "normalized_id": "D011230", "biotype": "disease", "name": "Precancerous Conditions", "accession": "@DISEASE_Precancerous_Conditions"}, "text": "carcinogenic", "locations": [{"offset": 871, "length": 12}]}, {"id": "38", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 1064, "length": 2}]}, {"id": "39", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 1217, "length": 2}]}, {"id": "40", "infons": {"identifier": "MESH:D063646", "type": "Disease", "valid": true, "normalized": ["D063646"], "database": "ncbi_mesh", "normalized_id": "D063646", "biotype": "disease", "name": "Carcinogenesis", "accession": "@DISEASE_Carcinogenesis"}, "text": "carcinogenesis", "locations": [{"offset": 1258, "length": 14}]}, {"id": "41", "infons": {"identifier": "MESH:D006528", "type": "Disease", "valid": true, "normalized": ["D006528"], "database": "ncbi_mesh", "normalized_id": "D006528", "biotype": "disease", "name": "Carcinoma Hepatocellular", "accession": "@DISEASE_Carcinoma_Hepatocellular"}, "text": "hepatocellular carcinoma", "locations": [{"offset": 1281, "length": 24}]}, {"id": "42", "infons": {"identifier": "MESH:D006528", "type": "Disease", "valid": true, "normalized": ["D006528"], "database": "ncbi_mesh", "normalized_id": "D006528", "biotype": "disease", "name": "Carcinoma Hepatocellular", "accession": "@DISEASE_Carcinoma_Hepatocellular"}, "text": "HCC", "locations": [{"offset": 1307, "length": 3}]}, {"id": "43", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 1409, "length": 2}]}, {"id": "44", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 1457, "length": 2}]}, {"id": "45", "infons": {"identifier": "MESH:D006528", "type": "Disease", "valid": true, "normalized": ["D006528"], "database": "ncbi_mesh", "normalized_id": "D006528", "biotype": "disease", "name": "Carcinoma Hepatocellular", "accession": "@DISEASE_Carcinoma_Hepatocellular"}, "text": "HCC", "locations": [{"offset": 1530, "length": 3}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9988", "role1": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "role2": {"identifier": "MESH:D011230", "type": "Disease", "valid": true, "normalized": ["D011230"], "database": "ncbi_mesh", "normalized_id": "D011230", "biotype": "disease", "name": "Precancerous Conditions", "accession": "@DISEASE_Precancerous_Conditions"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "0", "role": "10,14"}]}, {"id": "R2", "infons": {"score": "0.9992", "role1": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "role2": {"identifier": "MESH:D008107", "type": "Disease", "valid": true, "normalized": ["D008107"], "database": "ncbi_mesh", "normalized_id": "D008107", "biotype": "disease", "name": "Liver Diseases", "accession": "@DISEASE_Liver_Diseases"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "1", "role": "9,13"}]}, {"id": "R3", "infons": {"score": "0.9992", "role1": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "role2": {"identifier": "MESH:D008107", "type": "Disease", "valid": true, "normalized": ["D008107"], "database": "ncbi_mesh", "normalized_id": "D008107", "biotype": "disease", "name": "Liver Diseases", "accession": "@DISEASE_Liver_Diseases"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "2", "role": "10,13"}]}, {"id": "R4", "infons": {"score": "0.9895", "role1": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "role2": {"identifier": "MESH:D011230", "type": "Disease", "valid": true, "normalized": ["D011230"], "database": "ncbi_mesh", "normalized_id": "D011230", "biotype": "disease", "name": "Precancerous Conditions", "accession": "@DISEASE_Precancerous_Conditions"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "3", "role": "9,14"}]}, {"id": "R5", "infons": {"score": "0.7391", "role1": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "role2": {"identifier": "3630", "type": "Gene", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "4", "role": "21,8"}]}], "pmid": 41667791, "pmcid": null, "meta": {}, "date": "2026-02-11T00:00:00Z", "journal": "Mol Biomed", "authors": ["Yu L", "Qian J", "Li X", "Tian M", "Bai X", "Yang J", "Deng R", "Lu C", "He X", "Lu A", "Liu Y"], "relations_display": [{"name": "cause|@CHEMICAL_Lipids|@DISEASE_Precancerous_Conditions"}, {"name": "cause|@CHEMICAL_Glucose|@DISEASE_Liver_Diseases"}, {"name": "cause|@CHEMICAL_Lipids|@DISEASE_Liver_Diseases"}, {"name": "cause|@CHEMICAL_Glucose|@DISEASE_Precancerous_Conditions"}, {"name": "inhibit|@DISEASE_Insulin_Resistance|@GENE_INS"}]}, {"_id": "41671587|None", "id": "41671587", "infons": {}, "passages": [{"infons": {"journal": "Biomed Phys Eng Express;2026Feb11. doi:10.1088/2057-1976/ae44a0", "year": "2026", "type": "title", "authors": "Hart J, Nguyen T Tran L, Ena TF, Natekar NA, Rezaei B, Jiao Y, Zuo H, Wang H, Chugh V, Azizi E, Karampelas IH, He R, Gomez-Pastora J, Wu K, "}, "offset": 0, "text": "Magnetic nanoparticles for cancer theranostics.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 27, "length": 6}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 48, "text": "Magnetic nanoparticles (MNPs) have emerged as a powerful tool in cancer theranostics due to their unique size-dependent magnetic properties, surface functionalization capabilities, and responsiveness to external magnetic fields. This review outlines different types of MNPs, including those composed of pure metals, metal oxides, and metallic alloys, and highlights their size-dependent magnetic behavior, such as superparamagnetism and dynamic magnetizations. We also explore the critical role of surface modification strategies in enhancing MNPs' biocompatibility, colloidal stability, and functional versatility for targeted biomedical applications. The applications of MNPs in cancer therapy are discussed, with a focus on magnetic hyperthermia, drug and gene delivery, and a combination of various therapies. Additionally, we examine their cancer diagnostic roles in imaging techniques such as magnetic resonance imaging (MRI) and magnetic particle imaging (MPI), and emerging magnetic biosensing technologies such as giant magnetoresistance (GMR), magnetic tunnel junction (MTJ), magnetic particle spectroscopy (MPS), and nuclear magnetic resonance (NMR)-based platforms. These advances collectively establish MNPs as key components in the future of personalized cancer diagnosis and treatment.", "sentences": [], "annotations": [{"id": "6", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 113, "length": 6}]}, {"id": "7", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 729, "length": 6}]}, {"id": "8", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 893, "length": 6}]}, {"id": "9", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 1317, "length": 6}]}], "relations": []}], "relations": [], "pmid": 41671587, "pmcid": null, "meta": {}, "date": "2026-02-19T00:00:00Z", "journal": "Biomed Phys Eng Express", "authors": ["Hart J", "Nguyen T Tran L", "Ena TF", "Natekar NA", "Rezaei B", "Jiao Y", "Zuo H", "Wang H", "Chugh V", "Azizi E", "Karampelas IH", "He R", "Gomez-Pastora J", "Wu K"], "relations_display": []}, {"_id": "41677682|None", "id": "41677682", "infons": {}, "passages": [{"infons": {"journal": "Biology (Basel);2026Jan23; 15 (3) . doi:10.3390/biology15030211", "year": "2026", "article-id_pmc": "PMC12896615", "type": "title", "authors": "Lee DY, Liu J, Lamichhane G, Swayze A, Zhang G, Kim TY, Egan JM, Kim Y, "}, "offset": 0, "text": "Fermented Red Ginseng Restores Age-Associated Insulin Homeostasis and Gut Microbiome Balance in Mice.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "749906", "type": "Species", "valid": true, "normalized": [749906], "database": "ncbi_taxonomy", "normalized_id": 749906, "biotype": "species", "name": "749906", "accession": null}, "text": "Gut Microbiome", "locations": [{"offset": 70, "length": 14}]}, {"id": "3", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "Mice", "locations": [{"offset": 96, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 102, "text": "Biological aging disrupts liver-gut intercommunication, resulting in the development of insulin resistance and type 2 diabetes, coupled with the imbalance of gut microbiome composition known as gut dysbiosis. Fermented red ginseng (FRG) is a renowned functional food substance showing its notable anti-inflammatory and anti-diabetic effects owing to its unique bioactive compounds known as ginsenosides. However, whether FRG could impact biological aging and age-related metabolic dysfunction is still unclear. The current study aimed to determine the health benefits of FRG in improving age-associated impaired insulin homeostasis and gut dysbiosis in 19-month-old male mice. Mice were fed with a normal chow diet (NCD) or NCD with FRG (300 mg/kg) for 14 weeks. FRG supplementation significantly improved insulin homeostasis by activating the hepatic protein kinase B (AKT) and proline-rich AKT substrate of 40 kDa (PRAS40). We also observed suppressed mRNA expression of proinflammatory cytokines and diminished inflammatory infiltrates in the liver of FRG-fed mice compared with NCD-only controls. Furthermore, alongside a decreased ratio of Firmicutes to Bacteroidetes, FRG administration enriched beneficial genera, including Muribaculaceae, Borkfalkiaceae, Parasutterella, and Clostridia vadin BB60 group, whereas FRG reduced the abundance of Erysipelotrichaceae and Dubosiella at the genus level. In summary, we suggest that FRG can be a potential anti-aging dietary supplement to manage age-driven dysregulation of insulin homeostasis and gut microbiota composition.", "sentences": [], "annotations": [{"id": "25", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "insulin resistance", "locations": [{"offset": 190, "length": 18}]}, {"id": "26", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes", "locations": [{"offset": 213, "length": 15}]}, {"id": "27", "infons": {"identifier": "749906", "type": "Species", "valid": true, "normalized": [749906], "database": "ncbi_taxonomy", "normalized_id": 749906, "biotype": "species", "name": "749906", "accession": null}, "text": "gut microbiome", "locations": [{"offset": 260, "length": 14}]}, {"id": "28", "infons": {"identifier": "MESH:D064806", "type": "Disease", "valid": true, "normalized": ["D064806"], "database": "ncbi_mesh", "normalized_id": "D064806", "biotype": "disease", "name": "Dysbiosis", "accession": "@DISEASE_Dysbiosis"}, "text": "gut dysbiosis", "locations": [{"offset": 296, "length": 13}]}, {"id": "29", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 404, "length": 12}]}, {"id": "30", "infons": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "text": "diabetic", "locations": [{"offset": 426, "length": 8}]}, {"id": "31", "infons": {"identifier": "MESH:D036145", "type": "Chemical", "valid": true, "normalized": ["D036145"], "database": "ncbi_mesh", "normalized_id": "D036145", "biotype": "chemical", "name": "Ginsenosides", "accession": "@CHEMICAL_Ginsenosides"}, "text": "ginsenosides", "locations": [{"offset": 492, "length": 12}]}, {"id": "32", "infons": {"identifier": "MESH:D008659", "type": "Disease", "valid": true, "normalized": ["D008659"], "database": "ncbi_mesh", "normalized_id": "D008659", "biotype": "disease", "name": "Metabolic Diseases", "accession": "@DISEASE_Metabolic_Diseases"}, "text": "metabolic dysfunction", "locations": [{"offset": 573, "length": 21}]}, {"id": "33", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "impaired insulin homeostasis", "locations": [{"offset": 705, "length": 28}]}, {"id": "34", "infons": {"identifier": "MESH:D064806", "type": "Disease", "valid": true, "normalized": ["D064806"], "database": "ncbi_mesh", "normalized_id": "D064806", "biotype": "disease", "name": "Dysbiosis", "accession": "@DISEASE_Dysbiosis"}, "text": "gut dysbiosis", "locations": [{"offset": 738, "length": 13}]}, {"id": "35", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 773, "length": 4}]}, {"id": "36", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "Mice", "locations": [{"offset": 779, "length": 4}]}, {"id": "37", "infons": {"identifier": "11651", "type": "Gene", "ncbi_homologene": "3785", "valid": true, "normalized": [11651], "database": "ncbi_gene", "normalized_id": 11651, "biotype": "gene", "name": "Akt1", "accession": "@GENE_AKT1"}, "text": "AKT", "locations": [{"offset": 972, "length": 3}]}, {"id": "38", "infons": {"identifier": "67605", "type": "Gene", "ncbi_homologene": "12162", "valid": true, "normalized": [67605], "database": "ncbi_gene", "normalized_id": 67605, "biotype": "gene", "name": "Akt1s1", "accession": "@GENE_AKT1S1"}, "text": "proline-rich AKT substrate of 40 kDa", "locations": [{"offset": 981, "length": 36}]}, {"id": "39", "infons": {"identifier": "67605", "type": "Gene", "ncbi_homologene": "12162", "valid": true, "normalized": [67605], "database": "ncbi_gene", "normalized_id": 67605, "biotype": "gene", "name": "Akt1s1", "accession": "@GENE_AKT1S1"}, "text": "PRAS40", "locations": [{"offset": 1019, "length": 6}]}, {"id": "40", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "proinflammatory", "locations": [{"offset": 1075, "length": 15}]}, {"id": "41", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 1116, "length": 12}]}, {"id": "42", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 1165, "length": 4}]}, {"id": "43", "infons": {"identifier": "1239", "type": "Species", "valid": true, "normalized": [1239], "database": "ncbi_taxonomy", "normalized_id": 1239, "biotype": "species", "name": "1239", "accession": null}, "text": "Firmicutes", "locations": [{"offset": 1247, "length": 10}]}, {"id": "44", "infons": {"identifier": "577310", "type": "Species", "valid": true, "normalized": [577310], "database": "ncbi_taxonomy", "normalized_id": 577310, "biotype": "species", "name": "577310", "accession": null}, "text": "Parasutterella", "locations": [{"offset": 1365, "length": 14}]}, {"id": "45", "infons": {"identifier": "186801", "type": "Species", "valid": true, "normalized": [186801], "database": "ncbi_taxonomy", "normalized_id": 186801, "biotype": "species", "name": "186801", "accession": null}, "text": "Clostridia", "locations": [{"offset": 1385, "length": 10}]}], "relations": []}], "relations": [], "pmid": 41677682, "pmcid": null, "meta": {}, "date": "2026-01-23T00:00:00Z", "journal": "Biology (Basel)", "authors": ["Lee DY", "Liu J", "Lamichhane G", "Swayze A", "Zhang G", "Kim TY", "Egan JM", "Kim Y"], "relations_display": []}, {"_id": "41688442|None", "id": "41688442", "infons": {}, "passages": [{"infons": {"journal": "Nat Commun;2026Feb13. doi:10.1038/s41467-026-69132-6", "year": "2026", "type": "title", "authors": "Shu T, Zeng X, Wang J, Jiang H, Wang Y, Zhang M, Jiang L, He B, Yang L, Liu N, Tang M, Jiang Y, Zhang L, Chen P, Xie J, Fang D, Lee KE, Chen Y, Kim J, Liu R, Ye Y, Han Y, Ma J, Zeng C, "}, "offset": 0, "text": "MG53 mediates skeletal muscle-liver cross-talk and enhances alcohol metabolism in alcoholic liver disease.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D000438", "type": "Chemical", "valid": true, "normalized": ["D000438"], "database": "ncbi_mesh", "normalized_id": "D000438", "biotype": "chemical", "name": "Alcohols", "accession": "@CHEMICAL_Alcohols"}, "text": "alcohol", "locations": [{"offset": 60, "length": 7}]}, {"id": "3", "infons": {"identifier": "MESH:D008108", "type": "Disease", "valid": true, "normalized": ["D008108"], "database": "ncbi_mesh", "normalized_id": "D008108", "biotype": "disease", "name": "Liver Diseases Alcoholic", "accession": "@DISEASE_Liver_Diseases_Alcoholic"}, "text": "alcoholic liver disease", "locations": [{"offset": 82, "length": 23}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 107, "text": "Alcoholic liver disease (ALD) remains a significant clinical challenge with limited therapeutics. It is strongly associated with sarcopenia, which further worsens the prognosis in liver cirrhosis. Zinc-deficiency is a hallmark of ALD, impairing the liver's antioxidant defenses and alcohol metabolism. Here we identify a chaperone role for MG53/TRIM72 in facilitating crosstalk between zinc and alcohol dehydrogenase (ADH) and aldehyde dehydrogenase (ALDH2), acting as a metabolic regulator of muscle-liver communication. In ALD, muscle-derived MG53 is transported to liver and mitigates liver damage. MG53 deficiency exacerbates hepatic zinc-deficiency and impairs ADH and ALDH2 activity, which are reversed by systemic administration of recombinant human MG53 (rhMG53). MG53's B-box motif coordinates zinc interaction with ADH and ALDH2, enhancing their enzymatic activity to clear toxic alcohol byproducts. We developed a bio-derived nanoparticle for co-delivery of rhMG53 and zinc, offering a promising therapeutic approach for ALD. In vivo findings are applicable to the male sex only.", "sentences": [], "annotations": [{"id": "28", "infons": {"identifier": "MESH:D008108", "type": "Disease", "valid": true, "normalized": ["D008108"], "database": "ncbi_mesh", "normalized_id": "D008108", "biotype": "disease", "name": "Liver Diseases Alcoholic", "accession": "@DISEASE_Liver_Diseases_Alcoholic"}, "text": "Alcoholic liver disease", "locations": [{"offset": 107, "length": 23}]}, {"id": "29", "infons": {"identifier": "MESH:D008108", "type": "Disease", "valid": true, "normalized": ["D008108"], "database": "ncbi_mesh", "normalized_id": "D008108", "biotype": "disease", "name": "Liver Diseases Alcoholic", "accession": "@DISEASE_Liver_Diseases_Alcoholic"}, "text": "ALD", "locations": [{"offset": 132, "length": 3}]}, {"id": "30", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 236, "length": 10}]}, {"id": "31", "infons": {"identifier": "MESH:D008103", "type": "Disease", "valid": true, "normalized": ["D008103"], "database": "ncbi_mesh", "normalized_id": "D008103", "biotype": "disease", "name": "Liver Cirrhosis", "accession": "@DISEASE_Liver_Cirrhosis"}, "text": "liver cirrhosis", "locations": [{"offset": 287, "length": 15}]}, {"id": "32", "infons": {"identifier": "MESH:C564286", "type": "Disease", "valid": true, "normalized": ["C564286"], "database": "ncbi_mesh", "normalized_id": "C564286", "biotype": "disease", "name": "Zinc Deficiency Neonatal due to Low Breast Milk Zinc", "accession": "@DISEASE_Zinc_Deficiency_Neonatal_due_to_Low_Breast_Milk_Zinc"}, "text": "Zinc-deficiency", "locations": [{"offset": 304, "length": 15}]}, {"id": "33", "infons": {"identifier": "MESH:D008108", "type": "Disease", "valid": true, "normalized": ["D008108"], "database": "ncbi_mesh", "normalized_id": "D008108", "biotype": "disease", "name": "Liver Diseases Alcoholic", "accession": "@DISEASE_Liver_Diseases_Alcoholic"}, "text": "ALD", "locations": [{"offset": 337, "length": 3}]}, {"id": "34", "infons": {"identifier": "MESH:D000438", "type": "Chemical", "valid": true, "normalized": ["D000438"], "database": "ncbi_mesh", "normalized_id": "D000438", "biotype": "chemical", "name": "Alcohols", "accession": "@CHEMICAL_Alcohols"}, "text": "alcohol", "locations": [{"offset": 389, "length": 7}]}, {"id": "35", "infons": {"identifier": "493829", "type": "Gene", "ncbi_homologene": "66924", "valid": true, "normalized": [493829], "database": "ncbi_gene", "normalized_id": 493829, "biotype": "gene", "name": "TRIM72", "accession": "@GENE_TRIM72"}, "text": "TRIM72", "locations": [{"offset": 452, "length": 6}]}, {"id": "36", "infons": {"identifier": "MESH:D015032", "type": "Chemical", "valid": true, "normalized": ["D015032"], "database": "ncbi_mesh", "normalized_id": "D015032", "biotype": "chemical", "name": "Zinc", "accession": "@CHEMICAL_Zinc"}, "text": "zinc", "locations": [{"offset": 493, "length": 4}]}, {"id": "37", "infons": {"identifier": "10327", "type": "Gene", "ncbi_homologene": "74565", "valid": true, "normalized": [10327], "database": "ncbi_gene", "normalized_id": 10327, "biotype": "gene", "name": "AKR1A1", "accession": "@GENE_AKR1A1"}, "text": "alcohol dehydrogenase", "locations": [{"offset": 502, "length": 21}]}, {"id": "38", "infons": {"identifier": "10327", "type": "Gene", "ncbi_homologene": "74565", "valid": true, "normalized": [10327], "database": "ncbi_gene", "normalized_id": 10327, "biotype": "gene", "name": "AKR1A1", "accession": "@GENE_AKR1A1"}, "text": "ADH", "locations": [{"offset": 525, "length": 3}]}, {"id": "39", "infons": {"identifier": "217", "type": "Gene", "ncbi_homologene": "55480", "valid": true, "normalized": [217], "database": "ncbi_gene", "normalized_id": 217, "biotype": "gene", "name": "ALDH2", "accession": "@GENE_ALDH2"}, "text": "ALDH2", "locations": [{"offset": 558, "length": 5}]}, {"id": "40", "infons": {"identifier": "MESH:D008108", "type": "Disease", "valid": true, "normalized": ["D008108"], "database": "ncbi_mesh", "normalized_id": "D008108", "biotype": "disease", "name": "Liver Diseases Alcoholic", "accession": "@DISEASE_Liver_Diseases_Alcoholic"}, "text": "ALD", "locations": [{"offset": 632, "length": 3}]}, {"id": "41", "infons": {"identifier": "MESH:D056486", "type": "Disease", "valid": true, "normalized": ["D056486"], "database": "ncbi_mesh", "normalized_id": "D056486", "biotype": "disease", "name": "Chemical and Drug Induced Liver Injury", "accession": "@DISEASE_Chemical_and_Drug_Induced_Liver_Injury"}, "text": "liver damage", "locations": [{"offset": 695, "length": 12}]}, {"id": "42", "infons": {"identifier": "MESH:C564286", "type": "Disease", "valid": true, "normalized": ["C564286"], "database": "ncbi_mesh", "normalized_id": "C564286", "biotype": "disease", "name": "Zinc Deficiency Neonatal due to Low Breast Milk Zinc", "accession": "@DISEASE_Zinc_Deficiency_Neonatal_due_to_Low_Breast_Milk_Zinc"}, "text": "hepatic zinc-deficiency", "locations": [{"offset": 737, "length": 23}]}, {"id": "43", "infons": {"identifier": "10327", "type": "Gene", "ncbi_homologene": "74565", "valid": true, "normalized": [10327], "database": "ncbi_gene",