: "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "23411", "type": "Gene", "valid": true, "normalized": [23411], "database": "ncbi_gene", "normalized_id": 23411, "biotype": "gene", "name": "SIRT1", "accession": "@GENE_SIRT1"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "10,21"}]}, {"id": "R6", "infons": {"score": "0.9952", "role1": {"identifier": "MESH:D010300", "type": "Disease", "valid": true, "normalized": ["D010300"], "database": "ncbi_mesh", "normalized_id": "D010300", "biotype": "disease", "name": "Parkinson Disease", "accession": "@DISEASE_Parkinson_Disease"}, "role2": {"identifier": "23411", "type": "Gene", "valid": true, "normalized": [23411], "database": "ncbi_gene", "normalized_id": 23411, "biotype": "gene", "name": "SIRT1", "accession": "@GENE_SIRT1"}, "type": "Association"}, "nodes": [{"refid": "5", "role": "19,21"}]}, {"id": "R7", "infons": {"score": "0.9866", "role1": {"identifier": "MESH:D000544", "type": "Disease", "valid": true, "normalized": ["D000544"], "database": "ncbi_mesh", "normalized_id": "D000544", "biotype": "disease", "name": "Alzheimer Disease", "accession": "@DISEASE_Alzheimer_Disease"}, "role2": {"identifier": "23411", "type": "Gene", "valid": true, "normalized": [23411], "database": "ncbi_gene", "normalized_id": 23411, "biotype": "gene", "name": "SIRT1", "accession": "@GENE_SIRT1"}, "type": "Association"}, "nodes": [{"refid": "6", "role": "17,21"}]}], "pmid": 41934491, "pmcid": null, "meta": {}, "date": "2026-04-04T00:00:00Z", "journal": "Neuromolecular Med", "authors": ["Alameen AAM", "Al-Kuraishy HM", "Al-Gareeb AI", "Alexiou A", "Papadakis M", "Faheem SA", "El-Saber Batiha G"], "relations_display": [{"name": "associate|@DISEASE_Brain_Diseases|@GENE_SIRT1"}, {"name": "associate|@DISEASE_Night_blindness_congenital_stationary|@GENE_SIRT1"}, {"name": "associate|@DISEASE_Neurodegenerative_Diseases|@GENE_SIRT1"}, {"name": "associate|@DISEASE_Cognition_Disorders|@GENE_SIRT1"}, {"name": "associate|@DISEASE_Inflammation|@GENE_SIRT1"}, {"name": "associate|@DISEASE_Parkinson_Disease|@GENE_SIRT1"}, {"name": "associate|@DISEASE_Alzheimer_Disease|@GENE_SIRT1"}]}, {"_id": "40376969|None", "id": "40376969", "infons": {}, "passages": [{"infons": {"journal": "Mol Med Rep;2025Jul; 32 (1) . doi:10.3892/mmr.2025.13562", "year": "2025", "article-id_pmc": "PMC12105454", "type": "title", "authors": "Ikeda M, Matsumoto M, Tamura M, Kobayashi M, Iida K, "}, "offset": 0, "text": "Glucose, glutamine, lactic acid and a-ketoglutarate restore metabolic disturbances and atrophic changes  in energy-deprived muscle cells.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "Glucose", "locations": [{"offset": 0, "length": 7}]}, {"id": "6", "infons": {"identifier": "MESH:D005973", "type": "Chemical", "valid": true, "normalized": ["D005973"], "database": "ncbi_mesh", "normalized_id": "D005973", "biotype": "chemical", "name": "Glutamine", "accession": "@CHEMICAL_Glutamine"}, "text": "glutamine", "locations": [{"offset": 9, "length": 9}]}, {"id": "7", "infons": {"identifier": "MESH:D019344", "type": "Chemical", "valid": true, "normalized": ["D019344"], "database": "ncbi_mesh", "normalized_id": "D019344", "biotype": "chemical", "name": "Lactic Acid", "accession": "@CHEMICAL_Lactic_Acid"}, "text": "lactic acid", "locations": [{"offset": 20, "length": 11}]}, {"id": "8", "infons": {"identifier": "MESH:D007656", "type": "Chemical", "valid": true, "normalized": ["D007656"], "database": "ncbi_mesh", "normalized_id": "D007656", "biotype": "chemical", "name": "Ketoglutaric Acids", "accession": "@CHEMICAL_Ketoglutaric_Acids"}, "text": "α‑ketoglutarate", "locations": [{"offset": 36, "length": 15}]}, {"id": "9", "infons": {"identifier": "MESH:D020966", "type": "Disease", "valid": true, "normalized": ["D020966"], "database": "ncbi_mesh", "normalized_id": "D020966", "biotype": "disease", "name": "Muscular Disorders Atrophic", "accession": "@DISEASE_Muscular_Disorders_Atrophic"}, "text": "atrophic", "locations": [{"offset": 87, "length": 8}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 138, "text": "Skeletal muscle atrophy is often triggered by catabolic conditions such as fasting, malnutrition and chronic diseases; however, the efficacy of nutritional supplementation in maintaining muscle mass and preventing muscle atrophy remains controversial. The present study aimed to compare the inhibitory effects of various nutritional substrates on starvation-induced catabolic changes and muscle cell atrophy. C2C12 muscle cells were starved for up to 24 h in medium lacking serum and main nutrients (glucose, glutamine and pyruvate). To assess the effects of exogenous substrates, the cells were incubated in starvation medium and individually supplemented with each of the following nutrients: Glucose, amino acids, fatty acids, lactate or ketone bodies. The expression of each gene and protein was analyzed by reverse transcription-quantitative PCR and western blotting, respectively. Mitochondrial activity was determined by MTT assay and cell morphology was observed by immunofluorescence staining. The results revealed that starvation for >3 h suppressed mitochondrial activity, and after 5 h of starvation, the expression levels of several metabolic genes were increased; however, the levels of most, with the exception of Scot and <i>Cpt-1b</i>, were suppressed after 24 h. Protein degradation and a decrease in protein synthesis were observed after 5 h of starvation, followed by autophagy with morphological atrophy at 24 h. Supplementation with specific substrates, with the exception of leucine, such as glucose, glutamine, lactic acid or a-ketoglutarate, attenuated the suppression of mitochondrial activity, and altered gene expression, protein degradation and myotube atrophy in starved myotubes. Furthermore, the decrease in intracellular ATP production after 24 h of starvation was reversed by restoring glycolysis in glucose-treated cells, and via an increase in mitochondrial respiration in cells treated with glutamine, lactic acid or a-ketoglutarate. In conclusion, increasing the availability of glucose, glutamine, lactic acid or a-ketoglutarate may be beneficial for countering muscle atrophy associated with inadequate nutrient intake.", "sentences": [], "annotations": [{"id": "43", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 147, "length": 14}]}, {"id": "44", "infons": {"identifier": "MESH:D044342", "type": "Disease", "valid": true, "normalized": ["D044342"], "database": "ncbi_mesh", "normalized_id": "D044342", "biotype": "disease", "name": "Malnutrition", "accession": "@DISEASE_Malnutrition"}, "text": "malnutrition", "locations": [{"offset": 222, "length": 12}]}, {"id": "45", "infons": {"identifier": "MESH:D002908", "type": "Disease", "valid": true, "normalized": ["D002908"], "database": "ncbi_mesh", "normalized_id": "D002908", "biotype": "disease", "name": "Chronic Disease", "accession": "@DISEASE_Chronic_Disease"}, "text": "chronic diseases", "locations": [{"offset": 239, "length": 16}]}, {"id": "46", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 352, "length": 14}]}, {"id": "47", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle cell atrophy", "locations": [{"offset": 526, "length": 19}]}, {"id": "48", "infons": {"identifier": "CVCL:0188", "type": "CellLine", "valid": true, "normalized": ["0188"], "database": "cvcl", "normalized_id": "0188", "biotype": "cellline", "name": "0188", "accession": null}, "text": "C2C12", "locations": [{"offset": 547, "length": 5}]}, {"id": "49", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "glucose", "locations": [{"offset": 638, "length": 7}]}, {"id": "50", "infons": {"identifier": "MESH:D005973", "type": "Chemical", "valid": true, "normalized": ["D005973"], "database": "ncbi_mesh", "normalized_id": "D005973", "biotype": "chemical", "name": "Glutamine", "accession": "@CHEMICAL_Glutamine"}, "text": "glutamine", "locations": [{"offset": 647, "length": 9}]}, {"id": "51", "infons": {"identifier": "MESH:D019289", "type": "Chemical", "valid": true, "normalized": ["D019289"], "database": "ncbi_mesh", "normalized_id": "D019289", "biotype": "chemical", "name": "Pyruvic Acid", "accession": "@CHEMICAL_Pyruvic_Acid"}, "text": "pyruvate", "locations": [{"offset": 661, "length": 8}]}, {"id": "52", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "Glucose", "locations": [{"offset": 833, "length": 7}]}, {"id": "53", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession"