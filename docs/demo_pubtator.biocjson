abase": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "23,27"}]}, {"id": "R2", "infons": {"score": "0.975", "role1": {"identifier": "MESH:C008216", "type": "Chemical", "valid": true, "normalized": ["C008216"], "database": "ncbi_mesh", "normalized_id": "C008216", "biotype": "chemical", "name": "isovaleric acid", "accession": "@CHEMICAL_isovaleric_acid"}, "role2": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "1", "role": "24,27"}]}, {"id": "R3", "infons": {"score": "0.9994", "role1": {"identifier": "MESH:D005232", "type": "Chemical", "valid": true, "normalized": ["D005232"], "database": "ncbi_mesh", "normalized_id": "D005232", "biotype": "chemical", "name": "Fatty Acids Volatile", "accession": "@CHEMICAL_Fatty_Acids_Volatile"}, "role2": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "22,27"}]}, {"id": "R4", "infons": {"score": "0.8185", "role1": {"identifier": "MESH:D012964", "type": "Chemical", "valid": true, "normalized": ["D012964"], "database": "ncbi_mesh", "normalized_id": "D012964", "biotype": "chemical", "name": "Sodium", "accession": "@CHEMICAL_Sodium"}, "role2": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "21,27"}]}], "pmid": 41398907, "pmcid": null, "meta": {}, "date": "2025-12-15T00:00:00Z", "journal": "BMC Geriatr", "authors": ["Wang Z", "Shi Z", "Song Q", "Lu W", "Sun Z", "Zang J", "Shao C"], "relations_display": [{"name": "treat|@CHEMICAL_propionic_acid|@DISEASE_Sarcopenia"}, {"name": "treat|@CHEMICAL_isovaleric_acid|@DISEASE_Sarcopenia"}, {"name": "associate|@CHEMICAL_Fatty_Acids_Volatile|@DISEASE_Sarcopenia"}, {"name": "associate|@CHEMICAL_Sodium|@DISEASE_Sarcopenia"}]}, {"_id": "41400819|None", "id": "41400819", "infons": {}, "passages": [{"infons": {"journal": "Clin Exp Nephrol;2025Dec16. doi:10.1007/s10157-025-02793-7", "year": "2025", "article-id_pmc": "7669634", "type": "title", "authors": "Mandai S, "}, "offset": 0, "text": "Circulating small extracellular vesicles in chronic kidney disease and vascular calcification: \"Tiny packages with big biological mission\".", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "chronic kidney disease", "locations": [{"offset": 44, "length": 22}]}, {"id": "3", "infons": {"identifier": "MESH:D061205", "type": "Disease", "valid": true, "normalized": ["D061205"], "database": "ncbi_mesh", "normalized_id": "D061205", "biotype": "disease", "name": "Vascular Calcification", "accession": "@DISEASE_Vascular_Calcification"}, "text": "vascular calcification", "locations": [{"offset": 71, "length": 22}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 140, "text": "Chronic kidney disease (CKD), a condition affecting over 850 million people worldwide, is a major global health issue. CKD leads to multimorbidities and disease complexity, expediting the aging process and increasing mortality rates-a phenomenon sometimes referred to as \"renal senescence.\" The leading cause of death in patients with CKD is cardiovascular disease (CVD), accounting for one-third to one-half of all deaths, in stark contrast to cancer, which is the primary cause of death in the general population. While previous studies on kidney disease have focused extensively on urinary extracellular vesicles due to their potential as non-invasive diagnostic tools and their origin from kidney cells, our research highlighs the significance of circulating small extracellular vesicles (cEVs). We demonstrated that cEVs act as key mediators in the pathological intercellular and inter-organ communication between the kidneys and vascular smooth muscle cells (VSMCs). However, the biogenesis, cargo, and biological functions of cEVs remain incompletely understood under physiological and pathological conditions, including CKD. We identified microRNA (miRNA) transcriptomic signatures encapsulated in cEVs from CKD animal models, which were validated in human CKD samples. Notably, the depletion of specific miRNAs in CKD-derived cEVs promoted osteogenic differentiation of VSMCs and the deposition of calcium-phosphate crystals in vessels. In contrast, miRNAs enriched in cEVs from healthy individuals suppress these pathological processes, acting as a safeguard. These findings and future research could pave the way for the development of diagnostic and therapeutic platforms leveraging cEVs in nephrology.", "sentences": [], "annotations": [{"id": "22", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "Chronic kidney disease", "locations": [{"offset": 140, "length": 22}]}, {"id": "23", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 164, "length": 3}]}, {"id": "24", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 259, "length": 3}]}, {"id": "25", "infons": {"identifier": "MESH:D003643", "type": "Disease", "valid": true, "normalized": ["D003643"], "database": "ncbi_mesh", "normalized_id": "D003643", "biotype": "disease", "name": "Death", "accession": "@DISEASE_Death"}, "text": "death", "locations": [{"offset": 452, "length": 5}]}, {"id": "26", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 461, "length": 8}]}, {"id": "27", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 475, "length": 3}]}, {"id": "28", "infons": {"identifier": "MESH:D002318", "type": "Disease", "valid": true, "normalized": ["D002318"], "database": "ncbi_mesh", "normalized_id": "D002318", "biotype": "disease", "name": "Cardiovascular Diseases", "accession": "@DISEASE_Cardiovascular_Diseases"}, "text": "cardiovascular disease", "locations": [{"offset": 482, "length": 22}]}, {"id": "29", "infons": {"identifier": "MESH:D002318", "type": "Disease", "valid": true, "normalized": ["D002318"], "database": "ncbi_mesh", "normalized_id": "D002318", "biotype": "disease", "name": "Cardiovascular Diseases", "accession": "@DISEASE_Cardiovascular_Diseases"}, "text": "CVD", "locations": [{"offset": 506, "length": 3}]}, {"id": "30", "infons": {"identifier": "MESH:D003643", "type": "Disease", "valid": true, "normalized": ["D003643"], "database": "ncbi_mesh", "normalized_id": "D003643", "biotype": "disease", "name": "Death", "accession": "@DISEASE_Death"}, "text": "deaths", "locations": [{"offset": 556, "length": 6}]}, {"id": "31", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 585, "length": 6}]}, {"id": "32", "infons": {"identifier": "MESH:D003643", "type": "Disease", "valid": true, "normalized": ["D003643"], "database": "ncbi_mesh", "normalized_id": "D003643", "biotype": "disease", "name": "Death", "accession": "@DISEASE_Death"}, "text": "death", "locations": [{"offset": 623, "length": 5}]}, {"id": "33", "infons": {"identifier": "MESH:D007674", "type": "Disease", "valid": true, "normalized": ["D007674"], "database": "ncbi_mesh", "normalized_id": "D007674", "biotype": "disease", "name": "Kidney Diseases", "accession": "@DISEASE_Kidney_Diseases"}, "text": "kidney disease", "locations": [{"offset": 682, "length": 14}]}, {"id": "34", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 1268, "length": 3}]}, {"id": "35", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 1356, "length": 3}]}, {"id": "36", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 1399, "length": 5}]}, {"id": "37", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 1405, "length": 3}]}, {"id": "38", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 1463, "length": 3}]}, {"id": "39", "infons": {"identifier": "MESH:C020243", "type": "Chemical", "valid": true, "normalized": ["C020243"], "database": "ncbi_mesh", "normalized_id": "C020243", "biotype": "chemical", "name": "calcium phosphate", "accession": "@CHEMICAL_calcium_phosphate"}, "text": "calcium-phosphate", "locations": [{"offset": 1547, "length": 17}]}], "relations": []}], "relations": [], "pmid": 41400819, "pmcid": null, "meta": {}, "date": "2025-12-16T00:00:00Z", "journal": "Clin Exp Nephrol", "authors": ["Mandai S"], "relations_display": []}, {"_id": "41432033|None", "id": "41432033", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Potent and durable gene modulation in heart and muscle with chemically defined lipophilic siRNAs.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 98, "text": "Small interfering RNAs (siRNAs) hold promise for treating cardiac and muscular diseases, but robust and scalable delivery remains a hurdle. While biologic-siRNA conjugates (e.g. antibodies) are in clinical development, their manufacturing is complex. Lipophilic siRNAs are readily chemically synthesized at scale and support effective heart and muscle delivery. Here, we refine siRNA chemical design for enhanced potency and durability to support clinically relevant silencing. Targeting myostatin (MSTN), a key gene in muscle-wasting, a single subcutaneous dose in mice achieved potent silencing (80% inhibition up to 6 weeks, 30% up to 14 weeks). Biweekly dosing led to over 95% MSTN reduction for half-a-year with no observed toxicity. This resulted in muscle growth, increased lean mass, and improved grip strength. Phenotypical benefits extended beyond direct target silencing, suggesting prolonged effects. The siRNA scaffold was effective across multiple muscle groups, with its modularity confirmed by three additional targets. Optimized dosing extended durability to 20 weeks without compromising phenotypic outcomes. As a proof of concept, MSTN inhibition with siRNAs successfully combated muscle wasting in an inflammatory myopathy model (cardiotoxin). These findings pave the way for long-lasting gene modulation in heart and muscle, offering new therapeutic strategies for muscular diseases.", "sentences": [], "annotations": [{"id": "11", "infons": {"identifier": "MESH:D006331", "type": "Disease", "valid": true, "normalized": ["D006331"], "database": "ncbi_mesh", "normalized_id": "D006331", "biotype": "disease", "name": "Heart Diseases", "accession": "@DISEASE_Heart_Diseases"}, "text": "cardiac and muscular diseases", "locations": [{"offset": 156, "length": 29}]}, {"id": "12", "infons": {"identifier": "17700", "type": "Gene", "ncbi_homologene": "3850", "valid": true, "normalized": [17700], "database": "ncbi_gene", "normalized_id": 17700, "biotype": "gene", "name": "Mstn", "accession": "@GENE_MSTN"}, "text": "myostatin", "locations": [{"offset": 586, "length": 9}]}, {"id": "13", "infons": {"identifier": "17700", "type": "Gene", "ncbi_homologene": "3850", "valid": true, "normalized": [17700], "database": "ncbi_gene", "normalized_id": 17700, "biotype": "gene", "name": "Mstn", "accession": "@GENE_MSTN"}, "text": "MSTN", "locations": [{"offset": 597, "length": 4}]}, {"id": "14", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle-wasting", "locations": [{"offset": 618, "length": 14}]}, {"id": "15", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 664, "length": 4}]}, {"id": "16", "infons": {"identifier": "17700", "type": "Gene", "ncbi_homologene": "3850", "valid": true, "normalized": [17700], "database": "ncbi_gene", "normalized_id": 17700, "biotype": "gene", "name": "Mstn", "accession": "@GENE_MSTN"}, "text": "MSTN", "locations": [{"offset": 779, "length": 4}]}, {"id": "17", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mesh", "normalized_id": "D064420", "biotype": "disease", "name": "Drug-Related Side Effects and Adverse Reactions", "accession": "@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions"}, "text": "toxicity", "locations": [{"offset": 827, "length": 8}]}, {"id": "18", "infons": {"identifier": "17700", "type": "Gene", "ncbi_homologene": "3850", "valid": true, "normalized": [17700], "database": "ncbi_gene", "normalized_id": 17700, "biotype": "gene", "name": "Mstn", "accession": "@GENE_MSTN"}, "text": "MSTN", "locations": [{"offset": 1248, "length": 4}]}, {"id": "19", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle wasting", "locations": [{"offset": 1298, "length": 14}]}, {"id": "20", "infons": {"identifier": "MESH:D009220", "type": "Disease", "valid": true, "normalized": ["D009220"], "database": "ncbi_mesh", "normalized_id": "D009220", "biotype": "disease", "name": "Myositis", "accession": "@DISEASE_Myositis"}, "text": "inflammatory myopathy", "locations": [{"offset": 1319, "length": 21}]}, {"id": "21", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscular diseases", "locations": [{"offset": 1484, "length": 17}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9983", "role1": {"identifier": "MESH:D009220", "type": "Disease", "valid": true, "normalized": ["D009220"], "database": "ncbi_mesh", "normalized_id": "D009220", "biotype": "disease", "name": "Myositis", "accession": "@DISEASE_Myositis"}, "role2": {"identifier": "17700", "type": "Gene", "valid": true, "normalized": [17700], "database": "ncbi_gene", "normalized_id": 17700, "biotype": "gene", "name": "Mstn", "accession": "@GENE_MSTN"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "9,7"}]}, {"id": "R2", "infons": {"score": "0.9997", "role1": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "role2": {"identifier": "17700", "type": "Gene", "valid": true, "normalized": [17700], "database": "ncbi_gene", "normalized_id": 17700, "biotype": "gene", "name": "Mstn", "accession": "@GENE_MSTN"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "8,7"}]}], "pmid": 41432033, "pmcid": null, "meta": {}, "date": "2025-11-26T00:00:00Z", "journal": "Nucleic Acids Res", "authors": ["Fakih HH", "Lochmann C", "Gagnon R", "Summers A", "Caiazzi J", "Buchwald JE", "Tang Q", "Maru B", "Hildebrand SR", "Abideen MZUI", "Furgal RC", "Gross KY", "Yang YS", "Cooper D", "Monopoli KR", "Echeverria D", "Shim JH", "Yamada K", "Alterman JF", "Khvorova A"], "relations_display": [{"name": "associate|@DISEASE_Myositis|@GENE_MSTN"}, {"name": "associate|@DISEASE_Muscular_Atrophy|@GENE_MSTN"}]}, {"_id": "41437258|None", "id": "41437258", "infons": {}, "passages": [{"infons": {"journal": "J Transl Med;2025Dec23. doi:10.1186/s12967-025-07561-5", "year": "2025", "type": "title", "authors": "Ahmadi F, Hasanzadeh E, Mellati A, Fattahi R, Khalatbary AR, Ebrahimnejad P, Karimi N, Abasi M, "}, "offset": 0, "text": "Multifunctional electrospun PCL/CNT/EGCG nerve conduits with a collagen hydrogel for enhanced sciatic nerve regeneration.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "CNT", "locations": [{"offset": 32, "length": 3}]}, {"id": "3", "infons": {"identifier": "MESH:C045651", "type": "Chemical", "valid": true, "normalized": ["C045651"], "database": "ncbi_mesh", "normalized_id": "C045651", "biotype": "chemical", "name": "epigallocatechin gallate", "accession": "@CHEMICAL_epigallocatechin_gallate"}, "text": "EGCG", "locations": [{"offset": 36, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 122, "text": "", "sentences": [], "annotations": [], "relations": []}], "relations": [], "pmid": 41437258, "pmcid": null, "meta": {}, "date": "2025-12-23T00:00:00Z", "journal": "J Transl Med", "authors": ["Ahmadi F", "Hasanzadeh E", "Mellati A", "Fattahi R", "Khalatbary AR", "Ebrahimnejad P", "Karimi N", "Abasi M"], "relations_display": []}, {"_id": "41440470|None", "id": "41440470", "infons": {}, "passages": [{"infons": {"journal": "Clin Pract;2025Nov24; 15 (12) . doi:10.3390/clinpract15120219", "year": "2025", "article-id_pmc": "PMC12731771", "type": "title", "authors": "Dawi J, Misakyan Y, Gonzalez E, Kafaja K, Affa S, Tumanyan K, Qumsieh K, Venketaraman V, "}, "offset": 0, "text": "ECM Remodeling in Direct Inguinal Hernia: The Role of Aging, Oxidative Stress, and Antioxidants Defenses.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D006552", "type": "Disease", "valid": true, "normalized": ["D006552"], "database": "ncbi_mesh", "normalized_id": "D006552", "biotype": "disease", "name": "Hernia Inguinal", "accession": "@DISEASE_Hernia_Inguinal"}, "text": "Inguinal Hernia", "locations": [{"offset": 25, "length": 15}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 106, "text": "Inguinal hernia represents a multifactorial condition driven by extracellular matrix (ECM) dysregulation, collagen imbalance, and oxidative stress. Across studies, a consistent reduction in the collagen I:III ratio, coupled with altered expression of matrix metalloproteinases (MMPs) and tissue inhibitors of metalloproteinases (TIMPs), underpins weakened fascia and hernia susceptibility. Aging further impairs ECM remodeling through fibroblast senescence, cross-linking deficits, and elastic fiber attrition, while oxidative stress and inflammation amplify tissue degradation and impair repair mechanisms. Evidence from clinical and experimental studies underscores the interplay between surgical technique, mesh choice, redox balance, and recurrence risk. Understanding the combined impact of aging and oxidative stress provides a mechanistic framework for targeted therapeutic and surgical strategies aimed at preventing hernia development and recurrence.", "sentences": [], "annotations": [{"id": "6", "infons": {"identifier": "MESH:D006552", "type": "Disease", "valid": true, "normalized": ["D006552"], "database": "ncbi_mesh", "normalized_id": "D006552", "biotype": "disease", "name": "Hernia Inguinal", "accession": "@DISEASE_Hernia_Inguinal"}, "text": "Inguinal hernia", "locations": [{"offset": 106, "length": 15}]}, {"id": "7", "infons": {"identifier": "MESH:D006547", "type": "Disease", "valid": true, "normalized": ["D006547"], "database": "ncbi_mesh", "normalized_id": "D006547", "biotype": "disease", "name": "Hernia", "accession": "@DISEASE_Hernia"}, "text": "hernia", "locations": [{"offset": 473, "length": 6}]}, {"id": "8", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 644, "length": 12}]}, {"id": "9", "infons": {"identifier": "MESH:D006547", "type": "Disease", "valid": true, "normalized": ["D006547"], "database": "ncbi_mesh", "normalized_id": "D006547", "biotype": "disease", "name": "Hernia", "accession": "@DISEASE_Hernia"}, "text": "hernia", "locations": [{"offset": 1031, "length": 6}]}], "relations": []}], "relations": [], "pmid": 41440470, "pmcid": null, "meta": {}, "date": "2025-11-24T00:00:00Z", "journal": "Clin Pract", "authors": ["Dawi J", "Misakyan Y", "Gonzalez E", "Kafaja K", "Affa S", "Tumanyan K", "Qumsieh K", "Venketaraman V"], "relations_display": []}, {"_id": "41441183|None", "id": "41441183", "infons": {}, "passages": [{"infons": {"journal": "Pathophysiology;2025Dec17; 32 (4) . doi:10.3390/pathophysiology32040070", "year": "2025", "article-id_pmc": "PMC12735890", "type": "title", "authors": "Greco G, Petrelli A, Fischetti F, Cataldi S, "}, "offset": 0, "text": "Lifestyle-Based Approaches to Cancer Prevention and Treatment: Diet, Physical Activity, and Integrative Strategies.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "Cancer", "locations": [{"offset": 30, "length": 6}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 116, "text": "Cancer remains a leading global cause of morbidity and mortality. Modifiable lifestyle factors, including avoidance of tobacco use and excessive ultraviolet radiation, healthy dietary patterns, regular physical activity, and weight management, play key roles in prevention and care. This narrative review synthesizes evidence on lifestyle-based interventions influencing cancer risk, treatment tolerance, and survivorship. A literature search was conducted in PubMed and Scopus, supplemented by manual screening via Google Scholar. The time frame (2001-2025) was selected to reflect evidence produced within the modern era of molecular oncology and contemporary lifestyle medicine research. Eligible publications addressed carcinogen exposure (tobacco, alcohol, ultraviolet radiation), diet and nutritional strategies, physical activity, sedentary behavior, obesity, metabolic health, complementary therapies, and cancer outcomes. Evidence indicates that reducing exposure to tobacco and ultraviolet radiation remains central to cancer prevention. Adherence to predominantly plant-based diets, regular physical activity, and maintenance of healthy body weight are consistently associated with lower incidence of several cancers, including breast, colorectal, and liver cancer. Nutritional strategies such as caloric restriction, ketogenic diets, and fasting-mimicking diets show promise in improving treatment efficacy and quality of life. Complementary and mind-body therapies may alleviate treatment-related symptoms, although high-quality evidence on long-term safety and effectiveness is limited. Integrating lifestyle medicine into oncology offers a cost-effective, sustainable strategy to reduce cancer burden and enhance survivorship. Comprehensive programs combining carcinogen avoidance, dietary regulation, structured exercise, and effective radiation risk mitigation may extend healthspan, improve treatment tolerance, and help prevent recurrence.", "sentences": [], "annotations": [{"id": "14", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "Cancer", "locations": [{"offset": 116, "length": 6}]}, {"id": "15", "infons": {"identifier": "4097", "type": "Species", "valid": true, "normalized": [4097], "database": "ncbi_taxonomy", "normalized_id": 4097, "biotype": "species", "name": "4097", "accession": null}, "text": "tobacco", "locations": [{"offset": 235, "length": 7}]}, {"id": "16", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 487, "length": 6}]}, {"id": "17", "infons": {"identifier": "4097", "type": "Species", "valid": true, "normalized": [4097], "database": "ncbi_taxonomy", "normalized_id": 4097, "biotype": "species", "name": "4097", "accession": null}, "text": "tobacco", "locations": [{"offset": 860, "length": 7}]}, {"id": "18", "infons": {"identifier": "MESH:D000438", "type": "Chemical", "valid": true, "normalized": ["D000438"], "database": "ncbi_mesh", "normalized_id": "D000438", "biotype": "chemical", "name": "Alcohols", "accession": "@CHEMICAL_Alcohols"}, "text": "alcohol", "locations": [{"offset": 869, "length": 7}]}, {"id": "19", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 974, "length": 7}]}, {"id": "20", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 1030, "length": 6}]}, {"id": "21", "infons": {"identifier": "4097", "type": "Species", "valid": true, "normalized": [4097], "database": "ncbi_taxonomy", "normalized_id": 4097, "biotype": "species", "name": "4097", "accession": null}, "text": "tobacco", "locations": [{"offset": 1092, "length": 7}]}, {"id": "22", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 1145, "length": 6}]}, {"id": "23", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancers", "locations": [{"offset": 1336, "length": 7}]}, {"id": "24", "infons": {"identifier": "MESH:D001943", "type": "Disease", "valid": true, "normalized": ["D001943"], "database": "ncbi_mesh", "normalized_id": "D001943", "biotype": "disease", "name": "Breast Neoplasms", "accession": "@DISEASE_Breast_Neoplasms"}, "text": "breast, colorectal, and liver cancer", "locations": [{"offset": 1355, "length": 36}]}, {"id": "25", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 1818, "length": 6}]}], "relations": []}], "relations": [], "pmid": 41441183, "pmcid": null, "meta": {}, "date": "2025-12-17T00:00:00Z", "journal": "Pathophysiology", "authors": ["Greco G", "Petrelli A", "Fischetti F", "Cataldi S"], "relations_display": []}, {"_id": "41444954|None", "id": "41444954", "infons": {}, "passages": [{"infons": {"journal": "J Cardiothorac Surg;2025Dec24. doi:10.1186/s13019-025-03776-1", "year": "2025", "type": "title", "authors": "He Y, He L, Zhang Y, Shen C, "}, "offset": 0, "text": "The diagnostic value of serum Cystatin C in differentiating malignant from benign pulmonary nodules: a retrospective cohort study.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "1471", "type": "Gene", "ncbi_homologene": "78", "valid": true, "normalized": [1471], "database": "ncbi_gene", "normalized_id": 1471, "biotype": "gene", "name": "CST3", "accession": "@GENE_CST3"}, "text": "Cystatin C", "locations": [{"offset": 30, "length": 10}]}, {"id": "3", "infons": {"identifier": "MESH:D055613", "type": "Disease", "valid": true, "normalized": ["D055613"], "database": "ncbi_mesh", "normalized_id": "D055613", "biotype": "disease", "name": "Multiple Pulmonary Nodules", "accession": "@DISEASE_Multiple_Pulmonary_Nodules"}, "text": "pulmonary nodules", "locations": [{"offset": 82, "length": 17}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 131, "text": "", "sentences": [], "annotations": [], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9961", "role1": {"identifier": "MESH:D055613", "type": "Disease", "valid": true, "normalized": ["D055613"], "database": "ncbi_mesh", "normalized_id": "D055613", "biotype": "disease", "name": "Multiple Pulmonary Nodules", "accession": "@DISEASE_Multiple_Pulmonary_Nodules"}, "role2": {"identifier": "1471", "type": "Gene", "valid": true, "normalized": [1471], "database": "ncbi_gene", "normalized_id": 1471, "biotype": "gene", "name": "CST3", "accession": "@GENE_CST3"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "1,0"}]}], "pmid": 41444954, "pmcid": null, "meta": {}, "date": "2025-12-24T00:00:00Z", "journal": "J Cardiothorac Surg", "authors": ["He Y", "He L", "Zhang Y", "Shen C"], "relations_display": [{"name": "associate|@DISEASE_Multiple_Pulmonary_Nodules|@GENE_CST3"}]}, {"_id": "41451409|None", "id": "41451409", "infons": {}, "passages": [{"infons": {"journal": "RSC Med Chem;2025Dec24. doi:10.1039/d5md00760g", "year": "2025", "article-id_pmc": "PMC12728356", "type": "title", "authors": "Mandal S, Choudhary R, Konkimalla VB, "}, "offset": 0, "text": "Stereoselective design of amino acid bioconjugates: targeting strategies and physicochemical optimization.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "amino acid", "locations": [{"offset": 26, "length": 10}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 107, "text": "Amino acid conjugates are progressively becoming popular as a potent tactic to enhance the pharmacological efficacy of drugs, especially in the areas of cancer and antimicrobial therapy. By taking advantage of the intrinsic biological attributes of amino acids, their conjugates facilitate drug stability, selective accumulation, and enhanced therapeutic efficacies. In particular, the structural analogy of amino acids to physiological substrates enables these conjugates to use solute carrier transporters, commonly overexpressed in tumour cells, which allow for targeted and effective drug delivery. This review considers how amino acid properties like chirality, hydrophobicity and steric bulk can be modulated to maximize drug conjugates. We emphasize important design aspects, such as selection of linkers and coupling reagents, and how these have an impact on drug release and biodistribution. Specific focus is given to d-amino acid, which increases proteolytic stability and bioactivity for both anticancer and antimicrobial uses, and to l-amino acid, which is responsible for receptor recognition, metabolic compatibility and amino acid decorated nanoparticle formulation. The existing drawbacks of antibody-drug conjugates (ADCs) and peptide-drug conjugates (PDCs) are immunogenicity, enzymatic degradation and poor tissue penetration. Amino acid conjugates provide a strong rationale with higher chemical versatility and potential for better pharmacokinetics and less toxicity. By harnessing the insights from chemistry, transporter biology and therapeutic design, this review presents a strategy for the creation of next-generation amino acid conjugates that bridge molecular accuracy to clinical utility.", "sentences": [], "annotations": [{"id": "16", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "Amino acid", "locations": [{"offset": 107, "length": 10}]}, {"id": "17", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 260, "length": 6}]}, {"id": "18", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "amino", "locations": [{"offset": 356, "length": 5}]}, {"id": "19", "infons": {"identifier": "MESH:D000143", "type": "Chemical", "valid": true, "normalized": ["D000143"], "database": "ncbi_mesh", "normalized_id": "D000143", "biotype": "chemical", "name": "Acids", "accession": "@CHEMICAL_Acids"}, "text": "acids", "locations": [{"offset": 362, "length": 5}]}, {"id": "20", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "amino", "locations": [{"offset": 515, "length": 5}]}, {"id": "21", "infons": {"identifier": "MESH:D000143", "type": "Chemical", "valid": true, "normalized": ["D000143"], "database": "ncbi_mesh", "normalized_id": "D000143", "biotype": "chemical", "name": "Acids", "accession": "@CHEMICAL_Acids"}, "text": "acids", "locations": [{"offset": 521, "length": 5}]}, {"id": "22", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "tumour", "locations": [{"offset": 642, "length": 6}]}, {"id": "23", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "amino acid", "locations": [{"offset": 736, "length": 10}]}, {"id": "24", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "d-amino acid", "locations": [{"offset": 1035, "length": 12}]}, {"id": "25", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "l-amino acid", "locations": [{"offset": 1154, "length": 12}]}, {"id": "26", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "amino acid", "locations": [{"offset": 1243, "length": 10}]}, {"id": "27", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "Amino acid", "locations": [{"offset": 1454, "length": 10}]}, {"id": "28", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mesh", "normalized_id": "D064420", "biotype": "disease", "name": "Drug-Related Side Effects and Adverse Reactions", "accession": "@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions"}, "text": "toxicity", "locations": [{"offset": 1587, "length": 8}]}, {"id": "29", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "amino acid", "locations": [{"offset": 1752, "length": 10}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9858", "role1": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "role2": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "14,7"}]}], "pmid": 41451409, "pmcid": null, "meta": {}, "date": "2025-12-24T00:00:00Z", "journal": "RSC Med Chem", "authors": ["Mandal S", "Choudhary R", "Konkimalla VB"], "relations_display": [{"name": "treat|@CHEMICAL_Amino_Acids|@DISEASE_Neoplasms"}]}, {"_id": "41460648|None", "id": "41460648", "infons": {}, "passages": [{"infons": {"journal": "FASEB J;2026Jan15; 40 (1) 71333. doi:10.1096/fj.202502975R", "year": "2026", "article-id_pmc": "PMC12747219", "type": "title", "authors": "Aomura D, Nimura T, Yamaka K, Yamada Y, Harada M, Nakajima T, Kimura T, Hashimoto K, Kanno H, Yanagita M, Gonzalez FJ, Tanaka N, Kamijo Y, "}, "offset": 0, "text": "Proximal Tubule-Specific Genetic Deficiency of PPARalpha Worsens Systemic Lipid and Glucose Metabolism During Fasting.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:D018901", "type": "Disease", "valid": true, "normalized": ["D018901"], "database": "ncbi_mesh", "normalized_id": "D018901", "biotype": "disease", "name": "Peroxisomal Disorders", "accession": "@DISEASE_Peroxisomal_Disorders"}, "text": "of PPARalpha", "locations": [{"offset": 44, "length": 12}]}, {"id": "4", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "Lipid", "locations": [{"offset": 74, "length": 5}]}, {"id": "5", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "Glucose", "locations": [{"offset": 84, "length": 7}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 119, "text": "The proximal tubule (PT) of the kidney is a highly metabolic organ that regulates systemic homeostasis through ketogenesis and gluconeogenesis. Peroxisome proliferator-activated receptor alpha (PPARalpha), a nuclear receptor controlling fatty acid oxidation (FAO) and homeostasis, is expressed in the PT and is activated by fasting. Although the activation of systemic PPARalpha is essential for renal and systemic energy metabolism, the role of PPARalpha in PT has not been established. In this study, kidney PT-specific PPARalpha knockout mice (Ppara KPT) were generated, and the metabolic changes caused by 48 h of fasting were compared between Ppara KPT mice and controls. In Ppara KPT mice, renal FAO and ketogenesis were severely impaired, leading to lipid accumulation in the kidney after 48 h of fasting. The increase in the renal expression of gluconeogenesis-associated genes due to fasting was insufficient in Ppara KPT mice, causing a decrease in serum glucose levels and liver glycogen content. Fasting caused hepatic micro-steatosis and significantly increased the expression of genes linked to FAO and ketogenesis in the liver of Ppara KPT mice, as well as those associated with lipolysis in the white adipose tissue. These activities likely compensate for the impaired kidney FAO and ketogenesis in Ppara KPT mice and show that PPARalpha in PT regulates renal and systemic lipid and glucose metabolism during fasting. PPARalpha in PT may be a critical component in systemic lipid and glucose homeostasis during fasting.", "sentences": [], "annotations": [{"id": "34", "infons": {"identifier": "19013", "type": "Gene", "ncbi_homologene": "21047", "valid": true, "normalized": [19013], "database": "ncbi_gene", "normalized_id": 19013, "biotype": "gene", "name": "Ppara", "accession": "@GENE_PPARA"}, "text": "Peroxisome proliferator-activated receptor alpha", "locations": [{"offset": 263, "length": 48}]}, {"id": "35", "infons": {"identifier": "19013", "type": "Gene", "ncbi_homologene": "21047", "valid": true, "normalized": [19013], "database": "ncbi_gene", "normalized_id": 19013, "biotype": "gene", "name": "Ppara", "accession": "@GENE_PPARA"}, "text": "PPARalpha", "locations": [{"offset": 313, "length": 9}]}, {"id": "36", "infons": {"identifier": "MESH:D005227", "type": "Chemical", "valid": true, "normalized": ["D005227"], "database": "ncbi_mesh", "normalized_id": "D005227", "biotype": "chemical", "name": "Fatty Acids", "accession": "@CHEMICAL_Fatty_Acids"}, "text": "fatty acid", "locations": [{"offset": 356, "length": 10}]}, {"id": "37", "infons": {"identifier": "19013", "type": "Gene", "ncbi_homologene": "21047", "valid": true, "normalized": [19013], "database": "ncbi_gene", "normalized_id": 19013, "biotype": "gene", "name": "Ppara", "accession": "@GENE_PPARA"}, "text": "PPARalpha", "locations": [{"offset": 488, "length": 9}]}, {"id": "38", "infons": {"identifier": "MESH:D018901", "type": "Disease", "valid": true, "normalized": ["D018901"], "database": "ncbi_mesh", "normalized_id": "D018901", "biotype": "disease", "name": "Peroxisomal Disorders", "accession": "@DISEASE_Peroxisomal_Disorders"}, "text": "of PPARalpha", "locations": [{"offset": 562, "length": 12}]}, {"id": "39", "infons": {"identifier": "19013", "type": "Gene", "ncbi_homologene": "21047", "valid": true, "normalized": [19013], "database": "ncbi_gene", "normalized_id": 19013, "biotype": "gene", "name": "Ppara", "accession": "@GENE_PPARA"}, "text": "PPARalpha", "locations": [{"offset": 641, "length": 9}]}, {"id": "40", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 660, "length": 4}]}, {"id": "41", "infons": {"identifier": "19013", "type": "Gene", "ncbi_homologene": "21047", "valid": true, "normalized": [19013], "database": "ncbi_gene", "normalized_id": 19013, "biotype": "gene", "name": "Ppara", "accession": "@GENE_PPARA"}, "text": "Ppara", "locations": [{"offset": 666, "length": 5}]}, {"id": "42", "infons": {"identifier": "19013", "type": "Gene", "ncbi_homologene": "21047", "valid": true, "normalized": [19013], "database": "ncbi_gene", "normalized_id": 19013, "biotype": "gene", "name": "Ppara", "accession": "@GENE_PPARA"}, "text": "Ppara", "locations": [{"offset": 767, "length": 5}]}, {"id": "43", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession"