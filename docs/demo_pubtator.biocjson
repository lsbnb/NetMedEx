uropein aglycone", "accession": "@CHEMICAL_oleuropein_aglycone"}, "role2": {"identifier": "5563", "type": "Gene", "valid": true, "normalized": [5563], "database": "ncbi_gene", "normalized_id": 5563, "biotype": "gene", "name": "PRKAA2", "accession": "@GENE_PRKAA2"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "7", "role": "26,23"}]}], "pmid": 41257461, "pmcid": null, "meta": {}, "date": "2025-11-01T00:00:00Z", "journal": "Biofactors", "authors": ["Polacchini G", "Venerando A", "Bigot A", "Colitti M"], "relations_display": [{"name": "negative_correlate|@CHEMICAL_oleuropein_aglycone|@CHEMICAL_Reactive_Oxygen_Species"}, {"name": "negative_correlate|@CHEMICAL_oleuropein_aglycone|@CHEMICAL_Hydrogen_Peroxide"}, {"name": "positive_correlate|@CHEMICAL_oleuropein_aglycone|@GENE_SESN2"}, {"name": "positive_correlate|@CHEMICAL_Hydrogen_Peroxide|@CHEMICAL_Reactive_Oxygen_Species"}, {"name": "positive_correlate|@CHEMICAL_oleuropein_aglycone|@GENE_FOXO3"}, {"name": "negative_correlate|@CHEMICAL_oleuropein_aglycone|@CHEMICAL_5_bromo_4_chloro_3_indolyl_beta_galactoside"}, {"name": "positive_correlate|@CHEMICAL_oleuropein_aglycone|@GENE_SESN3"}, {"name": "positive_correlate|@CHEMICAL_oleuropein_aglycone|@GENE_PRKAA2"}]}, {"_id": "41277013|None", "id": "41277013", "infons": {}, "passages": [{"infons": {"journal": "J Extracell Vesicles;2025Nov; 14 (11) 70205. doi:10.1002/jev2.70205", "year": "2025", "article-id_pmc": "PMC12641061", "type": "title", "authors": "Fu PJ, Luo Y, Zheng SY, Ma ZR, Xiao WF, Li H, Li YS, "}, "offset": 0, "text": "The Role of Extracellular Vesicles in Musculoskeletal Diseases.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "Musculoskeletal Diseases", "locations": [{"offset": 38, "length": 24}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 64, "text": "Extracellular Vesicles (EVs), nanoscale membrane-bound cell-released structures, are vital for intercellular communication and material transport. Their role in musculoskeletal health and diseases has recently drawn significant attention. This review focuses on the latest EV research in musculoskeletal diseases, including their roles in disease progression and potential as biomarkers and therapies. Musculoskeletal disorders are the third-leading cause of global disability-adjusted life-years among adolescents and young adults. Current treatments face issues like limited tissue regeneration and poor drug targeting. With their natural messenger function and low immunogenicity, EVs have become a research focus. However, their action mechanisms in the musculoskeletal system remain un-systematically understood. This paper reviews EVs' role in musculoskeletal diseases. It covers classification, biogenesis, release, internalization, cargo and their involvement in muscle cell processes, joint diseases, bone metabolism and disc degeneration. It also explores EVs' role in musculoskeletal crosstalk and their potential as therapeutic agents and drug carriers through engineering with biomaterials. Future research should delve deeper into EV action mechanisms for better treatments. Overall, while EVs offer new treatment strategies for musculoskeletal diseases, more research is needed to overcome technical and clinical barriers.", "sentences": [], "annotations": [{"id": "8", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "musculoskeletal diseases", "locations": [{"offset": 352, "length": 24}]}, {"id": "9", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "Musculoskeletal disorders", "locations": [{"offset": 466, "length": 25}]}, {"id": "10", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "musculoskeletal diseases", "locations": [{"offset": 914, "length": 24}]}, {"id": "11", "infons": {"identifier": "MESH:D007592", "type": "Disease", "valid": true, "normalized": ["D007592"], "database": "ncbi_mesh", "normalized_id": "D007592", "biotype": "disease", "name": "Joint Diseases", "accession": "@DISEASE_Joint_Diseases"}, "text": "joint diseases", "locations": [{"offset": 1058, "length": 14}]}, {"id": "12", "infons": {"identifier": "MESH:D055959", "type": "Disease", "valid": true, "normalized": ["D055959"], "database": "ncbi_mesh", "normalized_id": "D055959", "biotype": "disease", "name": "Intervertebral Disc Degeneration", "accession": "@DISEASE_Intervertebral_Disc_Degeneration"}, "text": "disc degeneration", "locations": [{"offset": 1094, "length": 17}]}, {"id": "13", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "musculoskeletal diseases", "locations": [{"offset": 1407, "length": 24}]}], "relations": []}], "relations": [], "pmid": 41277013, "pmcid": null, "meta": {}, "date": "2025-11-01T00:00:00Z", "journal": "J Extracell Vesicles", "authors": ["Fu PJ", "Luo Y", "Zheng SY", "Ma ZR", "Xiao WF", "Li H", "Li YS"], "relations_display": []}, {"_id": "41277713|None", "id": "41277713", "infons": {}, "passages": [{"infons": {"journal": "Physiol Rep;2025Nov; 13 (22) 70677. doi:10.14814/phy2.70677", "year": "2025", "article-id_pmc": "PMC12641285", "type": "title", "authors": "Nariyama M, Ohnuki Y, Suita K, Ishikawa M, Matsubara R, Matsuo I, Mitsubayashi T, Mototani Y, Ito A, Abe M, Hayakawa Y, Nomura T, Wada S, Asada Y, Okumura S, "}, "offset": 0, "text": "Transcription factor MITF regulates masseter muscle growth and development.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "17342", "type": "Gene", "ncbi_homologene": "4892", "valid": true, "normalized": [17342], "database": "ncbi_gene", "normalized_id": 17342, "biotype": "gene", "name": "Mitf", "accession": "@GENE_MITF"}, "text": "MITF", "locations": [{"offset": 21, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 76, "text": "The microphthalmic mouse with a mutation at the locus of the microphthalmia-associated transcriptional factor (MITF) gene exhibits masticatory dysfunction due to impaired masseter muscle development and needs to be fed with powdered diet. However, the effects of MITF mutation on masseter muscle remain poorly understood. Here, we show that masseter muscle mass is markedly decreased in MITF-mutant mice (mi/mi), in contrast to the corresponding tibialis anterior and soleus muscles. The area of fibrosis and degree of myocyte apoptosis were strikingly increased in the masseter muscle of mi/mi. The expression of muscle-specific microRNAs (miR-1, miR-206, and miR-133a), which are necessary for proper skeletal muscle development and function, was strongly suppressed in the masseter muscle of mi/mi during development. In addition, the regulation of reactive oxygen species production, calcium homeostasis via sarcoendoplasmic reticulum calcium transport and autophagic activity, which are important for maintaining skeletal muscle mass and function, were all altered in the masseter muscle of mi/mi. These results indicate that MITF is required for masseter muscle growth and development.", "sentences": [], "annotations": [{"id": "16", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "microphthalmic", "locations": [{"offset": 80, "length": 14}]}, {"id": "17", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 95, "length": 5}]}, {"id": "18", "infons": {"identifier": "17342", "type": "Gene", "ncbi_homologene": "4892", "valid": true, "normalized": [17342], "database": "ncbi_gene", "normalized_id": 17342, "biotype": "gene", "name": "Mitf", "accession": "@GENE_MITF"}, "text": "microphthalmia-associated transcriptional factor", "locations": [{"offset": 137, "length": 48}]}, {"id": "19", "infons": {"identifier": "17342", "type": "Gene", "ncbi_homologene": "4892", "valid": true, "normalized": [17342], "database": "ncbi_gene", "normalized_id": 17342, "biotype": "gene", "name": "Mitf", "accession": "@GENE_MITF"}, "text": "MITF", "locations": [{"offset": 187, "length": 4}]}, {"id": "20", "infons": {"identifier": "MESH:C563600", "type": "Disease", "valid": true, "normalized": ["C563600"], "database": "ncbi_mesh", "normalized_id": "C563600", "biotype": "disease", "name": "Masticatory Muscles Hypertrophy of", "accession": "@DISEASE_Masticatory_Muscles_Hypertrophy_of"}, "text": "masticatory dysfunction", "locations": [{"offset": 207, "length": 23}]}, {"id": "21", "infons": {"identifier": "17342", "type": "Gene", "ncbi_homologene": "4892", "valid": true, "normalized": [17342], "database": "ncbi_gene", "normalized_id": 17342, "biotype": "gene", "name": "Mitf", "accession": "@GENE_MITF"}, "text": "MITF", "locations": [{"offset": 339, "length": 4}]}, {"id": "22", "infons": {"identifier": "17342", "type": "Gene", "ncbi_homologene": "4892", "valid": true, "normalized": [17342], "database": "ncbi_gene", "normalized_id": 17342, "biotype": "gene", "name": "Mitf", "accession": "@GENE_MITF"}, "text": "MITF", "locations": [{"offset": 463, "length": 4}]}, {"id": "23", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 475, "length": 4}]}, {"id": "24", "infons": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "text": "fibrosis", "locations": [{"offset": 572, "length": 8}]}, {"id": "25", "infons": {"identifier": "387202", "type": "Gene", "valid": true, "normalized": [387202], "database": "ncbi_gene", "normalized_id": 387202, "biotype": "gene", "name": "Mir206", "accession": "@GENE_MIR206"}, "text": "miR-206", "locations": [{"offset": 724, "length": 7}]}, {"id": "26", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "reactive oxygen species", "locations": [{"offset": 928, "length": 23}]}, {"id": "27", "infons": {"identifier": "MESH:D002118", "type": "Chemical", "valid": true, "normalized": ["D002118"], "database": "ncbi_mesh", "normalized_id": "D002118", "biotype": "chemical", "name": "Calcium", "accession": "@CHEMICAL_Calcium"}, "text": "calcium", "locations": [{"offset": 964, "length": 7}]}, {"id": "28", "infons": {"identifier": "MESH:D002118", "type": "Chemical", "valid": true, "normalized": ["D002118"], "database": "ncbi_mesh", "normalized_id": "D002118", "biotype": "chemical", "name": "Calcium", "accession": "@CHEMICAL_Calcium"}, "text": "calcium", "locations": [{"offset": 1015, "length": 7}]}, {"id": "29", "infons": {"identifier": "17342", "type": "Gene", "ncbi_homologene": "4892", "valid": true, "normalized": [17342], "database": "ncbi_gene", "normalized_id": 17342, "biotype": "gene", "name": "Mitf", "accession": "@GENE_MITF"}, "text": "MITF", "locations": [{"offset": 1207, "length": 4}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9989", "role1": {"identifier": "MESH:C563600", "type": "Disease", "valid": true, "normalized": ["C563600"], "database": "ncbi_mesh", "normalized_id": "C563600", "biotype": "disease", "name": "Masticatory Muscles Hypertrophy of", "accession": "@DISEASE_Masticatory_Muscles_Hypertrophy_of"}, "role2": {"identifier": "17342", "type": "Gene", "valid": true, "normalized": [17342], "database": "ncbi_gene", "normalized_id": 17342, "biotype": "gene", "name": "Mitf", "accession": "@GENE_MITF"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "5,14"}]}], "pmid": 41277713, "pmcid": null, "meta": {}, "date": "2025-11-01T00:00:00Z", "journal": "Physiol Rep", "authors": ["Nariyama M", "Ohnuki Y", "Suita K", "Ishikawa M", "Matsubara R", "Matsuo I", "Mitsubayashi T", "Mototani Y", "Ito A", "Abe M", "Hayakawa Y", "Nomura T", "Wada S", "Asada Y", "Okumura S"], "relations_display": [{"name": "associate|@DISEASE_Masticatory_Muscles_Hypertrophy_of|@GENE_MITF"}]}, {"_id": "41294420|None", "id": "41294420", "infons": {}, "passages": [{"infons": {"journal": "Biomimetics (Basel);2025Nov06; 10 (11) . doi:10.3390/biomimetics10110748", "year": "2025", "article-id_pmc": "PMC12650332", "type": "title", "authors": "Yeou SH, Shin YS, "}, "offset": 0, "text": "Regenerative Strategies for Vocal Fold Repair Using Injectable Materials.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 74, "text": "Injectable biomaterials for vocal fold disorders are being developed to provide not only mechanical reinforcement but also a regenerative microenvironment. Recent hydrogels based on hyaluronic acid (HA) derivatives, calcium hydroxylapatite and decellularized matrix scaffolds are designed to approximate the viscoelastic behavior of native tissue, allow controlled degradation, and modulate local immune responses. Rather than serving merely as space-filling agents, several of these materials deliver extracellular matrix (ECM)-like biochemical signals that help maintain pliability and overcome some limitations of conventional augmentation. Experimental and early clinical studies involving growth factor delivery, stem cell-based injections, and ECM-mimetic hydrogels have demonstrated improved mucosal wave vibration and reduced fibrosis in cases of scarring. In clinical series, benefits from basic fibroblast growth factor can persist for up to 12 months. Further progress will depend on correlating material properties with objective vibratory performance to achieve lasting restoration of phonation and advance true tissue-regenerative therapy.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "MESH:D014826", "type": "Disease", "valid": true, "normalized": ["D014826"], "database": "ncbi_mesh", "normalized_id": "D014826", "biotype": "disease", "name": "Vocal Cord Paralysis", "accession": "@DISEASE_Vocal_Cord_Paralysis"}, "text": "vocal fold disorders", "locations": [{"offset": 102, "length": 20}]}, {"id": "6", "infons": {"identifier": "MESH:D006820", "type": "Chemical", "valid": true, "normalized": ["D006820"], "database": "ncbi_mesh", "normalized_id": "D006820", "biotype": "chemical", "name": "Hyaluronic Acid", "accession": "@CHEMICAL_Hyaluronic_Acid"}, "text": "hyaluronic acid", "locations": [{"offset": 256, "length": 15}]}, {"id": "7", "infons": {"identifier": "MESH:D006820", "type": "Chemical", "valid": true, "normalized": ["D006820"], "database": "ncbi_mesh", "normalized_id": "D006820", "biotype": "chemical", "name": "Hyaluronic Acid", "accession": "@CHEMICAL_Hyaluronic_Acid"}, "text": "HA", "locations": [{"offset": 273, "length": 2}]}, {"id": "8", "infons": {"identifier": "MESH:D017886", "type": "Chemical", "valid": true, "normalized": ["D017886"], "database": "ncbi_mesh", "normalized_id": "D017886", "biotype": "chemical", "name": "Durapatite", "accession": "@CHEMICAL_Durapatite"}, "text": "calcium hydroxylapatite", "locations": [{"offset": 290, "length": 23}]}, {"id": "9", "infons": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "text": "fibrosis", "locations": [{"offset": 908, "length": 8}]}], "relations": []}], "relations": [], "pmid": 41294420, "pmcid": null, "meta": {}, "date": "2025-11-06T00:00:00Z", "journal": "Biomimetics (Basel)", "authors": ["Yeou SH", "Shin YS"], "relations_display": []}, {"_id": "41295382|None", "id": "41295382", "infons": {}, "passages": [{"infons": {"journal": "Mar Drugs;2025Oct23; 23 (11) . doi:10.3390/md23110415", "year": "2025", "article-id_pmc": "PMC12654020", "type": "title", "authors": "Sharma A, Yoon NY, Lee HJ, "}, "offset": 0, "text": "Therapeutic Potential of Neopyropia yezoensis: An Updated Review.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 66, "text": "Neopyropia (N.) yezoensis is a widely cultivated red alga in East Asia and valued worldwide for its rich bioactive constituents recognized for their health benefits, including polsaccharides, porphyrans, pigments, phenolic compounds, phycobiliproteins, polyunsaturated fatty acids, myosporin-like amino acids, and both synthetic and recombinant peptides. This review summarizes the current knowledge regarding the therapeutic potential of N. yezoensis extracts and their bioactive compounds. Based on in vitro, ex vitro, and in vivo experimental data (including those on Drosophila melanogaster larvae), this review comprehensively discusses its antioxidant, anti-inflammatory, neuroprotective, anti-atopic dermatitis, anti-colitis, anticancer, anti-aging, anti-atrophy, metabolic health-promoting effects, improving renal health, proliferating, anti-osteoarthritic, anti-allergic, antibacterial, and antivirus activities. The prebiotic effect of N. yezoensis porphyran through modulation of the gut microbiota was also investigated. Studies have indicated that protein hydrolysates and peptides derived from N. yezoensis with low molecular weights and aromatic and/or hydrophobic amino acids contribute significantly to these diverse bioactivities. Although N. yezoensis has shown promising bioactivity in preclinical models, validated clinical data in humans are currently lacking. Future research should prioritize the design and implementation of well-controlled human clinical trials to fully explore their therapeutic potential.", "sentences": [], "annotations": [{"id": "13", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "polsaccharides", "locations": [{"offset": 242, "length": 14}]}, {"id": "14", "infons": {"identifier": "MESH:C038549", "type": "Chemical", "valid": true, "normalized": ["C038549"], "database": "ncbi_mesh", "normalized_id": "C038549", "biotype": "chemical", "name": "porphyran", "accession": "@CHEMICAL_porphyran"}, "text": "porphyrans", "locations": [{"offset": 258, "length": 10}]}, {"id": "15", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "phenolic compounds", "locations": [{"offset": 280, "length": 18}]}, {"id": "16", "infons": {"identifier": "MESH:D005231", "type": "Chemical", "valid": true, "normalized": ["D005231"], "database": "ncbi_mesh", "normalized_id": "D005231", "biotype": "chemical", "name": "Fatty Acids Unsaturated", "accession": "@CHEMICAL_Fatty_Acids_Unsaturated"}, "text": "polyunsaturated fatty acids", "locations": [{"offset": 319, "length": 27}]}, {"id": "17", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "myosporin-like amino acids", "locations": [{"offset": 348, "length": 26}]}, {"id": "18", "infons": {"identifier": "7227", "type": "Species", "valid": true, "normalized": [7227], "database": "ncbi_taxonomy", "normalized_id": 7227, "biotype": "species", "name": "7227", "accession": null}, "text": "Drosophila melanogaster", "locations": [{"offset": 637, "length": 23}]}, {"id": "19", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 730, "length": 12}]}, {"id": "20", "infons": {"identifier": "MESH:D003876", "type": "Disease", "valid": true, "normalized": ["D003876"], "database": "ncbi_mesh", "normalized_id": "D003876", "biotype": "disease", "name": "Dermatitis Atopic", "accession": "@DISEASE_Dermatitis_Atopic"}, "text": "atopic dermatitis", "locations": [{"offset": 766, "length": 17}]}, {"id": "21", "infons": {"identifier": "MESH:D003092", "type": "Disease", "valid": true, "normalized": ["D003092"], "database": "ncbi_mesh", "normalized_id": "D003092", "biotype": "disease", "name": "Colitis", "accession": "@DISEASE_Colitis"}, "text": "colitis", "locations": [{"offset": 790, "length": 7}]}, {"id": "22", "infons": {"identifier": "MESH:D001284", "type": "Disease", "valid": true, "normalized": ["D001284"], "database": "ncbi_mesh", "normalized_id": "D001284", "biotype": "disease", "name": "Atrophy", "accession": "@DISEASE_Atrophy"}, "text": "atrophy", "locations": [{"offset": 828, "length": 7}]}, {"id": "23", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "osteoarthritic", "locations": [{"offset": 917, "length": 14}]}, {"id": "24", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "humans", "locations": [{"offset": 1420, "length": 6}]}, {"id": "25", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 1533, "length": 5}]}], "relations": []}], "relations": [], "pmid": 41295382, "pmcid": null, "meta": {}, "date": "2025-10-23T00:00:00Z", "journal": "Mar Drugs", "authors": ["Sharma A", "Yoon NY", "Lee HJ"], "relations_display": []}, {"_id": "41382999|None", "id": "41382999", "infons": {}, "passages": [{"infons": {"journal": "Zhong Nan Da Xue Xue Bao Yi Xue Ban;2025Aug28; 50 (8) 1371. doi:10.11817/j.issn.1672-7347.2025.250381", "year": "2025", "article-id_pmc": "PMC12723246", "type": "title", "authors": "Fang Y, Feng B, Li W, Zhu L, Chen F, Zeng W, "}, "offset": 0, "text": "Deep space environment empowering drug design and development.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 63, "text": "The unique characteristics of the deep space environment, microgravity, cosmic radiation, and extreme temperature fluctuations, are emerging as major driving forces for pharmaceutical innovation. These factors provide new avenues for optimizing drug formulations, improving crystal structure quality, and accelerating the discovery of therapeutic targets. Advances in deep space research not only help overcome critical bottlenecks in terrestrial drug development but also promote progress in structure-based drug design and deepen understanding of cellular stress-response mechanisms. Current progress in space-based pharmaceutical research primarily includes the study of disease mechanisms under microgravity, protein crystallization in microgravity, and drug development utilizing deep space radiation and resources. However, the operational complexity, high costs, and limited data reproducibility of space experiments remain key challenges hindering widespread application. Looking ahead, with the integration of automation, artificial intelligence analysis, and on-orbit manufacturing, deep space drug development is expected to achieve greater scalability and precision, opening a new frontier in biopharmaceutical science.", "sentences": [], "annotations": [], "relations": []}], "relations": [], "pmid": 41382999, "pmcid": null, "meta": {}, "date": "2025-08-28T00:00:00Z", "journal": "Zhong Nan Da Xue Xue Bao Yi Xue Ban", "authors": ["Fang Y", "Feng B", "Li W", "Zhu L", "Chen F", "Zeng W"], "relations_display": []}, {"_id": "41409165|None", "id": "41409165", "infons": {}, "passages": [{"infons": {"journal": "ACS Pharmacol Transl Sci;2025Dec12; 8 (12) 4214. doi:10.1021/acsptsci.5c00521", "year": "2025", "article-id_pmc": "PMC12707266", "type": "title", "authors": "Silva VAS, Aurista do Nascimento KG, Gubert P, Carneiro-da-Cunha MG, Ribeiro KA, Soares PAG, "}, "offset": 0, "text": "Impact of Symptomatic Slow-Acting Drugs on Inflammatory Pathways in Osteoarthritis: Therapeutic Advances and Future Challenges.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "Inflammatory", "locations": [{"offset": 43, "length": 12}]}, {"id": "3", "infons": {"identifier": "MESH:D010003", "type": "Disease", "valid": true, "normalized": ["D010003"], "database": "ncbi_mesh", "normalized_id": "D010003", "biotype": "disease", "name": "Osteoarthritis", "accession": "@DISEASE_Osteoarthritis"}, "text": "Osteoarthritis", "locations": [{"offset": 68, "length": 14}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 128, "text": "Osteoarthritis (OA) is a leading cause of physical disability, psychological distress, and a significant economic burden worldwide. Current treatments alleviate symptoms; however, disease progression remains largely uncontrolled, highlighting the urgent need for investigation of disease-modifying therapies. Symptomatic slow-acting drugs for osteoarthritis (SYSADOAs), such as glucosamine (GlcN), chondroitin sulfate (CS), and hyaluronic acid (HA), have gained increasing attention for their potential benefits in alleviating pain and mitigating the inflammatory and degenerative processes that characterize OA. These compounds modulate several homeostatic mechanisms, promoting anti-inflammatory, antioxidant, antiapoptotic, and anabolic countermensuring effects. Nevertheless, debates regarding their long-term efficacy and safety remain controversial, which explains why major osteoarthritis societies do not provide the same recommendations for the pharmacological treatment of OA. In this context, this review critically evaluates the current evidence surrounding HA, GlcN, and CS, highlighting their safety, mechanisms of action, and promising therapeutic perspectives for modifying the natural course of knee, hand, and hip OA.", "sentences": [], "annotations": [{"id": "24", "infons": {"identifier": "MESH:D010003", "type": "Disease", "valid": true, "normalized": ["D010003"], "database": "ncbi_mesh", "normalized_id": "D010003", "biotype": "disease", "name": "Osteoarthritis", "accession": "@DISEASE_Osteoarthritis"}, "text": "Osteoarthritis", "locations": [{"offset": 128, "length": 14}]}, {"id": "25", "infons": {"identifier": "MESH:D010003", "type": "Disease", "valid": true, "normalized": ["D010003"], "database": "ncbi_mesh", "normalized_id": "D010003", "biotype": "disease", "name": "Osteoarthritis", "accession": "@DISEASE_Osteoarthritis"}, "text": "OA", "locations": [{"offset": 144, "length": 2}]}, {"id": "26", "infons": {"identifier": "MESH:D059445", "type": "Disease", "valid": true, "normalized": ["D059445"], "database": "ncbi_mesh", "normalized_id": "D059445", "biotype": "disease", "name": "Anhedonia", "accession": "@DISEASE_Anhedonia"}, "text": "physical disability", "locations": [{"offset": 170, "length": 19}]}, {"id": "27", "infons": {"identifier": "MESH:D010003", "type": "Disease", "valid": true, "normalized": ["D010003"], "database": "ncbi_mesh", "normalized_id": "D010003", "biotype": "disease", "name": "Osteoarthritis", "accession": "@DISEASE_Osteoarthritis"}, "text": "osteoarthritis", "locations": [{"offset": 471, "length": 14}]}, {"id": "28", "infons": {"identifier": "MESH:D005944", "type": "Chemical", "valid": true, "normalized": ["D005944"], "database": "ncbi_mesh", "normalized_id": "D005944", "biotype": "chemical", "name": "Glucosamine", "accession": "@CHEMICAL_Glucosamine"}, "text": "glucosamine", "locations": [{"offset": 506, "length": 11}]}, {"id": "29", "infons": {"identifier": "MESH:D005944", "type": "Chemical", "valid": true, "normalized": ["D005944"], "database": "ncbi_mesh", "normalized_id": "D005944", "biotype": "chemical", "name": "Glucosamine", "accession": "@CHEMICAL_Glucosamine"}, "text": "GlcN", "locations": [{"offset": 519, "length": 4}]}, {"id": "30", "infons": {"identifier": "MESH:D002809", "type": "Chemical", "valid": true, "normalized": ["D002809"], "database": "ncbi_mesh", "normalized_id": "D002809", "biotype": "chemical", "name": "Chondroitin Sulfates", "accession": "@CHEMICAL_Chondroitin_Sulfates"}, "text": "chondroitin sulfate", "locations": [{"offset": 526, "length": 19}]}, {"id": "31", "infons": {"identifier": "MESH:D002809", "type": "Chemical", "valid": true, "normalized": ["D002809"], "database": "ncbi_mesh", "normalized_id": "D002809", "biotype": "chemical", "name": "Chondroitin Sulfates", "accession": "@CHEMICAL_Chondroitin_Sulfates"}, "text": "CS", "locations": [{"offset": 547, "length": 2}]}, {"id": "32", "infons": {"identifier": "MESH:D006820", "type": "Chemi