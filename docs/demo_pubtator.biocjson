ical", "name": "Iron", "accession": "@CHEMICAL_Iron"}, "role2": {"identifier": "664783", "type": "Gene", "valid": true, "normalized": [664783], "database": "ncbi_gene", "normalized_id": 664783, "biotype": "gene", "name": "Dux", "accession": "@GENE_DUX"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "8", "role": "43,41"}]}, {"id": "R10", "infons": {"score": "0.9989", "role1": {"identifier": "MESH:D020391", "type": "Disease", "valid": true, "normalized": ["D020391"], "database": "ncbi_mesh", "normalized_id": "D020391", "biotype": "disease", "name": "Muscular Dystrophy Facioscapulohumeral", "accession": "@DISEASE_Muscular_Dystrophy_Facioscapulohumeral"}, "role2": {"identifier": "664783", "type": "Gene", "valid": true, "normalized": [664783], "database": "ncbi_gene", "normalized_id": 664783, "biotype": "gene", "name": "Dux", "accession": "@GENE_DUX"}, "type": "Association"}, "nodes": [{"refid": "9", "role": "44,41"}]}], "pmid": 40591405, "pmcid": null, "meta": {}, "date": "2025-07-01T00:00:00Z", "journal": "J Clin Invest", "authors": ["Nakamura K", "Ortuste-Quiroga HP", "Horii N", "Fujimaki S", "Moroishi T", "Nakayama KI", "Hino S", "Saito Y", "Nishino I", "Ono Y"], "relations_display": [{"name": "negative_correlate|@CHEMICAL_ferrostatin_1|@CHEMICAL_Iron"}, {"name": "associate|@DISEASE_Retinal_Diseases|@GENE_DUX"}, {"name": "associate|@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions|@GENE_DUX"}, {"name": "negative_correlate|@CHEMICAL_ferrostatin_1|@CHEMICAL_Lipids"}, {"name": "cause|@CHEMICAL_Iron|@DISEASE_Muscular_Dystrophy_Facioscapulohumeral"}, {"name": "associate|@DISEASE_Muscle_Weakness|@GENE_DUX"}, {"name": "negative_correlate|@CHEMICAL_Iron|@CHEMICAL_Lipids"}, {"name": "treat|@CHEMICAL_Iron|@DISEASE_Retinal_Diseases"}, {"name": "negative_correlate|@CHEMICAL_Iron|@GENE_DUX"}, {"name": "associate|@DISEASE_Muscular_Dystrophy_Facioscapulohumeral|@GENE_DUX"}]}, {"_id": "40591724|None", "id": "40591724", "infons": {}, "passages": [{"infons": {"journal": "Clin Sci (Lond);2025Jul01; 139 (13) . doi:10.1042/CS20255458", "year": "2025", "type": "title", "authors": "Bongetti AJ, Caldow MK, Abdelhamid YA, Lynch GS, "}, "offset": 0, "text": "Evaluating skeletal muscle wasting and weakness in models of critical illness.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle wasting", "locations": [{"offset": 20, "length": 14}]}, {"id": "4", "infons": {"identifier": "MESH:D018908", "type": "Disease", "valid": true, "normalized": ["D018908"], "database": "ncbi_mesh", "normalized_id": "D018908", "biotype": "disease", "name": "Muscle Weakness", "accession": "@DISEASE_Muscle_Weakness"}, "text": "weakness", "locations": [{"offset": 39, "length": 8}]}, {"id": "5", "infons": {"identifier": "MESH:D016638", "type": "Disease", "valid": true, "normalized": ["D016638"], "database": "ncbi_mesh", "normalized_id": "D016638", "biotype": "disease", "name": "Critical Illness", "accession": "@DISEASE_Critical_Illness"}, "text": "critical illness", "locations": [{"offset": 61, "length": 16}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 79, "text": "Skeletal muscle wasting and weakness are common complications associated with admission to the intensive care unit (ICU), with the loss of muscle mass and function increasing mortality and contributing to physical impairments post-discharge. While our understanding of the pathophysiology of this condition, commonly termed 'ICU-acquired weakness' (ICU-AW), has advanced considerably, no effective therapies are available. ICU-AW broadly encompasses a range of muscle-related impairments in this setting, including, but not limited to, critical illness myopathy and sepsis-induced myopathy. Pre-clinical models of critical illness can provide insights into the mechanisms underlying muscle wasting and weakness. Cell culture systems can provide mechanistic interrogation, by isolating effects to skeletal muscle directly. Small animal models, like rats and mice, allow for mechanistic investigation of ICU-AW using genetic models and testing pharmacological interventions. Larger animal models, including pigs and sheep, facilitate repeated blood and tissue sampling and can more closely recapitulate the standard-of-care within ICU settings. Although animal models can be advantageous for scientific investigation, they also have important limitations. Barriers to developing effective interventions include difficulty in obtaining muscle biopsies from patients, translating experimental findings between animal models and humans and replicating aspects of different ICU settings. This review explores the advantages and shortcomings of different pre-clinical models of critical illness, identifies gaps in understanding muscle wasting and weakness in critical illness and provides recommendations for improving the translation of therapeutics to promote functional recovery for patients post-discharge.", "sentences": [], "annotations": [{"id": "33", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle wasting", "locations": [{"offset": 88, "length": 14}]}, {"id": "34", "infons": {"identifier": "MESH:D018908", "type": "Disease", "valid": true, "normalized": ["D018908"], "database": "ncbi_mesh", "normalized_id": "D018908", "biotype": "disease", "name": "Muscle Weakness", "accession": "@DISEASE_Muscle_Weakness"}, "text": "weakness", "locations": [{"offset": 107, "length": 8}]}, {"id": "35", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "loss of muscle mass and function", "locations": [{"offset": 210, "length": 32}]}, {"id": "36", "infons": {"identifier": "MESH:D059445", "type": "Disease", "valid": true, "normalized": ["D059445"], "database": "ncbi_mesh", "normalized_id": "D059445", "biotype": "disease", "name": "Anhedonia", "accession": "@DISEASE_Anhedonia"}, "text": "physical impairments", "locations": [{"offset": 284, "length": 20}]}, {"id": "37", "infons": {"identifier": "MESH:C000657744", "type": "Disease", "valid": true, "normalized": ["C000657744"], "database": "ncbi_mesh", "normalized_id": "C000657744", "biotype": "disease", "name": "postintensive care syndrome", "accession": "@DISEASE_postintensive_care_syndrome"}, "text": "ICU-acquired weakness", "locations": [{"offset": 404, "length": 21}]}, {"id": "38", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "AW", "locations": [{"offset": 432, "length": 2}]}, {"id": "39", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "AW", "locations": [{"offset": 506, "length": 2}]}, {"id": "40", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle-related impairments", "locations": [{"offset": 540, "length": 26}]}, {"id": "41", "infons": {"identifier": "MESH:D016638", "type": "Disease", "valid": true, "normalized": ["D016638"], "database": "ncbi_mesh", "normalized_id": "D016638", "biotype": "disease", "name": "Critical Illness", "accession": "@DISEASE_Critical_Illness"}, "text": "critical illness", "locations": [{"offset": 615, "length": 16}]}, {"id": "42", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "myopathy", "locations": [{"offset": 632, "length": 8}]}, {"id": "43", "infons": {"identifier": "MESH:D018805", "type": "Disease", "valid": true, "normalized": ["D018805"], "database": "ncbi_mesh", "normalized_id": "D018805", "biotype": "disease", "name": "Sepsis", "accession": "@DISEASE_Sepsis"}, "text": "sepsis", "locations": [{"offset": 645, "length": 6}]}, {"id": "44", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "myopathy", "locations": [{"offset": 660, "length": 8}]}, {"id": "45", "infons": {"identifier": "MESH:D016638", "type": "Disease", "valid": true, "normalized": ["D016638"], "database": "ncbi_mesh", "normalized_id": "D016638", "biotype": "disease", "name": "Critical Illness", "accession": "@DISEASE_Critical_Illness"}, "text": "critical illness", "locations": [{"offset": 693, "length": 16}]}, {"id": "46", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle wasting", "locations": [{"offset": 762, "length": 14}]}, {"id": "47", "infons": {"identifier": "MESH:D018908", "type": "Disease", "valid": true, "normalized": ["D018908"], "database": "ncbi_mesh", "normalized_id": "D018908", "biotype": "disease", "name": "Muscle Weakness", "accession": "@DISEASE_Muscle_Weakness"}, "text": "weakness", "locations": [{"offset": 781, "length": 8}]}, {"id": "48", "infons": {"identifier": "10116", "type": "Species", "valid": true, "normalized": [10116], "database":