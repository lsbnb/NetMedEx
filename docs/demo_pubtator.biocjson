"accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "56637", "type": "Gene", "valid": true, "normalized": [56637], "database": "ncbi_gene", "normalized_id": 56637, "biotype": "gene", "name": "Gsk3b", "accession": "@GENE_GSK3B"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "20,19"}]}, {"id": "R2", "infons": {"score": "0.9981", "role1": {"identifier": "320145", "type": "Gene", "valid": true, "normalized": [320145], "database": "ncbi_gene", "normalized_id": 320145, "biotype": "gene", "name": "Sp8", "accession": "@GENE_SP8"}, "role2": {"identifier": "56637", "type": "Gene", "valid": true, "normalized": [56637], "database": "ncbi_gene", "normalized_id": 56637, "biotype": "gene", "name": "Gsk3b", "accession": "@GENE_GSK3B"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "1", "role": "16,19"}]}, {"id": "R3", "infons": {"score": "0.748", "role1": {"identifier": "11651", "type": "Gene", "valid": true, "normalized": [11651], "database": "ncbi_gene", "normalized_id": 11651, "biotype": "gene", "name": "Akt1", "accession": "@GENE_AKT1"}, "role2": {"identifier": "320145", "type": "Gene", "valid": true, "normalized": [320145], "database": "ncbi_gene", "normalized_id": 320145, "biotype": "gene", "name": "Sp8", "accession": "@GENE_SP8"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "21,16"}]}, {"id": "R4", "infons": {"score": "0.9859", "role1": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "320145", "type": "Gene", "valid": true, "normalized": [320145], "database": "ncbi_gene", "normalized_id": 320145, "biotype": "gene", "name": "Sp8", "accession": "@GENE_SP8"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "3", "role": "20,16"}]}], "pmid": 41290705, "pmcid": null, "meta": {}, "date": "2025-11-25T00:00:00Z", "journal": "NPJ Aging", "authors": ["Nagaoka N", "Eguchi A", "Ma N", "Kawanokuchi J", "Yamamoto T", "Tempaku M", "Izuoka K", "Okabe J", "Iwasa M", "Nakagawa H", "Kobayashi Y"], "relations_display": [{"name": "associate|@DISEASE_Inflammation|@GENE_GSK3B"}, {"name": "negative_correlate|@GENE_SP8|@GENE_GSK3B"}, {"name": "associate|@GENE_AKT1|@GENE_SP8"}, {"name": "inhibit|@DISEASE_Inflammation|@GENE_SP8"}]}, {"_id": "41298489|None", "id": "41298489", "infons": {}, "passages": [{"infons": {"journal": "Nat Commun;2025Nov26. doi:10.1038/s41467-025-66687-8", "year": "2025", "type": "title", "authors": "Majcher A, Karsai G, Yusifov E, Schaettin M, Malagola E, Horvath P, Li J, Rodriguez-Gallardo S, Shimizu K, Zhibo G, Dubey R, Peterson T, Harayama T, Hornemann T, "}, "offset": 0, "text": "Very long-chain fatty acids drive 1-deoxySphingolipid toxicity.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "long-chain fatty acids", "locations": [{"offset": 5, "length": 22}]}, {"id": "4", "infons": {"identifier": "MESH:C000626286", "type": "Chemical", "valid": true, "normalized": ["C000626286"], "database": "ncbi_mesh", "normalized_id": "C000626286", "biotype": "chemical", "name": "1-deoxysphingolipid", "accession": "@CHEMICAL_1_deoxysphingolipid"}, "text": "1-deoxySphingolipid", "locations": [{"offset": 34, "length": 19}]}, {"id": "5", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mesh", "normalized_id": "D064420", "biotype": "disease", "name": "Drug-Related Side Effects and Adverse Reactions", "accession": "@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions"}, "text": "toxicity", "locations": [{"offset": 54, "length": 8}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 64, "text": "1-Deoxysphingolipids (1-deoxySLs) are atypical sphingolipids formed when serine palmitoyltransferase incorporates L-alanine instead of L-serine. Elevated 1-deoxySLs are associated with hereditary sensory neuropathy type 1 and diabetic neuropathy, but the molecular basis of their toxicity remains unclear. Here we show that toxicity is mediated by very long-chain (VLC) 1-deoxy-dihydroceramides (1-deoxyDHCer), particularly nervonyl-1-deoxyDHCer (m18:0/24:1) and lignoceryl-1-deoxyDHCer (m18:0/24:0). Using a CRISPR interference screen, we identify ELOVL1 and CERS2 as essential enzymes driving the formation of these toxic species. Genetic modulation or pharmacological inhibition of ELOVL1 prevents VLC 1-deoxyDHCer accumulation, rescuing the toxicity in cellular and neuronal models. Mechanistic studies reveal that m18:0/24:1 disrupts mitochondrial integrity and induces the mitochondrial permeability transition pore formation and BAX activation, leading to cell death. These findings establish a direct link between 1-deoxySL chemical structure and cytotoxicity and highlight ELOVL1 inhibition as a potential therapeutic strategy for 1-deoxySL-associated diseases.", "sentences": [], "annotations": [{"id": "30", "infons": {"identifier": "MESH:C000626286", "type": "Chemical", "valid": true, "normalized": ["C000626286"], "database": "ncbi_mesh", "normalized_id": "C000626286", "biotype": "chemical", "name": "1-deoxysphingolipid", "accession": "@CHEMICAL_1_deoxysphingolipid"}, "text": "1-Deoxysphingolipids", "locations": [{"offset": 64, "length": 20}]}, {"id": "31", "infons": {"identifier": "MESH:C000626286", "type": "Chemical", "valid": true, "normalized": ["C000626286"], "database": "ncbi_mesh", "normalized_id": "C000626286", "biotype": "chemical", "name": "1-deoxysphingolipid", "accession": "@CHEMICAL_1_deoxysphingolipid"}, "text": "1-deoxySLs", "locations": [{"offset": 86, "length": 10}]}, {"id": "32", "infons": {"identifier": "MESH:D013107", "type": "Chemical", "valid": true, "normalized": ["D013107"], "database": "ncbi_mesh", "normalized_id": "D013107", "biotype": "chemical", "name": "Sphingolipids", "accession": "@CHEMICAL_Sphingolipids"}, "text": "sphingolipids", "locations": [{"offset": 111, "length": 13}]}, {"id": "33", "infons": {"identifier": "MESH:D000409", "type": "Chemical", "valid": true, "normalized": ["D000409"], "database": "ncbi_mesh", "normalized_id": "D000409", "biotype": "chemical", "name": "Alanine", "accession": "@CHEMICAL_Alanine"}, "text": "L-alanine", "locations": [{"offset": 178, "length": 9}]}, {"id": "34", "infons": {"identifier": "MESH:D012694", "type": "Chemical", "valid": true, "normalized": ["D012694"], "database": "ncbi_mesh", "normalized_id": "D012694", "biotype": "chemical", "name": "Serine", "accession": "@CHEMICAL_Serine"}, "text": "L-serine", "locations": [{"offset": 199, "length": 8}]}, {"id": "35", "infons": {"identifier": "MESH:C000626286", "type": "Chemical", "valid": true, "normalized": ["C000626286"], "database": "ncbi_mesh", "normalized_id": "C000626286", "biotype": "chemical", "name": "1-deoxysphingolipid", "accession": "@CHEMICAL_1_deoxysphingolipid"}, "text": "1-deoxySLs", "locations": [{"offset": 218, "length": 10}]}, {"id": "36", "infons": {"identifier": "MESH:D009477", "type": "Disease", "valid": true, "normalized": ["D009477"], "database": "ncbi_mesh", "normalized_id": "D009477", "biotype": "disease", "name": "Hereditary Sensory and Autonomic Neuropathies", "accession": "@DISEASE_Hereditary_Sensory_and_Autonomic_Neuropathies"}, "text": "hereditary sensory neuropathy type 1", "locations": [{"offset": 249, "length": 36}]}, {"id": "37", "infons": {"identifier": "MESH:D003929", "type": "Disease", "valid": true, "normalized": ["D003929"], "database": "ncbi_mesh", "normalized_id": "D003929", "biotype": "disease", "name": "Diabetic Neuropathies", "accession": "@DISEASE_Diabetic_Neuropathies"}, "text": "diabetic neuropathy", "locations": [{"offset": 290, "length": 19}]}, {"id": "38", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mes