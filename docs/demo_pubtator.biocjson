zed_id": "D004958", "biotype": "chemical", "name": "Estradiol", "accession": "@CHEMICAL_Estradiol"}, "role2": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "1", "role": "15,18"}]}, {"id": "R3", "infons": {"score": "0.9965", "role1": {"identifier": "MESH:D013739", "type": "Chemical", "valid": true, "normalized": ["D013739"], "database": "ncbi_mesh", "normalized_id": "D013739", "biotype": "chemical", "name": "Testosterone", "accession": "@CHEMICAL_Testosterone"}, "role2": {"identifier": "MESH:D009410", "type": "Disease", "valid": true, "normalized": ["D009410"], "database": "ncbi_mesh", "normalized_id": "D009410", "biotype": "disease", "name": "Nerve Degeneration", "accession": "@DISEASE_Nerve_Degeneration"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "16,5"}]}, {"id": "R4", "infons": {"score": "0.9619", "role1": {"identifier": "MESH:D013739", "type": "Chemical", "valid": true, "normalized": ["D013739"], "database": "ncbi_mesh", "normalized_id": "D013739", "biotype": "chemical", "name": "Testosterone", "accession": "@CHEMICAL_Testosterone"}, "role2": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "3", "role": "16,18"}]}], "pmid": 40890834, "pmcid": null, "meta": {}, "date": "2025-09-01T00:00:00Z", "journal": "BMC Pharmacol Toxicol", "authors": ["Cui X", "Li X", "Qi X", "Wang D", "Kang B", "Li F", "Xu X"], "relations_display": [{"name": "treat|@CHEMICAL_Estradiol|@DISEASE_Nerve_Degeneration"}, {"name": "treat|@CHEMICAL_Estradiol|@DISEASE_Sarcopenia"}, {"name": "treat|@CHEMICAL_Testosterone|@DISEASE_Nerve_Degeneration"}, {"name": "treat|@CHEMICAL_Testosterone|@DISEASE_Sarcopenia"}]}, {"_id": "40914973|None", "id": "40914973", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Integrative physiology of skeletal muscle for maintaining cognitive health.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 76, "text": "Cognitive decline and physical impairment are often linked with ageing, contributing to declines in health span and loss of independence in older adults. Pathological cognitive decline with age is largely considered to be a brain-centric challenge. However, recent findings have begun to challenge this paradigm as the health of peripheral systems, namely skeletal muscle, predict cognitive decline associated with Alzheimer's disease (AD). Loss of muscle strength (dynapenia), loss of muscle mass (sarcopenia) and associated impairment in peripheral motor nerves and neuromuscular junctions have all been shown to either precede or coincide with AD pathology in the brain. The importance for skeletal muscle is also demonstrated in its role as an endocrine organ, secreting factors like brain-derived neurotrophic factor that promote neurogenesis in the brain. In this review we summarize the importance of skeletal muscle for cognition and discuss how the health of skeletal muscle and peripheral motor nerves may be novel sentinels for AD risk.", "sentences": [], "annotations": [{"id": "14", "infons": {"identifier": "MESH:D003072", "type": "Disease", "valid": true, "normalized": ["D003072"], "database": "ncbi_mesh", "normalized_id": "D003072", "biotype": "disease", "name": "Cognition Disorders", "accession": "@DISEASE_Cognition_Disorders"}, "text": "Cognitive decline", "locations": [{"offset": 76, "length": 17}]}, {"id": "15", "infons": {"identifier": "MESH:D059445", "type": "Disease", "valid": true, "normalized": ["D059445"], "database": "ncbi_mesh", "normalized_id": "D059445", "biotype": "disease", "name": "Anhedonia", "accession": "@DISEASE_Anhedonia"}, "text": "physical impairment", "locations": [{"offset": 98, "length": 19}]}, {"id": "16", "infons": {"identifier": "MESH:D003072", "type": "Disease", "valid": true, "normalized": ["D003072"], "database": "ncbi_mesh", "normalized_id": "D003072", "biotype": "disease", "name": "Cognition Disorders", "accession": "@DISEASE_Cognition_Disorders"}, "text": "cognitive decline", "locations": [{"offset": 243, "length": 17}]}, {"id": "17", "infons": {"identifier": "MESH:D003072", "type": "Disease", "valid": true, "normalized": ["D003072"], "database": "ncbi_mesh", "normalized_id": "D003072", "biotype": "disease", "name": "Cognition Disorders", "accession": "@DISEASE_Cognition_Disorders"}, "text": "cognitive decline", "locations": [{"offset": 457, "length": 17}]}, {"id": "18", "infons": {"identifier": "MESH:D000544", "type": "Disease", "valid": true, "normalized": ["D000544"], "database": "ncbi_mesh", "normalized_id": "D000544", "biotype": "disease", "name": "Alzheimer Disease", "accession": "@DISEASE_Alzheimer_Disease"}, "text": "Alzheimer's disease", "locations": [{"offset": 491, "length": 19}]}, {"id": "19", "infons": {"identifier": "MESH:D000544", "type": "Disease", "valid": true, "normalized": ["D000544"], "database": "ncbi_mesh", "normalized_id": "D000544", "biotype": "disease", "name": "Alzheimer Disease", "accession": "@DISEASE_Alzheimer_Disease"}, "text": "AD", "locations": [{"offset": 512, "length": 2}]}, {"id": "20", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "Loss of muscle strength", "locations": [{"offset": 517, "length": 23}]}, {"id": "21", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "dynapenia", "locations": [{"offset": 542, "length": 9}]}, {"id": "22", "infons": {"identifier": "MESH:C536030", "type": "Disease", "valid": true, "normalized": ["C536030"], "database": "ncbi_mesh", "normalized_id": "C536030", "biotype": "disease", "name": "MASS syndrome", "accession": "@DISEASE_MASS_syndrome"}, "text": "loss of muscle mass", "locations": [{"offset": 554, "length": 19}]}, {"id": "23", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 575, "length": 10}]}, {"id": "24", "infons": {"identifier": "MESH:D060825", "type": "Disease", "valid": true, "normalized": ["D060825"], "database": "ncbi_mesh", "normalized_id": "D060825", "biotype": "disease", "name": "Cognitive Dysfunction", "accession": "@DISEASE_Cognitive_Dysfunction"}, "text": "impairment", "locations": [{"offset": 602, "length": 10}]}, {"id": "25", "infons": {"identifier": "MESH:D000544", "type": "Disease", "valid": true, "normalized": ["D000544"], "database": "ncbi_mesh", "normalized_id": "D000544", "biotype": "disease", "name": "Alzheimer Disease", "accession": "@DISEASE_Alzheimer_Disease"}, "text": "AD", "locations": [{"offset": 723, "length": 2}]}, {"id": "26", "infons": {"identifier": "627", "type": "Gene", "ncbi_homologene": "7245", "valid": true, "normalized": [627], "database": "ncbi_gene", "normalized_id": 627, "biotype": "gene", "name": "BDNF", "accession": "@GENE_BDNF"}, "text": "brain-derived neurotrophic factor", "locations": [{"offset": 864, "length": 33}]}, {"id": "27", "infons": {"identifier": "MESH:D000544", "type": "Disease", "valid": true, "normalized": ["D000544"], "database": "ncbi_mesh", "normalized_id": "D000544", "biotype": "disease", "name": "Alzheimer Disease", "accession": "@DISEASE_Alzheimer_Disease"}, "text": "AD", "locations": [{"offset": 1115, "length": 2}]}], "relations": []}], "relations": [], "pmid": 40914973, "pmcid": null, "meta": {}, "date": "2025-09-07T00:00:00Z", "journal": "J Physiol", "authors": ["Brisendine MH", "Drake JC"], "relations_display": []}, {"_id": "40921883|None", "id": "40921883", "infons": {}, "passages": [{"infons": {"journal": "Biogerontology;2025Sep08; 26 (5) 179. doi:10.1007/s10522-025-10320-0", "year": "2025", "article-id_pmc": "PMC12417257", "type": "title", "authors": "Vittal M, Vinciguerra M, "}, "offset": 0, "text": "Enhancing healthspan with Ashwagandha (Withania somnifera): a comprehensive review of its multifaceted geroprotective benefits.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "126910", "type": "Species", "valid": true, "normalized": [126910], "database": "ncbi_taxonomy", "normalized_id": 126910, "biotype": "species", "name": "126910", "accession": null}, "text": "Ashwagandha", "locations": [{"offset": 26, "length": 11}]}, {"id": "3", "infons": {"identifier": "126910", "type": "Species", "valid": true, "normalized": [126910], "database": "ncbi_taxonomy", "normalized_id": 126910, "biotype": "species", "name": "126910", "accession": null}, "text": "Withania somnifera", "locations": [{"offset": 39, "length": 18}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 128, "text": "Ashwagandha (Withania somnifera), a revered herb in Ayurvedic medicine, has gained significant scientific recognition for its potential to promote healthy aging. Traditionally used as a Rasayana or rejuvenator, this potent adaptogen helps the body manage stress and enhance vitality. This review synthesises extensive evidence for its multifaceted anti-aging capabilities, which target key hallmarks of the aging process. The mechanisms underpinning its effects include enhancing telomerase activity to support cellular longevity, combating systemic oxidative stress, and powerfully countering inflammaging by modulating immune responses and lowering inflammatory markers like C-reactive protein. Robust clinical evidence demonstrates its efficacy in improving crucial physiological parameters, including significant gains in muscle strength and size, enhanced cardiorespiratory fitness, hormonal balance, skin health, and improved sleep quality in older adults. Furthermore, trials have consistently shown its ability to improve cognitive function, including memory and information-processing speed, particularly in adults with mild cognitive impairment. Promising preclinical data also highlight its neuroprotective potential in models of Alzheimer's and Parkinson's disease. Here, we review the current evidence supports Ashwagandha's therapeutic potential in extending healthspan and enhancing quality of life. Large-scale, long-term clinical trials using standardized extracts are essential to fully confirm its role in healthy aging within the global population.", "sentences": [], "annotations": [{"id": "12", "infons": {"identifier": "126910", "type": "Species", "valid": true, "normalized": [126910], "database": "ncbi_taxonomy", "normalized_id": 126910, "biotype": "species", "name": "126910", "accession": null}, "text": "Ashwagandha", "locations": [{"offset": 128, "length": 11}]}, {"id": "13", "infons": {"identifier": "126910", "type": "Species", "valid": true, "normalized": [126910], "database": "ncbi_taxonomy", "normalized_id": 126910, "biotype": "species", "name": "126910", "accession": null}, "text": "Withania somnifera", "locations": [{"offset": 141, "length": 18}]}, {"id": "14", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "inflammaging", "locations": [{"offset": 722, "length": 12}]}, {"id": "15", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 779, "length": 12}]}, {"id": "16", "infons": {"identifier": "1401", "type": "Gene", "ncbi_homologene": "128039", "valid": true, "normalized": [1401], "database": "ncbi_gene", "normalized_id": 1401, "biotype": "gene", "name": "CRP", "accession": "@GENE_CRP"}, "text": "C-reactive protein", "locations": [{"offset": 805, "length": 18}]}, {"id": "17", "infons": {"identifier": "MESH:D003072", "type": "Disease", "valid": true, "normalized": ["D003072"], "database": "ncbi_mesh", "normalized_id": "D003072", "biotype": "disease", "name": "Cognition Disorders", "accession": "@DISEASE_Cognition_Disorders"}, "text": "cognitive impairment", "locations": [{"offset": 1262, "length": 20}]}, {"id": "18", "infons": {"identifier": "MESH:D000544", "type": "Disease", "valid": true, "normalized": ["D000544"], "database": "ncbi_mesh", "normalized_id": "D000544", "biotype": "disease", "name": "Alzheimer Disease", "accession": "@DISEASE_Alzheimer_Disease"}, "text": "Alzheimer's", "locations": [{"offset": 1369, "length": 11}]}, {"id": "19", "infons": {"identifier": "MESH:D010300", "type": "Disease", "valid": true, "normalized": ["D010300"], "database": "ncbi_mesh", "normalized_id": "D010300", "biotype": "disease", "name": "Parkinson Disease", "accession": "@DISEASE_Parkinson_Disease"}, "text": "Parkinson's disease", "locations": [{"offset": 1385, "length": 19}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9829", "role1": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "1401", "type": "Gene", "valid": true, "normalized": [1401], "database": "ncbi_gene", "normalized_id": 1401, "biotype": "gene", "name": "CRP", "accession": "@GENE_CRP"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "5,6"}]}], "pmid": 40921883, "pmcid": null, "meta": {}, "date": "2025-09-08T00:00:00Z", "journal": "Biogerontology", "authors": ["Vittal M", "Vinciguerra M"], "relations_display": [{"name": "associate|@DISEASE_Inflammation|@GENE_CRP"}]}, {"_id": "40927995|None", "id": "40927995", "infons": {}, "passages": [{"infons": {"journal": "J Cachexia Sarcopenia Muscle;2025Oct; 16 (5) 70047. doi:10.1002/jcsm.70047", "year": "2025", "article-id_pmc": "PMC12421413", "type": "title", "authors": "Wang Z, Liu W, Sim HJ, Lee JC, Kook SH, Kim SH, "}, "offset": 0, "text": "Effects of Combined Exercise Training on Modulating Fine Particulate Matter-Induced Skeletal Muscle Damage in Offspring Gestationally Exposed.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "Muscle Damage", "locations": [{"offset": 93, "length": 13}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 143, "text": "BACKGROUND: Fine particulate matter has developmental toxicity, and midgestation is an important period for the development of foetal skeletal muscle. The ability of exercise to modulate skeletal muscle damage in mice exposed to PM2.5 during gestation remains unclear. METHODS: Pregnant C57BL/6 mice were exposed to 50 mug/m3 PM2.5 for 2 h on five consecutive days starting at embryonic day 12.5 (E12.5d). Combined exercise (treadmill endurance training and weighted ladder resistance training) was followed for 8 weeks in the 4-week-old offspring to verify the regulatory effect of exercise. RESULTS: Offspring exposed to PM2.5 during gestation showed lower body weight (male, -44.3%; female, -44.8%; p < 0.001), lower skeletal muscle mass (male: TA fibre size, -42%, p < 0.001; TA mass, -37%, p < 0.01; gastrocnemius mass, -46.5%, p < 0.001; female: TA fibre size, -51.6%, p < 0.001; TA mass, -29.8%, p < 0.05; gastrocnemius mass, -40.7%, p < 0.01) and mitochondrial (size decreased for TEM; male: PGC-1alpha, +78.1%, p < 0.05; Tfam, +591.3%, p < 0.001; FIS-1, +627%, p < 0.001; female: Tfam, +452%, p < 0.01; FIS-1, +345.6%, p < 0.01) dysfunction (at 4 weeks old). They also showed catch-up growth (between 3 and 8 weeks of age; male average weight gain level, +57.9%, p < 0.01; female average weight gain level, +66%, p < 0.05), although they still showed significant mitochondrial damage and impaired glucose metabolism (at 13 weeks of age; male: mitochondrial damage for TEM; Tfam, -46%, p < 0.01; PINK-1, -33.8%, p < 0.05; Parkin, -62%, p < 0.01; PFK-1, -17%, p < 0.05; female: mitochondrial damage for TEM; PFK-1, -28.7%, p < 0.01). Combined exercise was unable to regulate the skeletal muscle system disorder that occurred in male offspring exposed to PM2.5 during pregnancy. However, it activated the mitophagy (PINK-1, +94.6%, p < 0.05; Parkin, +90.2%, p < 0.001) in female offspring exposed to PM2.5 during pregnancy, thereby improving mitochondrial damage. CONCLUSIONS: Combined exercise had bidirectional, sex-specific effects: Male offspring exhibited reduced responsiveness to exercise, with persistent mitochondrial damage, whereas female offspring showed improved mitochondrial health through increased mitophagy flux.", "sentences": [], "annotations": [{"id": "27", "infons": {"identifier": "MESH:D064420", "type": "Disease", "valid": true, "normalized": ["D064420"], "database": "ncbi_mesh", "normalized_id": "D064420", "biotype": "disease", "name": "Drug-Related Side Effects and Adverse Reactions", "accession": "@DISEASE_Drug_Related_Side_Effects_and_Adverse_Reactions"}, "text": "toxicity", "locations": [{"offset": 197, "length": 8}]}, {"id": "28", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle damage", "locations": [{"offset": 339, "length": 13}]}, {"id": "29", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 356, "length": 4}]}, {"id": "30", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "PM2.5", "locations": [{"offset": 372, "length": 5}]}, {"id": "31", "infons": {"identifier": "CVCL:C0MU", "type": "CellLine", "valid": false, "normalized": ["C0MU"], "database": "cvcl", "normalized_id": "C0MU", "biotype": "cellline", "name": "C0MU", "accession": null}, "text": "C57BL/6", "locations": [{"offset": 430, "length": 7}]}, {"id": "32", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 438, "length": 4}]}, {"id": "33", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "PM2.5", "locations": [{"offset": 469, "length": 5}]}, {"id": "34", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "PM2.5", "locations": [{"offset": 766, "length": 5}]}, {"id": "35", "infons": {"identifier": "19017", "type": "Gene", "ncbi_homologene": "7485", "valid": true, "normalized": [19017], "database": "ncbi_gene", "normalized_id": 19017, "biotype": "gene", "name": "Ppargc1a", "accession": "@GENE_PPARGC1A"}, "text": "PGC-1alpha", "locations": [{"offset": 1143, "length": 10}]}, {"id": "36", "infons": {"identifier": "21780", "type": "Gene", "ncbi_homologene": "31139", "valid": true, "normalized": [21780], "database": "ncbi_gene", "normalized_id": 21780, "biotype": "gene", "name": "Tfam", "accession": "@GENE_TFAM"}, "text": "Tfam", "locations": [{"offset": 1173, "length": 4}]}, {"id": "37", "infons": {"identifier": "21780", "type": "Gene", "ncbi_homologene": "31139", "valid": true, "normalized": [21780], "database": "ncbi_gene", "normalized_id": 21780, "biotype": "gene", "name": "Tfam", "accession": "@GENE_TFAM"}, "text": "Tfam", "locations": [{"offset": 1232, "length": 4}]}, {"id": "38", "infons": {"identifier": "MESH:D015430", "type": "Disease", "valid": true, "normalized": ["D015430"], "database": "ncbi_mesh", "normalized_id": "D015430", "biotype": "disease", "name": "Weight Gain", "accession": "@DISEASE_Weight_Gain"}, "text": "weight gain", "locations": [{"offset": 1388, "length": 11}]}, {"id": "39", "infons": {"identifier": "MESH:D015430", "type": "Disease", "valid": true, "normalized": ["D015430"], "database": "ncbi_mesh", "normalized_id": "D015430", "biotype": "disease", "name": "Weight Gain", "accession": "@DISEASE_Weight_Gain"}, "text": "weight gain", "locations": [{"offset": 1440, "length": 11}]}, {"id": "40", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial damage", "locations": [{"offset": 1515, "length": 20}]}, {"id": "41", "infons": {"identifier": "MESH:D044882", "type": "Disease", "valid": true, "normalized": ["D044882"], "database": "ncbi_mesh", "normalized_id": "D044882", "biotype": "disease", "name": "Glucose Metabolism Disorders", "accession": "@DISEASE_Glucose_Metabolism_Disorders"}, "text": "impaired glucose metabolism", "locations": [{"offset": 1540, "length": 27}]}, {"id": "42", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial damage", "locations": [{"offset": 1595, "length": 20}]}, {"id": "43", "infons": {"identifier": "21780", "type": "Gene", "ncbi_homologene": "31139", "valid": true, "normalized": [21780], "database": "ncbi_gene", "normalized_id": 21780, "biotype": "gene", "name": "Tfam", "accession": "@GENE_TFAM"}, "text": "Tfam", "locations": [{"offset": 1625, "length": 4}]}, {"id": "44", "infons": {"identifier": "68943", "type": "Gene", "ncbi_homologene": "32672", "valid": true, "normalized": [68943], "database": "ncbi_gene", "normalized_id": 68943, "biotype": "gene", "name": "Pink1", "accession": "@GENE_PINK1"}, "text": "PINK-1", "locations": [{"offset": 1647, "length": 6}]}, {"id": "45", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial damage", "locations": [{"offset": 1728, "length": 20}]}, {"id": "46", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "skeletal muscle system disorder", "locations": [{"offset": 1829, "length": 31}]}, {"id": "47", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "PM2.5", "locations": [{"offset": 1904, "length": 5}]}, {"id": "48", "infons": {"identifier": "68943", "type": "Gene", "ncbi_homologene": "32672", "valid": true, "normalized": [68943], "database": "ncbi_gene", "normalized_id": 68943, "biotype": "gene", "name": "Pink1", "accession": "@GENE_PINK1"}, "text": "PINK-1", "locations": [{"offset": 1965, "length": 6}]}, {"id": "49", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "PM2.5", "locations": [{"offset": 2049, "length": 5}]}, {"id": "50", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial damage", "locations": [{"offset": 2091, "length": 20}]}, {"id": "51", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial damage", "locations": [{"offset": 2262, "length": 20}]}], "relations": []}], "relations": [], "pmid": 40927995, "pmcid": null, "meta": {}, "date": "2025-10-01T00:00:00Z", "journal": "J Cachexia Sarcopenia Muscle", "authors": ["Wang Z", "Liu W", "Sim HJ", "Lee JC", "Kook SH", "Kim SH"], "relations_display": []}, {"_id": "40936396|None", "id": "40936396", "infons": {}, "passages": [{"infons": {"journal": "FEBS Lett;2025Sep12. doi:10.1002/1873-3468.70152", "year": "2025", "type": "title", "authors": "Gunasekaran M, Campos G, Wells NM, Lambuu K, Draper I, Pacak CA, Kang PB, "}, "offset": 0, "text": "ACSS2 involved in acetyl-CoA synthesis regulates skeletal muscle function.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "60525", "type": "Gene", "ncbi_homologene": "6469", "valid": true, "normalized": [60525], "database": "ncbi_gene", "normalized_id": 60525, "biotype": "gene", "name": "Acss2", "accession": "@GENE_ACSS2"}, "text": "ACSS2", "locations": [{"offset": 0, "length": 5}]}, {"id": "3", "infons": {"identifier": "MESH:D000105", "type": "Chemical", "valid": true, "normalized": ["D000105"], "database": "ncbi_mesh", "normalized_id": "D000105", "biotype": "chemical", "name": "Acetyl Coenzyme A", "accession": "@CHEMICAL_Acetyl_Coenzyme_A"}, "text": "acetyl-CoA", "locations": [{"offset": 18, "length": 10}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 75, "text": "Acyl-coenzyme A synthetase short-chain family member-2 (ACSS2) catalyzes the conversion of acetate to acetyl-CoA, regulating cholesterol metabolism. Given the discovery of a muscular dystrophy associated with 3-hydroxy-3-methyl-glutaryl-coenzyme A reductase (HMGCR), a key enzyme in cholesterol synthesis, we studied Acss2 in mice and the orthologous gene AcCoA in flies. Skeletal muscle from Acss2-/- mice showed atrophic fibers, lipid accumulation, and depleted NADH levels, while myoblasts from these mice displayed precocious differentiation. Exercise induced fatigue in the Acss2-/- mice, which was accentuated by inhibition of ATP-citrate lyase (ACLY) activity. AcCoA knockdown yielded reduced body sizes and locomotor defects in Drosophila. ACSS2 is vital for skeletal muscle function and merits study as a potential factor in muscle diseases related to cholesterol metabolism. Impact statement ACSS2 catalyzes the conversion of acetate to acetyl-CoA, regulating cholesterol metabolism. Given the increasingly apparent links between cholesterol metabolism and skeletal muscle function, we investigated ACSS2 deficiency in mouse and fly models. We identified defects in muscle morphology, muscle metabolism, and motor function. ACSS2 is vital for skeletal muscle.", "sentences": [], "annotations": [{"id": "38", "infons": {"identifier": "60525", "type": "Gene", "ncbi_homologene": "6469", "valid": true, "normalized": [60525], "database": "ncbi_gene", "normalized_id": 60525, "biotype": "gene", "name": "Acss2", "accession": "@GENE_ACSS2"}, "text": "ACSS2", "locations": [{"offset": 131, "length": 5}]}, {"id": "39", "infons": {"identifier": "MESH:D000085", "type": "Chemical", "valid": true, "normalized": ["D000085"], "database": "ncbi_mesh", "normalized_id": "D000085", "biotype": "chemical", "name": "Acetates", "accession": "@CHEMICAL_Acetates"}, "text": "acetate", "locations": [{"offset": 166, "length": 7}]}, {"id": "40", "infons": {"identifier": "MESH:D000105", "type": "Chemical", "valid": true, "normalized": ["D000105"], "database": "ncbi_mesh", "normalized_id": "D000105", "biotype": "chemical", "name": "Acetyl Coenzyme A", "accession": "@CHEMICAL_Acetyl_Coenzyme_A"}, "text": "acetyl-CoA", "locations": [{"offset": 177, "length": 10}]}, {"id": "41", "infons": {"identifier": "MESH:D002784", "type": "Chemical", "valid": true, "normalized": ["D002784"], "database": "ncbi_mesh", "normalized_id": "D002784", "biotype": "chemical", "name": "Cholesterol", "accession": "@CHEMICAL_Cholesterol"}, "text": "cholesterol", "locations": [{"offset": 200, "length": 11}]}, {"id": "42", "infons": {"identifier": "MESH:D009136", "type": "Disease", "valid": true, "normalized": ["D009136"], "database": "ncbi_mesh", "normalized_id": "D009136", "biotype": "disease", "name": "Muscular Dystrophies", "accession": "@DISEASE_Muscular_Dystrophies"}, "text": "muscular dystrophy", "locations": [{"offset": 249, "length": 18}]}, {"id": "43", "infons": {"identifier": "15357", "type": "Gene", "ncbi_homologene": "30994", "valid": true, "normalized": [15357], "database": "ncbi_gene", "normalized_id": 15357, "biotype": "gene", "name": "Hmgcr", "accession": "@GENE_HMGCR"}, "text": "3-hydroxy-3-methyl-glutaryl-coenzyme A reductase", "locations": [{"offset": 284, "length": 48}]}, {"id": "44", "infons": {"identifier": "15357", "type": "Gene", "ncbi_homologene": "30994", "valid": true, "normalized": [15357], "database": "ncbi_gene", "normalized_id": 15357, "biotype": "gene", "name": "Hmgcr", "accession": "@GENE_HMGCR"}, "text": "HMGCR", "locations": [{"offset": 334, "length": 5}]}, {"id": "45", "infons": {"identifier": "MESH:D002784", "type": "Chemical", "valid": true, "normalized": ["D002784"], "database": "ncbi_mesh", "normalized_id": "D002784", "biotype": "chemical", "name": "Cholesterol", "accession": "@CHEMICAL_Chole