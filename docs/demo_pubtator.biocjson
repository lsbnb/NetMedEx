423", "role1": {"identifier": "MESH:D013438", "type": "Chemical", "valid": true, "normalized": ["D013438"], "database": "ncbi_mesh", "normalized_id": "D013438", "biotype": "chemical", "name": "Sulfhydryl Compounds", "accession": "@CHEMICAL_Sulfhydryl_Compounds"}, "role2": {"identifier": "5291", "type": "Gene", "valid": true, "normalized": [5291], "database": "ncbi_gene", "normalized_id": 5291, "biotype": "gene", "name": "PIK3CB", "accession": "@GENE_PIK3CB"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "19,15"}]}, {"id": "R3", "infons": {"score": "0.6729", "role1": {"identifier": "207", "type": "Gene", "valid": true, "normalized": [207], "database": "ncbi_gene", "normalized_id": 207, "biotype": "gene", "name": "AKT1", "accession": "@GENE_AKT1"}, "role2": {"identifier": "5291", "type": "Gene", "valid": true, "normalized": [5291], "database": "ncbi_gene", "normalized_id": 5291, "biotype": "gene", "name": "PIK3CB", "accession": "@GENE_PIK3CB"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "17,15"}]}, {"id": "R4", "infons": {"score": "0.6821", "role1": {"identifier": "MESH:D013438", "type": "Chemical", "valid": true, "normalized": ["D013438"], "database": "ncbi_mesh", "normalized_id": "D013438", "biotype": "chemical", "name": "Sulfhydryl Compounds", "accession": "@CHEMICAL_Sulfhydryl_Compounds"}, "role2": {"identifier": "2185", "type": "Gene", "valid": true, "normalized": [2185], "database": "ncbi_gene", "normalized_id": 2185, "biotype": "gene", "name": "PTK2B", "accession": "@GENE_PTK2B"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "19,16"}]}, {"id": "R5", "infons": {"score": "0.9989", "role1": {"identifier": "MESH:D013438", "type": "Chemical", "valid": true, "normalized": ["D013438"], "database": "ncbi_mesh", "normalized_id": "D013438", "biotype": "chemical", "name": "Sulfhydryl Compounds", "accession": "@CHEMICAL_Sulfhydryl_Compounds"}, "role2": {"identifier": "5747", "type": "Gene", "valid": true, "normalized": [5747], "database": "ncbi_gene", "normalized_id": 5747, "biotype": "gene", "name": "PTK2", "accession": "@GENE_PTK2"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "4", "role": "19,14"}]}], "pmid": 40787751, "pmcid": null, "meta": {}, "date": "2025-08-11T00:00:00Z", "journal": "Adv Healthc Mater", "authors": ["Kim J", "Hur SS", "Park JH", "Ban MJ", "Kim JY", "Kim JH", "Choo JH", "Kim HW", "Lee JH", "Lee MR", "Hwang Y"], "relations_display": [{"name": "associate|@CHEMICAL_Sulfhydryl_Compounds|@GENE_AKT1"}, {"name": "associate|@CHEMICAL_Sulfhydryl_Compounds|@GENE_PIK3CB"}, {"name": "associate|@GENE_AKT1|@GENE_PIK3CB"}, {"name": "associate|@CHEMICAL_Sulfhydryl_Compounds|@GENE_PTK2B"}, {"name": "positive_correlate|@CHEMICAL_Sulfhydryl_Compounds|@GENE_PTK2"}]}, {"_id": "40800728|None", "id": "40800728", "infons": {}, "passages": [{"infons": {"journal": "Front Physiol;2025; 16 1639174. doi:10.3389/fphys.2025.1639174", "year": "2025", "article-id_pmc": "PMC12339569", "type": "title", "authors": "Duan Z, Gao H, Xiao X, He B, "}, "offset": 0, "text": "Comparison of passive and active motion: effect of myokine irisin on cartilage in knee osteoarthritis rats.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "myokine", "locations": [{"offset": 51, "length": 7}]}, {"id": "5", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "irisin", "locations": [{"offset": 59, "length": 6}]}, {"id": "6", "infons": {"identifier": "MESH:D020370", "type": "Disease", "valid": true, "normalized": ["D020370"], "database": "ncbi_mesh", "normalized_id": "D020370", "biotype": "disease", "name": "Osteoarthritis Knee", "accession": "@DISEASE_Osteoarthritis_Knee"}, "text": "knee osteoarthritis", "locations": [{"offset": 82, "length": 19}]}, {"id": "7", "infons": {"identifier": "10116", "type": "Species", "valid": true, "normalized": [10116], "database": "ncbi_taxonomy", "normalized_id": 10116, "biotype": "species", "name": "10116", "accession": null}, "text": "rats", "locations": [{"offset": 102, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 108, "text": "Introduction: Knee osteoarthritis (KOA) severely impacts knee joint health. Irisin, a myokine secreted during muscle contraction, varies with different exercise. This study investigates the chondroprotective effects of irisin induced by active and passive motion in a rat model of KOA. Methods: The rats were randomly allocated into control (CG), model (OAG), passive motion (PAG), and active motion groups (AAG). KOA was induced by intra-articular injections of monosodium iodoacetate (MIA) in all groups except CG. The PAG and AAG group underwent 4 weeks of treadmill exercise or quadriceps femoris muscle electroacupuncture. Changes in irisin, chondrocyte metabolic markers, and inflammatory factors were evaluated using ELISA, histology, immunohistochemistry, and qRT-PCR. Pearson correlation analysis was performed to assess the relationship between irisin and inflammatory factors. Results: One-week post-modeling, the OAG group showed the lowest hindlimb grip strength and quadriceps weight, chondrocyte number, collagen II expression and irisin levels, while displaying the highest levels of matrix-degrading enzymes (MMP-13, MMP-9, ADAMTS-5) and inflammatory factors (IL-6, TNF-alpha, IL-1beta, IL-18). However, after 4 weeks of intervention, both the PAG and AAG groups reversed these trends. The PAG group exhibited greater improvements in hindlimb grip strength and quadriceps weight compared to the AAG group. HE staining, toluidine blue and safranin O showed smoother cartilage surfaces, increased cartilage thickness and stronger safranin O staining in PAG and AAG groups compared to OAG. Collagen II protein expression was upregulated (P < 0.001), while MMP-13 was downregulated (P < 0.001), and the mRNA levels of MMP-9 and ADAMTS-5 were downregulated (P < 0.001). Moreover, inflammatory factors were lower in PAG than in AAG. Irisin expression was highest in the PAG group, followed by AAG, CG, and OAG group, in serum, synovial fluid and cartilage. Irisin levels were negatively correlated with IL-6, TNF-alpha, IL-1beta, and IL-18. Conclusion: Both active and passive motion inhibited cartilage degeneration in KOA rats, with passive exercise showing superior effects on muscle strength, irisin secretion, and downregulation of inflammatory cytokines. The chondroprotective and anti-inflammatory effects were positively correlated with increased irisin expression.", "sentences": [], "annotations": [{"id": "47", "infons": {"identifier": "MESH:D020370", "type": "Disease", "valid": true, "normalized": ["D020370"], "database": "ncbi_mesh", "normalized_id": "D020370", "biotype": "disease", "name": "Osteoarthritis Knee", "accession": "@DISEASE_Osteoarthritis_Knee"}, "text": "Knee osteoarthritis", "locations": [{"offset": 122, "length": 19}]}, {"id": "48", "infons": {"identifier": "MESH:D020370", "type": "Disease", "valid": true, "normalized": ["D020370"], "database": "ncbi_mesh", "normalized_id": "D020370", "biotype": "disease", "name": "Osteoarthritis Knee", "accession": "@DISEASE_Osteoarthritis_Knee"}, "text": "KOA", "locations": [{"offset": 143, "length": 3}]}, {"id": "49", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "irisin", "locations": [{"offset": 327, "length": 6}]}, {"id": "50", "infons": {"identifier": "10116", "type": "Species", "valid": true, "normalized": [10116], "database": "ncbi_taxonomy", "normalized_id": 10116, "biotype": "species", "name": "10116", "accession": null}, "text": "rat", "locations": [{"offset": 376, "length": 3}]}, {"id": "51", "infons": {"identifier": "MESH:D020370", "type": "Disease", "valid": true, "normalized": ["D020370"], "database": "ncbi_mesh", "normalized_id": "D020370", "biotype": "disease", "name": "Osteoarthritis Knee", "accession": "@DISEASE_Osteoarthritis_Knee"}, "text": "KOA", "locations": [{"offset": 389, "length": 3}]}, {"id": "52", "infons": {"identifier": "10116", "type": "Species", "valid": true, "normalized": [10116], "database": "ncbi_taxonomy", "normalized_id": 10116, "biotype": "species", "name": "10116", "accession": null}, "text": "rats", "locations": [{"offset": 407, "length": 4}]}, {"id": "53", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "OAG", "locations": [{"offset": 462, "length": 3}]}, {"id": "54", "infons": {"identifier": "MESH:D020370", "type": "Disease", "valid": true, "normalized": ["D020370"], "database": "ncbi_mesh", "normalized_id": "D020370", "biotype": "disease", "name": "Osteoarthritis Knee", "accession": "@DISEASE_Osteoarthritis_Knee"}, "text": "KOA", "locations": [{"offset": 522, "length": 3}]}, {"id": "55", "infons": {"identifier": "MESH:D019807", "type": "Chemical", "valid": true, "normalized": ["D019807"], "database": "ncbi_mesh", "normalized_id": "D019807", "biotype": "chemical", "name": "Iodoacetic Acid", "accession": "@CHEMICAL_Iodoacetic_Acid"}, "text": "monosodium iodoacetate", "locations": [{"offset": 571, "length": 22}]}, {"id": "56", "infons": {"identifier": "MESH:D019807", "type": "Chemical", "valid": true, "normalized": ["D019807"], "database": "ncbi_mesh", "normalized_id": "D019807", "biotype": "chemical", "name": "Iodoacetic Acid", "accession": "@CHEMICAL_Iodoacetic_Acid"}, "text": "MIA", "locations": [{"offset": 595, "length": 3}]}, {"id": "57", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 790, "length": 12}]}, {"id": "58", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": t