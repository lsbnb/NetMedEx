": "C030228", "biotype": "chemical", "name": "11-hydroxyprogesterone", "accession": "@CHEMICAL_11_hydroxyprogesterone"}, "role2": {"identifier": "53328", "type": "Gene", "valid": true, "normalized": [53328], "database": "ncbi_gene", "normalized_id": 53328, "biotype": "gene", "name": "Pgrmc1", "accession": "@GENE_PGRMC1"}, "type": "Association"}, "nodes": [{"refid": "9", "role": "21,54"}]}, {"id": "R11", "infons": {"score": "0.6918", "role1": {"identifier": "11651", "type": "Gene", "valid": true, "normalized": [11651], "database": "ncbi_gene", "normalized_id": 11651, "biotype": "gene", "name": "Akt1", "accession": "@GENE_AKT1"}, "role2": {"identifier": "53328", "type": "Gene", "valid": true, "normalized": [53328], "database": "ncbi_gene", "normalized_id": 53328, "biotype": "gene", "name": "Pgrmc1", "accession": "@GENE_PGRMC1"}, "type": "Association"}, "nodes": [{"refid": "10", "role": "42,54"}]}, {"id": "R12", "infons": {"score": "0.9925", "role1": {"identifier": "20111", "type": "Gene", "valid": true, "normalized": [20111], "database": "ncbi_gene", "normalized_id": 20111, "biotype": "gene", "name": "Rps6ka1", "accession": "@GENE_RPS6KA1"}, "role2": {"identifier": "53328", "type": "Gene", "valid": true, "normalized": [53328], "database": "ncbi_gene", "normalized_id": 53328, "biotype": "gene", "name": "Pgrmc1", "accession": "@GENE_PGRMC1"}, "type": "Association"}, "nodes": [{"refid": "11", "role": "41,54"}]}], "pmid": 41208560, "pmcid": null, "meta": {}, "date": "2025-12-01T00:00:00Z", "journal": "J Cachexia Sarcopenia Muscle", "authors": ["Lee SR", "Mukae M", "Kim G", "Park JE", "Sung YH", "Won YS", "Kim TW", "Kwun HJ", "Baek IJ", "Hong EJ"], "relations_display": [{"name": "associate|@CHEMICAL_Glucose|@DISEASE_Diabetes_Mellitus_Type_2"}, {"name": "associate|@GENE_PPP2R5D|@GENE_PGRMC1"}, {"name": "cause|@CHEMICAL_Fats|@DISEASE_Diabetes_Mellitus_Type_2"}, {"name": "associate|@DISEASE_Diabetes_Mellitus_Type_2|@GENE_PPP2R1A"}, {"name": "cause|@CHEMICAL_Streptozocin|@DISEASE_Diabetes_Mellitus_Type_2"}, {"name": "associate|@DISEASE_Diabetes_Mellitus_Type_2|@GENE_PGRMC1"}, {"name": "associate|@CHEMICAL_Glucose|@DISEASE_Insulin_Resistance"}, {"name": "associate|@GENE_PPP2R1A|@GENE_PGRMC1"}, {"name": "associate|@CHEMICAL_Glucose|@GENE_PGRMC1"}, {"name": "associate|@CHEMICAL_11_hydroxyprogesterone|@GENE_PGRMC1"}, {"name": "associate|@GENE_AKT1|@GENE_PGRMC1"}, {"name": "associate|@GENE_RPS6KA1|@GENE_PGRMC1"}]}, {"_id": "41258103|None", "id": "41258103", "infons": {}, "passages": [{"infons": {"journal": "Cell Mol Life Sci;2025Nov19; 82 (1) 412. doi:10.1007/s00018-025-05901-8", "year": "2025", "article-id_pmc": "PMC12630441", "type": "title", "authors": "Hu M, Xu Z, Sun J, Li L, Liu P, Zhou H, Qi X, Ren W, Liu Y, Chen S, Kuang R, Wang D, Guo Y, Sun G, Zhao S, Zhu M, Li L, Zhao Y, "}, "offset": 0, "text": "Myogenic enhancer snatching promotes adipogenic differentiation during epigenetic reprogramming mediated by lineage-specific transcription factors.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 148, "text": "The myoblast-to-adipocyte trans-differentiation model is crucial for studying the regulatory mechanisms underlying ectopic fat deposition and cell fate determination. However, the comprehensive dynamics of chromatin accessibility and interactions during this process remain largely unexplored. To address this, we performed an integrative analysis of bulk and single-cell multi-omics data (ATAC-seq, RNA-seq), and Hi-C data on an adipogenesis model in C2C12 myoblasts. Our findings revealed significant reprogramming of chromatin accessibility driven by adipogenic lineage-specific transcription factors (TFs), particularly Cebps and Stats, during trans-differentiation. Notably, 63.46% of the distal open chromatin regions with increased accessibility were shared between myogenesis and adipogenesis. Further joint analysis with Hi-C data suggests that these pre-established enhancers in myoblasts undergo a \"regulatory redirection,\" shifting their influence from myogenic to adipogenic genes-a phenomenon we termed \"enhancer snatch.\" This model was validated by knocking out a \"snatched\" enhancer (Enhancer-R/L), which was found to be a critical regulator of both Rbl1 and Lbp expression. Overall, our study uncovers a mechanism that pre-established enhancers in original cell lineage are predominantly utilized by lineage-specific TFs during chromatin reprogramming, thereby altering cell's differentiation trajectory.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "CVCL:0188", "type": "CellLine", "valid": true, "normalized": ["0188"], "database": "cvcl", "normalized_id": "0188", "biotype": "cellline", "name": "0188", "accession": null}, "text": "C2C12 myoblasts", "locations": [{"offset": 600, "length": 15}]}, {"id": "4", "infons": {"identifier": "5933", "type": "Gene", "ncbi_homologene": "2172", "valid": true, "normalized": [5933], "database": "ncbi_gene", "normalized_id": 5933, "biotype": "gene", "name": "RBL1", "accession": "@GENE_RBL1"}, "text": "Rbl1", "locations": [{"offset": 1314, "length": 4}]}, {"id": "5", "infons": {"identifier": "3929", "type": "Gene", "ncbi_homologene": "3055", "valid": true, "normalized": [3929], "database": "ncbi_gene", "normalized_id": 3929, "biotype": "gene", "name": "LBP", "accession": "@GENE_LBP"}, "text": "Lbp", "locations": [{"offset": 1323, "length": 3}]}], "relations": []}], "relations": [], "pmid": 41258103, "pmcid": null, "meta": {}, "date": "2025-11-19T00:00:00Z", "journal": "Cell Mol Life Sci", "authors": ["Hu M", "Xu Z", "Sun J", "Li L", "Liu P", "Zhou H", "Qi X", "Ren W", "Liu Y", "Chen S", "Kuang R", "Wang D", "Guo Y", "Sun G", "Zhao S", "Zhu M", "Li L", "Zhao Y"], "relations_display": []}, {"_id": "41266379|None", "id": "41266379", "infons": {}, "passages": [{"infons": {"journal": "NPJ Aging;2025Nov20; 11 (1) 91. doi:10.1038/s41514-025-00280-7", "year": "2025", "article-id_pmc": "PMC12635253", "type": "title", "authors": "Dakhovnik A, Mantovani M, Knufinke M, Br&#xfc;gger V, Pramono I, Statzer C, Saravi B, Demidenko O, Budovskaya Y, R&#xfc;mmelein CB, Chabloz S, Ewald CY, "}, "offset": 0, "text": "A collagen amino acid composition supplementation reduces biological age in humans and increases health and lifespan in vivo.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "humans", "locations": [{"offset": 76, "length": 6}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 126, "text": "Collagen supplementation has gained attention with increasing claims regarding its beneficial effects on healthy aging based on clinical observations and lifespan extension in pre-clinical models; however, how and which part of an ingested collagen promotes healthy longevity is unknown. Here, we identified the minimal required unit of ingested collagen, which consists of the proper ratio of three glycine to one proline to one hydroxyproline that was sufficient to increase the motility-healthspan and lifespan of C. elegans, as well as collagen homeostasis in human fibroblasts in vitro. Supplementation in 20-month-old mice improved grip strength and prevented age-related fat accumulation. In a clinical observational trial (ISRCTN93189645, 03.07.2025), oral supplementation in humans demonstrated improved skin features within three months and a reduction in biological age by 1.4 years (p = 0.04) within 6 months. Thus, a ratio of three amino acids elicits evolutionarily conserved health benefits from ingested collagens.", "sentences": [], "annotations": [{"id": "9", "infons": {"identifier": "MESH:D005998", "type": "Chemical", "valid": true, "normalized": ["D005998"], "database": "ncbi_mesh", "normalized_id": "D005998", "biotype": "chemical", "name": "Glycine", "accession": "@CHEMICAL_Glycine"}, "text": "glycine", "locations": [{"offset": 526, "length": 7}]}, {"id": "10", "infons": {"identifier": "MESH:D011392", "type": "Chemical", "valid": true, "normalized": ["D011392"], "database": "ncbi_mesh", "normalized_id": "D011392", "biotype": "chemical", "name": "Proline", "accession": "@CHEMICAL_Proline"}, "text": "proline", "locations": [{"offset": 541, "length": 7}]}, {"id": "11", "infons": {"identifier": "MESH:D006909", "type": "Chemical", "valid": true, "normalized": ["D006909"], "database": "ncbi_mesh", "normalized_id": "D006909", "biotype": "chemical", "name": "Hydroxyproline", "accession": "@CHEMICAL_Hydroxyproline"}, "text": "hydroxyproline", "locations": [{"offset": 556, "length": 14}]}, {"id": "12", "infons": {"identifier": "328850", "type": "Species", "valid": true, "normalized": [328850], "database": "ncbi_taxonomy", "normalized_id": 328850, "biotype": "species", "name": "328850", "accession": null}, "text": "C. elegans", "locations": [{"offset": 643, "length": 10}]}, {"id": "13", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 690, "length": 5}]}, {"id": "14", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 750, "length": 4}]}, {"id": "15", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "humans", "locations": [{"offset": 910, "length": 6}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.3938", "role1": {"identifier": "MESH:D006909", "type": "Chemical", "valid": true, "normalized": ["D006909"], "database": "ncbi_mesh", "normalized_id": "D006909", "biotype": "chemical", "name": "Hydroxyproline", "accession": "@CHEMICAL_Hydroxyproline"}, "role2": {"identifier": "MESH:D011392", "type": "Chemical", "valid": true, "normalized": ["D011392"], "database": "ncbi_mesh", "normalized_id": "D011392", "biotype": "chemical", "name": "Proline", "accession": "@CHEMICAL_Proline"}, "type": "Bind"}, "nodes": [{"refid": "0", "role": "3,2"}]}, {"id": "R2", "infons": {"score": "0.5722", "role1": {"identifier": "MESH:D005998", "type": "Chemical", "valid": true, "normalized": ["D005998"], "database": "ncbi_mesh", "normalized_id": "D005998", "biotype": "chemical", "name": "Glycine", "accession": "@CHEMICAL_Glycine"}, "role2": {"identifier": "MESH:D006909", "type": "Chemical", "valid": true, "normalized": ["D006909"], "database": "ncbi_mesh", "normalized_id": "D006909", "biotype": "chemical", "name": "Hydroxyproline", "accession": "@CHEMICAL_Hydroxyproline"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "1", "role": "1,3"}]}], "pmid": 41266379, "pmcid": null, "meta": {}, "date": "2025-11-20T00:00:00Z", "journal": "NPJ Aging", "authors": ["Dakhovnik A", "Mantovani M", "Knufinke M", "Brügger V", "Pramono I", "Statzer C", "Saravi B", "Demidenko O", "Budovskaya Y", "Rümmelein CB", "Chabloz S", "Ewald CY"], "relations_display": [{"name": "interact|@CHEMICAL_Hydroxyproline|@CHEMICAL_Proline"}, {"name": "positive_correlate|@CHEMICAL_Glycine|@CHEMICAL_Hydroxyproline"}]}, {"_id": "41271737|None", "id": "41271737", "infons": {}, "passages": [{"infons": {"journal": "Nat Commun;2025Nov21. doi:10.1038/s41467-025-66582-2", "year": "2025", "type": "title", "authors": "Liu Y, Sch&#xfc;ler SC, Dumontier S, Balg F, Bedard S, Desgeorges T, Feige JN, Boudreault PL, Bentzinger CF, "}, "offset": 0, "text": "TGFbeta-Smad3 signaling restores cell-autonomous Srsf1-mediated splicing of fibronectin in aged skeletal muscle stem cells.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "21803", "type": "Gene", "ncbi_homologene": "540", "valid": true, "normalized": [21803], "database": "ncbi_gene", "normalized_id": 21803, "biotype": "gene", "name": "Tgfb1", "accession": "@GENE_TGFB1"}, "text": "TGFbeta", "locations": [{"offset": 0, "length": 7}]}, {"id": "5", "infons": {"identifier": "17127", "type": "Gene", "ncbi_homologene": "55937", "valid": true, "normalized": [17127], "database": "ncbi_gene", "normalized_id": 17127, "biotype": "gene", "name": "Smad3", "accession": "@GENE_SMAD3"}, "text": "Smad3", "locations": [{"offset": 8, "length": 5}]}, {"id": "6", "infons": {"identifier": "110809", "type": "Gene", "ncbi_homologene": "31411", "valid": true, "normalized": [110809], "database": "ncbi_gene", "normalized_id": 110809, "biotype": "gene", "name": "Srsf1", "accession": "@GENE_SRSF1"}, "text": "Srsf1", "locations": [{"offset": 49, "length": 5}]}, {"id": "7", "infons": {"identifier": "14268", "type": "Gene", "ncbi_homologene": "1533", "valid": true, "normalized": [14268], "database": "ncbi_gene", "normalized_id": 14268, "biotype": "gene", "name": "Fn1", "accession": "@GENE_FN1"}, "text": "fibronectin", "locations": [{"offset": 76, "length": 11}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 124, "text": "Loss of Fibronectin (FN) from the skeletal muscle stem cell (MuSC) niche represents a root cause of regenerative failure in aging. While FN has pleiotropic functions during healthy skeletal muscle regeneration, it remains unclear how aging affects its spatiotemporal specificity for MuSCs. Here, we demonstrate that activated MuSCs secrete an autoregulatory FN splice variant containing the EDB extra domain (EDB(+) FN), which is not expressed by accessory cells in the niche. EDB(+) FN splicing in MuSCs depends on serine/arginine-rich splicing factor 1 (Srsf1) whose promoter is controlled by Smad3. EDB(+) FN knockdown or downregulation in aging affects MuSC proliferation through aberrant integrin signaling and impairs skeletal muscle regeneration. During a defined regeneration interval in aged mice, Smad3 activation using transforming growth factor-beta 1 (TGFbeta1) improves MuSC function and skeletal muscle repair by stimulating EDB(+) FN secretion. Altogether, we identify and characterize the TGFbeta1-Smad3-Srsf1-EDB(+) FN pathway as a therapeutic target for age-associated regenerative failure.", "sentences": [], "annotations": [{"id": "35", "infons": {"identifier": "14268", "type": "Gene", "ncbi_homologene": "1533", "valid": true, "normalized": [14268], "database": "ncbi_gene", "normalized_id": 14268, "biotype": "gene", "name": "Fn1", "accession": "@GENE_FN1"}, "text": "Fibronectin", "locations": [{"offset": 132, "length": 11}]}, {"id": "36", "infons": {"identifier": "14268", "type": "Gene", "ncbi_homologene": "1533", "valid": true, "normalized": [14268], "database": "ncbi_gene", "normalized_id": 14268, "biotype": "gene", "name": "Fn1", "accession": "@GENE_FN1"}, "text": "FN", "locations": [{"offset": 145, "length": 2}]}, {"id": "37", "infons": {"identifier": "MESH:D051437", "type": "Disease", "valid": true, "normalized": ["D051437"], "database": "ncbi_mesh", "normalized_id": "D051437", "biotype": "disease", "name": "Renal Insufficiency", "accession": "@DISEASE_Renal_Insufficiency"}, "text": "regenerative failure", "locations": [{"offset": 224, "length": 20}]}, {"id": "38", "infons": {"identifier": "14268", "type": "Gene", "ncbi_homologene": "1533", "valid": true, "normalized": [14268], "database": "ncbi_gene", "normalized_id": 14268, "biotype": "gene", "name": "Fn1", "accession": "@GENE_FN1"}, "text": "FN", "locations": [{"offset": 261, "length": 2}]}, {"id": "39", "infons": {"identifier": "14268", "type": "Gene", "ncbi_homologene": "1533", "valid": true, "normalized": [14268], "database": "ncbi_gene", "normalized_id": 14268, "biotype": "gene", "name": "Fn1", "accession": "@GENE_FN1"}, "text": "FN", "locations": [{"offset": 482, "length": 2}]}, {"i