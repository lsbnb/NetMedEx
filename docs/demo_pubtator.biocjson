e": "0.9981", "role1": {"identifier": "MESH:D000082", "type": "Chemical", "valid": true, "normalized": ["D000082"], "database": "ncbi_mesh", "normalized_id": "D000082", "biotype": "chemical", "name": "Acetaminophen", "accession": "@CHEMICAL_Acetaminophen"}, "role2": {"identifier": "3064", "type": "Gene", "valid": true, "normalized": [3064], "database": "ncbi_gene", "normalized_id": 3064, "biotype": "gene", "name": "HTT", "accession": "@GENE_HTT"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "36,30"}]}, {"id": "R5", "infons": {"score": "0.9997", "role1": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "role2": {"identifier": "3064", "type": "Gene", "valid": true, "normalized": [3064], "database": "ncbi_gene", "normalized_id": 3064, "biotype": "gene", "name": "HTT", "accession": "@GENE_HTT"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "33,30"}]}, {"id": "R6", "infons": {"score": "0.9692", "role1": {"identifier": "OMIM:614878", "type": "Disease", "valid": true, "normalized": ["614878"], "database": "omim", "normalized_id": "614878", "biotype": "disease", "name": "614878", "accession": "@DISEASE_614878"}, "role2": {"identifier": "3064", "type": "Gene", "valid": true, "normalized": [3064], "database": "ncbi_gene", "normalized_id": 3064, "biotype": "gene", "name": "HTT", "accession": "@GENE_HTT"}, "type": "Association"}, "nodes": [{"refid": "5", "role": "35,30"}]}, {"id": "R7", "infons": {"score": "0.9997", "role1": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "role2": {"identifier": "54902", "type": "Gene", "valid": true, "normalized": [54902], "database": "ncbi_gene", "normalized_id": 54902, "biotype": "gene", "name": "TTC19", "accession": "@GENE_TTC19"}, "type": "Association"}, "nodes": [{"refid": "6", "role": "33,31"}]}], "pmid": 40703651, "pmcid": null, "meta": {}, "date": "2025-07-09T00:00:00Z", "journal": "Front Cell Dev Biol", "authors": ["Chen YW", "He S", "Wang Y", "Hu LY", "Chen QK", "Liu SY"], "relations_display": [{"name": "associate|@DISEASE_Diabetic_Nephropathies|@GENE_HTT"}, {"name": "associate|@DISEASE_614878|@GENE_TTC19"}, {"name": "associate|@DISEASE_Diabetic_Nephropathies|@GENE_TTC19"}, {"name": "associate|@CHEMICAL_Acetaminophen|@GENE_HTT"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_HTT"}, {"name": "associate|@DISEASE_614878|@GENE_HTT"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_TTC19"}]}, {"_id": "40707473|None", "id": "40707473", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Nucleic acid aptamers in orthopedic diseases: promising therapeutic agents for bone disorders.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "orthopedic diseases", "locations": [{"offset": 25, "length": 19}]}, {"id": "3", "infons": {"identifier": "MESH:D001847", "type": "Disease", "valid": true, "normalized": ["D001847"], "database": "ncbi_mesh", "normalized_id": "D001847", "biotype": "disease", "name": "Bone Diseases", "accession": "@DISEASE_Bone_Diseases"}, "text": "bone disorders", "locations": [{"offset": 79, "length": 14}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 95, "text": "Precision medicine has become a cornerstone in modern therapeutic strategies, with nucleic acid aptamers emerging as pivotal tools due to their unique properties. These oligonucleotide fragments, selected through the Systematic Evolution of Ligands by Exponential Enrichment process, exhibit high affinity and specificity toward their targets, such as DNA, RNA, proteins, and other biomolecules. Nucleic acid aptamers offer significant advantages over traditional therapeutic agents, including superior biological stability, minimal immunogenicity, and the capacity for universal chemical modifications that enhance their in vivo performance and targeting precision. In the realm of osseous tissue repair and regeneration, a complex physiological process essential for maintaining skeletal integrity, aptamers have shown remarkable potential in influencing molecular pathways crucial for bone regeneration, promoting osteogenic differentiation and supporting osteoblast survival. By engineering aptamers to regulate inflammatory responses and facilitate the proliferation and differentiation of fibroblasts, these oligonucleotides can be integrated into advanced drug delivery systems, significantly improving bone repair efficacy while minimizing adverse effects. Aptamer-mediated strategies, including the use of siRNA and miRNA mimics or inhibitors, have shown efficacy in enhancing bone mass and microstructure. These approaches hold transformative potential for treating a range of orthopedic conditions like osteoporosis, osteosarcoma, and osteoarthritis. This review synthesizes the molecular mechanisms and biological roles of aptamers in orthopedic diseases, emphasizing their potential to drive innovative and effective therapeutic interventions.", "sentences": [], "annotations": [{"id": "11", "infons": {"identifier": "MESH:D009841", "type": "Chemical", "valid": true, "normalized": ["D009841"], "database": "ncbi_mesh", "normalized_id": "D009841", "biotype": "chemical", "name": "Oligonucleotides", "accession": "@CHEMICAL_Oligonucleotides"}, "text": "oligonucleotide", "locations": [{"offset": 264, "length": 15}]}, {"id": "12", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 1111, "length": 12}]}, {"id": "13", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Aptamer", "locations": [{"offset": 1360, "length": 7}]}, {"id": "14", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "osteoporosis", "locations": [{"offset": 1609, "length": 12}]}, {"id": "15", "infons": {"identifier": "MESH:D012516", "type": "Disease", "valid": true, "normalized": ["D012516"], "database": "ncbi_mesh", "normalized_id": "D012516", "biotype": "disease", "name": "Osteosarcoma", "accession": "@DISEASE_Osteosarcoma"}, "text": "osteosarcoma", "locations": [{"offset": 1623, "length": 12}]}, {"id": "16", "infons": {"identifier": "MESH:D010003", "type": "Disease", "valid": true, "normalized": ["D010003"], "database": "ncbi_mesh", "normalized_id": "D010003", "biotype": "disease", "name": "Osteoarthritis", "accession": "@DISEASE_Osteoarthritis"}, "text": "osteoarthritis", "locations": [{"offset": 1641, "length": 14}]}, {"id": "17", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "orthopedic diseases", "locations": [{"offset": 1742, "length": 19}]}], "relations": []}], "relations": [], "pmid": 40707473, "pmcid": null, "meta": {}, "date": "2025-07-24T00:00:00Z", "journal": "Bone Res", "authors": ["He Z", "Peng Q", "Bin W", "Zhao L", "Chen Y", "Zhang Y", "Yang W", "Yan X", "Liu H"], "relations_display": []}, {"_id": "40710303|None", "id": "40710303", "infons": {}, "passages": [{"infons": {"journal": "Cells;2025Jul09; 14 (14) . doi:10.3390/cells14141050", "year": "2025", "article-id_pmc": "PMC12293372", "type": "title", "authors": "Lee HJ, Kim D, Jung Y, Oh S, Kim CH, Jang A, "}, "offset": 0, "text": "Horse Meat Hydrolysate Ameliorates Dexamethasone-Induced Muscle Atrophy in C57BL/6 Mice via the AKT/FoxO3a/mTOR Pathway.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "text": "Dexamethasone", "locations": [{"offset": 35, "length": 13}]}, {"id": "6", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "Muscle Atrophy", "locations": [{"offset": 57, "length": 14}]}, {"id": "7", "infons": {"identifier": "CVCL:C0MU", "type": "CellLine", "valid": false, "normalized": ["C0MU"], "database": "cvcl", "normalized_id": "C0MU", "biotype": "cellline", "name": "C0MU", "accession": null}, "text": "C57BL/6", "locations": [{"offset": 75, "length": 7}]}, {"id": "8", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "Mice", "locations": [{"offset": 83, "length": 4}]}, {"id": "9", "infons": {"identifier": "100051341", "type": "Gene", "valid": true, "normalized": [100051341], "database": "ncbi_gene", "normalized_id": 100051341, "biotype": "gene", "name": "MTOR", "accession": "@GENE_MTOR"}, "text": "mTOR", "locations": [{"offset": 107, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 121, "text": "As life expectancy increases, muscle atrophy, characterized by a decline in muscle mass and strength that can impair mobility, has become a growing concern, highlighting the potential of protein supplementation as a promising intervention strategy. A horse meat hydrolysate, with a molecular weight of less than 3 kDa, derived from m. biceps femoris and produced using the food-grade enzyme Alcalase  (A4 < 3kDa) was evaluated for its efficacy in mitigating dexamethasone-induced muscle atrophy, a widely accepted model for studying catabolic muscle loss. Administered orally to C57BL/6 mice at dosages of 200 mg/kg or 500 mg/kg body weight for 35 days, A4 < 3kDa effectively countered the weight loss induced by dexamethasone in the whole body, quadriceps, tibialis anterior, and gastrocnemius muscles. Moreover, it increased muscle fiber cross-sectional area and grip strength. These effects were attributed to increased protein synthesis via the protein kinase B (AKT)/forkhead box O3 (FoxO3a)/mammalian target of rapamycin (mTOR) signaling pathway. A4 < 3kDa augmented the phosphorylation of key components of the signaling pathways associated with muscle atrophy, resulting in reduced mRNA expression of Atrogin-1 and MuRF-1. These findings demonstrate the potential of A4 < 3kDa as a functional food ingredient for preventing muscle atrophy.", "sentences": [], "annotations": [{"id": "26", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 151, "length": 14}]}, {"id": "27", "infons": {"identifier": "MESH:C536030", "type": "Disease", "valid": true, "normalized": ["C536030"], "database": "ncbi_mesh", "normalized_id": "C536030", "biotype": "disease", "name": "MASS syndrome", "accession": "@DISEASE_MASS_syndrome"}, "text": "decline in muscle mass", "locations": [{"offset": 186, "length": 22}]}, {"id": "28", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "A4", "locations": [{"offset": 523, "length": 2}]}, {"id": "29", "infons": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "text": "dexamethasone", "locations": [{"offset": 579, "length": 13}]}, {"id": "30", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 601, "length": 14}]}, {"id": "31", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle loss", "locations": [{"offset": 664, "length": 11}]}, {"id": "32", "infons": {"identifier": "CVCL:C0MU", "type": "CellLine", "valid": false, "normalized": ["C0MU"], "database": "cvcl", "normalized_id": "C0MU", "biotype": "cellline", "name": "C0MU", "accession": null}, "text": "C57BL/6", "locations": [{"offset": 700, "length": 7}]}, {"id": "33", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 708, "length": 4}]}, {"id": "34", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "A4", "locations": [{"offset": 775, "length": 2}]}, {"id": "35", "infons": {"identifier": "MESH:D015431", "type": "Disease", "valid": true, "normalized": ["D015431"], "database": "ncbi_mesh", "normalized_id": "D015431", "biotype": "disease", "name": "Weight Loss", "accession": "@DISEASE_Weight_Loss"}, "text": "weight loss", "locations": [{"offset": 811, "length": 11}]}, {"id": "36", "infons": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "text": "dexamethasone", "locations": [{"offset": 834, "length": 13}]}, {"id": "37", "infons": {"identifier": "100066558", "type": "Gene", "valid": true, "normalized": [100066558], "database": "ncbi_gene", "normalized_id": 100066558, "biotype": "gene", "name": "FOXO3", "accession": "@GENE_FOXO3"}, "text": "forkhead box O3", "locations": [{"offset": 1093, "length": 15}]}, {"id": "38", "infons": {"identifier": "100051341", "type": "Gene", "valid": true, "normalized": [100051341], "database": "ncbi_gene", "normalized_id": 100051341, "biotype": "gene", "name": "MTOR", "accession": "@GENE_MTOR"}, "text": "mTOR", "locations": [{"offset": 1149, "length": 4}]}, {"id": "39", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 1274, "length": 14}]}, {"id": "40", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "A4", "locations": [{"offset": 1396, "length": 2}]}, {"id": "41", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 1453, "length": 14}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.999", "role1": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "role2": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "0", "role": "15,20"}]}, {"id": "R2", "infons": {"score": "0.9941", "role1": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "role2": {"identifier": "100051341", "type": "Gene", "valid": true, "normalized": [100051341], "database": "ncbi_gene", "normalized_id": 100051341, "biotype": "gene", "name": "MTOR", "accession": "@GENE_MTOR"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "20,17"}]}, {"id": "R3", "infons": {"score": "0.9978", "role1": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "role2": {"identifier": "MESH:D015431", "type": "Disease", "valid": true, "normalized": ["D015431"], "database": "ncbi_mesh", "normalized_id": "D015431", "biotype": "disease", "name": "Weight Loss", "accession": "@DISEASE_Weight_Loss"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "2", "role": "15,14"}]}], "pmid": 40710303, "pmcid": null, "meta": {}, "date": "2025-07-09T00:00:00Z", "journal": "Cells", "authors": ["Lee HJ", "Kim D", "Jung Y", "Oh S", "Kim CH", "Jang A"], "relations_display": [{"name": "cause|@CHEMICAL_Dexamethasone|@DISEASE_Muscular_Atrophy"}, {"name": "associate|@DISEASE_Muscular_Atrophy|@GENE_MTOR"}, {"name": "cause|@CHEMICAL_Dexamethasone|@DISEASE_Weight_Loss"}]}, {"_id": "40735206|None", "id": "40735206", "infons": {}, "passages": [{"infons": {"journal": "Front Public Health;2025; 13 1613435. doi:10.3389/fpubh.2025.1613435", "year": "2025", "article-id_pmc": "PMC12303945", "type": "title", "authors": "Wang P, Chen W, Fang H, Xu L, Zhao J, Huang J, "}, "offset": 0, "text": "Volatile organic compounds exposure associated with sarcopenia in US adults from NHANES 2011-2018.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D055549", "type": "Chemical", "valid": true, "normalized": ["D055549"], "database": "ncbi_mesh", "normalized_id": "D055549", "biotype": "chemical", "name": "Volatile Organic Compounds", "accession": "@CHEMICAL_Volatile_Organic_Compounds"}, "text": "Volatile organic compounds", "locations": [{"offset": 0, "length": 26}]}, {"id": "3", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 52, "length": 10}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 99, "text": "Background: Volatile organic compounds (VOCs) are emerging environmental pollutants linked to various health problems. However, the relationship between exposure to urinary volatile organic compound metabolites (mVOCs) and sarcopenia remains unclear. Methods: We used data from the National Health and Nutrition Examination Survey (NHANES 2011-2018) to assess the association between mVOCs and sarcopenia through multivariable logistic regression and restricted cubic spline (RCS) regression. We also employed Weighted Quantile Sum (WQS) regression model, a high-dimensional statistical approach used to evaluate the joint effects of multiple exposures, and Bayesian Kernel Machine regression (BKMR) model, a combination of Bayesian and statistical learning methods, to assess the mixture effects of mVOCs on sarcopenia risk. These methods account for non-linearity, collinearity, and dimensionality in exposure data. Mediation analysis was used to identify metabolic, endocrine, and inflammatory mediators in these associations. Subgroup analyses were conducted by gender and age. Network pharmacology analysis was performed to identify potential pathways and targets. Results: A total of 2,898 participants were included, with 145 (8%) diagnosed with sarcopenia. Logistic regression showed a positive correlation between mVOCs (3,4-MHA, ATCA, CEMA, CYMA, 2HPMA, 3HPMA, MHBMA3, and PGA) and sarcopenia. RCS results confirmed linear dose-response associations (P for overall <0.05, P for non-linear >=0.05). Subgroup analysis indicated stronger associations in older participants. The WQS and BKMR models consistently showed a positive link between VOC exposure and sarcopenia. Mediation analysis identified alkaline phosphatase (ALP), white blood cell count (WBC), systemic immune-inflammation index (SII), and vitamin D as mediators. Network analysis revealed significant enrichment in the endocrine resistance pathway. Conclusions: Our findings suggest that co-exposure to VOCs is associated with increased sarcopenia risk, potentially through disruption of endocrine and inflammatory pathways, as indicated by elevated alkaline phosphatase (ALP), white blood cell count (WBC), the systemic immune-inflammation index (SII), and reduced vitamin D levels, with enrichment observed in the endocrine resistance signaling pathway.", "sentences": [], "annotations": [{"id": "38", "infons": {"identifier": "MESH:D055549", "type": "Chemical", "valid": true, "normalized": ["D055549"], "database": "ncbi_mesh", "normalized_id": "D055549", "biotype": "chemical", "name": "Volatile Organic Compounds", "accession": "@CHEMICAL_Volatile_Organic_Compounds"}, "text": "Volatile organic compounds", "locations": [{"offset": 111, "length": 26}]}, {"id": "39", "infons": {"identifier": "MESH:D055549", "type": "Chemical", "valid": true, "normalized": ["D055549"], "database": "ncbi_mesh", "normalized_id": "D055549", "biotype": "chemical", "name": "Volatile Organic Compounds", "accession": "@CHEMICAL_Volatile_Organic_Compounds"}, "text": "VOCs", "locations": [{"offset": 139, "length": 4}]}, {"id": "40", "infons": {"identifier": "MESH:D055549", "type": "Chemical", "valid": true, "normalized": ["D055549"], "database": "ncbi_mesh", "normalized_id": "D055549", "biotype": "chemical", "name": "Volatile Organic Compounds", "accession": "@CHEMICAL_Volatile_Organic_Compounds"}, "text": "volatile organic compound", "locations": [{"offset": 272, "length": 25}]}, {"id": "41", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "mVOCs", "locations": [{"offset": 311, "length": 5}]}, {"id": "42", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 322, "length": 10}]}, {"id": "43", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "mVOCs", "locations": [{"offset": 483, "length": 5}]}, {"id": "44", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 493, "length": 10}]}, {"id": "45", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "mVOCs", "locations": [{"offset": 899, "length": 5}]}, {"id": "46", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 908, "length": 10}]}, {"id": "47", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 1083, "length": 12}]}, {"id": "48", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 1352, "length": 10}]}, {"id": "49", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "mVOCs", "locations": [{"offset": 1422, "length": 5}]}, {"id": "50", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "3,4-MHA", "locations": [{"offset": 1429, "length": 7}]}, {"id": "51", "infons": {"identifier": "MESH:C020213", "type": "Chemical", "valid": true, "normalized": ["C020213"], "database": "ncbi_mesh", "normalized_id": "C020213", "biotype": "chemical", "name": "arginine thiazolidinecarboxylate", "accession": "@CHEMICAL_arginine_thiazolidinecarboxylate"}, "text": "ATCA", "locations": [{"offset": 1438, "length": 4}]}, {"id": "52", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "CEMA", "locations": [{"offset": 1444, "length": 4}]}, {"id": "53", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "CYMA", "locations": [{"offset": 1450, "length": 4}]}, {"id": "54", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "2HPMA", "locations": [{"offset": 1456, "length": 5}]}, {"id": "55", "infons": {"identifier": "MESH:C001423", "type": "Chemical", "valid": true, "normalized": ["C001423"], "database": "ncbi_mesh", "normalized_id": "C001423", "biotype": "chemical", "name": "S-(3-hydroxypropyl)cysteine N-acetate", "accession": "@CHEMICAL_S_(3_hydroxypropyl)cysteine_N_acetate"}, "text": "3HPMA", "locations": [{"offset": 1463, "length": 5}]}, {"id": "56", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 1491, "length": 10}]}, {"id": "57", "infons": {"identifier": "MESH:D055549", "type": "Chemical", "valid": true, "normalized": ["D055549"], "database": "ncbi_mesh", "normalized_id": "D055549", "biotype": "chemical", "name": "Volatile Organic Compounds", "accession": "@CHEMICAL_Volatile_Organic_Compounds"}, "text": "VOC", "locations": [{"offset": 1748, "length": 3}]}, {"id": "58", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 1765, "length": 10}]}, {"id": "59", "infons": {"identifier": "250", "type": "Gene", "ncbi_homologene": "122414", "valid": true, "normalized": [250], "database": "ncbi_gene", "normalized_id": 250, "biotype": "gene", "name": "ALPP", "accessi