pe": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "3569", "type": "Gene", "valid": true, "normalized": [3569], "database": "ncbi_gene", "normalized_id": 3569, "biotype": "gene", "name": "IL6", "accession": "@GENE_IL6"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "27,25"}]}], "pmid": 41366614, "pmcid": null, "meta": {}, "date": "2025-12-09T00:00:00Z", "journal": "High Blood Press Cardiovasc Prev", "authors": ["Moscucci F", "Baratta F", "Bucciarelli V", "Mattioli AV", "Pinti M", "Zanini G", "Sciomer S", "Gallina S", "Piccirillo G", "Desideri G"], "relations_display": [{"name": "associate|@DISEASE_Inflammation|@GENE_CRP"}, {"name": "associate|@DISEASE_Inflammation|@GENE_IL6"}]}, {"_id": "41369335|None", "id": "41369335", "infons": {}, "passages": [{"infons": {"journal": "Cells;2025Nov23; 14 (23) . doi:10.3390/cells14231846", "year": "2025", "type": "title", "authors": "Guti&#xe9;rrez-Calabr&#xe9;s E, Campillo S, Alcalde-Est&#xe9;vez E, Cuevas-Delgado P, Barbas C, Garc&#xed;a-Villoria S, Silvestre-Vargas A, Griera M, de Frutos S, Ruiz-Torres MP, Rodr&#xed;guez-Puyol D, Calleros L, "}, "offset": 0, "text": "Role of Calpains in Uremia-Related Functional and Structural Muscle Changes: Protective Effect of Calpastatin Overexpression.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:D014511", "type": "Disease", "valid": true, "normalized": ["D014511"], "database": "ncbi_mesh", "normalized_id": "D014511", "biotype": "disease", "name": "Uremia", "accession": "@DISEASE_Uremia"}, "text": "Uremia", "locations": [{"offset": 20, "length": 6}]}, {"id": "4", "infons": {"identifier": "MESH:D019042", "type": "Disease", "valid": true, "normalized": ["D019042"], "database": "ncbi_mesh", "normalized_id": "D019042", "biotype": "disease", "name": "Muscle Neoplasms", "accession": "@DISEASE_Muscle_Neoplasms"}, "text": "Muscle", "locations": [{"offset": 61, "length": 6}]}, {"id": "5", "infons": {"identifier": "12380", "type": "Gene", "ncbi_homologene": "7658", "valid": true, "normalized": [12380], "database": "ncbi_gene", "normalized_id": 12380, "biotype": "gene", "name": "Cast", "accession": "@GENE_CAST"}, "text": "Calpastatin", "locations": [{"offset": 98, "length": 11}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 126, "text": "Sarcopenia, the progressive loss of muscle mass and strength, is a common complication in patients with chronic kidney disease (CKD). This condition arises from a combination of factors including reduced physical activity, insufficient protein intake, hyperphosphatemia, chronic inflammation, and uremia itself; however, the underlying molecular mechanisms remain poorly understood. Proteolysis in skeletal muscle is primarily controlled by the ubiquitin-proteasome system, autophagy-lysosome system, and calpains (CAPNs) cysteine proteases, which degrade structural proteins and mediate cell signaling. This study aims to investigate the role of CAPNs in CKD-associated muscle deterioration. CKD was induced in mice through an adenine-rich diet for 2, 4 and 6 weeks. The involvement of CAPNs in CKD-related sarcopenia was assessed using mice that overexpressed the CAPNs endogenous inhibitor, calpastatin (CAST). Gastrocnemius muscle strength, structural integrity, and function were evaluated. Mice with CKD showed elevated CAPNs, particularly CAPN2, expression and activity in the gastrocnemius, in parallel with significant muscle deterioration, including strength loss, structural damage, and impaired muscle performance. Overexpression of CAST prevented muscle strength loss, improved muscle function and structure without affecting renal function, and reversed fibrosis, inflammation and adipogenesis expression markers. Targeting CAPN2 could be a promising therapeutic strategy to mitigate muscle damage and improve physical performance in CKD patients.", "sentences": [], "annotations": [{"id": "40", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "Sarcopenia", "locations": [{"offset": 126, "length": 10}]}, {"id": "41", "infons": {"identifier": "MESH:C536030", "type": "Disease", "valid": true, "normalized": ["C536030"], "database": "ncbi_mesh", "normalized_id": "C536030", "biotype": "disease", "name": "MASS syndrome", "accession": "@DISEASE_MASS_syndrome"}, "text": "loss of muscle mass and", "locations": [{"offset": 154, "length": 23}]}, {"id": "42", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 216, "length": 8}]}, {"id": "43", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "chronic kidney disease", "locations": [{"offset": 230, "length": 22}]}, {"id": "44", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 254, "length": 3}]}, {"id": "45", "infons": {"identifier": "MESH:D054559", "type": "Disease", "valid": true, "normalized": ["D054559"], "database": "ncbi_mesh", "normalized_id": "D054559", "biotype": "disease", "name": "Hyperphosphatemia", "accession": "@DISEASE_Hyperphosphatemia"}, "text": "hyperphosphatemia", "locations": [{"offset": 378, "length": 17}]}, {"id": "46", "infons": {"identifier": "MESH:D002908", "type": "Di