, "locations": [{"offset": 1650, "length": 16}]}, {"id": "56", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle wasting", "locations": [{"offset": 1701, "length": 14}]}, {"id": "57", "infons": {"identifier": "MESH:D018908", "type": "Disease", "valid": true, "normalized": ["D018908"], "database": "ncbi_mesh", "normalized_id": "D018908", "biotype": "disease", "name": "Muscle Weakness", "accession": "@DISEASE_Muscle_Weakness"}, "text": "weakness", "locations": [{"offset": 1720, "length": 8}]}, {"id": "58", "infons": {"identifier": "MESH:D016638", "type": "Disease", "valid": true, "normalized": ["D016638"], "database": "ncbi_mesh", "normalized_id": "D016638", "biotype": "disease", "name": "Critical Illness", "accession": "@DISEASE_Critical_Illness"}, "text": "critical illness", "locations": [{"offset": 1732, "length": 16}]}, {"id": "59", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 1859, "length": 8}]}], "relations": []}], "relations": [], "pmid": 40591724, "pmcid": null, "meta": {}, "date": "2025-07-01T00:00:00Z", "journal": "Clin Sci (Lond)", "authors": ["Bongetti AJ", "Caldow MK", "Abdelhamid YA", "Lynch GS"], "relations_display": []}, {"_id": "40594054|None", "id": "40594054", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Low expression of SGCA promotes lung squamous cell carcinoma malignant progression.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "6442", "type": "Gene", "ncbi_homologene": "9", "valid": true, "normalized": [6442], "database": "ncbi_gene", "normalized_id": 6442, "biotype": "gene", "name": "SGCA", "accession": "@GENE_SGCA"}, "text": "SGCA", "locations": [{"offset": 18, "length": 4}]}, {"id": "3", "infons": {"identifier": "MESH:D002294", "type": "Disease", "valid": true, "normalized": ["D002294"], "database": "ncbi_mesh", "normalized_id": "D002294", "biotype": "disease", "name": "Carcinoma Squamous Cell", "accession": "@DISEASE_Carcinoma_Squamous_Cell"}, "text": "lung squamous cell carcinoma", "locations": [{"offset": 32, "length": 28}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 84, "text": "Lung squamous cell carcinoma (LUSC) is a common type of non-small-cell lung cancer with high mortality, lacks effective diagnostic indicators and therapeutic targets. This study aims to reveal that low expression of Alpha-Sarcoglycan (SGCA) promotes LUSC progression and to provide a biomarker for its diagnosis, prognosis evaluation, and targeted therapy. TCGA data and 70 clinical LUSC patients were analyzed. In vitro, H520 and H1703 cells with overexpressed SGCA were transfected with pc-SGCA plasmids, and their proliferation, apoptosis, and invasion were examined. In vivo, a subcutaneous tumorigenic mouse model was constructed. SGCA was significant in diagnosing LUSC and negatively correlated with T stage. Low SGCA expression enhanced proliferation, invasion, and migration, and inhibited apoptosis. Overexpression of SGCA inhibited tumor growth in mice. Low expression of SGCA is closely associated with LUSC progression, making it a potential prognostic factor and therapeutic target for LUSC.", "sentences": [], "annotations": [{"id": "27", "infons": {"identifier": "MESH:D002294", "type": "Disease", "valid": true, "normalized": ["D002294"], "database": "ncbi_mesh", "normalized_id": "D002294", "biotype": "disease", "name": "Carcinoma Squamous Cell", "accession": "@DISEASE_Carcinoma_Squamous_Cell"}, "text": "Lung squamous cell carcinoma", "locations": [{"offset": 84, "length": 28}]}, {"id": "28", "infons": {"identifier": "MESH:D002294", "type": "Disease", "valid": true, "normalized": ["D002294"], "database": "ncbi_mesh", "normalized_id": "D002294", "biotype": "disease", "name": "Carcinoma Squamous Cell", "accession": "@DISEASE_Carcinoma_Squamous_Cell"}, "text": "LUSC", "locations": [{"offset": 114, "length": 4}]}, {"id": "29", "infons": {"identifier": "MESH:D002289", "type": "Disease", "valid": true, "normalized": ["D002289"], "database": "ncbi_mesh", "normalized_id": "D002289", "biotype": "disease", "name": "Carcinoma Non-Small-Cell Lung", "accession": "@DISEASE_Carcinoma_Non_Small_Cell_Lung"}, "text": "non-small-cell lung cancer", "locations": [{"offset": 140, "length": 26}]}, {"id": "30", "infons": {"identifier": "6442", "type": "Gene", "ncbi_homologene": "9", "valid": true, "normalized": [6442], "database": "ncbi_gene", "normalized_id": 6442, "biotype": "gene", "name": "SGCA", "accession": "@GENE_SGCA"}, "text": "Alpha-Sarcoglycan", "locations": [{"offset": 300, "length": 17}]}, {"id": "31", "infons": {"identifier": "6442", "type": "Gene", "ncbi_homologene": "9", "valid": true, "normalized": [6442], "database": "ncbi_gene", "normalized_id": 6442, "biotype": "gene", "name": "SGCA", "accession": "@GENE_SGCA"}, "text": "SGCA", "locations": [{"offset": 319, "length": 4}]}, {"id": "32", "infons": {"identifier": "MESH:D002294", "type": "Disease", "valid": true, "normalized": ["D002294"], "database": "ncbi_mesh", "normalized_id": "D002294", "biotype": "disease", "name": "Carcinoma Squamous Cell", "accession": "@DISEASE_Carcinoma_Squamous_Cell"}, "text": "LUSC", "locations": [{"offset": 334, "length": 4}]}, {"id": "33", "infons": {"identifier": "MESH:D002294", "type": "Disease", "valid": true, "normalized": ["D002294"], "database": "ncbi_mesh", "normalized_id": "D002294", "biotype": "disease", "name": "Carcinoma Squamous Cell", "accession": "@DISEASE_Carcinoma_Squamous_Cell"}, "text": "LUSC", "locations": [{"offset": 467, "length": 4}]}, {"id": "34", "infons": {"identifier": "9606", "type": "Species", "valid"