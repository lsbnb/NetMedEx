on"}, "nodes": [{"refid": "1", "role": "27,33"}]}, {"id": "R3", "infons": {"score": "0.6784", "role1": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "role2": {"identifier": "12334", "type": "Gene", "valid": true, "normalized": [12334], "database": "ncbi_gene", "normalized_id": 12334, "biotype": "gene", "name": "Capn2", "accession": "@GENE_CAPN2"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "29,33"}]}, {"id": "R4", "infons": {"score": "0.997", "role1": {"identifier": "MESH:D019042", "type": "Disease", "valid": true, "normalized": ["D019042"], "database": "ncbi_mesh", "normalized_id": "D019042", "biotype": "disease", "name": "Muscle Neoplasms", "accession": "@DISEASE_Muscle_Neoplasms"}, "role2": {"identifier": "12334", "type": "Gene", "valid": true, "normalized": [12334], "database": "ncbi_gene", "normalized_id": 12334, "biotype": "gene", "name": "Capn2", "accession": "@GENE_CAPN2"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "30,33"}]}, {"id": "R5", "infons": {"score": "0.9908", "role1": {"identifier": "MESH:D000225", "type": "Chemical", "valid": true, "normalized": ["D000225"], "database": "ncbi_mesh", "normalized_id": "D000225", "biotype": "chemical", "name": "Adenine", "accession": "@CHEMICAL_Adenine"}, "role2": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "4", "role": "17,35"}]}, {"id": "R6", "infons": {"score": "0.9944", "role1": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "role2": {"identifier": "12334", "type": "Gene", "valid": true, "normalized": [12334], "database": "ncbi_gene", "normalized_id": 12334, "biotype": "gene", "name": "Capn2", "accession": "@GENE_CAPN2"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "5", "role": "35,33"}]}], "pmid": 41369335, "pmcid": null, "meta": {}, "date": "2025-11-23T00:00:00Z", "journal": "Cells", "authors": ["Gutiérrez-Calabrés E", "Campillo S", "Alcalde-Estévez E", "Cuevas-Delgado P", "Barbas C", "García-Villoria S", "Silvestre-Vargas A", "Griera M", "de Frutos S", "Ruiz-Torres MP", "Rodríguez-Puyol D", "Calleros L"], "relations_display": [{"name": "associate|@DISEASE_Muscular_Atrophy|@GENE_CAPN2"}, {"name": "stimulate|@DISEASE_Tooth_Loss|@GENE_CAPN2"}, {"name": "associate|@DISEASE_Muscular_Diseases|@GENE_CAPN2"}, {"name": "associate|@DISEASE_Muscle_Neoplasms|@GENE_CAPN2"}, {"name": "cause|@CHEMICAL_Adenine|@DISEASE_Renal_Insufficiency_Chronic"}, {"name": "stimulate|@DISEASE_Renal_Insufficiency_Chronic|@GENE_CAPN2"}]}, {"_id": "41369394|None", "id": "41369394", "infons": {}, "passages": [{"infons": {"journal": "Cells;2025Dec01; 14 (23) . doi:10.3390/cells14231905", "year": "2025", "type": "title", "authors": "Sarkar A, Sarkar S, Anwar A, Kim JW, Shim JH, John AA, "}, "offset": 0, "text": "The Growing Significance of microRNAs in Osteoporosis.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "Osteoporosis", "locations": [{"offset": 41, "length": 12}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 55, "text": "Osteoporosis is an aging-related disease characterized by low bone mineral density and deteriorated bone structure, resulting in an increased risk of fractures. Currently, most osteoporosis therapies target osteoclasts to inhibit bone resorption, while the three FDA-approved anabolic agents include parathyroid hormone, parathyroid hormone-related protein, and anti-sclerostin antibody that promote osteoblast function. However, long-term treatment with these agents is associated with potential adverse effects and decreased therapeutic efficacy. This has prompted exploration of novel therapeutic strategies, including microRNAs (miRNAs), which are emerging as promising candidates. miRNAs have been reported to play important roles in regulating pathways involved in bone formation and resorption. In addition to their direct roles in osteoblasts and osteoclasts, miRNAs also serve as key mediators of communication between these cells, which is essential for maintaining bone homeostasis. The complexity of osteoporosis requires versatile regulators such as miRNAs that can modulate multiple biological pathways. Recent studies have demonstrated the potential of miRNA-based therapy to restore bone homeostasis in osteoporotic models. However, further studies are needed to develop tissue-specific delivery systems and evaluate long-term safety to improve the therapeutic potential of miRNAs as new osteoporosis drugs.", "sentences": [], "annotations": [{"id": "11", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "Osteoporosis", "locations": [{"offset": 55, "length": 12}]}, {"id": "12", "infons": {"identifier": "MESH:D050723", "type": "Disease", "valid": true, "normalized": ["D050723"], "database": "ncbi_mesh", "normalized_id": "D050723", "biotype": "disease", "name": "Fractures Bone", "accession": "@DISEASE_Fractures_Bone"}, "text": "fractures", "locations": [{"offset": 205, "length": 9}]}, {"id": "13", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "osteoporosis", "locations": [{"offset": 232, "length": 12}]}, {"id": "14", "infons": {"identifier": "5741", "type": "Gene", "ncbi_homologene": "266", "valid": true, "normalized": [5741], "database": "ncbi_gene", "normalized_id": 5741, "biotype": "gene", "name": "PTH", "accession": "@GENE_PTH"}, "text": "parathyroid hormone", "locations": [{"offset": 355, "length": 19}]}, {"id": "15", "infons": {"identifier": "5744", "type": "Gene", "ncbi_homologene": "2113", "valid": true, "normalized": [5744], "database": "ncbi_gene", "normalized_id": 5744, "biotype": "gene", "name": "PTHLH", "accession": "@GENE_PTHLH"}, "text": "parathyroid hormone-related protein", "locations": [{"offset": 376, "length": 35}]}, {"id": "16", "infons": {"identifier": "50964", "type": "Gene", "ncbi_homologene": "11542", "valid": true, "normalized": [50964], "database": "ncbi_gene", "normalized_id": 50964, "biotype": "gene", "name": "SOST", "accession": "@GENE_SOST"}, "text": "sclerostin", "locations": [{"offset": 422, "length": 10}]}, {"id": "17", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "osteoporosis", "locations": [{"offset": 1067, "length": 12}]}, {"id": "18", "infons": {"identifier": "MESH:D058866", "type": "Disease", "valid": true, "normalized": ["D058866"], "database": "ncbi_mesh", "normalized_id": "D058866", "biotype": "disease", "name": "Osteoporotic Fractures", "accession": "@DISEASE_Osteoporotic_Fractures"}, "text": "osteoporotic", "locations": [{"offset": 1274, "length": 12}]}, {"id": "19", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "osteoporosis", "locations": [{"offset": 1459, "length": 12}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.4951", "role1": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "role2": {"identifier": "5741", "type": "Gene", "valid": true, "normalized": [5741], "database": "ncbi_gene", "normalized_id": 5741, "biotype": "gene", "name": "PTH", "accession": "@GENE_PTH"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "9,4"}]}], "pmid": 41369394, "pmcid": null, "meta": {}, "date": "2025-12-01T00:00:00Z", "journal": "Cells", "authors": ["Sarkar A", "Sarkar S", "Anwar A", "Kim JW", "Shim JH", "John AA"], "relations_display": [{"name": "inhibit|@DISEASE_Osteoporosis|@GENE_PTH"}]}, {"_id": "41372706|None", "id": "41372706", "infons": {}, "passages": [{"infons": {"journal": "Mol Syst Biol;2025Dec10. doi:10.1038/s44320-025-00177-3", "year": "2025", "article-id_pmc": "12117515", "type": "title", "authors": "Abou Elhassan SI, Clark JP, Kuang D, Rhoads TW, Colman RJ, Coon JJ, Anderson RM, Overmyer KA, "}, "offset": 0, "text": "Aging-linked systemic lipid signature is reprogrammed by caloric restriction in rhesus monkeys.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 22, "length": 5}]}, {"id": "3", "infons": {"identifier": "9544", "type": "Species", "valid": true, "normalized": [9544], "database": "ncbi_taxonomy", "normalized_id": 9544, "biotype": "species", "name": "9544", "accession": null}, "text": "rhesus monkeys", "locations": [{"offset": 80, "length": 14}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 96, "text": "Caloric restriction (CR) without malnutrition delays aging in diverse species, including primates, with metabolic changes implicated in this process. To facilitate exploration of CR metabolism with aging, we developed a 15-minute LC-MS/MS metabolomics and lipidomics method, leveraging monophasic extractions and wide elution-strength solvents. We analyzed 494 plasma samples collected over 25 years from male and female rhesus monkeys (Macaca mulatta) on a Control or CR (30% restricted) diet. Quantitation of 359 biomolecules revealed that aging, followed by sex and diet, had the largest impact on metabolite abundances. In both sexes, aging was associated with significantly lower plasma levels of sphingomyelins (SMs) and higher levels of diglycerides (DGs) and triglycerides (TGs), each of which was opposed by CR. Sex dimorphism was evident by the increased abundance of phosphocholine (PC)-containing lipids in females. These results highlight the utility of a rapid metabolomics and lipidomics approach to elucidate complex biology in large-scale studies.", "sentences": [], "annotations": [{"id": "16", "infons": {"identifier": "MESH:D044342", "type": "Disease", "valid": true, "normalized": ["D044342"], "database": "ncbi_mesh", "normalized_id": "D044342", "biotype": "disease", "name": "Malnutrition", "accession": "@DISEASE_Malnutrition"}, "text": "malnutrition", "locations": [{"offset": 129, "length": 12}]}, {"id": "17", "infons": {"identifier": "9544", "type": "Species", "valid": true, "normalized": [9544], "database": "ncbi_taxonomy", "normalized_id": 9544, "biotype": "species", "name": "9544", "accession": null}, "text": "rhesus monkeys", "locations": [{"offset": 517, "length": 14}]}, {"id": "18", "infons": {"identifier": "9544", "type": "Species", "valid": true, "normalized": [9544], "database": "ncbi_taxonomy", "normalized_id": 9544, "biotype": "species", "name": "9544", "accession": null}, "text": "Macaca mulatta", "locations": [{"offset": 533, "length": 14}]}, {"id": "19", "infons": {"identifier": "MESH:D013109", "type": "Chemical", "valid": true, "normalized": ["D013109"], "database": "ncbi_mesh", "normalized_id": "D013109", "biotype": "chemical", "name": "Sphingomyelins", "accession": "@CHEMICAL_Sphingomyelins"}, "text": "sphingomyelins", "locations": [{"offset": 798, "length": 14}]}, {"id": "20", "infons": {"identifier": "MESH:D013109", "type": "Chemical", "valid": true, "normalized": ["D013109"], "database": "ncbi_mesh", "normalized_id": "D013109", "biotype": "chemical", "name": "Sphingomyelins", "accession": "@CHEMICAL_Sphingomyelins"}, "text": "SMs", "locations": [{"offset": 814, "length": 3}]}, {"id": "21", "infons": {"identifier": "MESH:D004075", "type": "Chemical", "valid": true, "normalized": ["D004075"], "database": "ncbi_mesh", "normalized_id": "D004075", "biotype": "chemical", "name": "Diglycerides", "accession": "@CHEMICAL_Diglycerides"}, "text": "diglycerides", "locations": [{"offset": 840, "length": 12}]}, {"id": "22", "infons": {"identifier": "MESH:D004075", "type": "Chemical", "valid": true, "normalized": ["D004075"], "database": "ncbi_mesh", "normalized_id": "D004075", "biotype": "chemical", "name": "Diglycerides", "accession": "@CHEMICAL_Diglycerides"}, "text": "DGs", "locations": [{"offset": 854, "length": 3}]}, {"id": "23", "infons": {"identifier": "MESH:D014280", "type": "Chemical", "valid": true, "normalized": ["D014280"], "database": "ncbi_mesh", "normalized_id": "D014280", "biotype": "chemical", "name": "Triglycerides", "accession": "@CHEMICAL_Triglycerides"}, "text": "triglycerides", "locations": [{"offset": 863, "length": 13}]}, {"id": "24", "infons": {"identifier": "MESH:D014280", "type": "Chemical", "valid": true, "normalized": ["D014280"], "database": "ncbi_mesh", "normalized_id": "D014280", "biotype": "chemical", "name": "Triglycerides", "accession": "@CHEMICAL_Triglycerides"}, "text": "TGs", "locations": [{"offset": 878, "length": 3}]}, {"id": "25", "infons": {"identifier": "MESH:D010767", "type": "Chemical", "valid": true, "normalized": ["D010767"], "database": "ncbi_mesh", "normalized_id": "D010767", "biotype": "chemical", "name": "Phosphorylcholine", "accession": "@CHEMICAL_Phosphorylcholine"}, "text": "phosphocholine", "locations": [{"offset": 974, "length": 14}]}, {"id": "26", "infons": {"identifier": "MESH:D010767", "type": "Chemical", "valid": true, "normalized": ["D010767"], "database": "ncbi_mesh", "normalized_id": "D010767", "biotype": "chemical", "name": "Phosphorylcholine", "accession": "@CHEMICAL_Phosphorylcholine"}, "text": "PC", "locations": [{"offset": 990, "length": 2}]}, {"id": "27", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipids", "locations": [{"offset": 1005, "length": 6}]}], "relations": []}], "relations": [], "pmid": 41372706, "pmcid": null, "meta": {}, "date": "2025-12-10T00:00:00Z", "journal": "Mol Syst Biol", "authors": ["Abou Elhassan SI", "Clark JP", "Kuang D", "Rhoads TW", "Colman RJ", "Coon JJ", "Anderson RM", "Overmyer KA"], "relations_display": []}, {"_id": "41391160|None", "id": "41391160", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Multi-Omics Analysis identified ADAM7 as a Biomarker and Therapeutic Target for End-Stage Renal Disease.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "8756", "type": "Gene", "ncbi_homologene": "2830", "valid": true, "normalized": [8756], "database": "ncbi_gene", "normalized_id": 8756, "biotype": "gene", "name": "ADAM7", "accession": "@GENE_ADAM7"}, "text": "ADAM7", "locations": [{"offset": 32, "length": 5}]}, {"id": "3", "infons": {"identifier": "MESH:D007676", "type": "Disease", "valid": true, "normalized": ["D007676"], "database": "ncbi_mesh", "normalized_id": "D007676", "biotype": "disease", "name": "Kidney Failure Chronic", "accession": "@DISEASE_Kidney_Failure_Chronic"}, "text": "End-Stage Renal Disease", "locations": [{"offset": 80, "length": 23}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 105, "text": "BACKGROUND: Sarcopenia is a common comorbidity in end-stage renal disease (ESRD) and is associated with increased risk of adverse clinical outcomes. The genetic mechanisms underlying sarcopenia in ESRD remain largely unclear. This study employed multi-omics bioinformatics approaches to elucidate potential genetic determinants. METHODS: Gene expression datasets GSE1428 and GSE142135 were retrieved from the Gene Expression Omnibus (GEO) database to identify shared differentially expressed genes (DEGs). Machine learning approaches were applied to pinpoint hub genes, followed by Mendelian Randomization (MR) analyses to validate their associations with ESRD. Candidate therapeutic agents were subsequently predicted based on these hub genes. RESULTS: ADAM7 emerged as the principal hub gene, with MR analyses suggesting a protective role against ESRD and sarcopenia. Predicted therapeutics included arbutin, metribolone, and phenethyl isothiocyanate. Molecular docking studies revealed favorable interactions, with binding free energies consistently below 5.0 kcal/mol between ADAM7 and these compounds. CONCLUSION: Our findings identify ADAM7 as a potential biomarker and therapeutic target for ESRD-associated sarcopenia, offering insights for future intervention strategies.", "sentences": [], "annotations": [{"id": "20", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "Sarcopenia", "locations": [{"offset": 117, "length": 10}]}, {"id": "21", "infons": {"identifier": "MESH:D007676", "type": "Disease", "valid": true, "normalized": ["D007676"], "database": "ncbi_mesh", "normalized_id": "D007676", "biotype": "disease", "name": "Kidney Failure Chronic", "accession": "@DISEASE_Kidney_Failure_Chronic"}, "text": "end-stage renal disease", "locations": [{"offset": 155, "length": 23}]}, {"id": "22", "infons": {"identifier": "MESH:D007676", "type": "Disease", "valid": true, "normalized": ["D007676"], "database": "ncbi_mesh", "normalized_id": "D007676", "biotype": "disease", "name": "Kidney Failure Chronic", "accession": "@DISEASE_Kidney_Failure_Chronic"}, "text": "ESRD", "locations": [{"offset": 180, "length": 4}]}, {"id": "23", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 288, "length": 10}]}, {"id": "24", "infons": {"identifier": "MESH:D007676", "type": "Disease", "valid": true, "normalized": ["D007676"], "database": "ncbi_mesh", "normalized_id": "D007676", "biotype": "disease", "name": "Kidney Failure Chronic", "accession": "@DISEASE_Kidney_Failure_Chronic"}, "text": "ESRD", "locations": [{"offset": 302, "length": 4}]}, {"id": "25", "infons": {"identifier": "MESH:D007676", "type": "Disease", "valid": true, "normalized": ["D007676"], "database": "ncbi_mesh", "normalized_id": "D007676", "biotype": "disease", "name": "Kidney Failure Chronic", "accession": "@DISEASE_Kidney_Failure_Chronic"}, "text": "ESRD", "locations": [{"offset": 761, "length": 4}]}, {"id": "26", "infons": {"identifier": "8756", "type": "Gene", "ncbi_homologene": "2830", "valid": true, "normalized": [8756], "database": "ncbi_gene", "normalized_id": 8756, "biotype": "gene", "name": "ADAM7", "accession": "@GENE_ADAM7"}, "text": "ADAM7", "locations": [{"offset": 859, "length": 5}]}, {"id": "27", "infons": {"identifier": "MESH:D007676", "type": "Disease", "valid": true, "normalized": ["D007676"], "database": "ncbi_mesh", "normalized_id": "D007676", "biotype": "disease", "name": "Kidney Failure Chronic", "accession": "@DISEASE_Kidney_Failure_Chronic"}, "text": "ESRD", "locations": [{"offset": 954, "length": 4}]}, {"id": "28", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 963, "length": 10}]}, {"id": "29", "infons": {"identifier": "MESH:D001104", "type": "Chemical", "valid": true, "normalized": ["D001104"], "database": "ncbi_mesh", "normalized_id": "D001104", "biotype": "chemical", "name": "Arbutin", "accession": "@CHEMICAL_Arbutin"}, "text": "arbutin", "locations": [{"offset": 1007, "length": 7}]}, {"id": "30", "infons": {"identifier": "MESH:D015741", "type": "Chemical", "valid": true, "normalized": ["D015741"], "database": "ncbi_mesh", "normalized_id": "D015741", "biotype": "chemical", "name": "Metribolone", "accession": "@CHEMICAL_Metribolone"}, "text": "metribolone", "locations": [{"offset": 1016, "length": 11}]}, {"id": "31", "infons": {"identifier": "MESH:C058305", "type": "Chemical", "valid": true, "normalized": ["C058305"], "database": "ncbi_mesh", "normalized_id": "C058305", "biotype": "chemical", "name": "phenethyl isothiocyanate", "accession": "@CHEMICAL_phenethyl_isothiocyanate"}, "text": "phenethyl isothiocyanate", "locations": [{"offset": 1033, "length": 24}]}, {"id": "32", "infons": {"identifier": "8756", "type": "Gene", "ncbi_homologene": "2830", "valid": true, "normalized": [8756], "database": "ncbi_gene", "normalized_id": 8756, "biotype": "gene", "name": "ADAM7", "accession": "@GENE_ADAM7"}, "text": "ADAM7", "locations": [{"offset": 1185, "leng