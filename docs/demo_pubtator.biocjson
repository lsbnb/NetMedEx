Gene", "valid": true, "normalized": [6774], "database": "ncbi_gene", "normalized_id": 6774, "biotype": "gene", "name": "STAT3", "accession": "@GENE_STAT3"}, "role2": {"identifier": "9882", "type": "Gene", "valid": true, "normalized": [9882], "database": "ncbi_gene", "normalized_id": 9882, "biotype": "gene", "name": "TBC1D4", "accession": "@GENE_TBC1D4"}, "type": "Bind"}, "nodes": [{"refid": "0", "role": "23,22"}]}, {"id": "R2", "infons": {"score": "0.9996", "role1": {"identifier": "2185", "type": "Gene", "valid": true, "normalized": [2185], "database": "ncbi_gene", "normalized_id": 2185, "biotype": "gene", "name": "PTK2B", "accession": "@GENE_PTK2B"}, "role2": {"identifier": "23216", "type": "Gene", "valid": true, "normalized": [23216], "database": "ncbi_gene", "normalized_id": 23216, "biotype": "gene", "name": "TBC1D1", "accession": "@GENE_TBC1D1"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "12,20"}]}, {"id": "R3", "infons": {"score": "0.9883", "role1": {"identifier": "23216", "type": "Gene", "valid": true, "normalized": [23216], "database": "ncbi_gene", "normalized_id": 23216, "biotype": "gene", "name": "TBC1D1", "accession": "@GENE_TBC1D1"}, "role2": {"identifier": "6774", "type": "Gene", "valid": true, "normalized": [6774], "database": "ncbi_gene", "normalized_id": 6774, "biotype": "gene", "name": "STAT3", "accession": "@GENE_STAT3"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "20,23"}]}, {"id": "R4", "infons": {"score": "0.7531", "role1": {"identifier": "23216", "type": "Gene", "valid": true, "normalized": [23216], "database": "ncbi_gene", "normalized_id": 23216, "biotype": "gene", "name": "TBC1D1", "accession": "@GENE_TBC1D1"}, "role2": {"identifier": "9882", "type": "Gene", "valid": true, "normalized": [9882], "database": "ncbi_gene", "normalized_id": 9882, "biotype": "gene", "name": "TBC1D4", "accession": "@GENE_TBC1D4"}, "type": "Bind"}, "nodes": [{"refid": "3", "role": "20,22"}]}], "pmid": 41253787, "pmcid": null, "meta": {}, "date": "2025-11-18T00:00:00Z", "journal": "Nat Commun", "authors": ["Yang X", "Cao Y", "Mu Y", "Zhou Y", "Zhang L", "Ai H", "Zhu D", "Chen S", "Wang HY"], "relations_display": [{"name": "interact|@GENE_STAT3|@GENE_TBC1D4"}, {"name": "associate|@GENE_PTK2B|@GENE_TBC1D1"}, {"name": "associate|@GENE_TBC1D1|@GENE_STAT3"}, {"name": "interact|@GENE_TBC1D1|@GENE_TBC1D4"}]}, {"_id": "41257461|None", "id": "41257461", "infons": {}, "passages": [{"infons": {"journal": "Biofactors;2025Nov-Dec; 51 (6) 70058. doi:10.1002/biof.70058", "year": "2025", "article-id_pmc": "PMC12628643", "type": "title", "authors": "Polacchini G, Venerando A, Bigot A, Colitti M, "}, "offset": 0, "text": "Oleuropein Aglycone Modulates Oxidative Stress and Autophagy-Related Pathways in Human Skeletal Muscle Cells.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:C000625725", "type": "Chemical", "valid": true, "normalized": ["C000625725"], "database": "ncbi_mesh", "normalized_id": "C000625725", "biotype": "chemical", "name": "oleuropein aglycone", "accession": "@CHEMICAL_oleuropein_aglycone"}, "text": "Oleuropein Aglycone", "locations": [{"offset": 0, "length": 19}]}, {"id": "3", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "Human", "locations": [{"offset": 81, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 110, "text": "A gradual loss of muscle mass and strength increases the risk of falls, frailty and mortality. It is the result of a combination of intrinsic factors such as oxidative stress, mitochondrial dysfunction and extrinsic factors such as poor nutrition and inactivity. Oleuropein aglycone (OLE), a compound extracted from olive leaves, combats oxidative damage through its antioxidant and autophagy-inducing properties. It activates AMPK and FOXO3a signaling pathways, autophagy, mitochondrial function and muscle health. OLE is investigated in the human immortalized myoblast cell line AB1079 for its protective effect against muscle oxidative stress. Oxidative stress was induced in the AB1079 cell line after 7 days of differentiation by hydrogen peroxide (H2O2), leading to a significant increase in reactive oxygen species formation, which was reduced by approximately 43% by pretreatment with OLE. Cells treated with H2O2 showed a 33% increase in stress-induced senescent cells, while pretreatment with OLE significantly reduced the stained area of the X-gal reaction by 12% compared to H2O2. OLE increased the expression of genes involved in antioxidant defense and influencing the autophagic process by inducing an oscillator AMPK phosphorylation, as well as the expression of the stress-induced metabolic regulators SESN2 and SESN3. OLE has been shown to counteract the oxidative environment and promote autophagy-related signaling in vitro, suggesting a potential role in preventing cellular mechanisms associated with muscle aging. Further in vivo studies are required to confirm functional anti-aging effects.", "sentences": [], "annotations": [{"id": "29", "infons": {"identifier": "MESH:C536030", "type": "Disease", "valid": true, "normalized": ["C536030"], "database": "ncbi_mesh", "normalized_id": "C536030", "biotype": "disease", "name": "MASS syndrome", "accession": "@DISEASE_MASS_syndrome"}, "text": "loss of muscle mass", "locations": [{"offset": 120, "length": 19}]}, {"id": "30", "infons": {"identifier": "MESH:C537863", "type": "Disease", "valid": true, "normalized": ["C537863"], "database": "ncbi_mesh", "normalized_id": "C537863", "biotype": "disease", "name": "Ocular Albinism type 1", "accession": "@DISEASE_Ocular_Albinism_type_1"}, "text": "falls", "locations": [{"offset": 175, "length": 5}]}, {"id": "31", "infons": {"identifier": "MESH:D000073496", "type": "Disease", "valid": true, "normalized": ["D000073496"], "database": "ncbi_mesh", "normalized_id": "D000073496", "biotype": "disease", "name": "Frailty", "accession": "@DISEASE_Frailty"}, "text": "frailty", "locations": [{"offset": 182, "length": 7}]}, {"id": "32", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial dysfunction", "locations": [{"offset": 286, "length": 25}]}, {"id": "33", "infons": {"identifier": "MESH:C000625725", "type": "Chemical", "valid": true, "normalized": ["C000625725"], "database": "ncbi_mesh", "normalized_id": "C000625725", "biotype": "chemical", "name": "oleuropein aglycone", "accession": "@CHEMICAL_oleuropein_aglycone"}, "text": "Oleuropein aglycone", "locations": [{"offset": 373, "length": 19}]}, {"id": "34", "infons": {"identifier": "MESH:C000625725", "type": "Chemical", "valid": true, "normalized": ["C000625725"], "database": "ncbi_mesh", "normalized_id": "C000625725", "biotype": "chemical", "name": "oleuropein aglycone", "accession": "@CHEMICAL_oleuropein_aglycone"}, "text": "OLE", "locations": [{"offset": 394, "length": 3}]}, {"id": "35", "infons": {"identifier": "5563", "type": "Gene", "ncbi_homologene": "4551", "valid": true, "normalized": [5563], "database": "ncbi_gene", "normalized_id": 5563, "biotype": "gene", "name": "PRKAA2", "accession": "@GENE_PRKAA2"}, "text": "AMPK", "locations": [{"offset": 537, "length": 4}]}, {"id": "36", "infons": {"identifier": "2309", "type": "Gene", "ncbi_homologene": "31039", "valid": true, "normalized": [2309], "database": "ncbi_gene", "normalized_id": 2309, "biotype": "gene", "name": "FOXO3", "accession": "@GENE_FOXO3"}, "text": "FOXO3a", "locations": [{"offset": 546, "length": 6}]}, {"id": "37", "infons": {"identifier": "MESH:C000625725", "type": "Chemical", "valid": true, "normalized": ["C000625725"], "database": "ncbi_mesh", "normalized_id": "C000625725"