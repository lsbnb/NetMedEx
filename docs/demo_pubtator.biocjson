flammation|@GENE_MAPK8"}, {"name": "associate|@DISEASE_Hyperphosphatemia|@GENE_FGF23"}, {"name": "cause|@CHEMICAL_Glucose|@DISEASE_Inflammation"}, {"name": "associate|@CHEMICAL_Vitamin_B_12|@GENE_FGF23"}, {"name": "associate|@DISEASE_Hyperphosphatemia|@GENE_KL"}, {"name": "associate|@CHEMICAL_Vitamin_B_12|@GENE_KL"}, {"name": "cause|@CHEMICAL_Glucose|@DISEASE_Kidney_Diseases"}, {"name": "treat|@CHEMICAL_Vitamin_B_12|@DISEASE_Kidney_Diseases"}, {"name": "associate|@CHEMICAL_Vitamin_B_12|@GENE_GSK3B"}, {"name": "associate|@DISEASE_Kidney_Diseases|@GENE_LCN2"}, {"name": "treat|@CHEMICAL_Vitamin_B_12|@DISEASE_Hyperphosphatemia"}, {"name": "associate|@DISEASE_Fibrosis|@GENE_MAPK8"}, {"name": "associate|@CHEMICAL_Creatinine|@DISEASE_Kidney_Diseases"}, {"name": "associate|@CHEMICAL_Vitamin_B_12|@GENE_AGER"}, {"name": "associate|@CHEMICAL_Vitamin_B_12|@GENE_MAPK8"}]}, {"_id": "41101394|None", "id": "41101394", "infons": {}, "passages": [{"infons": {"journal": "Adv Nutr;2025Oct14; 16 (12) 100546. doi:10.1016/j.advnut.2025.100546", "year": "2025", "type": "title", "authors": "Xi X, Hu S, Zhang X, An P, Luo Y, Luo J, Zhu Y, "}, "offset": 0, "text": "Bioactives in Food-As-Medicine for Special Medical Purposes.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 61, "text": "With rising global attention to health and the accelerating trend of population aging, the demand for Foods for Special Medical Purposes (FSMPs) has increased substantially. These products are formulated not only to meet the basic nutritional needs of individuals with specific diseases or physiological conditions but also to provide regulatory physiological effects. In this context, the \"Food-As-Medicine\" (FAM) concept has gained growing interest. FAM seeks to prevent and treat diseases through the incorporation of functional foods into health management strategies and aligns closely with the traditional Chinese medicine (TCM) theory of \"Food-Medicine Homologous\" (FMH). Guided by FMH principles, natural bioactive compounds such as polysaccharides, flavonoids, and saponins have drawn significant attention for their anti-inflammatory, antioxidant, and immunomodulatory properties. However, their broader application faces several challenges, including low extraction efficiency, complex purification procedures, and difficulties in ensuring stability, all of which hinder industrial-scale development. This review systematically explores the potential, challenges, and opportunities of FMH-based products in FSMPs, with a particular emphasis on infant nutrition, maternal health, and the management of chronic diseases in the elderly. Our findings highlight the dual value of FMH ingredients in both nutritional support and functional modulation. Furthermore, by integrating FMH theory with modern nutritional science, this review offers a scientific basis for the innovative development of FSMPs. Given the growing global market demand and the increasing dissemination of TCM culture, this field is poised to enter a new phase of development.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "MESH:D011134", "type": "Chemical", "valid": true, "normalized": ["D011134"], "database": "ncbi_mesh", "normalized_id": "D011134", "biotype": "chemical", "name": "Polysaccharides", "accession": "@CHEMICAL_Polysaccharides"}, "text": "polysaccharides", "locations": [{"offset": 802, "length": 15}]}, {"id": "6", "infons": {"identifier": "MESH:D005419", "type": "Chemical", "valid": true, "normalized": ["D005419"], "database": "ncbi_mesh", "normalized_id": "D005419", "biotype": "chemical", "name": "Flavonoids", "accession": "@CHEMICAL_Flavonoids"}, "text": "flavonoids", "locations": [{"offset": 819, "length": 10}]}, {"id": "7", "infons": {"identifier": "MESH:D012503", "type": "Chemical", "valid": true, "normalized": ["D012503"], "database": "ncbi_mesh", "normalized_id": "D012503", "biotype": "chemical", "name": "Saponins", "accession": "@CHEMICAL_Saponins"}, "text": "saponins", "locations": [{"offset": 835, "length": 8}]}, {"id": "8", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 892, "length": 12}]}, {"id": "9", "infons": {"identifier": "MESH:D002908", "type": "Disease", "valid": true, "normalized": ["D002908"], "database": "ncbi_mesh", "normalized_id": "D002908", "biotype": "disease", "name": "Chronic Disease", "accession": "@DISEASE_Chronic_Disease"}, "text": "chronic diseases", "locations": [{"offset": 1373, "length": 16}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9991", "role1": {"identifier": "MESH:D005419", "type": "Chemical", "valid": true, "normalized": ["D005419"], "database": "ncbi_mesh", "normalized_id": "D005419", "biotype": "chemical", "name": "Flavonoids", "accession": "@CHEMICAL_Flavonoids"}, "role2": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "1,3"}]}, {"id": "R2", "infons": {"score": "0.9992", "role1": {"identifier": "MESH:D011134", "type": "Chemical", "valid": true, "normalized": ["D011134"], "database": "ncbi_mesh", "normalized_id": "D011134", "biotype": "chemical", "name": "Polysaccharides", "accession": "@CHEMICAL_Polysaccharides"}, "role2": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "1", "role": "0,3"}]}, {"id": "R3", "infons": {"score": "0.9992", "role1": {"identifier": "MESH:D012503", "type": "Chemical", "valid": true, "normalized": ["D012503"], "database": "ncbi_mesh", "normalized_id": "D012503", "biotype": "chemical", "name": "Saponins", "accession": "@CHEMICAL_Saponins"}, "role2": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "2,3"}]}], "pmid": 41101394, "pmcid": null, "meta": {}, "date": "2025-10-14T00:00:00Z", "journal": "Adv Nutr", "authors": ["Xi X", "Hu S", "Zhang X", "An P", "Luo Y", "Luo J", "Zhu Y"], "relations_display": [{"name": "treat|@CHEMICAL_Flavonoids|@DISEASE_Inflammation"}, {"name": "treat|@CHEMICAL_Polysaccharides|@DISEASE_Inflammation"}, {"name": "treat|@CHEMICAL_Saponins|@DISEASE_Inflammation"}]}, {"_id": "41162675|None", "id": "41162675", "infons": {}, "passages": [{"infons": {"journal": "Nat Aging;2025Oct29. doi:10.1038/s43587-025-01002-0", "year": "2025", "article-id_pmc": "4677447", "type": "title", "authors": "Riparini G, Mackenzie M, Naz F, Brooks S, Jiang K, Deewan A, Dulek B, Islam S, Ko KD, Tsai WL, Gadina M, Dell'Orso S, Sartorelli V, "}, "offset": 0, "text": "Epigenetic dysregulation in aged muscle stem cells drives mesenchymal progenitor expansion via IL-6 and Spp1 signaling.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "16193", "type": "Gene", "ncbi_homologene": "502", "valid": true, "normalized": [16193], "database": "ncbi_gene", "normalized_id": 16193, "biotype": "gene", "name": "Il6", "accession": "@GENE_IL6"}, "text": "IL-6", "locations": [{"offset": 95, "length": 4}]}, {"id": "3", "infons": {"identifier": "20750", "type": "Gene", "ncbi_homologene": "20156", "valid": true, "normalized": [20750], "database": "ncbi_gene", "normalized_id": 20750, "biotype": "gene", "name": "Spp1", "accession": "@GENE_SPP1"}, "text": "Spp1", "locations": [{"offset": 104, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 120, "text": "Sarcopenia, the age-related decline in muscle mass, strength and function, is characterized by impaired muscle homeostasis, reduced regenerative potential of muscle stem cells (MuSCs) and increased fibrosis. Here we report that aged MuSCs can autonomously instruct fibro-adipogenic progenitors (FAPs) to proliferate and acquire a fibrogenic phenotype, independent of other cell types. Both the polycomb-deficient Ezh2-/- mouse model and aged mice exhibited defective regeneration, FAP expansion, fibrosis and elevated secretion of interleukin 6 (IL-6) and secreted phosphoprotein 1 (Spp1; osteopontin) by MuSCs. In aged MuSCs, reduction of the histone H3K27me3 repressive mark at the Nfbk1 gene correlated with its increased expression and enhanced chromatin recruitment to the IL6 and Spp1 genes, leading to their activation. Pharmacological inhibition of IL-6 and Spp1 signaling in co-culture systems or in aged mice reduced FAP proliferation and muscle fibrosis. These findings indicate that epigenetic dysregulation of aged MuSCs contributes to aged-related muscle fibrosis.", "sentences": [], "annotations": [{"id": "22", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "Sarcopenia", "locations": [{"offset": 120, "length": 10}]}, {"id": "23", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "impaired muscle homeostasis", "locations": [{"offset": 215, "length": 27}]}, {"id": "24", "infons": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "text": "fibrosis", "locations": [{"offset": 318, "length": 8}]}, {"id": "25", "infons": {"identifier": "14056", "type": "Gene", "ncbi_homologene": "37926", "valid": true, "normalized": [14056], "database": "ncbi_gene", "normalized_id": 14056, "biotype": "gene", "name": "Ezh2", "accession": "@GENE_EZH2"}, "text": "Ezh2", "locations": [{"offset": 533, "length": 4}]}, {"id": "26", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 541, "length": 5}]}, {"id": "27", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 562, "length": 4}]}, {"id": "28", "infons": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "text": "fibrosis", "locations": [{"offset": 616, "length": 8}]}, {"id": "29", "infons": {"identifier": "16193", "type": "Gene", "ncbi_homologene": "502", "valid": true, "normalized": [16193], "database": "ncbi_gene", "normalized_id": 16193, "biotype": "gene", "name": "Il6", "accession": "@GENE_IL6"}, "text": "interleukin 6", "locations": [{"offset": 651, "length": 13}]}, {"id": "30", "infons": {"identifier": "16193", "type": "Gene", "ncbi_homologene": "502", "valid": true, "normalized": [16193], "database": "ncbi_gene", "normalized_id": 16193, "biotype": "gene", "name": "Il6", "accession": "@GENE_IL6"}, "text": "IL-6", "locations": [{"offset": 666, "length": 4}]}, {"id": "31", "infons": {"identifier": "20750", "type": "Gene", "ncbi_homologene": "20156", "valid": true, "normalized": [20750], "database": "ncbi_gene", "normalized_id": 20750, "biotype": "gene", "name": "Spp1", "accession": "@GENE_SPP1"}, "text": "Spp1", "locations": [{"offset": 703, "length": 4}]}, {"id": "32", "infons": {"identifier": "20750", "type": "Gene", "ncbi_homologene": "20156", "valid": true, "normalized": [20750], "database": "ncbi_gene", "normalized_id": 20750, "biotype": "gene", "name": "Spp1", "accession": "@GENE_SPP1"}, "text": "osteopontin", "locations": [{"offset": 709, "length": 11}]}, {"id": "33", "infons": {"identifier": "16193", "type": "Gene", "ncbi_homologene": "502", "valid": true, "normalized": [16193], "database": "ncbi_gene", "normalized_id": 16193, "biotype": "gene", "name": "Il6", "accession": "@GENE_IL6"}, "text": "IL6", "locations": [{"offset": 898, "length": 3}]}, {"id": "34", "infons": {"identifier": "20750", "type": "Gene", "ncbi_homologene": "20156", "valid": true, "normalized": [20750], "database": "ncbi_gene", "normalized_id": 20750, "biotype": "gene", "name": "Spp1", "accession": "@GENE_SPP1"}, "text": "Spp1", "locations": [{"offset": 906, "length": 4}]}, {"id": "35", "infons": {"identifier": "16193", "type": "Gene", "ncbi_homologene": "502", "valid": true, "normalized": [16193], "database": "ncbi_gene", "normalized_id": 16193, "biotype": "gene", "name": "Il6", "accession": "@GENE_IL6"}, "text": "IL-6", "locations": [{"offset": 977, "length": 4}]}, {"id": "36", "infons": {"identifier": "20750", "type": "Gene", "ncbi_homologene": "20156", "valid": true, "normalized": [20750], "database": "ncbi_gene", "normalized_id": 20750, "biotype": "gene", "name": "Spp1", "accession": "@GENE_SPP1"}, "text": "Spp1", "locations": [{"offset": 986, "length": 4}]}, {"id": "37", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 1034, "length": 4}]}, {"id": "38", "infons": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "text": "muscle fibrosis", "locations": [{"offset": 1069, "length": 15}]}, {"id": "39", "infons": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "text": "muscle fibrosis", "locations": [{"offset": 1182, "length": 15}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9993", "role1": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "role2": {"identifier": "20750", "type": "Gene", "valid": true, "normalized": [20750], "database": "ncbi_gene", "normalized_id": 20750, "biotype": "gene", "name": "Spp1", "accession": "@GENE_SPP1"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "19,16"}]}, {"id": "R2", "infons": {"score": "0.8389", "role1": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "role2": {"identifier": "14056", "type": "Gene", "valid": true, "normalized": [14056], "database": "ncbi_gene", "normalized_id": 14056, "biotype": "gene", "name": "Ezh2", "accession": "@GENE_EZH2"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "19,5"}]}, {"id": "R3", "infons": {"score": "0.9989", "role1": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "role2": {"identifier": "16193", "type": "Gene", "valid": true, "normalized": [16193], "database": "ncbi_gene", "normalized_id": 16193, "biotype": "gene", "name": "Il6", "accession": "@GENE_IL6"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "19,15"}]}], "pmid": 41162675, "pmcid": null, "meta": {}, "date": "2025-10-29T00:00:00Z", "journal": "Nat Aging", "authors": ["Riparini G", "Mackenzie M", "Naz F", "Brooks S", "Jiang K", "Deewan A", "Dulek B", "Islam S", "Ko KD", "Tsai WL", "Gadina M", "Dell'Orso S", "Sartorelli V"], "relations_display": [{"name": "associate|@DISEASE_Fibrosis|@GENE_SPP1"}, {"name": "associate|@DISEASE_Fibrosis|@GENE_EZH2"}, {"name": "associate|@DISEASE_Fibrosis|@GENE_IL6"}]}, {"_id": "41173008|None", "id": "41173008", "infons": {}, "passages": [{"infons": {"journal": "Stem Cell Reports;2025Nov11; 20 (11) 102692. doi:10.1016/j.stemcr.2025.102692", "year": "2025", "type": "title", "authors": "Caputo L, Stamenkovic C, Tierney MT, Cecchini A, Nicolau M, Guarnaccia G, Barajas JR, Falzarano MS, Bassel-Duby R, Ferlini A, Olson EN, Puri PL, Sacco A, "}, "offset": 0, "text": "Modulation of the JAK2-STAT3 pathway promotes expansion and maturation of human iPSC-derived myogenic progenitor cells.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "3717", "type": "Gene", "ncbi_homologene": "21033", "valid": true, "normalized": [3717], "database": "ncbi_gene", "normalized_id": 3717, "biotype": "gene", "name": "JAK2", "accession": "@GENE_JAK2"}, "text": "JAK2", "locations": [{"offset": 18, "length": 4}]}, {"id": "4", "infons": {"identifier": "6774", "type": "Gene", "ncbi_homologene": "7960", "valid": true, "normalized": [6774], "database": "ncbi_gene", "normalized_id": 6774, "biotype": "gene", "name": "STAT3", "accession": "@GENE_STAT3"}, "text": "STAT3", "locations": [{"offset": 23, "length": 5}]}, {"id": "5", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 74, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 120, "text": "Generation of in vitro human induced pluripotent cell (hiPSC)-derived skeletal muscle progenitor cells (SMPCs) holds great promise for regenerative medicine for skeletal muscle wasting diseases, for example Duchenne muscular dystrophy (DMD). While multiple approaches have been described to obtain SMPCs in vitro, hiPSC-derived SMPCs generated using transgene-free protocols are usually obtained in a low amount and resemble a more embryonal/fetal stage of differentiation. Here, we demonstrate that modulation of the JAK2/STAT3 signaling pathway during an in vitro skeletal muscle differentiation protocol increases the yield of PAX7+ and CD54+ human SMPCs (hSMPCs) and drives them to a higher maturation stage, in both human embryonic stem (ES) and patient-derived induced pluripotent cells (iPSCs). Importantly, the obtained SMPCs are able to differentiate into multinucleated myotubes in vitro and engraft in vivo. These findings reveal that modulation of the JAK2/STAT3 signaling pathway is a potential therapeutic avenue to generate SMPCs in vitro with potential for cell therapy approaches.", "sentences": [], "annotations": [{"id": "19", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 143, "length": 5}]}, {"id": "20", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle wasting diseases", "locations": [{"offset": 290, "length": 23}]}, {"id": "21", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "Duchenne muscular dystrophy", "locations": [{"offset": 327, "length": 27}]}, {"id": "22", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 356, "length": 3}]}, {"id": "23", "infons": {"identifier": "3717", "type": "Gene", "ncbi_homologene": "21033", "valid": true, "normalized": [3717], "database": "ncbi_gene", "normalized_id": 3717, "biotype": "gene", "name": "JAK2", "accession": "@GENE_JAK2"}, "text": "JAK2", "locations": [{"offset": 638, "length": 4}]}, {"id": "24", "infons": {"identifier": "6774", "type": "Gene", "ncbi_homologene": "7960", "valid": true, "normalized": [6774], "database": "ncbi_gene", "normalized_id": 6774, "biotype": "gene", "name": "STAT3", "accession": "@GENE_STAT3"}, "text": "STAT3", "locations": [{"offset": 643, "length": 5}]}, {"id": "25", "infons": {"identifier": "5081", "type": "Gene", "ncbi_homologene": "55665", "valid": true, "normalized": [5081], "database": "ncbi_gene", "normalized_id": 5081, "biotype": "gene", "name": "PAX7", "accession": "@GENE_PAX7"}, "text": "PAX7", "locations": [{"offset": 750, "length": 4}]}, {"id": "26", "infons": {"identifier": "3383", "type": "Gene", "ncbi_homologene": "168", "valid": true, "normalized": [3383], "database": "ncbi_gene", "normalized_id": 3383, "biotype": "gene", "name": "ICAM1", "accession": "@GENE_ICAM1"}, "tex