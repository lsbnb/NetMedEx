4", "type": "Gene", "valid": true, "normalized": [6194], "database": "ncbi_gene", "normalized_id": 6194, "biotype": "gene", "name": "RPS6", "accession": "@GENE_RPS6"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "5", "role": "17,11"}]}, {"id": "R7", "infons": {"score": "0.9976", "role1": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "role2": {"identifier": "493900", "type": "Gene", "valid": true, "normalized": [493900], "database": "ncbi_gene", "normalized_id": 493900, "biotype": "gene", "name": "TMEM9B-AS1", "accession": "@GENE_TMEM9B_AS1"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "6", "role": "7,17"}]}], "pmid": 40632859, "pmcid": null, "meta": {}, "date": "2025-07-11T00:00:00Z", "journal": "Sci Adv", "authors": ["Sen I", "Smith JAB", "Caria E", "Orlov I", "Savikj M", "Brady AJ", "Lian K", "Ellefsen S", "Zierath JR", "Krook A"], "relations_display": [{"name": "associate|@GENE_IGF2BP1|@GENE_TMEM9B_AS1"}, {"name": "associate|@GENE_MYC|@GENE_TMEM9B_AS1"}, {"name": "associate|@DISEASE_Fasciculation|@GENE_TMEM9B_AS1"}, {"name": "associate|@DISEASE_Metabolic_Diseases|@GENE_TMEM9B_AS1"}, {"name": "inhibit|@DISEASE_Sarcopenia|@GENE_TMEM9B_AS1"}, {"name": "positive_correlate|@GENE_TMEM9B_AS1|@GENE_RPS6"}, {"name": "inhibit|@DISEASE_Diabetes_Mellitus_Type_2|@GENE_TMEM9B_AS1"}]}, {"_id": "40636148|None", "id": "40636148", "infons": {}, "passages": [{"infons": {"journal": "Front Physiol;2025; 16 1607873. doi:10.3389/fphys.2025.1607873", "year": "2025", "article-id_pmc": "PMC12237687", "type": "title", "authors": "Yang J, Wang Y, Xu Y, Jia X, Lu F, "}, "offset": 0, "text": "Mechanisms of skeletal muscle atrophy in type 2 diabetes mellitus.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 23, "length": 14}]}, {"id": "3", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes mellitus", "locations": [{"offset": 41, "length": 24}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 67, "text": "Introduction: ERS-induced apoptosis may play a pivotal role in diabetic skeletal muscle atrophy. However, the specific mechanisms by which ERS regulates skeletal muscle atrophy in diabetes remain unclear. The research examines the impact of endoplasmic reticulum stress (ERS) on skeletal muscle atrophy in type 2 diabetes mellitus (T2DM) mice. Methods: Leptin receptor-deficient Db/db mice (n = 7, 24-week-old, male) were employed as a type 2 diabetes model, while age-matched male C57BL/6J mice (n = 7) served as normal controls. Pathway enrichment analysis of differentially expressed genes was performed based on transcriptome sequencing data, focusing on apoptosis, ERS, and ubiquitin-proteasome pathways. Skeletal muscle morphology was assessed via anatomical observation, Laminin Staining, and immunoblotting analysis (WB). WB was used to detect ERS markers (ATF6, p-eIF2alpha, Bip, p-JNK, Chop), apoptosis-related proteins (Bcl2, Bax, Cleaved Caspase-3, CytC), p-Akt, and muscle atrophy marker Atrogin1. Results: Transcriptomic enrichment analysis confirmed specific activation of apoptosis, ERS, and ubiquitin-proteasome pathways. WB revealed upregulated ERS-related proteins, increased apoptotic proteins, decreased p-Akt expression, elevated Atrogin1 levels, and enhanced proteolytic activity. Db/db mice exhibited significant skeletal muscle atrophy, with Laminin Staining demonstrating reduced cross-sectional area (CSA) of muscle fibers. Discussion: These findings uncovers a dual regulatory mechanism underlying diabetic muscle atrophy. The diabetic skeletal muscle microenvironment exhibits elevated oxidative stress and significantly enhanced ER stress, which promotes direct muscle atrophy through ER stress sensor-mediated apoptosis. Concurrently, sustained ER stress suppresses Akt activity while upregulating the muscle-specific E3 ubiquitin ligase Atrogin1, thereby accelerating proteolysis and inducing indirect muscle wasting. These findings provide crucial mechanistic insights into diabetic skeletal myopathy, highlighting the ER stress signaling network as a promising therapeutic target for mitigating muscle atrophy in diabetes.", "sentences": [], "annotations": [{"id": "40", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "diabetic skeletal muscle atrophy", "locations": [{"offset": 130, "length": 32}]}, {"id": "41", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 229, "length": 14}]}, {"id": "42", "infons": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "text": "diabetes", "locations": [{"offset": 247, "length": 8}]}, {"id": "43", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 355, "length": 14}]}, {"id": "44", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes mellitus", "locations": [{"offset": 373, "length": 24}]}, {"id": "45", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "T2DM", "locations": [{"offset": 399, "length": 4}]}, {"id": "46", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 405, "length": 4}]}, {"id": "47", "infons": {"identifier": "16847", "type": "Gene", "ncbi_homologene": "1731", "valid": true, "normalized": [16847], "database": "ncbi_gene", "normalized_id": 16847, "biotype": "gene", "name": "Lepr", "accession": "@GENE_LEPR"}, "text": "Leptin receptor", "locations": [{"offset": 420, "length": 15}]}, {"id": "48", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 452, "length": 4}]}, {"id": "49", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes", "locations": [{"offset": 503, "length": 15}]}, {"id": "50", "infons": {"identifier": "CVCL:W797", "type": "CellLine", "valid": true, "normalized": ["W797"], "database": "cvcl", "normalized_id": "W797", "biotype": "cellline", "name": "W797", "accession": null}, "text": "/6J", "locations": [{"offset": 554, "length": 3}]}, {"id": "51", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 558, "length": 4}]}, {"id": "52", "infons": {"identifier": "226641", "type": "Gene", "ncbi_homologene": "32015", "valid": true, "normalized": [226641], "database": "ncbi_gene", "normalized_id": 226641, "biotype": "gene", "name": "Atf6", "accession": "@GENE_ATF6"}, "text": "ATF6", "locations": [{"offset": 932, "length": 4}]}, {"id": "53", "infons": {"identifier": "229317", "type": "Gene", "ncbi_homologene": "5969", "valid": true, "normalized": [229317], "database": "ncbi_gene", "normalized_id": 229317, "biotype": "gene", "name": "Eif2a", "accession": "@GENE_EIF2A"}, "text": "eIF2alpha", "locations": [{"offset": 940, "length": 9}]}, {"id": "54", "infons": {"identifier": "14828", "type": "Gene", "ncbi_homologene": "3908", "valid": true, "normalized": [14828], "database": "ncbi_gene", "normalized_id": 14828, "biotype": "gene", "name": "Hspa5", "accession": "@GENE_HSPA5"}, "text": "Bip", "locations": [{"offset": 951, "length": 3}]}, {"id": "55", "infons": {"identifier": "26419", "type": "Gene", "ncbi_homologene": "56760", "valid": true, "normalized": [26419], "database": "ncbi_gene", "normalized_id": 26419, "biotype": "gene", "name": "Mapk8", "accession": "@GENE_MAPK8"}, "text": "JNK", "locations": [{"offset": 958, "length": 3}]}, {"id": "56", "infons": {"identifier": "13198", "type": "Gene", "ncbi_homol