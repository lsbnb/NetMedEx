 "text": "mitochondria-related diseases", "locations": [{"offset": 1952, "length": 29}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9997", "role1": {"identifier": "MESH:D009136", "type": "Disease", "valid": true, "normalized": ["D009136"], "database": "ncbi_mesh", "normalized_id": "D009136", "biotype": "disease", "name": "Muscular Dystrophies", "accession": "@DISEASE_Muscular_Dystrophies"}, "role2": {"identifier": "15510", "type": "Gene", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "type": "Association"}, "nodes": []}, {"id": "R2", "infons": {"score": "0.9825", "role1": {"identifier": "MESH:D000255", "type": "Chemical", "valid": true, "normalized": ["D000255"], "database": "ncbi_mesh", "normalized_id": "D000255", "biotype": "chemical", "name": "Adenosine Triphosphate", "accession": "@CHEMICAL_Adenosine_Triphosphate"}, "role2": {"identifier": "15510", "type": "Gene", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "15,29"}]}, {"id": "R3", "infons": {"score": "0.9985", "role1": {"identifier": "MESH:D005207", "type": "Disease", "valid": true, "normalized": ["D005207"], "database": "ncbi_mesh", "normalized_id": "D005207", "biotype": "disease", "name": "Fasciculation", "accession": "@DISEASE_Fasciculation"}, "role2": {"identifier": "15510", "type": "Gene", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "24,29"}]}, {"id": "R4", "infons": {"score": "0.9989", "role1": {"identifier": "MESH:D021081", "type": "Disease", "valid": true, "normalized": ["D021081"], "database": "ncbi_mesh", "normalized_id": "D021081", "biotype": "disease", "name": "Chronobiology Disorders", "accession": "@DISEASE_Chronobiology_Disorders"}, "role2": {"identifier": "15510", "type": "Gene", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "27,29"}]}, {"id": "R5", "infons": {"score": "0.9994", "role1": {"identifier": "MESH:D003643", "type": "Disease", "valid": true, "normalized": ["D003643"], "database": "ncbi_mesh", "normalized_id": "D003643", "biotype": "disease", "name": "Death", "accession": "@DISEASE_Death"}, "role2": {"identifier": "15510", "type": "Gene", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "25,29"}]}, {"id": "R6", "infons": {"score": "0.9994", "role1": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "role2": {"identifier": "15510", "type": "Gene", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "28,29"}]}, {"id": "R7", "infons": {"score": "0.7653", "role1": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "role2": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "type": "Association"}, "nodes": [{"refid": "5", "role": "17,18"}]}, {"id": "R8", "infons": {"score": "0.9997", "role1": {"identifier": "MESH:C564971", "type": "Disease", "valid": true, "normalized": ["C564971"], "database": "ncbi_mesh", "normalized_id": "C564971", "biotype": "disease", "name": "Myopathy with Giant Abnormal Mitochondria", "accession": "@DISEASE_Myopathy_with_Giant_Abnormal_Mitochondria"}, "role2": {"identifier": "15510", "type": "Gene", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "type": "Association"}, "nodes": [{"refid": "6", "role": "30,29"}]}], "pmid": 41507123, "pmcid": null, "meta": {}, "date": "2026-01-08T00:00:00Z", "journal": "Cell Death Dis", "authors": ["Chen TH", "Chou CK", "Lin KM"], "relations_display": [{"name": "associate|@DISEASE_Muscular_Dystrophies|@GENE_HSPD1"}, {"name": "associate|@CHEMICAL_Adenosine_Triphosphate|@GENE_HSPD1"}, {"name": "associate|@DISEASE_Fasciculation|@GENE_HSPD1"}, {"name": "associate|@DISEASE_Chronobiology_Disorders|@GENE_HSPD1"}, {"name": "associate|@DISEASE_Death|@GENE_HSPD1"}, {"name": "associate|@DISEASE_Muscular_Diseases|@GENE_HSPD1"}, {"name": "associate|@CHEMICAL_Reactive_Oxygen_Species|@DISEASE_Mitochondrial_Diseases"}, {"name": "associate|@DISEASE_Myopathy_with_Giant_Abnormal_Mitochondria|@GENE_HSPD1"}]}, {"_id": "41509286|None", "id": "41509286", "infons": {}, "passages": [{"infons": {"journal": "bioRxiv;2025Dec29. doi:10.64898/2025.12.29.696779", "year": "2025", "article-id_pmc": "PMC12776371", "type": "title", "authors": "Lu X, Sharko OL, Shmanai VV, Shchepinov MS, Markworth JF, "}, "offset": 0, "text": "Deuterated Polyunsaturated Fatty Acids Alleviate In Vitro Skeletal Muscle Dysfunction Induced by Oxidative Stress.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Deuterated Polyunsaturated Fatty Acids", "locations": [{"offset": 0, "length": 38}]}, {"id": "3", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "Muscle Dysfunction", "locations": [{"offset": 67, "length": 18}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 115, "text": "Excessive oxidative stress drives lipid peroxidation and contributes to skeletal muscle atrophy in a range of musculoskeletal diseases. Polyunsaturated fatty acids (PUFAs) are essential components of muscle cell membrane phospholipids and are especially susceptible to peroxidation due to the presence of double bonds. Currently, therapeutic options targeting lipid peroxidation to prevent muscle wasting are limited. Substituting the hydrogen atom at the bis-allylic position with deuterium could conceivably limit lipid peroxidation while retaining enzymatic PUFA metabolism. Here we investigated the potential role of deuterated PUFAs (D-PUFAs) in protecting against muscle cell dysfunction under conditions of elevated oxidative stress. Both native (H-) and deuterated (D-) forms of long chain PUFAs including arachidonic acid (ARA), eicosapentaenoic acid (EPA), docosapentaenoic acid (DPA), and docosahexaenoic acid (DHA) stimulated in vitro muscle cell growth and development in the absence of oxidative stress. D-ARA, D-EPA, D-DPA, and D-DHA each protected cultured myotubes against the deleterious effects of direct exposure to reactive oxygen species (ROS) by limiting lipid peroxidation. In contrast, H-ARA, H-EPA, H-DPA, and H-DHA each increased sensitivity to ROS-induced lipid peroxidation and exacerbated oxidative stress-induced muscle cell dysfunction. Deuterated short chain linoleic acid (D-LA), alpha linolenic acid (D-ALA), as well as D-ARA and D-EPA (but not D-DPA or D-DHA) also protected against the deleterious effects of ferroptosis inducer erastin on myogenic differentiation. Finally, D-PUFAs modulated local expression of endogenous antioxidant enzymes and muscle-specific protein ligases. Overall, our study suggests a promising role of D-PUFAs as novel therapeutics to protect against skeletal muscle dysfunction induced by oxidative stress.", "sentences": [], "annotations": [{"id": "54", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 149, "length": 5}]}, {"id": "55", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 196, "length": 14}]}, {"id": "56", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "musculoskeletal diseases", "locations": [{"offset": 225, "length": 24}]}, {"id": "57", "infons": {"identifier": "MESH:D005231", "type": "Chemical", "valid": true, "normalized": ["D005231"], "database": "ncbi_mesh", "normalized_id": "D005231", "biotype": "chemical", "name": "Fatty Acids Unsaturated", "accession": "@CHEMICAL_Fatty_Acids_Unsaturated"}, "text": "Polyunsaturated fatty acids", "locations": [{"offset": 251, "length": 27}]}, {"id": "58", "infons": {"identifier": "MESH:D005231", "type": "Chemical", "valid": true, "normalized": ["D005231"], "database": "ncbi_mesh", "normalized_id": "D005231", "biotype": "chemical", "name": "Fatty Acids Unsaturated", "accession": "@CHEMICAL_Fatty_Acids_Unsaturated"}, "text": "PUFAs", "locations": [{"offset": 280, "length": 5}]}, {"id": "59", "infons": {"identifier": "MESH:D010743", "type": "Chemical", "valid": true, "normalized": ["D010743"], "database": "ncbi_mesh", "normalized_id": "D010743", "biotype": "chemical", "name": "Phospholipids", "accession": "@CHEMICAL_Phospholipids"}, "text": "phospholipids", "locations": [{"offset": 336, "length": 13}]}, {"id": "60", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 475, "length": 5}]}, {"id": "61", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle wasting", "locations": [{"offset": 505, "length": 14}]}, {"id": "62", "infons": {"identifier": "MESH:D003903", "type": "Chemical", "valid": true, "normalized": ["D003903"], "database": "ncbi_mesh", "normalized_id": "D003903", "biotype": "chemical", "name": "Deuterium", "accession": "@CHEMICAL_Deuterium"}, "text": "deuterium", "locations": [{"offset": 597, "length": 9}]}, {"id": "63", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 631, "length": 5}]}, {"id": "64", "infons": {"identifier": "MESH:D005231", "type": "Chemical", "valid": true, "normalized": ["D005231"], "database": "ncbi_mesh", "normalized_id": "D005231", "biotype": "chemical", "name": "Fatty Acids Unsaturated", "accession": "@CHEMICAL_Fatty_Acids_Unsatu