dentifier": "22337", "type": "Gene", "valid": true, "normalized": [22337], "database": "ncbi_gene", "normalized_id": 22337, "biotype": "gene", "name": "Vdr", "accession": "@GENE_VDR"}, "type": "Association"}, "nodes": [{"refid": "8", "role": "32,37"}]}, {"id": "R10", "infons": {"score": "0.9669", "role1": {"identifier": "MESH:D014807", "type": "Chemical", "valid": true, "normalized": ["D014807"], "database": "ncbi_mesh", "normalized_id": "D014807", "biotype": "chemical", "name": "Vitamin D", "accession": "@CHEMICAL_Vitamin_D"}, "role2": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "type": "Association"}, "nodes": [{"refid": "9", "role": "39,41"}]}, {"id": "R11", "infons": {"score": "0.9838", "role1": {"identifier": "MESH:D014807", "type": "Chemical", "valid": true, "normalized": ["D014807"], "database": "ncbi_mesh", "normalized_id": "D014807", "biotype": "chemical", "name": "Vitamin D", "accession": "@CHEMICAL_Vitamin_D"}, "role2": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "10", "role": "39,40"}]}, {"id": "R12", "infons": {"score": "0.8473", "role1": {"identifier": "MESH:D002762", "type": "Chemical", "valid": true, "normalized": ["D002762"], "database": "ncbi_mesh", "normalized_id": "D002762", "biotype": "chemical", "name": "Cholecalciferol", "accession": "@CHEMICAL_Cholecalciferol"}, "role2": {"identifier": "22337", "type": "Gene", "valid": true, "normalized": [22337], "database": "ncbi_gene", "normalized_id": 22337, "biotype": "gene", "name": "Vdr", "accession": "@GENE_VDR"}, "type": "Association"}, "nodes": [{"refid": "11", "role": "38,37"}]}, {"id": "R13", "infons": {"score": "0.9989", "role1": {"identifier": "MESH:D002762", "type": "Chemical", "valid": true, "normalized": ["D002762"], "database": "ncbi_mesh", "normalized_id": "D002762", "biotype": "chemical", "name": "Cholecalciferol", "accession": "@CHEMICAL_Cholecalciferol"}, "role2": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "12", "role": "38,40"}]}], "pmid": 41286086, "pmcid": null, "meta": {}, "date": "2025-11-24T00:00:00Z", "journal": "Sci Rep", "authors": ["Watcharanapapan W", "Hirunsai M", "Srikuea R"], "relations_display": [{"name": "negative_correlate|@CHEMICAL_Cholecalciferol|@GENE_TGFB1"}, {"name": "treat|@CHEMICAL_Cholecalciferol|@DISEASE_Muscular_Diseases"}, {"name": "associate|@DISEASE_Muscular_Atrophy|@GENE_VDR"}, {"name": "positive_correlate|@GENE_ACTA2|@GENE_TGFB1"}, {"name": "associate|@GENE_ACTA2|@GENE_VDR"}, {"name": "associate|@CHEMICAL_Cholecalciferol|@DISEASE_Muscular_Atrophy"}, {"name": "associate|@GENE_COL1A1|@GENE_TGFB1"}, {"name": "negative_correlate|@CHEMICAL_Cholecalciferol|@GENE_COL1A1"}, {"name": "associate|@GENE_TGFB1|@GENE_VDR"}, {"name": "associate|@CHEMICAL_Vitamin_D|@DISEASE_Muscular_Diseases"}, {"name": "treat|@CHEMICAL_Vitamin_D|@DISEASE_Fibrosis"}, {"name": "associate|@CHEMICAL_Cholecalciferol|@GENE_VDR"}, {"name": "treat|@CHEMICAL_Cholecalciferol|@DISEASE_Fibrosis"}]}, {"_id": "41290519|None", "id": "41290519", "infons": {}, "passages": [{"infons": {"journal": "J Cachexia Sarcopenia Muscle;2025Dec; 16 (6) 70118. doi:10.1002/jcsm.70118", "year": "2025", "article-id_pmc": "PMC12646868", "type": "title", "authors": "Park EJ, Kim HJ, Lee SH, Choi S, Doan TP, Joo KH, An JP, Jung DW, Williams DR, Oh WK, "}, "offset": 0, "text": "Gymnemantoside A Ameliorates Steroid-Induced Skeletal Muscle Atrophy via Bridging Glucocorticoid and Insulin Receptor Signalling.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Gymnemantoside A", "locations": [{"offset": 0, "length": 16}]}, {"id": "5", "infons": {"identifier": "MESH:D013256", "type": "Chemical", "valid": true, "normalized": ["D013256"], "database": "ncbi_mesh", "normalized_id": "D013256", "biotype": "chemical", "name": "Steroids", "accession": "@CHEMICAL_Steroids"}, "text": "Steroid", "locations": [{"offset": 29, "length": 7}]}, {"id": "6", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "Muscle Atrophy", "locations": [{"offset": 54, "length": 14}]}, {"id": "7", "infons": {"identifier": "16337", "type": "Gene", "ncbi_homologene": "20090", "valid": true, "normalized": [16337], "database": "ncbi_gene", "normalized_id": 16337, "biotype": "gene", "name": "Insr", "accession": "@GENE_INSR"}, "text": "Insulin Receptor", "locations": [{"offset": 101, "length": 16}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 130, "text": "BACKGROUND: Skeletal muscle atrophy is a common condition caused by numerous factors, such as aging (termed sarcopenia), disease (e.g., cancer cachexia) or specific medications (such as glucocorticoids). There is no FDA-approved drug for treating skeletal muscle atrophy. Previously, clinical studies had highlighted the anti-diabetic properties of Gymnema inodorum extract, an indigenous medicinal plant and functional food in Thailand. However, these studies did not identify the active compound(s) responsible for its therapeutic effects. This research aimed to identify safe natural product-derived compounds from clinically relevant plants such as Gymnema inodorum that bridge the connection between metabolic diseases and skeletal muscle atrophy. METHODS: Utilizing the dexamethasone (Dex) induced skeletal muscle atrophy model, the major active compounds were isolated using bioactivity-guided screening. The chemical structure of active compound(s) was elucidated using various spectroscopic methods, including HRESIMS, 1D and 2D NMR. Active compound(s) were tested in cell-based and murine models of skeletal muscle atrophy. Insulin signaling and autophagy activity were assessed by western blotting and the mRFP-GFP-LC3 (ptf-LC3) probe. Docking studies determined the binding affinities of active compound(s) for the insulin and glucocorticoid receptors. RESULTS: We determined a new, previously undescribed methyl anthranilate-conjugated oleanane bioactive compound, termed gymnemantoside A. Treatment with gymnemantoside A recovered myotube diameter and skeletal muscle fibre CSA in atrophy models and downregulated expression of the atrogenes, atrogin-1 and MuRF-1 (myotube diameter: +33.82%, p < 0.05, CSA: +128%, p < 0.01; atrogin-1: -58.70%, MuRF-1: -57.32%, p < 0.05). Gymnemantoside A also reduced autophagy levels both in vitro and in vivo (-65.56%, p < 0.01), increased expression of insulin growth factor-1 (+78.05%, p < 0.05) and the insulin receptor (+56.42%, p < 0.05), and recovered activity of the downstream Akt/mTOR-mediated insulin signalling pathway. Molecular docking analysis with gymnemantoside A and standard receptor ligands revealed that gymnemantoside A could interact with the insulin receptor tyrosine kinase and prevent Dex binding with the glucocorticoid receptor. In the murine atrophy model, gymnemantoside A treatment enhanced exercise endurance in the rotarod test (+260%, p < 0.05) and the mass of the predominantly fast fibre type TA muscle (+116%, p < 0.05). CONCLUSIONS: A newly identified bioactive compound gymnemantoside A, isolated from Gymnema inodorum, was structurally characterized and showed efficacy in Dex-induced muscle atrophy models. Gymnemantoside A produces anti-muscle atrophy effects by a hitherto unreported mechanism: modulation of the insulin receptor kinase domain and activation of downstream signalling, alongside competitive inhibition of the glucocorticoid receptor, which has been implicated in multiple forms of skeletal muscle wasting.", "sentences": [], "annotations": [{"id": "52", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 151, "length": 14}]}, {"id": "53", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 238, "length": 10}]}, {"id": "54", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer cachexia", "locations": [{"offset": 266, "length": 15}]}, {"id": "55", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 386, "length": 14}]}, {"id": "56", "infons": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "text": "diabetic", "locations": [{"offset": 456, "length": 8}]}, {"id": "57", "infons": {"identifier": "187497", "type": "Species", "valid": true, "normalized": [187497], "database": "ncbi_taxonomy", "normalized_id": 187497, "biotype": "species", "name": "187497", "accession": null}, "text": "Gymnema inodorum", "locations": [{"offset": 783, "length": 16}]}, {"id": "58", "infons": {"identifier": "MESH:D008659", "type": "Disease", "valid": true, "normalized": ["D008659"], "database": "ncbi_mesh", "normalized_id": "D008659", "biotype": "disease", "name": "Metabolic Diseases", "accession": "@DISEASE_Metabolic_Diseases"}, "text": "metabolic diseases", "locations": [{"offset": 835, "length": 18}]}, {"id": "59", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 867, "length": 14}]}, {"id": "60", "infons": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "text": "dexamethasone", "locations": [{"offset": 906, "length": 13}]}, {"id": "61", "infons": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "text": "Dex", "locations": [{"offset": 921, "length": 3}]}, {"id": "62", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 943, "length": 14}]}, {"id": "63", "infons": {"