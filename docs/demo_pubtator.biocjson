s"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "11,13"}]}, {"id": "R6", "infons": {"score": "0.9689", "role1": {"identifier": "MESH:D010716", "type": "Chemical", "valid": true, "normalized": ["D010716"], "database": "ncbi_mesh", "normalized_id": "D010716", "biotype": "chemical", "name": "Phosphatidylinositols", "accession": "@CHEMICAL_Phosphatidylinositols"}, "role2": {"identifier": "MESH:D020914", "type": "Disease", "valid": true, "normalized": ["D020914"], "database": "ncbi_mesh", "normalized_id": "D020914", "biotype": "disease", "name": "Myopathies Structural Congenital", "accession": "@DISEASE_Myopathies_Structural_Congenital"}, "type": "Association"}, "nodes": [{"refid": "5", "role": "11,8"}]}], "pmid": 41851531, "pmcid": null, "meta": {}, "date": "2026-03-01T00:00:00Z", "journal": "Nat Metab", "authors": ["Picot M", "Hifdi N", "Vaucourt M", "Mansat M", "Li P", "Singer I", "Chicanne G", "Stella A", "Kuang S", "Miceli C", "Henneman NF", "Payrastre B", "Vandromme M", "Schiltz O", "Nemazanyy I", "de Araujo MEG", "Panasyuk G", "Viaud J", "Lämmerhofer M", "Hnia K"], "relations_display": [{"name": "associate|@CHEMICAL_Lipids|@GENE_MTM1"}, {"name": "associate|@CHEMICAL_Lipids|@DISEASE_Myopathies_Structural_Congenital"}, {"name": "associate|@DISEASE_Myopathies_Structural_Congenital|@GENE_MTM1"}, {"name": "associate|@CHEMICAL_Phosphatidylinositols|@GENE_MTM1"}, {"name": "associate|@CHEMICAL_Phosphatidylinositols|@DISEASE_Muscular_Diseases"}, {"name": "associate|@CHEMICAL_Phosphatidylinositols|@DISEASE_Myopathies_Structural_Congenital"}]}, {"_id": "41886728|None", "id": "41886728", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "SGA-DT: An adaptive fusion framework for missing data imputation and interpretable healthcare classification.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 110, "text": "Despite advances in machine learning and medical data processing, handling missing values remains a critical and complex challenge in healthcare analytics. Missing data, especially in non-class attributes can severely compromise model accuracy, clinical reliability, and interpretability. In sensitive domains such as healthcare, improper imputation may lead to biased outcomes or delayed interventions. To address this challenge, we propose SGA-DT, an adaptive and interpretable learning framework that combines the best features of genetically optimized support vector regression (SVR) with a decision tree (DT) classifier for robust healthcare prediction. The framework adaptively selects an imputation strategy based on the level of missingness. It uses standard SVR for low, iterative SVR for moderate, and k-Nearest Neighbor (KNN) followed by SVR refinement for high missingness. Genetic algorithm (GA) is used to select the best SVR kernel and tune its hyperparameters, enhancing imputation accuracy across different data patterns. The complete dataset is then classified using DT, providing both robustness and transparency in prediction. The SGA-DT framework is evaluated on three healthcare datasets, Breast Cancer, Mammographic, and Hepatitis, along with other real-world and synthetic datasets. For interpretability analysis, decision trees are generated under varying missingness levels to support clinical transparency. Comparative results show that SGA-DT consistently outperforms multiple integrated frameworks across accuracy, precision, recall, and F-measure, demonstrating its robustness, interpretability, and generalizability in healthcare prediction tasks.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D001943", "type": "Disease", "valid": true, "normalized": ["D001943"], "database": "ncbi_mesh", "normalized_id": "D001943", "biotype": "disease", "name": "Breast Neoplasms", "accession": "@DISEASE_Breast_Neoplasms"}, "text": "Breast Cancer", "locations": [{"offset": 1321, "length": 13}]}, {"id": "3", "infons": {"identifier": "MESH:D056486", "type": "Disease", "valid": true, "normalized": ["D056486"], "database": "ncbi_mesh", "normalized_id": "D056486", "biotype": "disease", "name": "Chemical and Drug Induced Liver Injury", "accession": "@DISEASE_Chemical_and_Drug_Induced_Liver_Injury"}, "text": "Hepatitis", "locations": [{"offset": 1354, "length": 9}]}], "relations": []}], "relations": [], "pmid": 41886728, "pmcid": null, "meta": {}, "date": "2026-03-26T00:00:00Z", "journal": "PLoS One", "authors": ["Jena M", "Dehuri S", "Cho SB"], "relations_display": []}, {"_id": "41888986|None", "id": "41888986", "infons": {}, "passages": [{"infons": {"journal": "Arthroplasty;2026Mar26; 8 (Suppl 1) . doi:10.1186/s42836-026-00376-9", "year": "2026", "article-id_pmc": "PMC13019721", "type": "title"}, "offset": 0, "text": "Abstracts from the 11th Annual Meeting of Arthroplasty Society In Asia (ASIA), the 4th Annual Meeting of the Malaysian Society for Hip and Knee Surgeons (MSHKS), and the 17th Annual Meeting of the ASEAN Arthroplasty Association (AAA).", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 235, "text": "", "sentences": [], "annotations": [], "relations": []}], "relations": [], "pmid": 41888986, "pmcid": null, "meta": {}, "date": "2026-03-26T00:00:00Z", "journal": "Arthroplasty", "authors": [], "relations_display": []}, {"_id": "41892682|None", "id": "41892682", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Probiotic Bacillus subtilis, but Not a Lactobacillus spp., Ameliorates Cognitive Impairment in a Mouse Model of LPS and Zidovudine-Induced Neuroinflammation.", "sentences": [], "annotations": [{"id": "6", "infons": {"identifier": "1423", "type": "Species", "valid": true, "normalized": [1423], "database": "ncbi_taxonomy", "normalized_id": 1423, "biotype": "species", "name": "1423", "accession": null}, "text": "Bacillus subtilis", "locations": [{"offset": 10, "length": 17}]}, {"id": "7", "infons": {"identifier": "MESH:D003072", "type": "Disease", "valid": true, "normalized": ["D003072"], "database": "ncbi_mesh", "normalized_id": "D003072", "biotype": "disease", "name": "Cognition Disorders", "accession": "@DISEASE_Cognition_Disorders"}, "text": "Cognitive Impairment", "locations": [{"offset": 71, "length": 20}]}, {"id": "8", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "Mouse", "locations": [{"offset": 97, "length": 5}]}, {"id": "9", "infons": {"identifier": "MESH:D008070", "type": "Chemical", "valid": true, "normalized": ["D008070"], "database": "ncbi_mesh", "normalized_id": "D008070", "biotype": "chemical", "name": "Lipopolysaccharides", "accession": "@CHEMICAL_Lipopolysaccharides"}, "text": "LPS", "locations": [{"offset": 112, "length": 3}]}, {"id": "10", "infons": {"identifier": "MESH:D015215", "type": "Chemical", "valid": true, "normalized": ["D015215"], "database": "ncbi_mesh", "normalized_id": "D015215", "biotype": "chemical", "name": "Zidovudine", "accession": "@CHEMICAL_Zidovudine"}, "text": "Zidovudine", "locations": [{"offset": 120, "length": 10}]}, {"id": "11", "infons": {"identifier": "MESH:D000090862", "type": "Disease", "valid": true, "normalized": ["D000090862"], "database": "ncbi_mesh", "normalized_id": "D000090862", "biotype": "disease", "name": "Neuroinflammatory Diseases", "accession": "@DISEASE_Neuroinflammatory_Diseases"}, "text": "Neuroinflammation", "locations": [{"offset": 139, "length": 17}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 158, "text": "Background/Objectives: The gut-brain axis is increasingly recognized as a critical modulator of cognitive function. This study investigated the neurotoxic effects of combined exposure to bacterial lipopolysaccharide (LPS) and the antiretroviral drug zidovudine (ZDV) in a mouse model, and evaluated the protective potential of two probiotic interventions: Bacillus subtilis and a mixture of lactobacilli. Methods: Cognitive function was assessed using the Morris water maze (MWM). Gut microbiota composition was analyzed by 16S rRNA sequencing, and intestinal morphology was examined histologically. Gene expression of neuroinflammatory markers and mitophagy-related genes in brain tissue was quantified by RT-PCR. Plasma levels of cell-free mitochondrial DNA (cf-mtDNA) were measured as a marker of mitochondrial damage. Results: Combined LPS + ZDV exposure induced systemic inflammation, impaired spatial memory, damaged the intestinal mucosa, and caused dysbiosis characterized by an increase in pro-inflammatory Muribaculaceae. In the brain, LPS + ZDV significantly upregulated Tnfa expression, confirming neuroinflammation. Bacillus subtilis administration prevented cognitive deficits, maintained Tnfa at control levels, and significantly reduced Il1b and Il6 expression compared to the LPS + ZDV group. This was accompanied by activation of the PINK1/PTEN-dependent mitophagy pathway, prevention of cf-mtDNA release, and restoration of gut microbial diversity. In contrast, the Lactobacilli mixture not only failed to improve outcomes but was associated with exacerbated intestinal damage, more pronounced cognitive dysfunction, and no reduction in neuroinflammatory markers. Conclusions: Combined exposure to LPS and ZDV induces gut-brain axis dysfunction characterized by neuroinflammation, cognitive impairment, intestinal damage, and dysbiosis. Bacillus subtilis effectively preserves cognitive function through activation of PINK1/PTEN-dependent mitophagy and suppression of neuroinflammation, highlighting its potential as a therapeutic candidate for cognitive impairments associated with gut-brain axis dysfunction. The contrasting effects of the lactobacilli mixture underscore the critical importance of strain-specificity in probiotic interventions.", "sentences": [], "annotations": [{"id": "47", "infons": {"identifier": "MESH:D020258", "type": "Disease", "valid": true, "normalized": ["D020258"], "database": "ncbi_mesh", "normalized_id": "D020258", "biotype": "disease", "name": "Neurotoxicity Syndromes", "accession": "@DISEASE_Neurotoxicity_Syndromes"}, "text": "neurotoxic", "locations": [{"offset": 302, "length": 10}]}, {"id": "48", "infons": {"identifier": "MESH:D008070", "type": "Chemical", "valid": true, "normalized": ["D008070"], "database": "ncbi_mesh", "normalized_id": "D008070", "biotype": "chemical", "name": "Lipopolysaccharides", "accession": "@CHEMICAL_Lipopolysaccharides"}, "text": "lipopolysaccharide", "locations": [{"offset": 355, "length": 18}]}, {"id": "49", "infons": {"identifier": "MESH:D008070", "type": "Chemical", "valid": true, "normalized": ["D008070"], "database": "ncbi_mesh", "normalized_id": "D008070", "biotype": "chemical", "name": "Lipopolysaccharides", "accession": "@CHEMICAL_Lipopolysaccharides"}, "text": "LPS", "locations": [{"offset": 375, "length": 3}]}, {"id": "50", "infons": {"identifier": "MESH:D015215", "type": "Chemical", "valid": true, "normalized": ["D015215"], "database": "ncbi_mesh", "normalized_id": "D015215", "biotype": "chemical", "name": "Zidovudine", "accession": "@CHEMICAL_Zidovudine"}, "text": "zidovudine", "locations": [{"offset": 408, "length": 10}]}, {"id": "51", "infons": {"identifier": "MESH:D015215", "type": "Chemical", "valid": true, "normalized": ["D015215"], "database": "ncbi_mesh", "normalized_id": "D015215", "biotype": "chemical", "name": "Zidovudine", "accession": "@CHEMICAL_Zidovudine"}, "text": "ZDV", "locations": [{"offset": 420, "length": 3}]}, {"id": "52", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 430, "length": 5}]}, {"id": "53", "infons": {"identifier": "1423", "type": "Species", "valid": true, "normalized": [1423], "database": "ncbi_taxonomy", "normalized_id": 1423, "biotype": "species", "name": "1423", "accession": null}, "text": "Bacillus subtilis", "locations": [{"offset": 514, "length": 17}]}, {"id": "54", "infons": {"identifier": "MESH:D000090862", "type": "Disease", "valid": true, "normalized": ["D000090862"], "database": "ncbi_mesh", "normalized_id": "D000090862", "biotype": "disease", "name": "Neuroinflammatory Diseases", "accession": "@DISEASE_Neuroinflammatory_Diseases"}, "text": "neuroinflammatory", "locations": [{"offset": 777, "length": 17}]}, {"id": "55", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial damage", "locations": [{"offset": 958, "length": 20}]}, {"id": "56", "infons": {"identifier": "MESH:D008070", "type": "Chemical", "valid": true, "normalized": ["D008070"], "database": "ncbi_mesh", "normalized_id": "D008070", "biotype": "chemical", "name": "Lipopolysaccharides", "accession": "@CHEMICAL_Lipopolysaccharides"}, "text": "LPS", "locations": [{"offset": 998, "length": 3}]}, {"id": "57", "infons": {"identifier": "MESH:D015215", "type": "Chemical", "valid": true, "normalized": ["D015215"], "database": "ncbi_mesh", "normalized_id": "D015215", "biotype": "chemical", "name": "Zidovudine", "accession": "@CHEMICAL_Zidovudine"}, "text": "ZDV", "locations": [{"offset": 1004, "length": 3}]}, {"id": "58", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 1034, "length": 12}]}, {"id": "59", "infons": {"identifier": "MESH:D064806", "type": "Disease", "valid": true, "normalized": 