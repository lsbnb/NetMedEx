ging Premature", "accession": "@DISEASE_Aging_Premature"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "27,29"}]}, {"id": "R6", "infons": {"score": "0.9756", "role1": {"identifier": "MESH:D005204", "type": "Chemical", "valid": true, "normalized": ["D005204"], "database": "ncbi_mesh", "normalized_id": "D005204", "biotype": "chemical", "name": "Farnesol", "accession": "@CHEMICAL_Farnesol"}, "role2": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "5", "role": "8,12"}]}, {"id": "R7", "infons": {"score": "0.9095", "role1": {"identifier": "MESH:C009034", "type": "Chemical", "valid": true, "normalized": ["C009034"], "database": "ncbi_mesh", "normalized_id": "C009034", "biotype": "chemical", "name": "prenol", "accession": "@CHEMICAL_prenol"}, "role2": {"identifier": "MESH:D002784", "type": "Chemical", "valid": true, "normalized": ["D002784"], "database": "ncbi_mesh", "normalized_id": "D002784", "biotype": "chemical", "name": "Cholesterol", "accession": "@CHEMICAL_Cholesterol"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "6", "role": "27,24"}]}, {"id": "R8", "infons": {"score": "0.9985", "role1": {"identifier": "MESH:C009034", "type": "Chemical", "valid": true, "normalized": ["C009034"], "database": "ncbi_mesh", "normalized_id": "C009034", "biotype": "chemical", "name": "prenol", "accession": "@CHEMICAL_prenol"}, "role2": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "7", "role": "27,12"}]}, {"id": "R9", "infons": {"score": "0.9986", "role1": {"identifier": "MESH:C009034", "type": "Chemical", "valid": true, "normalized": ["C009034"], "database": "ncbi_mesh", "normalized_id": "C009034", "biotype": "chemical", "name": "prenol", "accession": "@CHEMICAL_prenol"}, "role2": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "8", "role": "27,11"}]}], "pmid": 41759582, "pmcid": null, "meta": {}, "date": "2026-02-25T00:00:00Z", "journal": "J Lipid Res", "authors": ["Verdaguer IB", "Hernández A", "Torres S", "Rodríguez-Peiris M", "Arenas F", "Martinez DE", "López MB", "Crispim M", "Tabata Y", "Garcia-Ruiz C", "Fernandez-Checa JC"], "relations_display": [{"name": "treat|@CHEMICAL_geranylgeraniol|@DISEASE_Inflammation"}, {"name": "treat|@CHEMICAL_Farnesol|@DISEASE_Neoplasms"}, {"name": "treat|@CHEMICAL_geranylgeraniol|@DISEASE_Neoplasms"}, {"name": "associate|@CHEMICAL_prenol|@CHEMICAL_Aldehydes"}, {"name": "associate|@CHEMICAL_prenol|@DISEASE_Aging_Premature"}, {"name": "treat|@CHEMICAL_Farnesol|@DISEASE_Inflammation"}, {"name": "negative_correlate|@CHEMICAL_prenol|@CHEMICAL_Cholesterol"}, {"name": "treat|@CHEMICAL_prenol|@DISEASE_Inflammation"}, {"name": "treat|@CHEMICAL_prenol|@DISEASE_Neoplasms"}]}, {"_id": "41777703|None", "id": "41777703", "infons": {}, "passages": [{"infons": {"journal": "J Orthop Translat;2026Mar; 57 101061. doi:10.1016/j.jot.2026.101061", "year": "2026", "article-id_pmc": "PMC12950377", "type": "title", "authors": "Ekanayake Mudiyanselage D, Ouyang CE, Jin RD, Velmurugan S, Jiang Y, Sun J, Ma D, "}, "offset": 0, "text": "Vitamin D deficiency and disease conditions relevant to: Orthopaedic translation.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D014808", "type": "Disease", "valid": true, "normalized": ["D014808"], "database": "ncbi_mesh", "normalized_id": "D014808", "biotype": "disease", "name": "Vitamin D Deficiency", "accession": "@DISEASE_Vitamin_D_Deficiency"}, "text": "Vitamin D deficiency", "locations": [{"offset": 0, "length": 20}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 82, "text": "Vitamin D, traditionally known for its role in calcium-phosphate homeostasis and bone health, is now recognised as a pleiotropic hormone with critical effects on multiple physiological processes. It exists primarily as ergocalciferol (vitamin D2) and cholecalciferol (vitamin D3), which are biologically inactive until undergoing a sequential hydroxylation in the liver to form 25-hydroxyvitamin D (calcidiol), and subsequently in kidney to form the active metabolite 1,25-dihydroxyvitamin D (calcitriol). By engaging the vitamin D receptor, it exerts immunomodulatory, neuroprotective, and anti-frailty functions. Deficiency in vitamin D has been implicated in a wide range of disorders, including musculoskeletal weakness, frailty, cognitive decline, autoimmune diseases, and respiratory infections. Vitamin D deficiency affects nearly half of the global population and remains a widespread public health challenge, and effective interventions such as food fortification and targeted supplementation should be prioritized in future strategies. The translational potential of this article: Vitamin D deficiency represents a modifiable risk factor with implicated effects across systemic, neurocognitive and musculoskeletal systems. Epidemiological evidence links deficiency to increased risk of infection, cognitive decline, frailty and orthopaedic morbidity. In orthopaedic and geriatric populations, maintaining sufficient vitamin D supplementation may reduce fracture and fall risk as well as postoperative complications and infections. These factors are also influenced by vitamin D deficiency-related effects on neurocognition. Vitamin D status may also be relevant in the management of infectious diseases, including respiratory illnesses and COVID-19. This review also discusses mechanistic and practical rationales for clinical translation. Potential interventions include vitamin D co-supplementation, dietary fortification and optimised sun exposure. However, limitations in existing randomised trials underscore the need for consistency in dosing, appropriate formulation, targeted population, as well as baseline deficiency progression status. These insights can guide clinicians, public health policy makers and researchers in developing evidence-based protocols and interventions to reduce vitamin D deficiency-related morbidity.", "sentences": [], "annotations": [{"id": "39", "infons": {"identifier": "MESH:D014807", "type": "Chemical", "valid": true, "normalized": ["D014807"], "database": "ncbi_mesh", "normalized_id": "D014807", "biotype": "chemical", "name": "Vitamin D", "accession": "@CHEMICAL_Vitamin_D"}, "text": "Vitamin D", "locations": [{"offset": 82, "length": 9}]}, {"id": "40", "infons": {"identifier": "MESH:C020243", "type": "Chemical", "valid": true, "normalized": ["C020243"], "database": "ncbi_mesh", "normalized_id": "C020243", "biotype": "chemical", "name": "calcium phosphate", "accession": "@CHEMICAL_calcium_phosphate"}, "text": "calcium-phosphate", "locations": [{"offset": 129, "length": 17}]}, {"id": "41", "infons": {"identifier": "MESH:D004872", "type": "Chemical", "valid": true, "normalized": ["D004872"], "database": "ncbi_mesh", "normalized_id": "D004872", "biotype": "chemical", "name": "Ergocalciferols", "accession": "@CHEMICAL_Ergocalciferols"}, "text": "ergocalciferol", "locations": [{"offset": 301, "length": 14}]}, {"id": "42", "infons": {"identifier": "MESH:D004872", "type": "Chemical", "valid": true, "normalized": ["D004872"], "database": "ncbi_mesh", "normalized_id": "D004872", "biotype": "chemical", "name": "Ergocalciferols", "accession": "@CHEMICAL_Ergocalciferols"}, "text": "vitamin D2", "locations": [{"offset": 317, "length": 10}]}, {"id": "43", "infons": {"identifier": "MESH:D002762", "ty