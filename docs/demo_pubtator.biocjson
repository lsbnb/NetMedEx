MICAL_Glucose|@DISEASE_Peroxisomal_Disorders"}, {"name": "associate|@DISEASE_Fatty_Liver|@GENE_PPARA"}, {"name": "associate|@CHEMICAL_Lipids|@GENE_PPARA"}, {"name": "associate|@CHEMICAL_Lipids|@DISEASE_Peroxisomal_Disorders"}]}, {"_id": "41469664|None", "id": "41469664", "infons": {}, "passages": [{"infons": {"journal": "J Neuroinflammation;2025Dec30. doi:10.1186/s12974-025-03629-7", "year": "2025", "type": "title", "authors": "Yu X, Xiao H, Bao S, Dong Y, Dong Z, Zhao J, Wang G, Meng X, Wang F, "}, "offset": 0, "text": "Cigarette smoke-induced lung-brain barrier dysfunction drives neurocognitive impairment via inflammatory spill-over.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Cigarette smoke", "locations": [{"offset": 0, "length": 15}]}, {"id": "4", "infons": {"identifier": "MESH:D019965", "type": "Disease", "valid": true, "normalized": ["D019965"], "database": "ncbi_mesh", "normalized_id": "D019965", "biotype": "disease", "name": "Neurocognitive Disorders", "accession": "@DISEASE_Neurocognitive_Disorders"}, "text": "neurocognitive impairment", "locations": [{"offset": 62, "length": 25}]}, {"id": "5", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 92, "length": 12}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 117, "text": "", "sentences": [], "annotations": [], "relations": []}], "relations": [], "pmid": 41469664, "pmcid": null, "meta": {}, "date": "2025-12-30T00:00:00Z", "journal": "J Neuroinflammation", "authors": ["Yu X", "Xiao H", "Bao S", "Dong Y", "Dong Z", "Zhao J", "Wang G", "Meng X", "Wang F"], "relations_display": []}, {"_id": "41469838|None", "id": "41469838", "infons": {}, "passages": [{"infons": {"journal": "Cell Mol Life Sci;2025Dec31. doi:10.1007/s00018-025-06045-5", "year": "2025", "type": "title", "authors": "Yokoyama S, Kido T, Yoneda M, Springer DA, Awasthi PP, Chari R, Patterson AD, Kimura S, "}, "offset": 0, "text": "Secretoglobin 3A1 in activated muscle satellite cells contributes to myosin heavy chain IIX and IIB fiber differentiation.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "50771", "type": "Gene", "ncbi_homologene": "21915", "valid": true, "normalized": [50771], "database": "ncbi_gene", "normalized_id": 50771, "biotype": "gene", "name": "Atp9b", "accession": "@GENE_ATP9B"}, "text": "IIB", "locations": [{"offset": 96, "length": 3}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 123, "text": "Skeletal muscle has an innate ability to restore damaged muscle fibers by contributing specific progenitor cells, called muscle satellite cells. Here we show that secretoglobin (SCGB) 3A1, a tumor suppressor gene in various malignancies including rhabdomyosarcoma, is induced just after muscle injury and contributes to damaged muscle fiber regeneration. Lineage tracing of SCGB3A1 in mice show that SCGB3A1-positive cells highly express myosin heavy chain (MyHC)-IIX in damaged fiber area. Scgb3a1-null and Pax7CreERT2;Scgb3a1f/f conditional-null mice exhibit defective IIX and IIB fiber regeneration, with a concomitant reduction in the expression of Notch3, a gene important for the maintenance of satellite cell self-renewal pools. Aged Scgb3a1-null mice show reduced size of muscle fibers and mass, resulting in compromised muscle performance as compared to the age-matched wild-type mice. This study reveals that SCGB3A1 is an unexpected novel molecule expressed in muscle satellite cells that contributes to fiber type specific muscle regeneration.", "sentences": [], "annotations": [{"id": "19", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "tumor", "locations": [{"offset": 314, "length": 5}]}, {"id": "20", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "malignancies", "locations": [{"offset": 347, "length": 12}]}, {"id": "21", "infons": {"identifier": "MESH:D012208", "type": "Disease", "valid": true, "normalized": ["D012208"], "database": "ncbi_mesh", "normalized_id": "D012208", "biotype": "disease", "name": "Rhabdomyosarcoma", "accession": "@DISEASE_Rhabdomyosarcoma"}, "text": "rhabdomyosarcoma", "locations": [{"offset": 370, "length": 16}]}, {"id": "22", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle injury", "locations": [{"offset": 410, "length": 13}]}, {"id": "23", "infons": {"identifier": "68662", "type": "Gene", "ncbi_homologene": "14160", "valid": true, "normalized": [68662], "database": "ncbi_gene", "normalized_id": 68662, "biotype": "gene", "name": "Scgb3a1", "accession": "@GENE_SCGB3A1"}, "text": "SCGB3A1", "locations": [{"offset": 497, "length": 7}]}, {"id": "24", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 508, "length": 4}]}, {"id": "25", "infons": {"identifier": "68662", "type": "Gene", "ncbi_homologene": "14160", "valid": true, "normalized": [68662], "database": "ncbi_gene", "normalized_id": 68662, "biotype": "gene", "name": "Scgb3a1", "accession": "@GENE_SCGB3A1"}, "text": "SCGB3A1", "locations": [{"offset": 523, "length": 7}]}, {"id": "26", "infons": {"identifier": "111671", "type": "Gene", "valid": true, "normalized": [111671], "database": "ncbi_gene", "normalized_id": 111671, "biotype": "gene", "name": "Myhc", "accession": "@GENE_MYHC"}, "text": "myosin heavy chain", "locations": [{"offset": 561, "length": 18}]}, {"id": "27", "infons": {"identifier": "111671", "type": "Gene", "valid": true, "normalized": [111671], "database": "ncbi_gene", "normalized_id": 111671, "biotype": "gene", "name": "Myhc", "accession": "@GENE_MYHC"}, "text": "MyHC", "locations": [{"offset": 581, "length": 4}]}, {"id": "28", "infons": {"identifier": "68662", "type": "Gene", "ncbi_homologene": "14160", "valid": true, "normalized": [68662], "database": "ncbi_gene", "normalized_id": 68662, "biotype": "gene", "name": "Scgb3a1", "accession": "@GENE_SCGB3A1"}, "text": "Scgb3a1", "locations": [{"offset": 614, "length": 7}]}, {"id": "29", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 671, "length": 4}]}, {"id": "30", "infons": {"identifier": "50771", "type": "Gene", "ncbi_homologene": "21915", "valid": true, "normalized": [50771], "database": "ncbi_gene", "normalized_id": 50771, "biotype": "gene", "name": "Atp9b", "accession": "@GENE_ATP9B"}, "text": "IIB", "locations": [{"offset": 702, "length": 3}]}, {"id": "31", "infons": {"identifier": "18131", "type": "Gene", "ncbi_homologene": "376", "valid": true, "normalized": [18131], "database": "ncbi_gene", "normalized_id": 18131, "biotype": "gene", "name": "Notch3", "accession": "@GENE_NOTCH3"}, "text": "Notch3", "locations": [{"offset": 776, "length": 6}]}, {"id": "32", "infons": {"identifier": "68662", "type": "Gene", "ncbi_homologene": "14160", "valid": true, "normalized": [68662], "database": "ncbi_gene", "normalized_id": 68662, "biotype": "gene", "name": "Scgb3a1", "accession": "@GENE_SCGB3A1"}, "text": "Scgb3a1", "locations": [{"offset": 864, "length": 7}]}, {"id": "33", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 877, "length": 4}]}, {"id": "34", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 1012, "length": 4}]}, {"id": "35", "infons": {"identifier": "68662", "type": "Gene", "ncbi_homologene": "14160", "valid": true, "normalized": [68662], "database": "ncbi_gene", "normalized_id": 68662, "biotype": "gene", "name": "Scgb3a1", "accession": "@GENE_SCGB3A1"}, "text": "SCGB3A1", "locations": [{"offset": 1042, "length": 7}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9948", "role1": {"identifier": "111671", "type": "Gene", "valid": true, "normalized": [111671], "database": "ncbi_gene", "normalized_id": 111671, "biotype": "gene", "name": "Myhc", "accession": "@GENE_MYHC"}, "role2": {"identifier": "68662", "type": "Gene", "valid": true, "normalized": [68662], "database": "ncbi_gene", "normalized_id": 68662, "biotype": "gene", "name": "Scgb3a1", "accession": "@GENE_SCGB3A1"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "0", "role": "9,17"}]}, {"id": "R2", "infons": {"score": "0.7511", "role1": {"identifier": "18131", "type": "Gene", "valid": true, "normalized": [18131], "database": "ncbi_gene", "normalized_id": 18131, "biotype": "gene", "name": "Notch3", "accession": "@GENE_NOTCH3"}, "role2": {"identifier": "68662", "type": "Gene", "valid": true, "normalized": [68662], "database": "ncbi_gene", "normalized_id": 68662, "biotype": "gene", "name": "Scgb3a1", "accession": "@GENE_SCGB3A1"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "1", "role": "13,17"}]}], "pmid": 41469838, "pmcid": null, "meta": {}, "date": "2025-12-31T00:00:00Z", "journal": "Cell Mol Life Sci", "authors": ["Yokoyama S", "Kido T", "Yoneda M", "Springer DA", "Awasthi PP", "Chari R", "Patterson AD", "Kimura S"], "relations_display": [{"name": "positive_correlate|@GENE_MYHC|@GENE_SCGB3A1"}, {"name": "positive_correlate|@GENE_NOTCH3|@GENE_SCGB3A1"}]}, {"_id": "41472861|None", "id": "41472861", "infons": {}, "passages": [{"infons": {"journal": "NFS J;2025Dec; 41. doi:10.1016/j.nfs.2025.100253", "year": "2025", "article-id_pmc": "PMC12747565", "type": "title", "authors": "Obrosov O, Coppey LJ, Davidson EP, Ebert SM, Adams CM, Yorek MA, "}, "offset": 0, "text": "Skeletal muscle disuse atrophy: protection by omega-3 polyunsaturated fatty acids.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D020966", "type": "Disease", "valid": true, "normalized": ["D020966"], "database": "ncbi_mesh", "normalized_id": "D020966", "biotype": "disease", "name": "Muscular Disorders Atrophic", "accession": "@DISEASE_Muscular_Disorders_Atrophic"}, "text": "muscle disuse atrophy", "locations": [{"offset": 9, "length": 21}]}, {"id": "3", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "omega-3 polyunsaturated fatty acids", "locations": [{"offset": 46, "length": 35}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 83, "text": "The goal of this study was to examine benefit of omega-3 polyunsaturated fatty acids (PUFA) derived from fish oil or resolvin D1, metabolite of docosahexaenoic acid, on skeletal muscle disuse atrophy. Atrophy was induced of the left leg of C57Bl6/J male mice for 1 week. Three different treatment experimental protocols were used by feeding a diet enriched with menhaden oil or daily injections with resolvin D1 before or after immobilization. Evaluation of muscle atrophy was performed by determining the difference in weight of the tibialis anterior muscle between the immobilized (left) and mobile contralateral side (right) and by immunohistochemistry. A 2-week prevention protocol with menhaden oil enriched diet or daily injections of 2 ng/g resolvin D1 provided the greatest protection from muscle atrophy. Significant protection was also observed when dietary treatment of the mice was initiated at time of immobilization. This study demonstrated that omega-3 PUFA and metabolites provide protection toward skeletal muscle disuse atrophy.", "sentences": [], "annotations": [{"id": "21", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "omega-3 polyunsaturated fatty acids", "locations": [{"offset": 132, "length": 35}]}, {"id": "22", "infons": {"identifier": "MESH:D005231", "type": "Chemical", "valid": true, "normalized": ["D005231"], "database": "ncbi_mesh", "normalized_id": "D005231", "biotype": "chemical", "name": "Fatty Acids Unsaturated", "accession": "@CHEMICAL_Fatty_Acids_Unsaturated"}, "text": "PUFA", "locations": [{"offset": 169, "length": 4}]}, {"id": "23", "infons": {"identifier": "MESH:D005395", "type": "Chemical", "valid": true, "normalized": ["D005395"], "database": "ncbi_mesh", "normalized_id": "D005395", "biotype": "chemical", "name": "Fish Oils", "accession": "@CHEMICAL_Fish_Oils"}, "text": "fish oil", "locations": [{"offset": 188, "length": 8}]}, {"id": "24", "infons": {"identifier": "MESH:C518399", "type": "Chemical", "valid": true, "normalized": ["C518399"], "database": "ncbi_mesh", "normalized_id": "C518399", "biotype": "chemical", "name": "resolvin D1", "accession": "@CHEMICAL_resolvin_D1"}, "text": "resolvin D1", "locations": [{"offset": 200, "length": 11}]}, {"id": "25", "infons": {"identifier": "MESH:D004281", "type": "Chemical", "valid": true, "normalized": ["D004281"], "database": "ncbi_mesh", "normalized_id": "D004281", "biotype": "chemical", "name": "Docosahexaenoic Acids", "accession": "@CHEMICAL_Docosahexaenoic_Acids"}, "text": "docosahexaenoic acid", "locations": [{"offset": 227, "length": 20}]}, {"id": "26", "infons": {"identifier": "MESH:D020966", "type": "Disease", "valid": true, "normalized": ["D020966"], "database": "ncbi_mesh", "normalized_id": "D020966", "biotype": "disease", "name": "Muscular Disorders Atrophic", "accession": "@DISEASE_Muscular_Disorders_Atrophic"}, "text": "muscle disuse atrophy", "locations": [{"offset": 261, "length": 21}]}, {"id": "27", "infons": {"identifier": "MESH:D001284", "type": "Disease", "valid": true, "normalized": ["D001284"], "database": "ncbi_mesh", "normalized_id": "D001284", "biotype": "disease", "name": "Atrophy", "accession": "@DISEASE_Atrophy"}, "text": "Atrophy", "locations": [{"offset": 284, "length": 7}]}, {"id": "28", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 337, "length": 4}]}, {"id": "29", "infons": {"identifier": "MESH:C033266", "type": "Chemical", "valid": true, "normalized": ["C033266"], "database": "ncbi_mesh", "normalized_id": "C033266", "biotype": "chemical", "name": "Menhaden oil", "accession": "@CHEMICAL_Menhaden_oil"}, "text": "menhaden oil", "locations": [{"offset": 445, "length": 12}]}, {"id": "30", "infons": {"identifier": "MESH:C518399", "type": "Chemical", "valid": true, "normalized": ["C518399"], "database": "ncbi_mesh", "normalized_id": "C518399", "biotype": "chemical", "name": "resolvin D1", "accession": "@CHEMICAL_resolvin_D1"}, "text": "resolvin D1", "locations": [{"offset": 483, "length": 11}]}, {"id": "31", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 541, "length": 14}]}, {"id": "32", "infons": {"identifier": "MESH:C033266", "type": "Chemical", "valid": true, "normalized": ["C033266"], "database": "ncbi_mesh", "normalized_id": "C033266", "biotype": "chemical", "name": "Menhaden oil", "accession": "@CHEMICAL_Menhaden_oil"}, "text": "menhaden oil", "locations": [{"offset": 774, "length": 12}]}, {"id": "33", "infons": {"identifier": "MESH:C518399", "type": "Chemical", "valid": true, "normalized": ["C518399"], "database": "ncbi_mesh", "normalized_id": "C518399", "biotype": "chemical", "name": "resolvin D1", "accession": "@CHEMICAL_resolvin_D1"}, "text": "resolvin D1", "locations": [{"offset": 831, "length": 11}]}, {"id": "34", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 881, "length": 14}]}, {"id": "35", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 968, "length": 4}]}, {"id": "36", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "omega-3 PUFA", "locations": [{"offset": 1043, "length": 12}]}, {"id": "37", "infons": {"identifier": "MESH:D020966", "type": "Disease", "valid": true, "normalized": ["D020966"], "database": "ncbi_mesh", "normalized_id": "D020966", "biotype": "disease", "name": "Muscular Disorders Atrophic", "accession": "@DISEASE_Muscular_Disorders_Atrophic"}, "text": "muscle disuse atrophy", "locations": [{"offset": 1107, "length": 21}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9834", "role1": {"identifier": "MESH:C518399", "type": "Chemical", "valid": true, "normalized": ["C518399"], "database": "ncbi_mesh", "normalized_id": "C518399", "biotype": "chemical", "name": "resolvin D1", "accession": "@CHEMICAL_resolvin_D1"}, "role2": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "14,15"}]}, {"id": "R2", "infons": {"score": "0.7093", "role1": {"identifier": "MESH:C033266", "type": "Chemical", "valid": true, "normalized": ["C033266"], "database": "ncbi_mesh", "normalized_id": "C033266", "biotype": "chemical", "name": "Menhaden oil", "accession": "@CHEMICAL_Menhaden_oil"}, "role2": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "1", "role": "13,15"}]}, {"id": "R3", "infons": {"score": "0.9865", "role1": {"identifier": "MESH:C518399", "type": "Chemical", "valid": true, "normalized": ["C518399"], "database": "ncbi_mesh", "normalized_id": "C518399", "biotype": "chemical", "name": "resolvin D1", "accession": "@CHEMICAL_resolvin_D1"}, "role2": {"identifier": "MESH:D020966", "type": "Disease", "valid": true, "normalized": ["D020966"], "database": "ncbi_mesh", "normalized_id": "D020966", "biotype": "disease", "name": "Muscular Disorders Atrophic", "accession": "@DISEASE_Muscular_Disorders_Atrophic"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "14,18"}]}], "pmid": 41472861, "pmcid": null, "meta": {}, "date": "2025-12-01T00:00:00Z", "journal": "NFS J", "authors": ["Obrosov O", "Coppey LJ", "Davidson EP", "Ebert SM", "Adams CM", "Yorek MA"], "relations_display": [{"name": "treat|@CHEMICAL_resolvin_D1|@DISEASE_Muscular_Atrophy"}, {"name": "cause|@CHEMICAL_Menhaden_oil|@DISEASE_Muscular_Atrophy"}, {"name": "treat|@CHEMICAL_resolvin_D1|@DISEASE_Muscular_Disorders_Atrophic"}]}, {"_id": "41473262|None", "id": "41473262", "infons": {}, "passages": [{"infons": {"journal": "J Clin Transl Hepatol;2025Dec28; 13 (12) 1092. doi:10.14218/JCTH.2025.00383", "year": "2025", "article-id_pmc": "PMC12745355", "type": "title", "authors": "Yang J, Liu Q, Sun C, "}, "offset": 0, "text": "Quality and Quantity? The Clinical Significance of Myosteatosis in Various Liver Diseases: A Narrative Review.", "sentences": [], "annotations": [{"id": "2", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "Myosteatosis", "locations": [{"offset": 51, "length": 12}]}, {"id": "3", "infons": {"identifier": "MESH:D008107", "type": "Disease", "valid": true, "normalized": ["D008107"], "database": "ncbi_mesh", "normalized_id": "D008107", "biotype": "disease", "name": "Liver Diseases", "accession": "@DISEASE_Liver_Diseases"}, "text": "Liver Diseases", "locations": [{"offset": 75, "length": 14}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 111, "text": "Myosteatosis is associated with poor outcomes in various liver diseases. However, standardized methods for assessing, defining, and diagnosing myosteatosis in the context of liver diseases remain unclear. Furthermore, the underlying mechanisms by which myosteatosis leads to pathophysiological progression and adverse health outcomes remain elusive. Therefore, in this review, we elaborate on the currently available measures, definitions, and diagnostic criteria of myosteatosis in the existing literature. We thoroughly clarify the recent evidence and data regarding the possible involvement of myosteatosis in the progression and deterioration of various liver diseases and resulting complications, including liver cirrhosis, chronic viral hepatitis, non-alcoholic/metabolic-associated fatty liver disease, primary sclerosing cholangitis, liver transplantation, and hepatocellular carcinoma. Additionally, it synthesizes insights from basic research on the pathogenesis of myosteatosis, which involves multifactorial mechanisms, including insulin resistance, mitochondrial dysfunction, and chronic inflammation. Finally, from an operational and pragmatic perspective, several regimens, including physical, nutritional, and pharmacological therapies, have been discussed as potential treatments for myosteatosis.", "sentences": [], "annotations": [{"id": "22", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "Myosteatosis", "locations": [{"offset": 111, "length": 12}]}, {"id": "23", "infons": {"identifier": "MESH:D008107", "type": "Disease", "valid": true, "normalized": ["D008107"], "database": "ncbi_mesh", "normalized_id": "D008107", "biotype": "disease", "name": "Liver Diseases", "accession": "@DISEASE_Liver_Diseases"}, "text": "liver diseases", "locations": [{"offset": 168, "length": 14}]}, {"id": "24", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "myosteatosis", "locations": [{"offset": 254, "length": 12}]}, {"id": "25", "infons": {"identifier": "MESH:D008107", "type": "Disease", "valid": true, "normalized": ["D008107"], "database": "ncbi_mesh", "normalized_id": "D008107", "biotype": "disease", "name": "Liver Diseases", "accession": "@DISEASE_Liver_Diseases"}, "text": "liver diseases", "locations": [{"offset": 285, "length": 14}]}, {"id": "26", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "myosteatosis", "locations": [{"offset": 364, "length": 12}]}, {"id": "27", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "myosteatosis", "locations": [{"offset": 578, "length": 12}]}, {"id": "28", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "myosteatosis", "locations": [{"offset": 708, "length": 12}]}, {"id": "29", "infons": {"identifier": "MESH:D008107", "type": "Disease", "valid": true, "normalized": ["D008107"], "database": "ncbi_mesh", "normalized_id": "D008107", "biotype": "disease", "name": "Liver Diseases", "accession": "@DISEASE_Liver_Diseases"}, "text": "liver diseases", "locations": [{"offset": 769, "length": 14}]}, {"id": "30", "infons": {"identifier": "MESH:D008103", "type": "Disease", "valid": true, "normalized": ["D008103"], "database": "ncbi_mesh", "normalized_id": "D008103", "biotype": "disease", "name": "Liver Cirrhosis", "accession": "@DISEASE_Liver_Cirrhosis"}, "text": "liver cirrhosis", "locations": [{"offset": 823, "length": 15}]}, {"id": "31", "infons": {"identifier": "MESH:D006525", "type": "Disease", "valid": true, "normalized": ["D006525"], "database": "ncbi_mesh", "normalized_id": "D006525", "biotype": "disease", "name": "Hepatitis Viral Human", "accession": "@DISEASE_Hepatitis_Viral_Human"}, "text": "chronic viral hepatitis", "locations": [{"offset": 840, "length": 23}]}, {"id": "32", "infons": {"identifier": "MESH:D065626", "type": "Disease", "valid": true, "normalized": ["D065626"], "database": "ncbi_mesh", "normalized_id": "D065626", "biotype": "disease", "name": "Non-alcoholic Fatty Liver Disease", "accession": "@DISEASE_Non_alcoholic_Fatty_Liver_Disease"}, "text": "non-alcoholic/metabolic-associated fatty liver disease", "locations": [{"offset": 865, "length": 54}]}, {"id": "33", "infons": {"identifier": "MESH:D015209", "type": "Disease", "valid": true, "normalized": ["D015209"], "database": "ncbi_mesh", "normalized_id": "D015209", "biotype": "disease", "name": "Cholangitis Sclerosing", "accession": "@DISEASE_Cholangitis_Sclerosing"}, "text": "primary sclerosing cholangitis", "locations": [{"offset": 921, "length": 30}]}, {"id": "34", "infons": {"identifier": "MESH:D006528", "type": "Disease", "valid": true, "normalized": ["D006528"], "database": "ncbi_mesh", "normalized_id": "D006528", "biotype": "disease", "name": "Carcinoma Hepatocellular", "accession": "@DISEASE_Carcinoma_Hepatocellular"}, "text": "hepatocellular carcinoma", "locations": [{"offset": 980, "length": 24}]}, {"id": "35", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "myosteatosis", "locations": [{"offset": 1087, "length": 12}]}, {"id": "36", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "insulin resistance", "locations": [{"offset": 1153, "length": 18}]}, {"id": "37", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial dysfunction", "locations": [{"offset": 1173, "length": 25}]}, {"id": "38", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "chronic inflammation", "locations": [{"offset": 1204, "length": 20}]}, {"id": "39", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "myosteatosis", "locations": [{"offset": 1412, "length": 12}]}], "relations": []}], "relations": [], "pmid": 41473262, "pmcid": null, "meta": {}, "date": "2025-12-28T00:00:00Z", "journal": "J Clin Transl Hepatol", "authors": ["Yang J", "Liu Q", "Sun C"], "relations_display": []}, {"_id": "41477761|None", "id": "41477761", "infons": {}, "passages": [{"infons": {"journal": "Cell Rep;2025Dec30; 45 (1) 116768. doi:10.1016/j.celrep.2025.116768", "year": "2025", "type": "title", "authors": "Gugel J, Currie J, Alamillo L, Flint J, Kim KY, Debliqui M, Ellisman MH, Lam MPY, Lau E, Arrojo E Drigo R, Leinwand L, "}, "offset": 0, "text": "Longevity of cardiac and skeletal muscle proteins is dependent on tissue and subcellular compartmentation patterns.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 116, "text": "Myocytes are exceptionally long-lived cells that must maintain proteome integrity over decades while adjusting for changes in functional output and metabolic demand. We used in vivo stable isotope labeling combined with mass spectrometry proteomics and correlated multi-isotope imaging mass spectrometry to quantify and visualize protein turnover across cardiac, fast-twitch, and slow-twitch skeletal muscles, creating a resource of hundreds of individual protein turnover rates from each tissue. We found that cardiac muscle has the highest rate of protein turnover, followed by slow-twitch skeletal muscle and then fast-twitch skeletal muscle, and that these different rates of protein turnover are driven by different levels of muscle use, rather than myosin isoform composition. We also identified protein age heterogeneity at the myofiber and sarcomere levels. These findings uncover fundamental principles of muscle protein maintenance and have broad implications for understanding cellular aging, muscle disease, and the design of therapeutic strategies targeting muscle protein turnover.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "79784", "type": "Gene", "ncbi_homologene": "23480", "valid": true, "normalized": [79784], "database": "ncbi_gene", "normalized_id": 79784, "biotype": "gene", "name": "MYH14", "accession": "@GENE_MYH14"}, "text": "myosin", "locations": [{"offset": 871, "length": 6}]}, {"id": "3", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle disease", "locations": [{"offset": 1120, "length": 14}]}], "relations": []}], "relations": [], "pmid": 41477761, "pmcid": null, "meta": {}, "date": "2025-12-30T00:00:00Z", "journal": "Cell Rep", "authors": ["Gugel J", "Currie J", "Alamillo L", "Flint J", "Kim KY", "Debliqui M", "Ellisman MH", "Lam MPY", "Lau E", "Arrojo E Drigo R", "Leinwand L"], "relations_display": []}, {"_id": "41484831|None", "id": "41484831", "infons": {}, "passages": [{"infons": {"journal": "BioDrugs;2026Jan03. doi:10.1007/s40259-025-00761-x", "year": "2026", "article-id_pmc": "8229348", "type": "title", "authors": "Lee HG, Kim J, Jang CY, Shin M, "}, "offset": 0, "text": "Antisense Oligonucleotide Therapeutics Targeting Age-Related Diseases.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "Age-Related Diseases", "locations": [{"offset": 49, "length": 20}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 71, "text": "The rapid growth in the global aging population has intensified concerns regarding age-related diseases (ARDs), which pose substantial health and socioeconomic burdens. Current therapeutic strategies, such as small-molecule drugs, primarily target downstream pathophysiological manifestations, including inflammation, fibrosis, and metabolic imbalance, but have limited ability to address the underlying molecular causes of disease. Antisense oligonucleotides (ASOs) are emerging as a promising modality capable of precise, sequence-specific regulation of gene expression at the RNA level, offering the potential to directly modulate disease etiology. This review examines the relationship between major ARD categories and the hallmarks of aging and highlights recent research trends in ASO-based therapeutics. We explore the connections between hallmark aging processes and major ARDs, including neurodegenerative, cardiovascular, metabolic, and musculoskeletal disorders, emphasizing dysregulated genes that contribute to disease progression. Preclinical and clinical studies demonstrate that ASOs can offer targeted intervention against key pathological mechanisms such as protein aggregation, chronic inflammation, metabolic dysfunction, and tissue fibrosis by modulating gene expression. Despite their promise, major challenges remain, including poor tissue-specific delivery, limited penetration into certain tissues, and concerns around long-term safety. Emerging delivery strategies such as ligand conjugates and lipid nanoparticle systems are expanding the therapeutic reach of ASOs. By providing a programmable approach to precisely regulate pathogenic gene expression, ASOs have the potential to redefine the therapeutic landscape for ARDs in an aging society. This review provides an integrated perspective on these advances and their implications for future therapeutic development.", "sentences": [], "annotations": [{"id": "15", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "age-related diseases", "locations": [{"offset": 154, "length": 20}]}, {"id": "16", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "ARDs", "locations": [{"offset": 176, "length": 4}]}, {"id": "17", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 375, "length": 12}]}, {"id": "18", "infons": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "text": "fibrosis", "locations": [{"offset": 389, "length": 8}]}, {"id": "19", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "ARD", "locations": [{"offset": 775, "length": 3}]}, {"id": "20", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "ARDs", "locations": [{"offset": 952, "length": 4}]}, {"id": "21", "infons": {"identifier": "MESH:D019636", "type": "Disease", "valid": true, "normalized": ["D019636"], "database": "ncbi_mesh", "normalized_id": "D019636", "biotype": "disease", "name": "Neurodegenerative Diseases", "accession": "@DISEASE_Neurodegenerative_Diseases"}, "text": "neurodegenerative, cardiovascular, metabolic, and musculoskeletal disorders", "locations": [{"offset": 968, "length": 75}]}, {"id": "22", "infons": {"identifier": "MESH:D002908", "type": "Disease", "valid": true, "normalized": ["D002908"], "database": "ncbi_mesh", "normalized_id": "D002908", "biotype": "disease", "name": "Chronic Disease", "accession": "@DISEASE_Chronic_Disease"}, "text": "chronic", "locations": [{"offset": 1268, "length": 7}]}, {"id": "23", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 1276, "length": 12}]}, {"id": "24", "infons": {"identifier": "MESH:D008659", "type": "Disease", "valid": true, "normalized": ["D008659"], "database": "ncbi_mesh", "normalized_id": "D008659", "biotype": "disease", "name": "Metabolic Diseases", "accession": "@DISEASE_Metabolic_Diseases"}, "text": "metabolic dysfunction", "locations": [{"offset": 1290, "length": 21}]}, {"id": "25", "infons": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "text": "fibrosis", "locations": [{"offset": 1324, "length": 8}]}, {"id": "26", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 1592, "length": 5}]}, {"id": "27", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "ARDs", "locations": [{"offset": 1817, "length": 4}]}], "relations": []}], "relations": [], "pmid": 41484831, "pmcid": null, "meta": {}, "date": "2026-01-03T00:00:00Z", "journal": "BioDrugs", "authors": ["Lee HG", "Kim J", "Jang CY", "Shin M"], "relations_display": []}, {"_id": "41491917|None", "id": "41491917", "infons": {}, "passages": [{"infons": {"journal": "Signal Transduct Target Ther;2026Jan06; 11 (1) 8. doi:10.1038/s41392-025-02329-1", "year": "2026", "article-id_pmc": "PMC12769719", "type": "title", "authors": "Che H, Gao Y, Xu Y, Xu H, Eils R, Tian M, "}, "offset": 0, "text": "Organ cross-talk: molecular mechanisms, biological functions, and therapeutic interventions for diseases.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 106, "text": "Organ cross-talk, also known as the organ axis or organ interaction network, plays a vital role in maintaining physiological homeostasis and responding to environmental stimuli. This review comprehensively integrates cutting-edge observations in organ communication research, with a particular focus on the brain, heart, and gut-the three core organs that garner the most attention in organ connection studies. The current state of organ interaction network research is clearly presented as a Sankey diagram. For brain-related connections, the interactions among the brain-gut, brain-liver, and brain-heart connections are thoroughly reviewed; for heart-related connections, the relationships among the heart-kidney, heart-lung, and heart-liver connections are explored in detail; and for gut-related connections, the interactions among the gut-liver, gut-kidney, and gut-lung connections are emphasized. Additional information on other prevalent organ connections is systematically organized in tables for intuitive presentation. Through the integration of profound insights into molecular mechanisms and biological functions, the complex signaling pathways regulating organ interactions in health and disease states have been systematically elucidated. In terms of therapeutic strategy development, numerous directions with potential application value are proposed on the basis of these research findings. Furthermore, this review meticulously discusses the diverse methods and advanced technologies employed in organ connection research, comprehensively highlighting the critical role of technological support in advancing this field. In the future, this review advocates the adoption of network-driven models, innovative diagnostic approaches, and personalized treatment strategies to offer new perspectives for addressing complex diseases from a systems biology standpoint.", "sentences": [], "annotations": [], "relations": []}], "relations": [], "pmid": 41491917, "pmcid": null, "meta": {}, "date": "2026-01-06T00:00:00Z", "journal": "Signal Transduct Target Ther", "authors": ["Che H", "Gao Y", "Xu Y", "Xu H", "Eils R", "Tian M"], "relations_display": []}, {"_id": "41498377|None", "id": "41498377", "infons": {}, "passages": [{"infons": {"journal": "J Cachexia Sarcopenia Muscle;2026Feb; 17 (1) 70180. doi:10.1002/jcsm.70180", "year": "2026", "type": "title", "authors": "Przymusza&#x142;a M, Bia&#x142;obrzeska M, Dulak J, Florczyk-Soluch U, "}, "offset": 0, "text": "Current Trends in Duchenne Muscular Dystrophy Research and Therapy: 3D Cardiac Modelling.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "Duchenne Muscular Dystrophy", "locations": [{"offset": 18, "length": 27}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 90, "text": "Duchenne muscular dystrophy (DMD), caused by dystrophin deficiency, presents a multifaceted challenge that affects both skeletal muscle function and cardiomyocyte homeostasis, causing progressive degeneration and life-threatening cardiac complications by adolescence. Current treatments fail to prevent poor prognoses, and while FDA-approved therapies show promise in targeting dystrophin restoration, including RNA-based approaches and microdystrophin gene therapy, clinical evidence supporting their efficacy remains limited. Substantial challenges persist, particularly in achieving effective cardiac targeting, ensuring long-term safety and developing scalable treatments. Alternative therapies addressing muscle and cardiac pathophysiology are being explored alongside dystrophin-based approaches. DMD treatment is increasingly focusing on heart targeting with optimized cardiac-specific delivery strategies. Human-induced pluripotent stem cells (hiPSCs) enable DMD modelling, bridging pathophysiology and clinical phenotypes. DMD patient-specific hiPSC-derived cardiomyocytes (hiPSC-CMs) serve as in vitro models for disease mechanisms and therapy, with 3D cardiac models, either self-organizing (spheroids) or moulded, expanding on hiPSC-CMs to reflect cell interactions and myocardial tissue architecture. Advanced methods like 2D cell sheets, patches and engineered 3D human cardiac models show potential for improving cell engraftment and functional recovery in injured hearts, but their direct therapeutic application in DMD remains speculative due to extensive muscle mass loss; the complexity of cardiac and skeletal muscle interactions; and unresolved challenges related to cell integration, maturation and long-term function. Considering the premature state of cell-based therapies in this complex disease, current DMD treatment efforts focus on genetic approaches. Progress will likely depend on combining dystrophin-restoring strategies with therapies targeting disease mechanisms and improving cardiac delivery.", "sentences": [], "annotations": [{"id": "19", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "Duchenne muscular dystrophy", "locations": [{"offset": 90, "length": 27}]}, {"id": "20", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 119, "length": 3}]}, {"id": "21", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "dystrophin deficiency", "locations": [{"offset": 135, "length": 21}]}, {"id": "22", "infons": {"identifier": "MESH:D009410", "type": "Disease", "valid": true, "normalized": ["D009410"], "database": "ncbi_mesh", "normalized_id": "D009410", "biotype": "disease", "name": "Nerve Degeneration", "accession": "@DISEASE_Nerve_Degeneration"}, "text": "degeneration", "locations": [{"offset": 286, "length": 12}]}, {"id": "23", "infons": {"identifier": "MESH:D006331", "type": "Disease", "valid": true, "normalized": ["D006331"], "database": "ncbi_mesh", "normalized_id": "D006331", "biotype": "disease", "name": "Heart Diseases", "accession": "@DISEASE_Heart_Diseases"}, "text": "cardiac complications", "locations": [{"offset": 320, "length": 21}]}, {"id": "24", "infons": {"identifier": "1756", "type": "Gene", "ncbi_homologene": "20856", "valid": true, "normalized": [1756], "database": "ncbi_gene", "normalized_id": 1756, "biotype": "gene", "name": "DMD", "accession": "@GENE_DMD"}, "text": "dystrophin", "locations": [{"offset": 468, "length": 10}]}, {"id": "25", "infons": {"identifier": "1756", "type": "Gene", "ncbi_homologene": "20856", "valid": true, "normalized": [1756], "database": "ncbi_gene", "normalized_id": 1756, "biotype": "gene", "name": "DMD", "accession": "@GENE_DMD"}, "text": "dystrophin", "locations": [{"offset": 864, "length": 10}]}, {"id": "26", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 893, "length": 3}]}, {"id": "27", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "Human", "locations": [{"offset": 1004, "length": 5}]}, {"id": "28", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 1057, "length": 3}]}, {"id": "29", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 1122, "length": 3}]}, {"id": "30", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patient", "locations": [{"offset": 1126, "length": 7}]}, {"id": "31", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 1468, "length": 5}]}, {"id": "32", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 1622, "length": 3}]}, {"id": "33", "infons": {"identifier": "MESH:C536030", "type": "Disease", "valid": true, "normalized": ["C536030"], "database": "ncbi_mesh", "normalized_id": "C536030", "biotype": "disease", "name": "MASS syndrome", "accession": "@DISEASE_MASS_syndrome"}, "text": "muscle mass loss", "locations": [{"offset": 1663, "length": 16}]}, {"id": "34", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 1920, "length": 3}]}, {"id": "35", "infons": {"identifier": "1756", "type": "Gene", "ncbi_homologene": "20856", "valid": true, "normalized": [1756], "database": "ncbi_gene", "normalized_id": 1756, "biotype": "gene", "name": "DMD", "accession": "@GENE_DMD"}, "text": "dystrophin", "locations": [{"offset": 2012, "length": 10}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9939", "role1": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "role2": {"identifier": "1756", "type": "Gene", "valid": true, "normalized": [1756], "database": "ncbi_gene", "normalized_id": 1756, "biotype": "gene", "name": "DMD", "accession": "@GENE_DMD"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "16,17"}]}], "pmid": 41498377, "pmcid": null, "meta": {}, "date": "2026-02-01T00:00:00Z", "journal": "J Cachexia Sarcopenia Muscle", "authors": ["Przymuszała M", "Białobrzeska M", "Dulak J", "Florczyk-Soluch U"], "relations_display": [{"name": "inhibit|@DISEASE_Muscular_Dystrophy_Duchenne|@GENE_DMD"}]}, {"_id": "41507123|None", "id": "41507123", "infons": {}, "passages": [{"infons": {"journal": "Cell Death Dis;2026Jan08; 17 (1) 9. doi:10.1038/s41419-025-08260-1", "year": "2026", "article-id_pmc": "PMC12783612", "type": "title", "authors": "Chen TH, Chou CK, Lin KM, "}, "offset": 0, "text": "Aberrant mitochondrial hsp60 expression affects mitochondria homeostasis and results in muscle dystrophy and premature death.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "15510", "type": "Gene", "ncbi_homologene": "1626", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "text": "hsp60", "locations": [{"offset": 23, "length": 5}]}, {"id": "4", "infons": {"identifier": "MESH:D009136", "type": "Disease", "valid": true, "normalized": ["D009136"], "database": "ncbi_mesh", "normalized_id": "D009136", "biotype": "disease", "name": "Muscular Dystrophies", "accession": "@DISEASE_Muscular_Dystrophies"}, "text": "muscle dystrophy", "locations": [{"offset": 88, "length": 16}]}, {"id": "5", "infons": {"identifier": "MESH:D003643", "type": "Disease", "valid": true, "normalized": ["D003643"], "database": "ncbi_mesh", "normalized_id": "D003643", "biotype": "disease", "name": "Death", "accession": "@DISEASE_Death"}, "text": "premature death", "locations": [{"offset": 109, "length": 15}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 126, "text": "Heat shock protein 60 (HSP60) plays a vital role in maintaining mitochondrial homeostasis and essential functions and requires ATP for its assembly into chaperone complexes. This study aimed to investigate the long-term effects of HSP60 induction on mitochondrial homeostasis at varying doses and durations using HSP60 transgenic mice. In this study, we generated transgenic mice with elevated levels of native HSP60 using the LoxP-Cre system. These mice exhibited impaired postnatal development, skeletal muscle dystrophy, and increased mortality. Initially, excess HSP60 enhanced the mitochondrial oxidative respiratory capacity, which was later compensated for by increased glycolysis. Surplus HSP60 primarily accumulated in the mitochondria, likely due to insufficient ATP availability, leading to the buildup of HSP60 heptamers. Consequently, mitochondrial number and morphology were altered, protein levels in electron transport chain complexes were reduced, and oxidative phosphorylation was impaired. Additionally, reactive oxygen species accumulated, contributing to mitochondrial dysfunction in skeletal muscles. The upregulation of Pink-1/Parkin triggered enhanced autophagy, while increased Bax and poly (ADP-ribose) polymerase (PARP) cleavage mediated heightened apoptosis; both mechanisms aimed at eliminating damaged mitochondria. However, prolonged HSP60 accumulation overwhelmed these protective processes, ultimately leading to skeletal muscle dystrophy and premature death. Our findings demonstrated that excessive mitochondrial HSP60 initially boosts oxidative respiration; however, over time, it contributes to mitochondrial dysregulation and myopathy. This study provides novel insights into how excessive HSP60 affects mitochondrial oxidative respiration and glycolysis, with potential links to certain mitochondria-related diseases.", "sentences": [], "annotations": [{"id": "34", "infons": {"identifier": "15510", "type": "Gene", "ncbi_homologene": "1626", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "text": "Heat shock protein 60", "locations": [{"offset": 126, "length": 21}]}, {"id": "35", "infons": {"identifier": "15510", "type": "Gene", "ncbi_homologene": "1626", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "text": "HSP60", "locations": [{"offset": 149, "length": 5}]}, {"id": "36", "infons": {"identifier": "MESH:D000255", "type": "Chemical", "valid": true, "normalized": ["D000255"], "database": "ncbi_mesh", "normalized_id": "D000255", "biotype": "chemical", "name": "Adenosine Triphosphate", "accession": "@CHEMICAL_Adenosine_Triphosphate"}, "text": "ATP", "locations": [{"offset": 253, "length": 3}]}, {"id": "37", "infons": {"identifier": "15510", "type": "Gene", "ncbi_homologene": "1626", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "text": "HSP60", "locations": [{"offset": 357, "length": 5}]}, {"id": "38", "infons": {"identifier": "15510", "type": "Gene", "ncbi_homologene": "1626", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "text": "HSP60", "locations": [{"offset": 439, "length": 5}]}, {"id": "39", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 456, "length": 4}]}, {"id": "40", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 501, "length": 4}]}, {"id": "41", "infons": {"identifier": "15510", "type": "Gene", "ncbi_homologene": "1626", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "text": "HSP60", "locations": [{"offset": 537, "length": 5}]}, {"id": "42", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 576, "length": 4}]}, {"id": "43", "infons": {"identifier": "MESH:D005207", "type": "Disease", "valid": true, "normalized": ["D005207"], "database": "ncbi_mesh", "normalized_id": "D005207", "biotype": "disease", "name": "Fasciculation", "accession": "@DISEASE_Fasciculation"}, "text": "skeletal muscle dystrophy", "locations": [{"offset": 623, "length": 25}]}, {"id": "44", "infons": {"identifier": "15510", "type": "Gene", "ncbi_homologene": "1626", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "text": "HSP60", "locations": [{"offset": 693, "length": 5}]}, {"id": "45", "infons": {"identifier": "15510", "type": "Gene", "ncbi_homologene": "1626", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "text": "HSP60", "locations": [{"offset": 823, "length": 5}]}, {"id": "46", "infons": {"identifier": "MESH:D000255", "type": "Chemical", "valid": true, "normalized": ["D000255"], "database": "ncbi_mesh", "normalized_id": "D000255", "biotype": "chemical", "name": "Adenosine Triphosphate", "accession": "@CHEMICAL_Adenosine_Triphosphate"}, "text": "ATP", "locations": [{"offset": 899, "length": 3}]}, {"id": "47", "infons": {"identifier": "15510", "type": "Gene", "ncbi_homologene": "1626", "valid": true, "normalized": [15510], "database": "ncbi_gene", "normalized_id": 15510, "biotype": "gene", "name": "Hspd1", "accession": "@GENE_HSPD1"}, "text": "HSP60", "locations": [{"offset": 943, "length": 5}]}, {"id": "48", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "reactive oxygen species", "locations": [{"offset": 1149, "length": 23}]}, {"id": "49", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotyp