4", "infons": {"score": "0.9991", "role1": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "role2": {"identifier": "16476", "type": "Gene", "valid": true, "normalized": [16476], "database": "ncbi_gene", "normalized_id": 16476, "biotype": "gene", "name": "Jun", "accession": "@GENE_JUN"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "3", "role": "33,30"}]}, {"id": "R5", "infons": {"score": "0.9408", "role1": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "role2": {"identifier": "MESH:D000092202", "type": "Disease", "valid": true, "normalized": ["D000092202"], "database": "ncbi_mesh", "normalized_id": "D000092202", "biotype": "disease", "name": "Exercise-Induced Allergies", "accession": "@DISEASE_Exercise_Induced_Allergies"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "4", "role": "29,35"}]}], "pmid": 41572488, "pmcid": null, "meta": {}, "date": "2026-02-01T00:00:00Z", "journal": "J Cachexia Sarcopenia Muscle", "authors": ["Liu R", "She J", "Li X", "Yan Y", "Mo J", "Sheng J", "Yang H", "Huang H"], "relations_display": [{"name": "positive_correlate|@CHEMICAL_Glucose|@GENE_FOS"}, {"name": "positive_correlate|@CHEMICAL_Glucose|@CHEMICAL_Lipids"}, {"name": "positive_correlate|@CHEMICAL_Glucose|@GENE_JUNB"}, {"name": "positive_correlate|@CHEMICAL_Glucose|@GENE_JUN"}, {"name": "cause|@CHEMICAL_Lipids|@DISEASE_Exercise_Induced_Allergies"}]}, {"_id": "41574692|None", "id": "41574692", "infons": {}, "passages": [{"infons": {"journal": "Int J Mol Med;2026Mar; 57 (3) . doi:10.3892/ijmm.2026.5738", "year": "2026", "type": "title", "authors": "Cui RM, Zheng M, Hong JB, Wang ZX, Cun YF, Gao SJ, Zhu YL, Yang ZB, Liu MW, "}, "offset": 0, "text": "Research progress on the effects of macrophage-derived exosomes on muscle factors IGF-1 and FGF-2 mediating musculoskeletal crosstalk molecular signaling pathway on bone metabolism (Review).", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "3479", "type": "Gene", "ncbi_homologene": "515", "valid": true, "normalized": [3479], "database": "ncbi_gene", "normalized_id": 3479, "biotype": "gene", "name": "IGF1", "accession": "@GENE_IGF1"}, "text": "IGF-1", "locations": [{"offset": 82, "length": 5}]}, {"id": "3", "infons": {"identifier": "2247", "type": "Gene", "ncbi_homologene": "1521", "valid": true, "normalized": [2247], "database": "ncbi_gene", "normalized_id": 2247, "biotype": "gene", "name": "FGF2", "accession": "@GENE_FGF2"}, "text": "FGF-2", "locations": [{"offset": 92, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 191, "text": "Musculoskeletal crosstalk is essential for maintaining the balance of bone metabolism, with macrophage-derived exosomes emerging as key regulators of this process. Exosomes, small extracellular vesicles secreted by cells, carry a variety of bioactive molecules; proteins, lipids, mRNAs and miRNAs and facilitate intercellular communication by transferring these cargos to recipient cells. Specifically, macrophage-derived exosomes mediate muscle-bone interactions by transferring key regulators such as insulin-like growth factor-1 (IGF-1) and fibroblast growth factor-2 (FGF-2), thereby playing a pivotal role in bone metabolic homeostasis. Macrophages are classified into pro-inflammatory M1 and anti-inflammatory M2 phenotypes, each performing distinct functions in immune responses. Exosomes from M1 macrophages typically carry pro-inflammatory factors that can activate osteoclastic bone resorption, disrupting bone metabolism in pathological conditions. By contrast, exosomes from M2 macrophages often contain anti-inflammatory factors that promote tissue repair and bone formation. In the context of bone metabolism, exosomes from M1 and M2 macrophages modulate muscle-bone signaling by delivering regulators that influence the expression of IGF-1 and FGF-2, affecting osteoblast proliferation, differentiation, and mineralization. M1 macrophage-derived exosomes activate signaling pathways such as NF-kappaB and MAPK through the transfer of pro-inflammatory cargo, thereby enhancing bone resorption. By contrast, exosomes from M2 macrophages can suppress pro-inflammatory signaling while activating pathways like TGF-beta and PI3K/Akt, promoting bone synthesis and repair. As critical myokines, IGF-1 and FGF-2 not only support muscle growth, repair, and maintenance but also directly influence bone remodeling through musculoskeletal crosstalk.", "sentences": [], "annotations": [{"id": "23", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipids", "locations": [{"offset": 463, "length": 6}]}, {"id": "24", "infons": {"identifier": "3479", "type": "Gene", "ncbi_homologene": "515", "valid": true, "normalized": [3479], "database": "ncbi_gene", "normalized_id": 3479, "biotype": "gene", "name": "IGF1", "accession": "@GENE_IGF1"}, "text": "insulin-like growth factor-1", "locations": [{"offset": 694, "length": 28}]}, {"id": "25", "infons": {"identifier": "3479", "type": "Gene", "ncbi_homologene": "515", "valid": true, "normalized": [3479], "database": "ncbi_gene", "normalized_id": 3479, "biotype": "gene", "name": "IGF1", "accession": "@GENE_IGF1"}, "text": "IGF-1", "locations": [{"offset": 724, "length": 5}]}, {"id": "26", "infons": {"identifier": "2247", "type": "Gene", "ncbi_homologene": "1521", "valid": true, "normalized": [2247], "database": "ncbi_gene", "normalized_id": 2247, "biotype": "gene", "name": "FGF2", "accession": "@GENE_FGF2"}, "text": "fibroblast growth factor-2", "locations": [{"offset": 735, "length": 26}]}, {"id": "27", "infons": {"identifier": "2247", "type": "Gene", "ncbi_homologene": "1521", "valid": true, "normalized": [2247], "database": "ncbi_gene", "normalized_id": 2247, "biotype": "gene", "name": "FGF2", "accession": "@GENE_FGF2"}, "text": "FGF-2", "locations": [{"offset": 763, "length": 5}]}, {"id": "28", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 869, "length": 12}]}, {"id": "29", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 894, "length": 12}]}, {"id": "30", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 1027, "length": 12}]}, {"id": "31", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 1212, "length": 12}]}, {"id": "32", "infons": {"identifier": "3479", "type": "Gene", "ncbi_homologene": "515", "valid": true, "normalized": [3479], "database": "ncbi_gene", "normalized_id": 3479, "biotype": "gene", "name": "IGF1", "accession": "@GENE_IGF1"}, "text": "IGF-1", "locations": [{"offset": 1440, "length": 5}]}, {"id": "33", "infons": {"identifier": "2247", "type": "Gene", "ncbi_homologene": "1521", "valid": true, "normalized": [2247], "database": "ncbi_gene", "normalized_id": 2247, "biotype": "gene", "name": "FGF2", "accession": "@GENE_FGF2"}, "text": "FGF-2", "locations": [{"offset": 1450, "length": 5}]}, {"id": "34", "infons": {"identifier": "4790", "type": "Gene", "ncbi_homologene": "2971", "valid": true, "normalized": [4790], "database": "ncbi_gene", "normalized_id": 4790, "biotype": "gene", "name": "NFKB1", "accession": "@GENE_NFKB1"}, "text": "NF-kappaB", "locations": [{"offset": 1597, "length": 9}]}, {"id": "35", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 1644, "length": 12}]}, {"id": "36", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 1758, "length": 12}]}, {"id": "37", "infons": {"identifier": "7040", "type": "Gene", "ncbi_homologene": "540", "valid": true, "normalized": [7040], "database": "ncbi_gene", "normalized_id": 7040, "biotype": "gene", "name": "TGFB1", "accession": "@GENE_TGFB1"}, "text": "TGF-beta", "locations": [{"offset": 1812, "length": 8}]}, {"id": "38", "infons": {"identifier": "5291", "type": "Gene", "ncbi_homologene": "21250", "valid": true, "normalized": [5291], "database": "ncbi_gene", "normalized_id": 5291, "biotype": "gene", "name": "PIK3CB", "accession": "@GENE_PIK3CB"}, "text": "PI3K", "locations": [{"offset": 1825, "length": 4}]}, {"id": "39", "infons": {"identifier": "207", "type": "Gene", "ncbi_homologene": "3785", "valid": true, "normalized": [207], "database": "ncbi_gene", "normalized_id": 207, "biotype": "gene", "name": "AKT1", "accession": "@GENE_AKT1"}, "text": "Akt", "locations": [{"offset": 1830, "length": 3}]}, {"id": "40", "infons": {"identifier": "3479", "type": "Gene", "ncbi_homologene": "515", "valid": true, "normalized": [3479], "database": "ncbi_gene", "normalized_id": 3479, "biotype": "gene", "name": "IGF1", "accession": "@GENE_IGF1"}, "text": "IGF-1", "locations": [{"offset": 1894, "length": 5}]}, {"id": "41", "infons": {"identifier": "2247", "type": "Gene", "ncbi_homologene": "1521", "valid": true, "normalized": [2247], "database": "ncbi_gene", "normalized_id": 2247, "biotype": "gene", "name": "FGF2", "accession": "@GENE_FGF2"}, "text": "FGF-2", "locations": [{"offset": 1904, "length": 5}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9974", "role1": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "4790", "type": "Gene", "valid": true, "normalized": [4790], "database": "ncbi_gene", "normalized_id": 4790, "biotype": "gene", "name": "NFKB1", "accession": "@GENE_NFKB1"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "0", "role": "15,13"}]}], "pmid": 41574692, "pmcid": null, "meta": {}, "date": "2026-03-01T00:00:00Z", "journal": "Int J Mol Med", "authors": ["Cui RM", "Zheng M", "Hong JB", "Wang ZX", "Cun YF", "Gao SJ", "Zhu YL", "Yang ZB", "Liu MW"], "relations_display": [{"name": "stimulate|@DISEASE_Inflammation|@GENE_NFKB1"}]}, {"_id": "41582627|None", "id": "41582627", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Quantitative MRI Findings and Their Relationship to Muscle Histopathology and Ambulatory Clinical Function in Duchenne Muscular Dystrophy.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "Duchenne Muscular Dystrophy", "locations": [{"offset": 110, "length": 27}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 139, "text": "BACKGROUND: Iterative decomposition of water and fat with echo asymmetry and least-squares estimation quantitation (IDEAL-IQ), a quantitative 6-point Dixon magnetic resonance imaging (MRI) sequence, has been increasingly used for quantifying muscle fat fraction (FF) in neuromuscular disorders. However, its utility for correlating FF with disease severity and mapping spatiotemporal disease progression in Duchenne muscular dystrophy (DMD) requires further investigation. METHODS: In 10 patients with dystrophinopathies (seven DMD and three BMD) we correlated the muscle FF with the histopathological fatty infiltration. IDEAL-IQ MRI images of 19 individual lower limb muscles were acquired from 133 DMD patients and 41 healthy controls. Ambulatory function tests, including three timed function tests (TFTs) and North Star Ambulatory Assessment (NSAA), were performed. We investigated the spatial distribution of fatty infiltration across five axial MRI slices. Disease progression patterns were analysed using a piecewise linear model and a normal cumulative distribution function model. RESULTS: A significant positive correlation between muscle FF on MRI and histopathologic fatty infiltration was observed (rho = 0.98, p < 0.001). A mild to moderate correlation was noted for the FF of 19 individual muscles, excluding the sartorius and gracilis muscles, with TFTs (rho = 0.27-0.60, p < 0.001) and NSAA (rho = -0.32--0.73, p < 0.001). All the eight individual muscles, except the tibialis posterior muscle, showed an inhomogeneous fatty infiltration pattern with higher FF in muscle ends compared to bellies. Thigh muscle FF aligned well with both piecewise linear and sigmoidal models, showing non-linear increases with disease duration. The piecewise linear model identified an average inflection point for thigh muscle FF at 7.3 (range, 5.2-7.6) years, with average annual FF increase of 1.7% before and 6.7% after the point in DMD. The average mu of DMD patients for thigh muscles was 11.4 years (+-2.8), occurring 7.6 years earlier compared to BMD patients. CONCLUSIONS: Our study demonstrates a significant relationship between muscle FF on IDEAL-IQ MRI and histopathologic muscle fatty infiltration, as well as ambulatory clinical function in DMD. DMD patients exhibit a distinct and inhomogeneous fat infiltration pattern of lower limb muscles.", "sentences": [], "annotations": [{"id": "25", "infons": {"identifier": "MESH:D014867", "type": "Chemical", "valid": true, "normalized": ["D014867"], "database": "ncbi_mesh", "normalized_id": "D014867", "biotype": "chemical", "name": "Water", "accession": "@CHEMICAL_Water"}, "text": "water", "locations": [{"offset": 178, "length": 5}]}, {"id": "26", "infons": {"identifier": "MESH:D009468", "type": "Disease", "valid": true, "normalized": ["D009468"], "database": "ncbi_mesh", "normalized_id": "D009468", "biotype": "disease", "name": "Neuromuscular Diseases", "accession": "@DISEASE_Neuromuscular_Diseases"}, "text": "neuromuscular disorders", "locations": [{"offset": 409, "length": 23}]}, {"id": "27", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "Duchenne muscular dystrophy", "locations": [{"offset": 546, "length": 27}]}, {"id": "28", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 575, "length": 3}]}, {"id": "29", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 627, "length": 8}]}, {"id": "30", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "dystrophinopathies", "locations": [{"offset": 641, "length": 18}]}, {"id": "31", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 667, "length": 3}]}, {"id": "32", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "BMD", "locations": [{"offset": 681, "length": 3}]}, {"id": "33", "infons": {"identifier": "MESH:D017254", "type": "Disease", "valid": true, "normalized": ["D017254"], "database": "ncbi_mesh", "normalized_id": "D017254", "biotype": "disease", "name": "Leukemic Infiltration", "accession": "@DISEASE_Leukemic_Infiltration"}, "text": "fatty infiltration", "locations": [{"offset": 741, "length": 18}]}, {"id": "34", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 840, "length": 3}]}, {"id": "35", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 844, "length": 8}]}, {"id": "36", "infons": {"identifier": "MESH:D017254", "type": "Disease", "valid": true, "normalized": ["D017254"], "database": "ncbi_mesh", "normalized_id": "D017254", "biotype": "disease", "name": "Leukemic Infiltration", "accession": "@DISEASE_Leukemic_Infiltration"}, "text": "fatty infiltration", "locations": [{"offset": 1054, "length": 18}]}, {"id": "37", "infons": {"identifier": "MESH:D017254", "type": "Disease", "valid": true, "normalized": ["D017254"], "database": "ncbi_mesh", "normalized_id": "D017254", "biotype": "disease", "name": "Leukemic Infiltration", "accession": "@DISEASE_Leukemic_Infiltration"}, "text": "fatty infiltration", "locations": [{"offset": 1319, "length": 18}]}, {"id": "38", "infons": {"identifier": "MESH:D017254", "type": "Disease", "valid": true, "normalized": ["D017254"], "database": "ncbi_mesh", "normalized_id": "D017254", "biotype": "disease", "name": "Leukemic Infiltration", "accession": "@DISEASE_Leukemic_Infiltration"}, "text": "fatty infiltration", "locations": [{"offset": 1676, "length": 18}]}, {"id": "39", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 2076, "length": 3}]}, {"id": "40", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 2099, "length": 3}]}, {"id": "41", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 2103, "length": 8}]}, {"id": "42", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "BMD", "locations": [{"offset": 2194, "length": 3}]}, {"id": "43", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 2198, "length": 8}]}, {"id": "44", "infons": {"identifier": "MESH:D017254", "type": "Disease", "valid": true, "normalized": ["D017254"], "database": "ncbi_mesh", "normalized_id": "D017254", "biotype": "disease", "name": "Leukemic Infiltration", "accession": "@DISEASE_Leukemic_Infiltration"}, "text": "muscle fatty infiltration", "locations": [{"offset": 2325, "length": 25}]}, {"id": "45", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 2395, "length": 3}]}, {"id": "46", "infons": {"identifier": "MESH:D020388", "type": "Disease", "valid": true, "normalized": ["D020388"], "database": "ncbi_mesh", "normalized_id": "D020388", "biotype": "disease", "name": "Muscular Dystrophy Duchenne", "accession": "@DISEASE_Muscular_Dystrophy_Duchenne"}, "text": "DMD", "locations": [{"offset": 2400, "length": 3}]}, {"id": "47", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 2404, "length": 8}]}], "relations": []}], "relations": [], "pmid": 41582627, "pmcid": null, "meta": {}, "date": "2026-02-01T00:00:00Z", "journal": "J Cachexia Sarcopenia Muscle", "authors": ["Lu Y", "Yin L", "Liu C", "Yuan Q", "Xie Z", "Liao J", "Chen S", "Gang Q", "Zhao Y", "Meng L", "Zhang W", "Xiao J", "Wang Z", "Yuan Y", "Xie Z"], "relations_display": []}, {"_id": "41603258|None", "id": "41603258", "infons": {}, "passages": [{"infons": {"journal": "J Cachexia Sarcopenia Muscle;2026Feb; 17 (1) 70176. doi:10.1002/jcsm.70176", "year": "2026", "type": "title", "authors": "Park WY, Kim B, Song G, Kim SH, Kim JH, Park JY, Jung SJ, Jiao W, Han J, Kong T, Ahn KS, Kwak HJ, Um JY, "}, "offset": 0, "text": "Ellagic Acid Alleviates Abnormal Fat Reduction by Activating the RXRbeta-PPARgamma Pathways in a CT26 Tumour-Induced Cachexia Mouse Model.", "sentences": [], "annotations": [{"id": "7", "infons": {"identifier": "MESH:D004610", "type": "Chemical", "valid": true, "normalized": ["D004610"], "database": "ncbi_mesh", "normalized_id": "D004610", "biotype": "chemical", "name": "Ellagic Acid", "accession": "@CHEMICAL_Ellagic_Acid"}, "text": "Ellagic Acid", "locations": [{"offset": 0, "length": 12}]}, {"id": "8", "infons": {"identifier": "MESH:D004620", "type": "Disease", "valid": true, "normalized": ["D004620"], "database": "ncbi_mesh", "normalized_id": "D004620", "biotype": "disease", "name": "Embolism Fat", "accession": "@DISEASE_Embolism_Fat"}, "text": "Fat", "locations": [{"offset": 33, "length": 3}]}, {"id": "9", "infons": {"identifier": "20182", "type": "Gene", "ncbi_homologene": "7923", "valid": true, "normalized": [20182], "database": "ncbi_gene", "normalized_id": 20182, "biotype": "gene", "name": "Rxrb", "accession": "@GENE_RXRB"}, "text": "RXRbeta", "locations": [{"offset": 65, "length": 7}]}, {"id": "10", "infons": {"identifier": "19016", "type": "Gene", "ncbi_homologene": "7899", "valid": true, "normalized": [19016], "database": "ncbi_gene", "normalized_id": 19016, "biotype": "gene", "name": "Pparg", "accession": "@GENE_PPARG"}, "text": "PPARgamma", "locations": [{"offset": 73, "length": 9}]}, {"id": "11", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "Tumour", "locations": [{"offset": 102, "length": 6}]}, {"id": "12", "infons": {"identifier": "MESH:D002100", "type": "Disease", "valid": true, "normalized": ["D002100"], "database": "ncbi_mesh", "normalized_id": "D002100", "biotype": "disease", "name": "Cachexia", "accession": "@DISEASE_Cachexia"}, "text": "Cachexia", "locations": [{"offset": 117, "length": 8}]}, {"id": "13", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "Mouse", "locations": [{"offset": 126, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 139, "text": "BACKGROUND: Cancer cachexia is a syndrome characterized by significant weight loss, particularly of adipose tissue, which negatively impacts patient survival. Pharmacological approaches to prevent this abnormal fat reduction remain poorly defined. This study investigated the potential of ellagic acid (EA) to mitigate cancer-induced fat loss. METHODS: In vitro, 3T3-L1 adipocytes were exposed to 50% conditioned medium (CM) from CT26 colon cancer cells to mimic cachectic conditions. The effects of EA on lipid accumulation and adipogenesis-related markers (PPARgamma and RXRbeta) were analysed. The mechanism was validated using molecular docking and siRNA-mediated gene silencing. In vivo, a cachexia mouse model was established by subcutaneous injection of CT26 cells into BALB/c mice. Mice were orally administered EA at dose of 10, 20 and 40 mg/kg, respectively (n = 7 per group) for 14 days to evaluate its protective effects. RESULTS: In 3T3-L1 cells, the 50% CM-treatment reduced lipid accumulation by 14% (p < 0.05) and downregulated PPARgamma (p < 0.05) and RXRbeta (p < 0.01) expression. The EA treatment restored diminished lipid levels and rescued downregulated the expression of PPARgamma (p < 0.05) and RXRbeta (p < 0.01). This pro-adipogenic effect was abolished by siRNA-mediated inhibition of RXRbeta. In the cachexia mouse model, EA treatment significantly improved physical performance and body composition. Specifically, EA enhanced grip strength by 1.32-fold (10 mg/kg, p < 0.0001) and 1.24-fold (20 mg/kg, p < 0.001), increased the inguinal white adipose tissue (iWAT) mass by 59.8% (10 mg/kg, p < 0.01), and 56.1% (20 mg/kg, p < 0.05), and was accompanied by a significant increase in the tumour-free body weight of 6.4% (10 mg/kg, p < 0.05), and 5.6% (20 mg/kg, p < 0.01) compared to cachectic mice. EA treatment did not affect tumour growth. It increased the adipogenesis-related protein expression of C/EBPalpha (2.1-fold, p < 0.05), PPARgamma (1.5-fold, p < 0.05) and SREBP1 (1.5-fold, p < 0.05) in the iWAT. The EA treatment enhanced the nuclear localization index of RXRbeta in the iWAT by 0.51 (10 mg/kg, 1.9-fold, p < 0.05) and 0.46 (20 mg/kg, 1.7-fold, p < 0.05) compared to cachectic mice. CONCLUSIONS: EA mitigates cancer cachexia-induced fat loss by the activation of the RXRbeta-PPARgamma pathway. These findings present EA as a potential pharmacological agent to improve the abnormal fat reduction and muscle dysfunction associated with cachexia.", "sentences": [], "annotations": [{"id": "63", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "Cancer cachexia", "locations": [{"offset": 151, "length": 15}]}, {"id": "64", "infons": {"identifier": "MESH:D015431", "type": "Disease", "valid": true, "normalized": ["D015431"], "database": "ncbi_mesh", "normalized_id": "D015431", "biotype": "disease", "name": "Weight Loss", "accession": "@DISEASE_Weight_Loss"}, "text": "weight loss", "locations": [{"offset": 210, "length": 11}]}, {"id": "65", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patient", "locations": [{"offset": 280, "length": 7}]}, {"id": "66", "infons": {"identifier": "MESH:D004620", "type": "Disease", "valid": true, "normalized": ["D004620"], "database": "ncbi_mesh", "normalized_id": "D004620", "biotype": "disease", "name": "Embolism Fat", "accession": "@DISEASE_Embolism_Fat"}, "text": "fat", "locations": [{"offset": 350, "length": 3}]}, {"id": "67", "infons": {"identifier": "MESH:D004610", "type": "Chemical", "valid": true, "normalized": ["D004610"], "database": "ncbi_mesh", "normalized_id": "D004610", "biotype": "chemical", "name": "Ellagic Acid", "accession": "@CHEMICAL_Ellagic_Acid"}, "text": "ellagic acid", "locations": [{"offset": 428, "length": 12}]}, {"id": "68", "infons": {"identifier": "MESH:D004610", "type": "Chemical", "valid": true, "normalized": ["D004610"], "database": "ncbi_mesh", "normalized_id": "D004610", "biotype": "chemical", "name": "Ellagic Acid", "accession": "@CHEMICAL_Ellagic_Acid"}, "text": "EA", "locations": [{"offset": 442, "length": 2}]}, {"id": "69", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 458, "length": 6}]}, {"id":