"SGCA", "accession": "@GENE_SGCA"}, "text": "SGCA", "locations": [{"offset": 967, "length": 4}]}, {"id": "48", "infons": {"identifier": "MESH:D002294", "type": "Disease", "valid": true, "normalized": ["D002294"], "database": "ncbi_mesh", "normalized_id": "D002294", "biotype": "disease", "name": "Carcinoma Squamous Cell", "accession": "@DISEASE_Carcinoma_Squamous_Cell"}, "text": "LUSC", "locations": [{"offset": 999, "length": 4}]}, {"id": "49", "infons": {"identifier": "MESH:D002294", "type": "Disease", "valid": true, "normalized": ["D002294"], "database": "ncbi_mesh", "normalized_id": "D002294", "biotype": "disease", "name": "Carcinoma Squamous Cell", "accession": "@DISEASE_Carcinoma_Squamous_Cell"}, "text": "LUSC", "locations": [{"offset": 1084, "length": 4}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9964", "role1": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "role2": {"identifier": "6442", "type": "Gene", "valid": true, "normalized": [6442], "database": "ncbi_gene", "normalized_id": 6442, "biotype": "gene", "name": "SGCA", "accession": "@GENE_SGCA"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "20,22"}]}, {"id": "R2", "infons": {"score": "0.7921", "role1": {"identifier": "MESH:D002294", "type": "Disease", "valid": true, "normalized": ["D002294"], "database": "ncbi_mesh", "normalized_id": "D002294", "biotype": "disease", "name": "Carcinoma Squamous Cell", "accession": "@DISEASE_Carcinoma_Squamous_Cell"}, "role2": {"identifier": "6442", "type": "Gene", "valid": true, "normalized": [6442], "database": "ncbi_gene", "normalized_id": 6442, "biotype": "gene", "name": "SGCA", "accession": "@GENE_SGCA"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "24,22"}]}], "pmid": 40594054, "pmcid": null, "meta": {}, "date": "2025-07-02T00:00:00Z", "journal": "Sci Rep", "authors": ["Chen G", "Mao G", "Zong X", "Chen X", "Ting G", "Lin M"], "relations_display": [{"name": "inhibit|@DISEASE_Neoplasms|@GENE_SGCA"}, {"name": "associate|@DISEASE_Carcinoma_Squamous_Cell|@GENE_SGCA"}]}, {"_id": "40598440|None", "id": "40598440", "infons": {}, "passages": [{"infons": {"journal": "J Anim Sci Biotechnol;2025Jul02; 16 (1) 93. doi:10.1186/s40104-025-01229-2", "year": "2025", "article-id_pmc": "PMC12220238", "type": "title", "authors": "Lin Z, Zhou X, Lu T, An W, Chen S, Li S, Miao H, Han X, "}, "offset": 0, "text": "Co-cultivation of Lactobacillus acidophilus and Bacillus subtilis mediates the gut-muscle axis affecting pork quality and flavor.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "1579", "type": "Species", "valid": true, "normalized": [1579], "database": "ncbi_taxonomy", "normalized_id": 1579, "biotype": "species", "name": "1579", "accession": null}, "text": "Lactobacillus acidophilus", "locations": [{"offset": 18, "length": 25}]}, {"id": "3", "infons": {"identifier": "1423", "type": "Species", "valid": true, "normalized": [1423], "database": "ncbi_taxonomy", "normalized_id": 1423, "biotype": "species", "name": "1423", "accession": null}, "text": "Bacillus subtilis", "locations": [{"offset": 48, "length": 17}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 130, "text": "BACKGROUND: Pork quality and flavor are critical determinants of consumer preference, yet the role of gut microbiota in shaping meat characteristics remains underexplored. In this study, we investigated how a probiotic consortium (FAM: Lactobacillus acidophilus and Bacillus subtilis) modulates the gut-muscle axis to enhance pork flavor. RESULTS: In finishing pigs, FAM supplementation significantly increased flavor-associated nucleotides and umami-enhancing amino acids in longissimus dorsi muscle. Metagenomic analysis revealed FAM-driven enrichment of glycan-degrading Prevotella and short-chain fatty acid-producing Phascolarctobacterium, accompanied by reduced antibiotic resistance genes and virulence factors. Spearman correlation linked Prevotella copri abundance with elevated muscle amino acids, suggesting microbial-encoded CAZymes as key mediators. CONCLUSIONS: This study provides the first evidence that probiotic-induced gut microbiota remodeling enhances pork flavor through metabolic cross-talk along the gut-muscle axis. The findings suggest a novel strategy for improving pork quality via dietary interventions targeting gut microbiota.", "sentences": [], "annotations": [{"id": "18", "infons": {"identifier": "MESH:C031179", "type": "Chemical", "valid": true, "normalized": ["C031179"], "database": "ncbi_mesh", "normalized_id": "C031179", "biotype": "chemical", "name": "FAM protocol", "accession": "@CHEMICAL_FAM_protocol"}, "text": "FAM", "locations": [{"offset": 361, "length": 3}]}, {"id": "19", "infons": {"identifier": "1579", "type": "Species", "valid": true, "normalized": [1579], "database": "ncbi_taxonomy", "normalized_id": 1579, "biotype": "species", "name": "1579", "accession": null}, "text": "Lactobacillus acidophilus", "locations": [{"offset": 366, "length": 25}]}, {"id": "20", "infons": {"identifier": "1423", "type": "Species", "valid": true, "normalized": [1423], "database": "ncbi_taxonomy", "normalized_id": 1423, "biotype": "species", "name": "1423", "accession": null}, "text": "Bacillus subtilis", "locations": [{"offset": 396, "length": 17}]}, {"id": "21", "infons": {"identifier": "9823", "type": "Species", "valid": true, "normalized": [9823], "database": "ncbi_taxonomy", "normalized_id": 9823, "biotype": "species", "name": "9823", "accession": null}, "text": "pigs", "locations": [{"offset": 491, "length": 4}]}, {"id": "22", "infons": {"identifier": "MESH:C031179", "type": "Chemical", "valid": true, "normalized": ["C031179"], "database": "ncbi_mesh", "normalized_id": "C031179", "biotype": "chemical", "name": "FAM protocol", "accession": "@CHEMICAL_FAM_protocol"}, "text": "FAM", "locations": [{"offset": 497, "length": 3}]}, {"id": "23", "infons": {"identifier": "MESH:D009711", "type": "Chemical", "valid": true, "normalized": ["D009711"], "database": "ncbi_mesh", "normalized_id": "D009711", "biotype": "chemical", "name": "Nucleotides", "accession": "@CHEMICAL_Nucleotides"}, "text": "nucleotides", "locations": [{"offset": 559, "length": 11}]}, {"id": "24", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "amino acids", "locations": [{"offset": 591, "length": 11}]}, {"id": "25", "infons": {"identifier": "MESH:C031179", "type": "Chemical", "valid": true, "normalized": ["C031179"], "database": "ncbi_mesh", "normalized_id": "C031179", "biotype": "chemical", "name": "FAM protocol", "accession": "@CHEMICAL_FAM_protocol"}, "text": "FAM", "locations": [{"offset": 662, "length": 3}]}, {"id": "26", "infons": {"identifier": "MESH:D011134", "type": "Chemical", "valid": true, "normalized": ["D011134"], "database": "ncbi_mesh", "normalized_id": "D011134", "biotype": "chemical", "name": "Polysaccharides", "accession": "@CHEMICAL_Polysaccharides"}, "text": "glycan", "locations": [{"offset": 687, "length": 6}]}, {"id": "27", "infons": {"identifier": "165179", "type": "Species", "valid": true, "normalized": [165179], "database": "ncbi_taxonomy", "normalized_id": 165179, "biotype": "species", "name": "165179", "accession": null}, "text": "Prevotella", "locations": [{"offset": 704, "length": 10}]}, {"id": "28", "infons": {"identifier": "MESH:D005232", "type": "Chemical", "valid": true, "normalized": ["D005232"], "database": "ncbi_mesh", "normalized_id": "D005232", "biotype": "chemical", "name": "Fatty Acids Volatile", "accession": "@CHEMICAL_Fatty_Acids_Volatile"}, "text": "short-chain fatty acid", "locations": [{"offset": 719, "length": 22}]}, {"id": "29", "infons": {"identifier": "33024", "type": "Species", "valid": true, "normalized": [33024], "database": "ncbi_taxonomy", "normalized_id": 33024, "biotype": "species", "name": "33024", "accession": null}, "text": "Phascolarctobacterium", "locations": [{"offset": 752, "length": 21}]}, {"id": "30", "infons": {"identifier": "165179", "type": "Species", "valid": true, "normalized": [165179], "database": "ncbi_taxonomy", "normalized_id": 165179, "biotype": "species", "name": "165179", "accession": null}, "text": "Prevotella copri", "locations": [{"offset": 877, "length": 16}]}, {"id": "31", "infons": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "text": "amino acids", "locations": [{"offset": 925, "length": 11}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9993", "role1": {"identifier": "MESH:C031179", "type": "Chemical", "valid": true, "normalized": ["C031179"], "database": "ncbi_mesh", "normalized_id": "C031179", "biotype": "chemical", "name": "FAM protocol", "accession": "@CHEMICAL_FAM_protocol"}, "role2": {"identifier": "MESH:D000596", "type": "Chemical", "valid": true, "normalized": ["D000596"], "database": "ncbi_mesh", "normalized_id": "D000596", "biotype": "chemical", "name": "Amino Acids", "accession": "@CHEMICAL_Amino_Acids"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "0", "role": "9,15"}]}, {"id": "R2", "infons": {"score": "0.999", "role1": {"identifier": "MESH:C031179", "type": "Chemical", "valid": true, "normalized": ["C031179"], "database": "ncbi_mesh", "normalized_id": "C031179", "biotype": "chemical", "name": "FAM protocol", "accession": "@CHEMICAL_FAM_protocol"}, "role2": {"identifier": "MESH:D009711", "type": "Chemical", "valid": true, "normalized": ["D009711"], "database": "ncbi_mesh", "normalized_id": "D009711", "biotype": "chemical", "name": "Nucleotides", "accession": "@CHEMICAL_Nucleotides"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "1", "role": "9,7"}]}, {"id": "R3", "infons": {"score": "0.9732", "role1": {"identifier": "MESH:C031179", "type": "Chemical", "valid": true, "normalized": ["C031179"], "database": "ncbi_mesh", "normalized_id": "C031179", "biotype": "chemical", "name": "FAM protocol", "accession": "@CHEMICAL_FAM_protocol"}, "role2": {"identifier": "MESH:D005232", "type": "Chemical", "valid": true, "normalized": ["D005232"], "database": "ncbi_mesh", "normalized_id": "D005232", "biotype": "chemical", "name": "Fatty Acids Volatile", "accession": "@CHEMICAL_Fatty_Acids_Volatile"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "2", "role": "9,12"}]}, {"id": "R4", "infons": {"score": "0.9983", "role1": {"identifier": "MESH:C031179", "type": "Chemical", "valid": true, "normalized": ["C031179"], "database": "ncbi_mesh", "normalized_id": "C031179", "biotype": "chemical", "name": "FAM protocol", "accession": "@CHEMICAL_FAM_protocol"}, "role2": {"identifier": "MESH:D011134", "type": "Chemical", "valid": true, "normalized": ["D011134"], "database": "ncbi_mesh", "normalized_id": "D011134", "biotype": "chemical", "name": "Polysaccharides", "accession": "@CHEMICAL_Polysaccharides"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "3", "role": "9,10"}]}], "pmid": 40598440, "pmcid": null, "meta": {}, "date": "2025-07-02T00:00:00Z", "journal": "J Anim Sci Biotechnol", "authors": ["Lin Z", "Zhou X", "Lu T", "An W", "Chen S", "Li S", "Miao H", "Han X"], "relations_display": [{"name": "positive_correlate|@CHEMICAL_FAM_protocol|@CHEMICAL_Amino_Acids"}, {"name": "positive_correlate|@CHEMICAL_FAM_protocol|@CHEMICAL_Nucleotides"}, {"name": "positive_correlate|@CHEMICAL_FAM_protocol|@CHEMICAL_Fatty_Acids_Volatile"}, {"name": "positive_correlate|@CHEMICAL_FAM_protocol|@CHEMICAL_Polysaccharides"}]}, {"_id": "40599237|None", "id": "40599237", "infons": {}, "passages": [{"infons": {"journal": "MedComm (2020);2025Jul; 6 (7) 70268. doi:10.1002/mco2.70268", "year": "2025", "article-id_pmc": "PMC12209598", "type": "title", "authors": "Liu S, Liu J, Wang Y, Deng F, Deng Z, "}, "offset": 0, "text": "Oxidative Stress: Signaling Pathways, Biological Functions, and Disease.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 73, "text": "The dysregulated accumulation of reactive oxygen species (ROS) and reactive nitrogen species disrupts redox homeostasis, triggering oxidative stress (OS) and driving pathophysiological changes across multiple organ systems. OS modulates critical signaling pathways, induces inflammation, impairs mitochondrial function, alters metabolic homeostasis, and dysregulates autophagy, contributing to disease progression. While prior research has largely focused on OS within single-organ diseases (e.g., neurodegenerative, cardiovascular, and oncological disorders), the systemic role of OS in pan-organ diseases and interorgan communication remains insufficiently explored. This review integrates multidisciplinary evidence to elucidate the biological functions of OS in cellular signaling, homeostasis, and cross-organ crosstalk. It systematically dissects OS-driven molecular mechanisms and pathophysiological networks across 10 major organ systems, including the nervous, cardiovascular, oncological, hepatic, and renal systems. Furthermore, it critically examines OS-related therapeutic targets, including antioxidant and ROS-generating enzymes, and explores synergistic redox-based therapeutic strategies. By moving beyond traditional single-organ paradigms, this review constructs a holistic framework to decode the systemic impact of OS, offering novel insights into disease mechanisms and therapeutic innovations. Ultimately, it lays the foundation for precision medicine approaches aimed at mitigating OS-driven diseases and improving multiorgan health outcomes.", "sentences": [], "annotations": [{"id": "6", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "reactive oxygen species", "locations": [{"offset": 106, "length": 23}]}, {"id": "7", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 131, "length": 3}]}, {"id": "8", "infons": {"identifier": "MESH:D026361", "type": "Chemical", "valid": true, "normalized": ["D026361"], "database": "ncbi_mesh", "normalized_id": "D026361", "biotype": "chemical", "name": "Reactive Nitrogen Species", "accession": "@CHEMICAL_Reactive_Nitrogen_Species"}, "text": "reactive nitrogen species", "locations": [{"offset": 140, "length": 25}]}, {"id": "9", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 347, "length": 12}]}, {"id": "10", "infons": {"identifier": "MESH:D019636", "type": "Disease", "valid": true, "normalized": ["D019636"], "database": "ncbi_mesh", "normalized_id": "D019636", "biotype": "disease", "name": "Neurodegenerative Diseases", "accession": "@DISEASE_Neurodegenerative_Diseases"}, "text": "neurodegenerative, cardiovascular, and oncological disorders", "locations": [{"offset": 571, "length": 60}]}, {"id": "11", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 1194, "length": 3}]}], "relations": []}], "relations": [], "pmid": 40599237, "pmcid": null, "meta": {}, "date": "2025-07-01T00:00:00Z", "journal": "MedComm (2020)", "authors": ["Liu S", "Liu J", "Wang Y", "Deng F", "Deng Z"], "relations_display": []}, {"_id": "40601066|None", "id": "40601066", "infons": {}, "passages": [{"infons": {"journal": "Biogerontology;2025Jul02; 26 (4) 139. doi:10.1007/s10522-025-10275-2", "year": "2025", "article-id_pmc": "PMC12222320", "type": "title", "authors": "Dezawa M, "}, "offset": 0, "text": "Comparison of MSCs and Muse cells: the possible use for healthspan optimization.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 81, "text": "The exploration for safe, effective intervention strategies to improve longevity and aging-related diseases is attracting attention to prolong the healthy lifespan. Since aging is based on cellular changes, including telomere attrition, DNA damage, and mitochondrial dysfunction, therapies related to stem cells are expected to be a rational strategy for solving aging problems at the cellular level. Mesenchymal stem cells (MSCs) are an easily accessible, safe candidate, as they supply paracrine factors and extracellular vesicles to deliver pleiotropic effects for aging tissues. Multilineage-differentiating stress enduring (Muse) cells represent endogenous, reparative macrophage-like/pluripotent-like stem cells distributed in various tissues, including extraembryonic tissues such as the umbilical cord, and are also found in MSCs as a small percentage of the total population. Muse cell characteristics are different from those of MSCs. Intravenously injected Muse cells sharply sense the universal damage signal sphingosine-1-P and selectively migrate to damaged tissue rather than being trapped in the lung, phagocytose damaged/apoptotic cells in the tissue and directly differentiate into the same cell type. Muse cells then repair the three dimensional structure of the tissue by replacing multiple tissue component with healthy cells through pluripotent-like differentiation. Clinical trials have shown that HLA-mismatched donor Muse cells escape immune rejection and survive in the recipient tissue for an extended period without immunosuppressant treatment. Therefore, the pleiotropic bystander effects of Muse cells are more potent than those of MSCs. Due to heterogeneity, the properties of MSCs are still not fully understood; they have limited differentiation ability into osteogenic, chondrogenic, and adipogenic cells, and the main biological action in vivo is bystander effects. Muse cells are key, not only to the medical benefits of MSCs, but also to their potential use in anti-aging therapy. Enriching and purifying Muse cells will significantly enhance the therapeutic effect of MSCs, leading to further expansion of the use of MSCs. This review discusses the fundamental differences between MSCs and Muse cells and their potential applications in anti-aging therapy.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial dysfunction", "locations": [{"offset": 334, "length": 25}]}, {"id": "3", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "sphingosine-1-P", "locations": [{"offset": 1102, "length": 15}]}], "relations": []}], "relations": [], "pmid": 40601066, "pmcid": null, "meta": {}, "date": "2025-07-02T00:00:00Z", "journal": "Biogerontology", "authors": ["Dezawa M"], "relations_display": []}, {"_id": "40603685|None", "id": "40603685", "infons": {}, "passages": [{"infons": {"journal": "Stem Cell Rev Rep;2025Jul03. doi:10.1007/s12015-025-10915-7", "year": "2025", "article-id_pmc": "4073943", "type": "title", "authors": "Skrivergaard S, Rasmussen MK, Therkildsen M, Young JF, "}, "offset": 0, "text": "High-Throughput Label-Free Continuous Quantification of Muscle Stem Cell Proliferation and Myogenic Differentiation.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 117, "text": "BACKGROUND: Quantifying muscle satellite cell proliferation and differentiation is crucial for applications in muscle regeneration, disease modeling, and cultivated meat research. Traditional fluorescence-based assays, while sensitive, are labor-intensive, endpoint-restricted, and disruptive to myotube integrity. METHODS: In this study, we present a novel high-contrast brightfield (HCBF) imaging technique for high-throughput, label-free assessment of both satellite cell proliferation and myogenic differentiation. Using the BioTek Cytation 5 automated imager and Gen5 software (Agilent Technologies), we optimized imaging parameters to achieve continuous, highly time-resolved quantification in standard 96- and 384-well formats without any additional reagents or cell manipulation needed. RESULTS: Our approach enabled detailed kinetic profiling of satellite cell behavior, revealing myotube formation dynamics, species-specific media responses, optimal seeding conditions and the influence of mechanical factors on differentiation. We also demonstrated that serum-free media formulations could support efficient myotube formation in both bovine and porcine satellite cells, while having very different myotube kinetics and morphology than serum-containing samples. Furthermore, we highlighted the high degree of well-to-well variation and the sporadic formation and detachment of myotubes in culture, and the interesting phenomena of a second wave of myotubes being formed following detachment in serum-containing samples. Additionally, the 384-well format enabled a label-free screening method to assess clonal myogenicity of isolated satellite cells. CONCLUSION: By eliminating the need for genetic labeling, invasive staining or specialized consumables, our high-throughput HCBF methodology advances myogenic research, offering new opportunities for efficient screening and highly detailed kinetic data acquisition for serum-free media development, drug discovery and pathophysiological testing for both cultivated meat and musculoskeletal research.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "9913", "type": "Species", "valid": true, "normalized": [9913], "database": "ncbi_taxonomy", "normalized_id": 9913, "biotype": "species", "name": "9913", "accession": null}, "text": "bovine", "locations": [{"offset": 1262, "length": 6}]}], "relations": []}], "relations": [], "pmid": 40603685, "pmcid": null, "meta": {}, "date": "2025-07-03T00:00:00Z", "journal": "Stem Cell Rev Rep", "authors": ["Skrivergaard S", "Rasmussen MK", "Therkildsen M", "Young JF"], "relations_display": []}, {"_id": "40603885|None", "id": "40603885", "infons": {}, "passages": [{"infons": {"journal": "NPJ Sci Food;2025Jul02; 9 (1) 119. doi:10.1038/s41538-025-00505-9", "year": "2025", "article-id_pmc": "PMC12222533", "type": "title", "authors": "Asaeda K, Takagi T, Murakami E, Hashimoto H, Yasuda T, Kajiwara&#x30fc;Kubota M, Sugaya T, Mizushima K, Higashimura Y, Ryuji OK, Kimura I, Inoue K, Uchiyama K, Shimamoto S, Ukawa Y, Kohara A, Kudoh M, Naito Y, Itoh Y, "}, "offset": 0, "text": "Water-soluble cellulose acetate attenuates glucose intolerance through GLP-1 and PYY signal upregulation.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Water-soluble cellulose acetate", "locations": [{"offset": 0, "length": 31}]}, {"id": "5", "infons": {"identifier": "MESH:D018149", "type": "Disease", "valid": true, "normalized": ["D018149"], "database": "ncbi_mesh", "normalized_id": "D018149", "biotype": "disease", "name": "Glucose Intolerance", "accession": "@DISEASE_Glucose_Intolerance"}, "text": "glucose intolerance", "locations": [{"offset": 43, "length": 19}]}, {"id": "6", "infons": {"identifier": "14526", "type": "Gene", "ncbi_homologene": "1553", "valid": true, "normalized": [14526], "database": "ncbi_gene", "normalized_id": 14526, "biotype": "gene", "name": "Gcg", "accession": "@GENE_GCG"}, "text": "GLP-1", "locations": [{"offset": 71, "length": 5}]}, {"id": "7", "infons": {"identifier": "217212", "type": "Gene", "ncbi_homologene": "3066", "valid": true, "normalized": [217212], "database": "ncbi_gene", "normalized_id": 217212, "biotype": "gene", "name": "Pyy", "accession": "@GENE_PYY"}, "text": "PYY", "locations": [{"offset": 81, "length": 3}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 106, "text": "Water-soluble cellulose acetate (WSCA), derived from natural cellulose and acetate, can be used as a food additive and deliver acetate to the large intestine. In this study, we investigated the effects of dietary WSCA supplementation on impaired glucose metabolism in db/db mice, a model of type 2 diabetes mellitus. db/m and db/db mice were fed either a control diet or a WSCA-supplemented diet for eight weeks. The WSCA-supplemented group exhibited improved glucose intolerance or lipid metabolism without any loss of skeletal muscle mass or grip strength. WSCA supplementation significantly increased acetate concentrations in the cecum, stool, and blood. Furthermore, serum levels of glucagon-like peptide-1 (GLP-1) and peptide YY (PYY) were significantly higher in the WSCA group than in the control group. These findings suggest that WSCA delivers acetate to the colon and prevents diabetes by enhancing GLP-1 and PYY secretion in db/db mice.", "sentences": [], "annotations": [{"id": "34", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Water-soluble cellulose acetate", "locations": [{"offset": 106, "length": 31}]}, {"id": "35", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "WSCA", "locations": [{"offset": 139, "length": 4}]}, {"id": "36", "infons": {"identifier": "MESH:D002482", "type": "Chemical", "valid": true, "normalized": ["D002482"], "database": "ncbi_mesh", "normalized_id": "D002482", "biotype": "chemical", "name": "Cellulose", "accession": "@CHEMICAL_Cellulose"}, "text": "cellulose", "locations": [{"offset": 167, "length": 9}]}, {"id": "37", "infons": {"identifier": "MESH:D000085", "type": "Chemical", "valid": true, "normalized": ["D000085"], "database": "ncbi_mesh", "normalized_id": "D000085", "biotype": "chemical", "name": "Acetates", "accession": "@CHEMICAL_Acetates"}, "text": "acetate", "locations": [{"offset": 181, "length": 7}]}, {"id": "38", "infons": {"identifier": "MESH:D000085", "type": "Chemical", "valid": true, "normalized": ["D000085"], "database": "ncbi_mesh", "normalized_id": "D000085", "biotype": "chemical", "name": "Acetates", "accession": "@CHEMICAL_Acetates"}, "text": "acetate", "locations": [{"offset": 233, "length": 7}]}, {"id": "39", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "WSCA", "locations": [{"offset": 319, "length": 4}]}, {"id": "40", "infons": {"identifier": "MESH:D044882", "type": "Disease", "valid": true, "normalized": ["D044882"], "database": "ncbi_mesh", "normalized_id": "D044882", "biotype": "disease", "name": "Glucose Metabolism Disorders", "accession": "@DISEASE_Glucose_Metabolism_Disorders"}, "text": "impaired glucose metabolism", "locations": [{"offset": 343, "length": 27}]}, {"id": "41", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 380, "length": 4}]}, {"id": "42", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes mellitus", "locations": [{"offset": 397, "length": 24}]}, {"id": "43", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 438, "length": 4}]}, {"id": "44", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "WSCA", "locations": [{"offset": 479, "length": 4}]}, {"id": "45", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "WSCA", "locations": [{"offset": 523, "length": 4}]}, {"id": "46", "infons": {"identifier": "MESH:D018149", "type": "Disease", "valid": true, "normalized": ["D018149"], "database": "ncbi_mesh", "normalized_id": "D018149", "biotype": "disease", "name": "Glucose Intolerance", "accession": "@DISEASE_Glucose_Intolerance"}, "text": "glucose intolerance", "locations": [{"offset": 566, "length": 19}]}, {"id": "47", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 589, "length": 5}]}, {"id": "48", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "WSCA", "locations": [{"offset": 665, "length": 4}]}, {"id": "49", "infons": {"identifier": "MESH:D000085", "type": "Chemical", "valid": true, "normalized": ["D000085"], "database": "ncbi_mesh", "normalized_id": "D000085", "biotype": "chemical", "name": "Acetates", "accession": "@CHEMICAL_Acetates"}, "text": "acetate", "locations": [{"offset": 710, "length": 7}]}, {"id": "50", "infons": {"identifier": "14526", "type": "Gene", "ncbi_homologene": "1553", "valid": true, "normalized": [14526], "database": "ncbi_gene", "normalized_id": 14526, "biotype": "gene", "name": "Gcg", "accession": "@GENE_GCG"}, "text": "glucagon-like peptide-1", "locations": [{"offset": 794, "length": 23}]}, {"id": "51", "infons": {"identifier": "14526", "type": "Gene", "ncbi_homologene": "1553", "valid": true, "normalized": [14526], "database": "ncbi_gene", "normalized_id": 14526, "biotype": "gene", "name": "Gcg", "accession": "@GENE_GCG"}, "text": "GLP-1", "locations": [{"offset": 819, "length": 5}]}, {"id": "52", "infons": {"identifier": "217212", "type": "Gene", "ncbi_homologene": "3066", "valid": true, "normalized": [217212], "database": "ncbi_gene", "normalized_id": 217212, "biotype": "gene", "name": "Pyy", "accession": "@GENE_PYY"}, "text": "PYY", "locations": [{"offset": 842, "length": 3}]}, {"id": "53", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "WSCA", "locations": [{"offset": 880, "length": 4}]}, {"id": "54", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "WSCA", "locations": [{"offset": 946, "length": 4}]}, {"id": "55", "infons": {"identifier": "MESH:D000085", "type": "Chemical", "valid": true, "normalized": ["D000085"], "database": "ncbi_mesh", "normalized_id": "D000085", "biotype": "chemical", "name": "Acetates", "accession": "@CHEMICAL_Acetates"}, "text": "acetate", "locations": [{"offset": 960, "length": 7}]}, {"id": "56", "infons": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "text": "diabetes", "locations": [{"offset": 994, "length": 8}]}, {"id": "57", "infons": {"identifier": "14526", "type": "Gene", "ncbi_homologene": "1553", "valid": true, "normalized": [14526], "database": "ncbi_gene", "normalized_id": 14526, "biotype": "gene", "name": "Gcg", "accession": "@GENE_GCG"}, "text": "GLP-1", "locations": [{"offset": 1016, "length": 5}]}, {"id": "58", "infons": {"identifier": "217212", "type": "Gene", "ncbi_homologene": "3066", "valid": true, "normalized": [217212], "database": "ncbi_gene", "normalized_id": 217212, "biotype": "gene", "name": "Pyy", "accession": "@GENE_PYY"}, "text": "PYY", "locations": [{"offset": 1026, "length": 3}]}, {"id": "59", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 1049, "length": 4}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9294", "role1": {"identifier": "MESH:D018149", "type": "Disease", "valid": true, "normalized": ["D018149"], "database": "ncbi_mesh", "normalized_id": "D018149", "biotype": "disease", "name": "Glucose Intolerance", "accession": "@DISEASE_Glucose_Intolerance"}, "role2": {"identifier": "217212", "type": "Gene", "valid": true, "normalized": [217212], "database": "ncbi_gene", "normalized_id": 217212, "biotype": "gene", "name": "Pyy", "accession": "@GENE_PYY"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "16,28"}]}], "pmid": 40603885, "pmcid": null, "meta": {}, "date": "2025-07-02T00:00:00Z", "journal": "NPJ Sci Food", "authors": ["Asaeda K", "Takagi T", "Murakami E", "Hashimoto H", "Yasuda T", "KajiwaraーKubota M", "Sugaya T", "Mizushima K", "Higashimura Y", "Ryuji OK", "Kimura I", "Inoue K", "Uchiyama K", "Shimamoto S", "Ukawa Y", "Kohara A", "Kudoh M", "Naito Y", "Itoh Y"], "relations_display": [{"name": "associate|@DISEASE_Glucose_Intolerance|@GENE_PYY"}]}, {"_id": "40609830|None", "id": "40609830", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Inactivity-induced NR4A3 downregulation in human skeletal muscle affects glucose metabolism and translation: Insights from in vitro analysis.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "8013", "type": "Gene", "ncbi_homologene": "5074", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "text": "NR4A3", "locations": [{"offset": 19, "length": 5}]}, {"id": "4", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 43, "length": 5}]}, {"id": "5", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "glucose", "locations": [{"offset": 73, "length": 7}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 142, "text": "OBJECTIVE: Physical activity promotes health, whereas inactivity is associated with metabolic impairment. The transcription factor nuclear receptor subfamily 4 group A member 3 (NR4A3) is a pleiotropic regulator of skeletal muscle exercise adaptation and metabolism. However, the consequence of lower NR4A3 expression remains largely unexplored. We investigated the impact of NR4A3 downregulation on human skeletal muscle metabolism. METHODS: Published transcriptomic datasets from human bed rest and limb immobilisation studies were curated to meta-analyse the effect of physical inactivity on skeletal muscle NR4A3 levels. In primary human skeletal myotubes, siRNA and lentivirus were used to silence and overexpress NR4A3, respectively. Basal and stimulated (insulin +- leucine) signal transduction was determined by immunoblot analysis. Effects on glucose, fatty acid, and protein metabolism were measured using radiolabelled substrate assays. Lactate production was assessed in culture supernatant by colourimetry. Cell morphology was analysed by immunocytochemistry and gene expression was quantified by RT-qPCR. RESULTS: Physical inactivity decreased skeletal muscle NR4A3 (-27%), concomitant with pathways related to mitochondrial function, cytoskeleton organization, chromatin regulation, protein synthesis and degradation. Silencing of NR4A3 reduced glucose oxidation (-18%) and increased lactate production (+23%) in vitro. This coincided with greater signalling downstream of AMPK and elevated rates of basal (+26%) and FCCP-stimulated (+55%) fatty acid oxidation. NR4A3 downregulation lowered protein synthesis (-25%), and impaired mTORC1 signalling and ribosomal transcription. Alternatively, overexpression of the canonical NR4A3 protein isoform (+290%) augmented translation and total cellular protein content, which protected myotubes against dexamethasone-induced atrophy. Moreover, partial restoration of NR4A3 levels rescued glucose oxidation in NR4A3-silenced muscle cells and restored phosphorylation of mTORC1 substrates. NR4A3 depletion reduced myotube area (-48%) and further altered protein and gene expression of key contractile elements in skeletal muscle. CONCLUSIONS: Our study connects reduced NR4A3 expression with physical inactivity and indicates that NR4A3 downregulation in human skeletal muscle has adverse effects on glucose metabolism and protein synthesis. Thus, decrements in NR4A3 abundance could be causal in the deleterious health consequences resulting from sedentary lifestyles and targeting NR4A3 may offer new avenues for combating conditions such as disuse muscle atrophy.", "sentences": [], "annotations": [{"id": "43", "infons": {"identifier": "MESH:D008659", "type": "Disease", "valid": true, "normalized": ["D008659"], "database": "ncbi_mesh", "normalized_id": "D008659", "biotype": "disease", "name": "Metabolic Diseases", "accession": "@DISEASE_Metabolic_Diseases"}, "text": "metabolic impairment", "locations": [{"offset": 226, "length": 20}]}, {"id": "44", "infons": {"identifier": "8013", "type": "Gene", "ncbi_homologene": "5074", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "text": "nuclear receptor subfamily 4 group A member 3", "locations": [{"offset": 273, "length": 45}]}, {"id": "45", "infons": {"identifier": "8013", "type": "Gene", "ncbi_homologene": "5074", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "text": "NR4A3", "locations": [{"offset": 320, "length": 5}]}, {"id": "46", "infons": {"identifier": "8013", "type": "Gene", "ncbi_homologene": "5074", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "text": "NR4A3", "locations": [{"offset": 443, "length": 5}]}, {"id": "47", "infons": {"identifier": "8013", "type": "Gene", "ncbi_homologene": "5074", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "text": "NR4A3", "locations": [{"offset": 518, "length": 5}]}, {"id": "48", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 542, "length": 5}]}, {"id": "49", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 624, "length": 5}]}, {"id": "50", "infons": {"identifier": "8013", "type": "Gene", "ncbi_homologene": "5074", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "text": "NR4A3", "locations": [{"offset": 753, "length": 5}]}, {"id": "51", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 778, "length": 5}]}, {"id": "52", "infons": {"identifier": "8013", "type": "Gene", "ncbi_homologene": "5074", "valid": true, "normalized": [8013], "database": "ncbi_gene", "normalized_id": 8013, "biotype": "gene", "name": "NR4A3", "accession": "@GENE_NR4A3"}, "text": "NR4A3", "locations": [{"offset": 861, "length": 5}]}, {"id": "53", "infons": {"identifier": "3630", "type": "Gene", "ncbi_homologene": "173", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "text": "insulin", "locations": [{"offset": 904, "length": 7}]}, {"id": "54", "infons": {"identifier": "MESH:D007930", "type": "Chemical", "valid": true, "normalized": ["D007930"], "database": "ncbi_mesh", "normalized_id": "D007930", "biotype": "chemical", "name": "Leucine", "accession": "@CHEMICAL_Leucine"}, "text": "leucine", "locations": [{"offset": 915, "length": 7}]}, {"id": "55", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "glucose", "locations": [{"offset": 994, "leng