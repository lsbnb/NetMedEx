atabase": "ncbi_mesh", "normalized_id": "D020966", "biotype": "disease", "name": "Muscular Disorders Atrophic", "accession": "@DISEASE_Muscular_Disorders_Atrophic"}, "type": "Negative_Correlation"}, "nodes": []}, {"id": "R16", "infons": {"score": "0.9988", "role1": {"identifier": "MESH:D007656", "type": "Chemical", "valid": true, "normalized": ["D007656"], "database": "ncbi_mesh", "normalized_id": "D007656", "biotype": "chemical", "name": "Ketoglutaric Acids", "accession": "@CHEMICAL_Ketoglutaric_Acids"}, "role2": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "11", "role": "36,37"}]}], "pmid": 40376969, "pmcid": null, "meta": {}, "date": "2025-07-01T00:00:00Z", "journal": "Mol Med Rep", "authors": ["Ikeda M", "Matsumoto M", "Tamura M", "Kobayashi M", "Iida K"], "relations_display": [{"name": "associate|@CHEMICAL_Leucine|@DISEASE_Atrophy"}, {"name": "treat|@CHEMICAL_Glutamine|@DISEASE_Atrophy"}, {"name": "positive_correlate|@CHEMICAL_Adenosine_Triphosphate|@CHEMICAL_Ketoglutaric_Acids"}, {"name": "positive_correlate|@CHEMICAL_Adenosine_Triphosphate|@CHEMICAL_Lactic_Acid"}, {"name": "treat|@CHEMICAL_Lactic_Acid|@DISEASE_Muscular_Disorders_Atrophic"}, {"name": "negative_correlate|@CHEMICAL_Adenosine_Triphosphate|@CHEMICAL_Glutamine"}, {"name": "treat|@CHEMICAL_Lactic_Acid|@DISEASE_Atrophy"}, {"name": "treat|@CHEMICAL_Glutamine|@DISEASE_Muscular_Disorders_Atrophic"}, {"name": "treat|@CHEMICAL_Glucose|@DISEASE_Atrophy"}, {"name": "treat|@CHEMICAL_Ketoglutaric_Acids|@DISEASE_Muscular_Disorders_Atrophic"}, {"name": "treat|@CHEMICAL_Lactic_Acid|@DISEASE_Muscular_Atrophy"}, {"name": "treat|@CHEMICAL_Ketoglutaric_Acids|@DISEASE_Atrophy"}, {"name": "treat|@CHEMICAL_Glucose|@DISEASE_Muscular_Atrophy"}, {"name": "treat|@CHEMICAL_Glutamine|@DISEASE_Muscular_Atrophy"}, {"name": "treat|@CHEMICAL_Glucose|@DISEASE_Muscular_Disorders_Atrophic"}, {"name": "treat|@CHEMICAL_Ketoglutaric_Acids|@DISEASE_Muscular_Atrophy"}]}, {"_id": "40500132|None", "id": "40500132", "infons": {}, "passages": [{"infons": {"journal": "Int J Stem Cells;2025Jun12. doi:10.15283/ijsc25037", "year": "2025", "type": "title", "authors": "Lee JE, Yoon SH, Shim KS, Do JT, "}, "offset": 0, "text": "Regulatory Landscapes of Muscle Satellite Cells: From Mechanism to Application.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 80, "text": "Muscle satellite cells (SCs), also known as muscle stem cells, are crucial for the regeneration, maintenance, and growth of skeletal muscles. SCs possess a distinctive capability to self-renew and differentiate, rendering them highly promising candidates for regenerative therapies and emerging cellular agriculture applications, including cultured meat production. This review explores the mechanisms that govern SC activation, proliferation, and commitment, and emphasizes their functional heterogeneity across anatomical regions. Region-specific gene expression, including that of homeobox (<i>Hox</i>) genes, contributes to the positional identity and myogenic potential. Understanding these regulatory landscapes is essential for optimizing SC expansion and improving their applications in muscle repair, stem cell-based therapies, and cellular manufacturing systems.", "sentences": [], "annotations": [], "relations": []}], "relations": [], "pmid": 40500132, "pmcid": null, "meta": {}, "date": "2025-06-12T00:00:00Z", "journal": "Int J Stem Cells", "authors": ["Lee JE", "Yoon SH", "Shim KS", "Do JT"], "relations_display": []}, {"_id": "40527924|None", "id": "40527924", "infons": {}, "passages": [{"infons": {"journal": "Nat Metab;2025Jun17. doi:10.1038/s42255-025-01311-z", "year": "2025", "article-id_pmc": "3928004", "type": "title", "authors": "Cal K, Leyva A, Rodr&#xed;guez-Duarte J, Ruiz S, Santos L, Garat MP, Colella L, Ingold M, Benitez-Rosendo A, P&#xe9;rez-Torrado V, Vilaseca C, Galliussi G, Ziegler L, Peclat TR, Bresque M, Handy RM, King R, Menezes Dos Reis L, Alves JM, Espasand&#xed;n C, de la Sovera V, Breining P, Dapueto R, Lopez A, Thompson KL, Lino CA, Fran&#xe7;a JV, Vieira TS, Rattan R, Agorrody G, DeVallance E, Haag J, Meadows E, Lewis SE, Santana Barbosa GC, Lai de Souza LO, Chichierchio MS, Valez V, Aicardo A, Contreras P, Vendelbo MH, Jakobsen S, Kamaid A, Porcal W, Calliari A, Verdes JM, Du J, Wang Y, Hollander JM, White TA, Radi R, Moyna G, Quijano C, O'Doherty R, Moraes-Vieira P, Giri S, Holloway GP, Festuccia WT, Leiria LO, Leonardi R, Mori MA, Camacho-Pereira J, Kelley EE, Duran R, L&#xf3;pez GV, Chini EN, Batthy&#xe1;ny C, Escande C, "}, "offset": 0, "text": "A nitroalkene derivative of salicylate, SANA, induces creatine-dependent thermogenesis and promotes weight loss.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "nitroalkene", "locations": [{"offset": 2, "length": 11}]}, {"id": "6", "infons": {"identifier": "MESH:D012459", "type": "Chemical", "valid": true, "normalized": ["D012459"], "database": "ncbi_mesh", "normalized_id": "D012459", "biotype": "chemical", "name": "Salicylates", "accession": "@CHEMICAL_Salicylates"}, "text": "salicylate", "locations": [{"offset": 28, "length": 10}]}, {"id": "7", "infons": {"identifier": "MESH:C015516", "type": "Chemical", "valid": true, "normalized": ["C015516"], "database": "ncbi_mesh", "normalized_id": "C015516", "biotype": "chemical", "name": "succinyl-trialanine-4-nitroanilide", "accession": "@CHEMICAL_succinyl_trialanine_4_nitroanilide"}, "text": "SANA", "locations": [{"offset": 40, "length": 4}]}, {"id": "8", "infons": {"identifier": "MESH:D003401", "type": "Chemical", "valid": true, "normalized": ["D003401"], "database": "ncbi_mesh", "normalized_id": "D003401", "biotype": "chemical", "name": "Creatine", "accession": "@CHEMICAL_Creatine"}, "text": "creatine", "locations": [{"offset": 54, "length": 8}]}, {"id": "9", "infons": {"identifier": "MESH:D015431", "type": "Disease", "valid": true, "normalized": ["D015431"], "database": "ncbi_mesh", "normalized_id": "D015431", "biotype": "disease", "name": "Weight Loss", "accession": "@DISEASE_Weight_Loss"}, "text": "weight loss", "locations": [{"offset": 100, "length": 11}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 113, "text": "The emergence of glucagon-like peptide-1 agonists represents a notable advancement in the pharmacological treatment of obesity, yet complementary approaches are essential. Through phenotypic drug discovery, we developed promising nitroalkene-containing small molecules for obesity-related metabolic dysfunctions. Here, we present SANA, a nitroalkene derivative of salicylate, demonstrating notable efficacy in preclinical models of diet-induced obesity. SANA reduces liver steatosis and insulin resistance by enhancing mitochondrial respiration and increasing creatine-dependent energy expenditure in adipose tissue, functioning effectively in thermoneutral conditions and independently of uncoupling protein 1 and AMPK activity. Finally, we conducted a randomized, double-blind, placebo-controlled phase 1A/B clinical trial, which consisted of two parts, each with four arms: (A) single ascending doses (200-800 mg) in healthy lean volunteers; (B) multiple ascending doses (200-400 mg per day for 15 days) in healthy volunteers with overweight or obesity. The primary endpoint assessed safety and tolerability. Secondary and exploratory endpoints included pharmacokinetics, tolerability, body weight and metabolic markers. SANA shows good safety and tolerability, and demonstrates beneficial effects on body weight and glucose management within 2 weeks of treatment. Overall, SANA appears to be a first-in-class activator of creatine-dependent energy expenditure and thermogenesis, highlighting its potential as a therapeutic candidate for 'diabesity'. Australian New Zealand Clinical Trials Registry registration: ACTRN12622001519741 .", "sentences": [], "annotations": [{"id": "32", "infons": {"identifier": "2641", "type": "Gene", "ncbi_homologene": "136497", "valid": true, "normalized": [2641], "database": "ncbi_gene", "normalized_id": 2641, "biotype": "gene", "name": "GCG", "accession": "@GENE_GCG"}, "text": "glucagon-like peptide-1", "locations": [{"offset": 130, "length": 23}]}, {"id": "33", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 232, "length": 7}]}, {"id": "34", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "nitroalkene", "locations": [{"offset": 343, "length": 11}]}, {"id": "35", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 386, "length": 7}]}, {"id": "36", "infons": {"identifier": "MESH:D008659", "type": "Disease", "valid": true, "normalized": ["D008659"], "database": "ncbi_mesh", "normalized_id": "D008659", "biotype": "disease", "name": "Metabolic Diseases", "accession": "@DISEASE_Metabolic_Diseases"}, "text": "metabolic dysfunctions", "locations": [{"offset": 402, "length": 22}]}, {"id": "37", "infons": {"identifier": "MESH:C015516", "type": "Chemical", "valid": true, "normalized": ["C015516"], "database": "ncbi_mesh", "normalized_id": "C015516", "biotype": "chemical", "name": "succinyl-trialanine-4-nitroanilide", "accession": "@CHEMICAL_succinyl_trialanine_4_nitroanilide"}, "text": "SANA", "locations": [{"offset": 443, "length": 4}]}, {"id": "38", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "nitroalkene", "locations": [{"offset": 451, "length": 11}]}, {"id": "39", "infons": {"identifier": "MESH:D012459", "type": "Chemical", "valid": true, "normalized": ["D012459"], "database": "ncbi_mesh", "normalized_id": "D012459", "biotype": "chemical", "name": "Salicylates", "accession": "@CHEMICAL_Salicylates"}, "text": "salicylate", "locations": [{"offset": 477, "length": 10}]}, {"id": "40", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 558, "length": 7}]}, {"id": "41", "infons": {"identifier": "MESH:C015516", "type": "Chemical", "valid": true, "normalized": ["C015516"], "database": "ncbi_mesh", "normalized_id": "C015516", "biotype": "chemical", "name": "succinyl-trialanine-4-nitroanilide", "accession": "@CHEMICAL_succinyl_trialanine_4_nitroanilide"}, "text": "SANA", "locations": [{"offset": 567, "length": 4}]}, {"id": "42", "infons": {"identifier": "MESH:D005234", "type": "Disease", "valid": true, "normalized": ["D005234"], "database": "ncbi_mesh", "normalized_id": "D005234", "biotype": "disease", "name": "Fatty Liver", "accession": "@DISEASE_Fatty_Liver"}, "text": "liver steatosis", "locations": [{"offset": 580, "length": 15}]}, {"id": "43", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "insulin resistance", "locations": [{"offset": 600, "length": 18}]}, {"id": "44", "infons": {"identifier": "MESH:D003401", "type": "Chemical", "valid": true, "normalized": ["D003401"], "database": "ncbi_mesh", "normalized_id": "D003401", "biotype": "chemical", "name": "Creatine", "accession": "@CHEMICAL_Creatine"}, "text": "creatine", "locations": [{"offset": 673, "length": 8}]}, {"id": "45", "infons": {"identifier": "7350", "type": "Gene", "ncbi_homologene": "22524", "valid": true, "normalized": [7350], "database": "ncbi_gene", "normalized_id": 7350, "biotype": "gene", "name": "UCP1", "accession": "@GENE_UCP1"}, "text": "uncoupling protein 1", "locations": [{"offset": 803, "length": 20}]}, {"id": "46", "infons": {"identifier": "5562", "type": "Gene", "ncbi_homologene": "49590", "valid": true, "normalized": [5562], "database": "ncbi_gene", "normalized_id": 5562, "biotype": "gene", "name": "PRKAA1", "accession": "@GENE_PRKAA1"}, "text": "AMPK", "locations": [{"offset": 828, "length": 4}]}, {"id": "47", "infons": {"identifier": "MESH:D050177", "type": "Disease", "valid": true, "normalized": ["D050177"], "database": "ncbi_mesh", "normalized_id": "D050177", "biotype": "disease", "name": "Overweight", "accession": "@DISEASE_Overweight"}, "text": "overweight", "locations": [{"offset": 1147, "length": 10}]}, {"id": "48", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 1161, "length": 7}]}, {"id": "49", "infons": {"identifier": "MESH:C015516", "type": "Chemical", "valid": true, "normalized": ["C015516"], "database": "ncbi_mesh", "normalized_id": "C015516", "biotype": "chemical", "name": "succinyl-trialanine-4-nitroanilide", "accession": "@CHEMICAL_succinyl_trialanine_4_nitroanilide"}, "text": "SANA", "locations": [{"offset": 1337, "length": 4}]}, {"id": "50", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", 