FB1", "accession": "@GENE_TGFB1"}, "type": "Association"}, "nodes": []}], "pmid": 41275142, "pmcid": null, "meta": {}, "date": "2025-11-22T00:00:00Z", "journal": "BMC Geriatr", "authors": ["Juárez-Cedillo T", "Martínez-Rodríguez N", "Rocha-Cruz A", "Fragoso JM", "Robles-Ramírez RJ", "Juárez-Cedillo E"], "relations_display": [{"name": "cause|@DISEASE_Frailty|@VARIANT_c._308G>A_TNF_human"}, {"name": "cause|@DISEASE_Frailty|@VARIANT_c._1616C>T_IFNG_human"}, {"name": "cause|@DISEASE_Frailty|@VARIANT_c._889C>T_IL1A_human"}, {"name": "cause|@DISEASE_Frailty|@VARIANT_c._238G>A_TNF_human"}, {"name": "cause|@DISEASE_Frailty|@VARIANT_c._572G>C_IL6_human"}, {"name": "cause|@DISEASE_Frailty|@VARIANT_c.869T>C_TGFB1_human"}, {"name": "associate|@DISEASE_Frailty|@GENE_IL6"}, {"name": "associate|@DISEASE_Frailty|@GENE_IL1A"}, {"name": "associate|@DISEASE_Frailty|@GENE_IFNG"}, {"name": "associate|@DISEASE_Frailty|@GENE_TNF"}, {"name": "associate|@DISEASE_Frailty|@GENE_TGFB1"}]}, {"_id": "41286086|None", "id": "41286086", "infons": {}, "passages": [{"infons": {"journal": "Sci Rep;2025Nov24; 15 (1) 41599. doi:10.1038/s41598-025-25496-1", "year": "2025", "article-id_pmc": "PMC12644712", "type": "title", "authors": "Watcharanapapan W, Hirunsai M, Srikuea R, "}, "offset": 0, "text": "Regulatory role of vitamin D3 on myogenesis and fibrogenesis under Vdr gene silencing and TGF-beta1 stimulation in skeletal muscle cells.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "MESH:D002762", "type": "Chemical", "valid": true, "normalized": ["D002762"], "database": "ncbi_mesh", "normalized_id": "D002762", "biotype": "chemical", "name": "Cholecalciferol", "accession": "@CHEMICAL_Cholecalciferol"}, "text": "vitamin D3", "locations": [{"offset": 19, "length": 10}]}, {"id": "6", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "myogenesis", "locations": [{"offset": 33, "length": 10}]}, {"id": "7", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "fibrogenesis", "locations": [{"offset": 48, "length": 12}]}, {"id": "8", "infons": {"identifier": "22337", "type": "Gene", "ncbi_homologene": "37297", "valid": true, "normalized": [22337], "database": "ncbi_gene", "normalized_id": 22337, "biotype": "gene", "name": "Vdr", "accession": "@GENE_VDR"}, "text": "Vdr", "locations": [{"offset": 67, "length": 3}]}, {"id": "9", "infons": {"identifier": "21803", "type": "Gene", "ncbi_homologene": "540", "valid": true, "normalized": [21803], "database": "ncbi_gene", "normalized_id": 21803, "biotype": "gene", "name": "Tgfb1", "accession": "@GENE_TGFB1"}, "text": "TGF-beta1", "locations": [{"offset": 90, "length": 9}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 138, "text": "Vitamin D deficiency is associated with a decline in muscle function and an increasing risk of muscle injury in athletes and the elderly. Nevertheless, how vitamin D3 and vitamin D receptor (VDR) regulate skeletal muscle cells under profibrotic factor stimulation that could be pronounced during repetitive muscle damage have not been elucidated. Therefore, this study aimed to investigate the regulatory role of cholecalciferol (D3), calcidiol (25D3), calcitriol (1,25D3), and the effect of Vdr gene suppression under TGF-beta1 stimulation in C2C12 mouse skeletal muscle cells. All forms of vitamin D3 exerted antifibrotic effects under TGF-beta1 stimulation by suppression of COL1A1; however, D3 preserves this effect without negative impact on myogenesis. Moreover, LC-MS/MS-based proteomics analysis revealed that myoblast fusion protein and mitochondrial regulation were altered following Vdr knockdown. These changes were associated with exacerbation of alpha-SMA expression in TGF-beta1-treated cells and suggested VDR modulates fibrogenesis in skeletal muscle cells regardless of ligand binding. Under TGF-beta1 stimulation, antifibrotic effects of 1,25D3 but not D3 were diminished after Vdr knockdown, supporting that D3 action is largely mediated independently of VDR. Collectively, understanding antifibrotic effects of vitamin D3 is beneficial for providing a strategy of vitamin D supplementation to counteract fibrosis development after muscle injury.", "sentences": [], "annotations": [{"id": "47", "infons": {"identifier": "MESH:D014808", "type": "Disease", "valid": true, "normalized": ["D014808"], "database": "ncbi_mesh", "normalized_id": "D014808", "biotype": "disease", "name": "Vitamin D Deficiency", "accession": "@DISEASE_Vitamin_D_Deficiency"}, "text": "Vitamin D deficiency", "locations": [{"offset": 138, "length": 20}]}, {"id": "48", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "a", "locations": [{"offset": 178, "length": 1}]}, {"id": "49", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "decline in muscle function", "locations": [{"offset": 180, "length": 26}]}, {"id": "50", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle injury", "locations": [{"offset": 233, "length": 13}]}, {"id": "51", "infons": {"identifier": "MESH:D002762", "type": "Chemical", "valid": true, "normalized": ["D002762"], "database": "ncbi_mesh", "normalized_id": "D002762", "biotype": "chemical", "name": "Cholecalciferol", "accession": "@CHEMICAL_Cholecalciferol"}, "text": "vitamin D3", "locations": [{"offset": 294, "length": 10}]}, {"id": "52", "infons": {"identifier": "22337", "type": "Gene", "ncbi_homologene": "37297", "valid": true, "normalized": [22337], "database": "ncbi_gene", "normal