], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 1196, "length": 4}]}, {"id": "71", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 1221, "length": 4}]}, {"id": "72", "infons": {"identifier": "53376", "type": "Gene", "ncbi_homologene": "3098", "valid": true, "normalized": [53376], "database": "ncbi_gene", "normalized_id": 53376, "biotype": "gene", "name": "Usp2", "accession": "@GENE_USP2"}, "text": "USP2", "locations": [{"offset": 1261, "length": 4}]}, {"id": "73", "infons": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "text": "ROS", "locations": [{"offset": 1276, "length": 3}]}, {"id": "74", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial damage", "locations": [{"offset": 1308, "length": 20}]}, {"id": "75", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 1348, "length": 4}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9988", "role1": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "role2": {"identifier": "53376", "type": "Gene", "valid": true, "normalized": [53376], "database": "ncbi_gene", "normalized_id": 53376, "biotype": "gene", "name": "Usp2", "accession": "@GENE_USP2"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "36,34"}]}, {"id": "R2", "infons": {"score": "0.9903", "role1": {"identifier": "MESH:D008054", "type": "Chemical", "valid": true, "normalized": ["D008054"], "database": "ncbi_mesh", "normalized_id": "D008054", "biotype": "chemical", "name": "Lipid Peroxides", "accession": "@CHEMICAL_Lipid_Peroxides"}, "role2": {"identifier": "53376", "type": "Gene", "valid": true, "normalized": [53376], "database": "ncbi_gene", "normalized_id": 53376, "biotype": "gene", "name": "Usp2", "accession": "@GENE_USP2"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "24,34"}]}, {"id": "R3", "infons": {"score": "0.9965", "role1": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "role2": {"identifier": "53376", "type": "Gene", "valid": true, "normalized": [53376], "database": "ncbi_gene", "normalized_id": 53376, "biotype": "gene", "name": "Usp2", "accession": "@GENE_USP2"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "35,34"}]}], "pmid": 40691076, "pmcid": null, "meta": {}, "date": "2025-07-19T00:00:00Z", "journal": "Exp Anim", "authors": ["Fujimoto M", "Iwasaki T", "Hosotani Saito M", "Takahashi N", "Hashimoto M", "Takahashi E", "Kitamura H"], "relations_display": [{"name": "associate|@DISEASE_Mitochondrial_Diseases|@GENE_USP2"}, {"name": "associate|@CHEMICAL_Lipid_Peroxides|@GENE_USP2"}, {"name": "associate|@CHEMICAL_Reactive_Oxygen_Species|@GENE_USP2"}]}, {"_id": "40692551|None", "id": "40692551", "infons": {}, "passages": [{"infons": {"journal": "J Nutr Sci;2025; 14 47. doi:10.1017/jns.2025.10009", "year": "2025", "article-id_pmc": "PMC12278179", "type": "title", "authors": "Cai W, Wang X, Liu H, Hua L, Han D, Zhu X, Jin J, Zhang Z, Yang Y, Xie S, "}, "offset": 0, "text": "Dietary supplementation with glutamate improves the flesh quality of gibel carp (Carassius gibelio) by altering muscle texture characteristics and increasing the deposition of flavour substances.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:D018698", "type": "Chemical", "valid": true, "normalized": ["D018698"], "database": "ncbi_mesh", "normalized_id": "D018698", "biotype": "chemical", "name": "Glutamic Acid", "accession": "@CHEMICAL_Glutamic_Acid"}, "text": "glutamate", "locations": [{"offset": 29, "length": 9}]}, {"id": "4", "infons": {"identifier": "101364", "type": "Species", "valid": true, "normalized": [101364], "database": "ncbi_taxonomy", "normalized_id": 101364, "biotype": "species", "name": "101364", "accession": null}, "text": "gibel carp", "locations": [{"offset": 69, "length": 10}]}, {"id": "5", "infons": {"identifier": "101364", "type": "Species", "valid": true, "normalized": [101364], "database": "ncbi_taxonomy", "normalized_id": 101364, "biotype": "species", "name": "101364", "accession": null}, "text": "Carassius gibelio", "locations": [{"offset": 81, "length": 17}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 196, "text": "Nutrition intervention is an effective way to improve flesh qualities of fish. The effect of feed supplementation with glutamate (Glu) on flesh quality of gibel carp (Carassius gibelio) was investigated. In trial 1, the fish (initial weight: 37.49 +- 0.08 g) were fed two practical diets with 0 and 2% Glu supplementation. In trial 2, the fish (37.26 +- 0.04 g) were fed two purified diets with 0 and 3% Glu supplementation. The results after feeding trials showed that dietary Glu supplementation increased the hardness and springiness of muscle, whether using practical or purified diets. Glu-supplemented diets increased the thickness and density of myofibres and collagen content between myofibres. Furthermore, Glu promoted muscle protein deposition by regulating the IGF-1-AKT-mTOR signalling pathway, and enhanced the myofibre hypertrophy by upregulating genes related to myofibre growth and development (mef2a, mef2d, myod, myf5, mlc, tpi and pax7alpha). The protein deposition and myofibre hypertrophy in turn improved the flesh texture. In addition, IMP content in flesh increased when supplementing Glu whether to practical or to purified diet. Metabolomics confirmed that Glu promoted the deposition of muscle-flavoured substances and purine metabolic pathway most functioned, echoed by the upregulation of key genes (ampd, ppat and adsl) in purine metabolism. The sensory test also clarified that dietary Glu improved the flesh quality by enhancing the muscle texture and flavour. Conclusively, dietary Glu supplementation can improve the flesh quality in this fish, which can further support evidence from other studies more generally that improve flesh quality of cultured fish.", "sentences": [], "annotations": [{"id": "24", "infons": {"identifier": "MESH:D018698", "type": "Chemical", "valid": true, "normalized": ["D018698"], "database": "ncbi_mesh", "normalized_id": "D018698", "biotype": "chemical", "name": "Glutamic Acid", "accession": "@CHEMICAL_Glutamic_Acid"}, "text": "glutamate", "locations": [{"offset": 315, "length": 9}]}, {"id": "25", "infons": {"identifier": "MESH:D018698", "type": "Chemical", "valid": true, "normalized": ["D018698"], "database": "ncbi_mesh", "normalized_id": "D018698", "biotype": "chemical", "name": "Glutamic Acid", "accession": "@CHEMICAL_Glutamic_Acid"}, "text": "Glu", "locations": [{"offset": 326, "length": 3}]}, {"id": "26", "infons": {"identifier": "101364", "type": "Species", "valid": true, "normalized": [101364], "database": "ncbi_taxonomy", "normalized_id": 101364, "biotype": "species", "name": "101364", "accession": null}, "text": "gibel carp", "locations": [{"offset": 351, "length": 10}]}, {"id": "27", "infons": {"identifier": "101364", "type": "Species", "valid": true, "normalized": [101364], "database": "ncbi_taxonomy", "normalized_id": 101364, "biotype": "species", "name": "101364", "accession": null}, "text": "Carassius gibelio", "locations": [{"offset": 363, "length": 17}]}, {"id": "28", "infons": {"identifier": "MESH:D018698", "type": "Chemical", "valid": true, "normalized": ["D018698"], "database": "ncbi_mesh", "normalized_id": "D018698", "biotype": "chemical", "name": "Glutamic Acid", "accession": "@CHEMICAL_Glutamic_Acid"}, "text": "Glu", "locations": [{"offset": 498, "length": 3}]}, {"id": "29", "infons": {"identifier": "MESH:D018698", "type": "Chemical", "valid": true, "normalized": ["D018698"], "database": "ncbi_mesh", "normalized_id": "D018698", "biotype": "chemical", "name": "Glutamic Acid", "accession": "@CHEMICAL_Glutamic_Acid"}, "text": "Glu", "locations": [{"offset": 600, "length": 3}]}, {"id": "30", "infons": {"identifier": "MESH:D018698", "type": "Chemical", "valid": true, "normalized": ["D018698"], "database": "ncbi_mesh", "normalized_id": "D018698", "biotype": "chemical", "name": "Glutamic Acid", "accession": "@CHEMICAL_Glutamic_Acid"}, "text": "Glu", "locations": [{"offset": 674, "length": 3}]}, {"id": "31", "infons": {"identifier": "MESH:D018698", "type": "Chemical", "valid": true, "normalized": ["D018698"], "database": "ncbi_mesh", "normalized_id": "D018698", "biotype": "chemical", "name": "Glutamic Acid", "accession": "@CHEMICAL_Glutamic_Acid"}, "text": "Glu", "locations": [{"offset": 787, "length": 3}]}, {"id": "32", "infons": {"identifier": "MESH:D018698", "type": "Chemical", "valid": true, "normalized": ["D018698"], "database": "ncbi_mesh", "normalized_id": "D018698", "biotype": "chemical", "name": "Glutamic Acid", "accession": "@CHEMICAL_Glutamic_Acid"}, "text": "Glu", "locations": [{"offset": 912, "length": 3}]}, {"i