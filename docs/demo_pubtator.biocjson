": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "role2": {"identifier": "250", "type": "Gene", "valid": true, "normalized": [250], "database": "ncbi_gene", "normalized_id": 250, "biotype": "gene", "name": "ALPP", "accession": "@GENE_ALPP"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "33,32"}]}, {"id": "R5", "infons": {"score": "0.8798", "role1": {"identifier": "MESH:D055549", "type": "Chemical", "valid": true, "normalized": ["D055549"], "database": "ncbi_mesh", "normalized_id": "D055549", "biotype": "chemical", "name": "Volatile Organic Compounds", "accession": "@CHEMICAL_Volatile_Organic_Compounds"}, "role2": {"identifier": "250", "type": "Gene", "valid": true, "normalized": [250], "database": "ncbi_gene", "normalized_id": 250, "biotype": "gene", "name": "ALPP", "accession": "@GENE_ALPP"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "28,32"}]}, {"id": "R6", "infons": {"score": "0.9952", "role1": {"identifier": "MESH:C020213", "type": "Chemical", "valid": true, "normalized": ["C020213"], "database": "ncbi_mesh", "normalized_id": "C020213", "biotype": "chemical", "name": "arginine thiazolidinecarboxylate", "accession": "@CHEMICAL_arginine_thiazolidinecarboxylate"}, "role2": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "5", "role": "15,29"}]}], "pmid": 40735206, "pmcid": null, "meta": {}, "date": "2025-07-15T00:00:00Z", "journal": "Front Public Health", "authors": ["Wang P", "Chen W", "Fang H", "Xu L", "Zhao J", "Huang J"], "relations_display": [{"name": "associate|@CHEMICAL_Volatile_Organic_Compounds|@DISEASE_Inflammation"}, {"name": "cause|@CHEMICAL_Volatile_Organic_Compounds|@DISEASE_Sarcopenia"}, {"name": "cause|@CHEMICAL_S_(3_hydroxypropyl)cysteine_N_acetate|@DISEASE_Sarcopenia"}, {"name": "associate|@DISEASE_Inflammation|@GENE_ALPP"}, {"name": "associate|@CHEMICAL_Volatile_Organic_Compounds|@GENE_ALPP"}, {"name": "cause|@CHEMICAL_arginine_thiazolidinecarboxylate|@DISEASE_Sarcopenia"}]}, {"_id": "40739991|None", "id": "40739991", "infons": {}, "passages": [{"infons": {"journal": "J Diabetes;2025Aug; 17 (8) 70119. doi:10.1111/1753-0407.70119", "year": "2025", "article-id_pmc": "PMC12311314", "type": "title", "authors": "Wen J, Ansari U, Shehabat M, Ansari Z, Syed B, Razick A, Razick D, Akhtar M, Frezza E, "}, "offset": 0, "text": "The Potential of SARMs and Antimyostatin Agents in Addressing Lean Body Mass Loss From GLP-1 Agonists: A Literature Review.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Antimyostatin", "locations": [{"offset": 27, "length": 13}]}, {"id": "4", "infons": {"identifier": "MESH:C536030", "type": "Disease", "valid": true, "normalized": ["C536030"], "database": "ncbi_mesh", "normalized_id": "C536030", "biotype": "disease", "name": "MASS syndrome", "accession": "@DISEASE_MASS_syndrome"}, "text": "Mass", "locations": [{"offset": 72, "length": 4}]}, {"id": "5", "infons": {"identifier": "2740", "type": "Gene", "ncbi_homologene": "1558", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "text": "GLP-1", "locations": [{"offset": 87, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 124, "text": "Glucagon-like peptide-1 receptor agonists (GLP-1 RAs) have demonstrated substantial weight loss effects among patients with diabetes and obesity. However, given the rapid weight loss induced, there is concern about the total change in body composition, including lean body mass (LBM). Current literature on these effects contains significant heterogeneity, with some studies reporting a loss of 40%-60% of LBM and others reporting 15% or less. To combat this, selective androgen receptor modulators (SARMs) have become a popular candidate. Given their androgen receptor selectivity, SARMs have notable anabolic properties and proposed improved safety profiles over traditional anabolic compounds. Several of these agents, such as enobosarm, have been investigated in clinical trials involving older patient populations or patients with cachexia or sarcopenia secondary to chronic diseases. Furthermore, other agents to maintain or enhance LBM, such as antimyostatin agents, are also under investigation. Exploring this potential synergy could lead to better weight loss and body composition management in patients using GLP-1 RAs for diabetes or weight loss therapy. This review aims to evaluate the potential benefits and uses of SARMs in ameliorating the body composition changes induced by GLP-1 RAs. Other investigational agents to retain or increase muscle mass and the future possibilities of these drugs will be discussed.", "sentences": [], "annotations": [{"id": "31", "infons": {"identifier": "2740", "type": "Gene", "ncbi_homologene": "1558", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "text": "Glucagon-like peptide-1 receptor", "locations": [{"offset": 124, "length": 32}]}, {"id": "32", "infons": {"identifier": "2740", "type": "Gene", "ncbi_homologene": "1558", "valid": true, "normalized": [2740], "database": "ncbi_gene", "normalized_id": 2740, "biotype": "gene", "name": "GLP1R", "accession": "@GENE_GLP1R"}, "text": "GLP-1", "locations": [{"offset": 167, "length": 5}]}, {"id": "33", "infons": {"identifier": "MESH:D015431", "type": "Disease", "valid": true, "normalized": ["D015431"], "database": "ncbi_mesh", "normalized_id": "D015431", "biotype": "disease", "name": "Weight Loss", "accession": "@DISEASE_Weight_Loss"}, "text": "weight loss", "locations": [{"offset": 208, "length": 11}]}, {"id": "34", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 234, "length": 8}]}, {"id": "35", "infons": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "text": "diabetes", "locations": [{"offset": 248, "length": 8}]}, {"id": "36", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 261, "length": 7}]}, {"id": "37", "infons": {"identifier": "MESH:D015431", "type": "Disease", "valid": true, "normalized": ["D015431"], "database": "ncbi_mesh", "normalized_id": "D015431", "biotype": "disease", "name": "Weight Loss", "accession": "@DISEASE_Weight_Loss"}, "text": "weight loss", "locations": [{"offset": 295, "length": 11}]}, {"id": "38", "infons": {"identifier": "MESH:C536030", "type": "Disease", "valid": true, "normalized": ["C536030"], "database": "ncbi_mesh", "normalized_id": "C536030", "biotype": "disease", "name": "MASS syndrome", "accession": "@DISEASE_MASS_syndrome"}, "text": "mass", "locations": [{"offset": 397, "length": 4}]}, {"id": "39", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "selective", "locations": [{"offset": 584, "length": 9}]}, {"id": "40", "infons": {"identifier": "367", "type": "Gene", "ncbi_homologene": "28", "valid": true, "normalized": [367], "database": "ncbi_gene", "normalized_id": 367, "biotype": "gene", "name": "AR", "accession": "@GENE_AR"}, "text": "androgen receptor", "locations": [{"offset": 594, "length": 17}]}, {"id": "41", "infons": {"identifier": "367", "type": "Gene", "ncbi_homologene": "28", "valid": true, "normalized": [367], "database": "ncbi_gene", "normalized_id": 367, "biotype": "gene", "name": "AR", "accession": "@GENE_AR"}, "text": "androgen receptor", "locations": [{"offset": 676, "length": 17}]}, {"id": "42", "infons": {"identifier": "MESH:C547106", "type": "Chemical", "valid": true, "normalized": ["C547106"], "database": "ncbi_mesh", "normalized_id": "C547106", "biotype": "chemical", "name": "ostarine", "accession": "@CHEMICAL_ostarine"}, "text": "enobosarm", "locations": [{"offset": 854, "length": 9}]}, {"id": "43", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patient", "locations": [{"offset": 923, "length": 7}]}, {"id": "44", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 946, "length": 8}]}, {"id": "45", "infons": {"identifier": "MESH:D002100", "type": "Disease", "valid": true, "normalized": ["D002100"], "database": "ncbi_mesh", "normalized_id": "D002100", "biotype": "disease", "name": "Cachexia", "accession": "@DISEASE_Cachexia"}, "text": "cachexia", "locations": [{"offset": 960, "length": 8}]}, {"id": "46", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 9