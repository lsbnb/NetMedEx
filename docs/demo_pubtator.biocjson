rrelation"}, "nodes": [{"refid": "5", "role": "15,10"}]}, {"id": "R7", "infons": {"score": "0.9974", "role1": {"identifier": "MESH:D006886", "type": "Chemical", "valid": true, "normalized": ["D006886"], "database": "ncbi_mesh", "normalized_id": "D006886", "biotype": "chemical", "name": "Hydroxychloroquine", "accession": "@CHEMICAL_Hydroxychloroquine"}, "role2": {"identifier": "MESH:D012216", "type": "Disease", "valid": true, "normalized": ["D012216"], "database": "ncbi_mesh", "normalized_id": "D012216", "biotype": "disease", "name": "Rheumatic Diseases", "accession": "@DISEASE_Rheumatic_Diseases"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "6", "role": "15,13"}]}], "pmid": 40693372, "pmcid": null, "meta": {}, "date": "2025-08-01T00:00:00Z", "journal": "Basic Clin Pharmacol Toxicol", "authors": ["Ates I", "Sahin H", "Irham LM", "Yilmaz S", "Suzen S"], "relations_display": [{"name": "treat|@CHEMICAL_Hydroxychloroquine|@DISEASE_Sjogren's_Syndrome"}, {"name": "treat|@CHEMICAL_Hydroxychloroquine|@DISEASE_Lupus_Erythematosus_Systemic"}, {"name": "treat|@CHEMICAL_Hydroxychloroquine|@DISEASE_Autoimmune_Diseases"}, {"name": "treat|@CHEMICAL_Hydroxychloroquine|@DISEASE_Arthritis_Rheumatoid"}, {"name": "treat|@CHEMICAL_Hydroxychloroquine|@DISEASE_Malaria"}, {"name": "treat|@CHEMICAL_Hydroxychloroquine|@DISEASE_Antiphospholipid_Syndrome"}, {"name": "treat|@CHEMICAL_Hydroxychloroquine|@DISEASE_Rheumatic_Diseases"}]}, {"_id": "40703355|None", "id": "40703355", "infons": {}, "passages": [{"infons": {"journal": "Front Pharmacol;2025; 16 1582216. doi:10.3389/fphar.2025.1582216", "year": "2025", "article-id_pmc": "PMC12283682", "type": "title", "authors": "Jeong JY, Son Y, Kim Y, Lee N, Kim Y, Heo YJ, Choi SE, Choi J, Han SJ, Jeon J, Kim HJ, Lee KW, "}, "offset": 0, "text": "Deferoxamine prevents dexamethasone-induced muscle atrophy by reducing MuRF1 and atrogin-1.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "MESH:D003676", "type": "Chemical", "valid": true, "normalized": ["D003676"], "database": "ncbi_mesh", "normalized_id": "D003676", "biotype": "chemical", "name": "Deferoxamine", "accession": "@CHEMICAL_Deferoxamine"}, "text": "Deferoxamine", "locations": [{"offset": 0, "length": 12}]}, {"id": "6", "infons": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "text": "dexamethasone", "locations": [{"offset": 22, "length": 13}]}, {"id": "7", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 44, "length": 14}]}, {"id": "8", "infons": {"identifier": "433766", "type": "Gene", "ncbi_homologene": "41878", "valid": true, "normalized": [433766], "database": "ncbi_gene", "normalized_id": 433766, "biotype": "gene", "name": "Trim63", "accession": "@GENE_TRIM63"}, "text": "MuRF1", "locations": [{"offset": 71, "length": 5}]}, {"id": "9", "infons": {"identifier": "67731", "type": "Gene", "ncbi_homologene": "12182", "valid": true, "normalized": [67731], "database": "ncbi_gene", "normalized_id": 67731, "biotype": "gene", "name": "Fbxo32", "accession": "@GENE_FBXO32"}, "text": "atrogin-1", "locations": [{"offset": 81, "length": 9}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 92, "text": "Introduction: Muscle atrophy, commonly triggered by glucocorticoids such as dexamethasone (DEX), involves increased protein degradation via the ubiquitin-proteasome system. Recent findings suggest that iron imbalance can also induce muscle atrophy. However, there have been no reports indicating that DEX causes intracellular iron imbalance leading to muscle atrophy. This study evaluated whether DEX causes iron imbalance-mediated muscle atrophy and whether deferoxamine (DFO), an iron chelator, can protect against DEX-induced muscle atrophy, exploring the underlying mechanisms in vitro and in vivo. Method: Differentiated C2C12 myotubes were exposed to DEX, with or without DFO, to evaluate morphological changes, expression of muscle-specific ubiquitin ligases (atrogin-1 and MuRF1), and related signaling pathways via quantitative reverse transcription polymerase chain reaction, Western blotting, and immunocytochemistry. Intracellular iron accumulation was quantified using fluorescence imaging. Additionally, C57BL/6J mice were administered intraperitoneal injections of DEX, with or without DFO, every other day for 12 days. Muscle function was assessed by grip strength, and muscle mass and fiber size were measured histologically. Results: DEX significantly induced muscle atrophy in C2C12 myotubes, elevating intracellular iron and upregulating atrogin-1 and MuRF1 via increased nuclear translocation of FOXO3a and expression of KLF15. DFO treatment prevented these effects by restoring the iron balance, enhancing AKT phosphorylation, inhibiting FOXO3a nuclear translocation, and reducing KLF15 expression. Consistently, animal experiments demonstrated that DFO administration effectively preserved grip strength, tibialis anterior muscle mass, and muscle fiber size in DEX-treated mice. Furthermore, DFO treatment restored insulin-like growth factor 1 and myostatin expression levels altered by DEX. Discussion: DFO effectively ameliorates DEX-induced muscle atrophy by modulating the AKT/FOXO3a and KLF15 signaling pathways and restoring the intracellular iron balance. These findings highlight DFO as a potential therapeutic agent for glucocorticoid-induced muscle atrophy.", "sentences": [], "annotations": [{"id": "65", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "Muscle atrophy", "locations": [{"offset": 106, "length": 14}]}, {"id": "66", "infons": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "text": "dexamethasone", "locations": [{"offset": 168, "length": 13}]}, {"id": "67", "infons": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "text": "DEX", "locations": [{"offset": 183, "length": 3}]}, {"id": "68", "infons": {"identifier": "MESH:D007501", "type": "Chemical", "valid": true, "normalized": ["D007501"], "database": "ncbi_mesh", "normalized_id": "D007501", "biotype": "chemical", "name": "Iron", "accession": "@CHEMICAL_Iron"}, "text": "iron", "locations": [{"offset": 294, "length": 4}]}, {"id": "69", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 325, "length": 14}]}, {"id": "70", "infons": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "text": "DEX", "locations": [{"offset": 393, "length": 3}]}, {"id": "71", "infons": {"identifier": "MESH:D007501", "type": "Chemical", "valid": true, "normalized": ["D007501"], "database": "ncbi_mesh", "normalized_id": "D007501", "biotype": "chemical", "name": "Iron", "accession": "@CHEMICAL_