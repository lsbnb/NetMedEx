_Correlation"}, "nodes": [{"refid": "4", "role": "22,18"}]}, {"id": "R6", "infons": {"score": "0.9681", "role1": {"identifier": "MESH:D013107", "type": "Chemical", "valid": true, "normalized": ["D013107"], "database": "ncbi_mesh", "normalized_id": "D013107", "biotype": "chemical", "name": "Sphingolipids", "accession": "@CHEMICAL_Sphingolipids"}, "role2": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "5", "role": "22,16"}]}, {"id": "R7", "infons": {"score": "0.9776", "role1": {"identifier": "MESH:D002518", "type": "Chemical", "valid": true, "normalized": ["D002518"], "database": "ncbi_mesh", "normalized_id": "D002518", "biotype": "chemical", "name": "Ceramides", "accession": "@CHEMICAL_Ceramides"}, "role2": {"identifier": "MESH:D005227", "type": "Chemical", "valid": true, "normalized": ["D005227"], "database": "ncbi_mesh", "normalized_id": "D005227", "biotype": "chemical", "name": "Fatty Acids", "accession": "@CHEMICAL_Fatty_Acids"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "6", "role": "21,9"}]}], "pmid": 41692247, "pmcid": null, "meta": {}, "date": "2026-02-13T00:00:00Z", "journal": "J Lipid Res", "authors": ["Summers SA"], "relations_display": [{"name": "cause|@CHEMICAL_Lipids|@DISEASE_Obesity"}, {"name": "cause|@CHEMICAL_Sphingolipids|@DISEASE_Fatty_Liver"}, {"name": "interact|@CHEMICAL_Fatty_Acids|@CHEMICAL_Sphingolipids"}, {"name": "cause|@CHEMICAL_Sphingolipids|@DISEASE_Kidney_Diseases"}, {"name": "cause|@CHEMICAL_Sphingolipids|@DISEASE_Heart_Failure"}, {"name": "cause|@CHEMICAL_Sphingolipids|@DISEASE_Diabetes_Mellitus"}, {"name": "positive_correlate|@CHEMICAL_Ceramides|@CHEMICAL_Fatty_Acids"}]}, {"_id": "41693292|None", "id": "41693292", "infons": {}, "passages": [{"infons": {"journal": "Physiol Rep;2026Feb; 14 (4) 70780. doi:10.14814/phy2.70780", "year": "2026", "article-id_pmc": "PMC12907578", "type": "title", "authors": "Cole PL, Gillham SH, Viggars MR, Close GL, Owens DJ, "}, "offset": 0, "text": "Palmitoylethanolamide (PEA) regulates cell cycle progression and promotes an anti-inflammatory transcriptomic signature in C2C12 skeletal muscle cells.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:C005958", "type": "Chemical", "valid": true, "normalized": ["C005958"], "database": "ncbi_mesh", "normalized_id": "C005958", "biotype": "chemical", "name": "palmidrol", "accession": "@CHEMICAL_palmidrol"}, "text": "Palmitoylethanolamide", "locations": [{"offset": 0, "length": 21}]}, {"id": "4", "infons": {"identifier": "MESH:C005958", "type": "Chemical", "valid": true, "normalized": ["C005958"], "database": "ncbi_mesh", "normalized_id": "C005958", "biotype": "chemical", "name": "palmidrol", "accession": "@CHEMICAL_palmidrol"}, "text": "PEA", "locations": [{"offset": 23, "length": 3}]}, {"id": "5", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 82, "length": 12}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 152, "text": "Palmitoylethanolamide (PEA) is an endogenous lipid mediator with immunomodulatory actions, yet its effects in skeletal muscle remain poorly defined. We examined whether PEA influences myogenesis and profiled the acute transcriptomic response of differentiated C2C12 myotubes to 10 muM PEA. PEA decreased myotube number (90.3 +- 10.6 vs. 112.6 +- 10.1 control) while increasing nuclear fusion index (37.8 +- 5.7% vs. 30.7 +- 3.2%); myotube area was unchanged. In myoblasts, 24 h PEA increased G0/G1 (48.2 +- 1.2% vs. 42.3 +- 1.9%) and reduced S-phase (21.7 +- 1.2% vs. 25.5 +- 1.2%), consistent with G1 arrest. RNA sequencing identified 1952 differentially expressed genes enriched for cytokine-receptor interactions and inflammatory signaling. PEA downregulated NF-kappaB target cytokines while upregulating interferon-related and chemokine genes, indicating an anti-inflammatory/immune-priming profile. N-acylethanolamine acid amidase was highly expressed and induced, whereas fatty acid amide hydrolase remained low and unchanged, suggesting muscle-specific reliance on NAAA metabolism. These data show that PEA biases skeletal muscle toward a less proliferative but more fused and inflammation-resolving phenotype, with transcriptional reprogramming of immune pathways and preferential NAAA engagement. These findings motivate in vivo studies to test whether such actions benefit muscle regeneration, adaptation, or anti-atrophy interventions.", "sentences": [], "annotations": [{"id": "24", "infons": {"identifier": "MESH:C005958", "type": "Chemical", "valid": true, "normalized": ["C005958"], "database": "ncbi_mesh", "normalized_id": "C005958", "biotype": "chemical", "name": "palmidrol", "accession": "@CHEMICAL_palmidrol"}, "text": "Palmitoylethanolamide", "locations": [{"offset": 152, "length": 21}]}, {"id": "25", "infons": {"identifier": "MESH:C005958", "type": "Chemical", "valid": true, "normalized": ["C005958"], "database": "ncbi_mesh", "normalized_id": "C005958", "biotype": "chemical", "name": "palmidrol", "accession": "@CHEMICAL_palmidrol"}, "text": "PEA", "locations": [{"offset": 175, "length": 3}]}, {"id": "26", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 197, "length": 5}]}, {"id": "27", "infons": {"identifier": "MESH:C005958", "type": "Chemical", "valid": true, "normalized": ["C005958"], "database": "ncbi_mesh", "normal