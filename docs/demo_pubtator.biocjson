ntifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "role2": {"identifier": "21926", "type": "Gene", "valid": true, "normalized": [21926], "database": "ncbi_gene", "normalized_id": 21926, "biotype": "gene", "name": "Tnf", "accession": "@GENE_TNF"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "12,29"}]}], "pmid": 40984725, "pmcid": null, "meta": {}, "date": "2025-09-01T00:00:00Z", "journal": "J Extracell Vesicles", "authors": ["Hakkar R", "Brun CE", "Leblanc P", "Meugnier E", "Berger-Danty E", "Blanc-Brude O", "Tacconi S", "Jalabert A", "Reininger L", "Pesenti S", "Calzada C", "Gache V", "Vasan SB", "Pichon J", "Larcher T", "Errazuriz-Cerda E", "Cassin C", "Sung BH", "Weaver A", "Bongiovanni A", "Rouger K", "de Barros JP", "Bouzakri K", "Rome S"], "relations_display": [{"name": "stimulate|@DISEASE_Muscular_Diseases|@GENE_TNF"}, {"name": "stimulate|@DISEASE_Inflammation|@GENE_TNF"}, {"name": "associate|@DISEASE_Diabetes_Mellitus_Type_2|@GENE_TNF"}]}, {"_id": "40987776|None", "id": "40987776", "infons": {}, "passages": [{"infons": {"journal": "Bone Res;2025Sep23; 13 (1) 78. doi:10.1038/s41413-025-00455-8", "year": "2025", "article-id_pmc": "PMC12457612", "type": "title", "authors": "Mao X, Lv K, Qi W, Cheng W, Li T, Sun Y, Jin H, Pan H, Wang D, "}, "offset": 0, "text": "Research progress on sarcopenia in the musculoskeletal system.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 21, "length": 10}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 63, "text": "Sarcopenia, a progressive and systemic skeletal muscle disorder marked by the accelerated deterioration of both muscle function and mass, is highly prevalent among the elderly population, significantly contributing to an elevated risk of adverse outcomes, including falls, fractures, and muscle weakness. Clinical investigations have identified a strong correlation between sarcopenia and several prevalent degenerative skeletal muscle disorders. This correlation is attributed to imbalances in joint mechanics resulting from localized muscle atrophy and the influence of musculoskeletal secretory factors. In this review, we discuss the broader implications of sarcopenia and critically evaluate the currently established assessment methods. Furthermore, the clinical significance of prevalent musculoskeletal disorders (including osteoporosis, osteoarthritis, and spinal pathologies) in relation to sarcopenia, alongside the underlying mechanisms influencing this relationship, is summarized. Additionally, the effects of sarcopenia on the therapeutic efficacy of medications and surgical interventions for musculoskeletal conditions are reviewed. Sarcopenia is intricately linked to the onset, progression, and prognosis of musculoskeletal disorders. Future research should prioritize elucidating the potential mechanisms that connect muscle loss with skeletal muscle diseases, and investigating whether mitigating sarcopenia symptoms could decelerate the progression of these disorders, thereby paving new pathways for therapeutic interventions.", "sentences": [], "annotations": [{"id": "23", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "Sarcopenia", "locations": [{"offset": 63, "length": 10}]}, {"id": "24", "infons": {"identifier": "MESH:D005207", "type": "Disease", "valid": true, "normalized": ["D005207"], "database": "ncbi_mesh", "normalized_id": "D005207", "biotype": "disease", "name": "Fasciculation", "accession": "@DISEASE_Fasciculation"}, "text": "skeletal muscle disorder", "locations": [{"offset": 102, "length": 24}]}, {"id": "25", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle function", "locations": [{"offset": 175, "length": 15}]}, {"id": "26", "infons": {"identifier": "MESH:D050723", "type": "Disease", "valid": true, "normalized": ["D050723"], "database": "ncbi_mesh", "normalized_id": "D050723", "biotype": "disease", "name": "Fractures Bone", "accession": "@DISEASE_Fractures_Bone"}, "text": "fractures", "locations": [{"offset": 336, "length": 9}]}, {"id": "27", "infons": {"identifier": "MESH:D018908", "type": "Disease", "valid": true, "normalized": ["D018908"], "database": "ncbi_mesh", "normalized_id": "D018908", "biotype": "disease", "name": "Muscle Weakness", "accession": "@DISEASE_Muscle_Weakness"}, "text": "muscle weakness", "locations": [{"offset": 351, "length": 15}]}, {"id": "28", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 437, "length": 10}]}, {"id": "29", "infons": {"identifier": "MESH:D019636", "type": "Disease", "valid": true, "normalized": ["D019636"], "database": "ncbi_mesh", "normalized_id": "D019636", "biotype": "disease", "name": "Neurodegenerative Diseases", "accession": "@DISEASE_Neurodegenerative_Diseases"}, "text": "degenerative skeletal muscle disorders", "locations": [{"offset": 470, "length": 38}]}, {"id": "30", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 599, "length": 14}]}, {"id": "31", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 725, "length": 10}]}, {"id": "32", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "musculoskeletal disorders", "locations": [{"offset": 858, "length": 25}]}, {"id": "33", "infons": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "text": "osteoporosis", "locations": [{"offset": 895, "length": 12}]}, {"id": "34", "infons": {"identifier": "MESH:D010003", "type": "Disease", "valid": true, "normalized": ["D010003"], "database": "ncbi_mesh", "normalized_id": "D010003", "biotype": "disease", "name": "Osteoarthritis", "accession": "@DISEASE_Osteoarthritis"}, "text": "osteoarthritis", "locations": [{"offset": 909, "length": 14}]}, {"id": "35", "infons": {"identifier": "MESH:D013122", "type": "Disease", "valid": true, "normalized": ["D013122"], "database": "ncbi_mesh", "normalized_id": "D013122", "biotype": "disease", "name": "Spinal Diseases", "accession": "@DISEASE_Spinal_Diseases"}, "text": "spinal", "locations": [{"offset": 929, "length": 6}]}, {"id": "36", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "norm