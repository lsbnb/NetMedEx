SEASE_Obesity"}, "role2": {"identifier": "14313", "type": "Gene", "valid": true, "normalized": [14313], "database": "ncbi_gene", "normalized_id": 14313, "biotype": "gene", "name": "Fst", "accession": "@GENE_FST"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "41,39"}]}, {"id": "R4", "infons": {"score": "0.9936", "role1": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "role2": {"identifier": "14313", "type": "Gene", "valid": true, "normalized": [14313], "database": "ncbi_gene", "normalized_id": 14313, "biotype": "gene", "name": "Fst", "accession": "@GENE_FST"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "9,39"}]}, {"id": "R5", "infons": {"score": "0.9969", "role1": {"identifier": "14313", "type": "Gene", "valid": true, "normalized": [14313], "database": "ncbi_gene", "normalized_id": 14313, "biotype": "gene", "name": "Fst", "accession": "@GENE_FST"}, "role2": {"identifier": "18595", "type": "Gene", "valid": true, "normalized": [18595], "database": "ncbi_gene", "normalized_id": 18595, "biotype": "gene", "name": "Pdgfra", "accession": "@GENE_PDGFRA"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "39,22"}]}, {"id": "R6", "infons": {"score": "0.9889", "role1": {"identifier": "14313", "type": "Gene", "valid": true, "normalized": [14313], "database": "ncbi_gene", "normalized_id": 14313, "biotype": "gene", "name": "Fst", "accession": "@GENE_FST"}, "role2": {"identifier": "21803", "type": "Gene", "valid": true, "normalized": [21803], "database": "ncbi_gene", "normalized_id": 21803, "biotype": "gene", "name": "Tgfb1", "accession": "@GENE_TGFB1"}, "type": "Association"}, "nodes": [{"refid": "4", "role": "39,5"}]}, {"id": "R7", "infons": {"score": "0.8779", "role1": {"identifier": "14313", "type": "Gene", "valid": true, "normalized": [14313], "database": "ncbi_gene", "normalized_id": 14313, "biotype": "gene", "name": "Fst", "accession": "@GENE_FST"}, "role2": {"identifier": "17700", "type": "Gene", "valid": true, "normalized": [17700], "database": "ncbi_gene", "normalized_id": 17700, "biotype": "gene", "name": "Mstn", "accession": "@GENE_MSTN"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "5", "role": "39,33"}]}], "pmid": 41272451, "pmcid": null, "meta": {}, "date": "2025-11-21T00:00:00Z", "journal": "Mol Med", "authors": ["Aslam MR", "Bilal M", "Nawaz A", "Kado T", "Abe S", "Phuong NQ", "Memoona", "Khalid S", "Anh LD", "Nishimura A", "Watanabe Y", "Igarashi Y", "Iqbal N", "Yokoyama M", "Onogi Y", "Hirabayashi K", "Miwa H", "Era T", "Matzuk MM", "Yamamoto S", "Ikuta K", "Usui I", "Kobayashi K", "Satake T", "Kato M", "Fujisaka S", "Tobe K"], "relations_display": [{"name": "associate|@CHEMICAL_Fatty_Acids|@GENE_FST"}, {"name": "associate|@DISEASE_Muscular_Atrophy|@GENE_FST"}, {"name": "associate|@DISEASE_Obesity|@GENE_FST"}, {"name": "associate|@DISEASE_Muscular_Diseases|@GENE_FST"}, {"name": "associate|@GENE_FST|@GENE_PDGFRA"}, {"name": "associate|@GENE_FST|@GENE_TGFB1"}, {"name": "negative_correlate|@GENE_FST|@GENE_MSTN"}]}, {"_id": "41275142|None", "id": "41275142", "infons": {}, "passages": [{"infons": {"journal": "BMC Geriatr;2025Nov22. doi:10.1186/s12877-025-06782-z", "year": "2025", "type": "title", "authors": "Ju&#xe1;rez-Cedillo T, Mart&#xed;nez-Rodr&#xed;guez N, Rocha-Cruz A, Fragoso JM, Robles-Ram&#xed;rez RJ, Ju&#xe1;rez-Cedillo E, "}, "offset": 0, "text": "Genetic association of proinflammatory cytokines in the pathogenesis of frailty syndrome: an application of ordinal logistic regression model.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D000073496", "type": "Disease", "valid": true, "normalized": ["D000073496"], "database": "ncbi_mesh", "normalized_id": "D000073496", "biotype": "disease", "name": "Frailty", "accession": "@DISEASE_Frailty"}, "text": "frailty syndrome", "locations": [{"offset": 72, "length": 16}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 143, "text": "BACKGROUND: Frailty is a geriatric syndrome of multifactorial origin whose associated pathophysiological mechanisms must be studied; some inflammatory markers have recently been implicated, but the mechanisms are still not clear. In this study we have explored the relationship between cytokine polymorphisms and frailty in older adults through an ordinal logistic regression model and analysis of the main components (PCA). METHODS: This study included a total of 908 older adults and the genotypes of IL-1 (rs rs1800587), IL-6 (rs1800796), TNF-alpha (rs361525; rs1800629), IFNG rs2069705 and TGFB1 (rs1800470). The study groups were characterized to identify the factors that give rise to the frailty syndrome. The best model was considered to be the pseudo R2 and the percentage of coincidence between the forecast. and observed value. RESULTS: We found an association between the polymorphisms and frailty under different inheritance models; IL-1-a, additive rs1800587(OR = 0.60, 95%CI = 0.47-0.76; p < 0.001), TNF-alpha, rs361525 (OR = 1.91, 95%CI = 1.55-2.36; p < 0.001), IL-6, codominant rs1800796 (GC; OR = 2.10, 95%CI = 1.60-2.77), GG; OR = 4.64, 95%IC = 3.35-6.43; p < 0.001), and IFNG, rs2069705 (TA; OR = 1.32, 95%CI = 1.03-1.70. TNF-alpha, recessive rs1800629 (OR = 18.54, 95%CI = 7.82-43.9; p < 0.001), and TT; OR = 1.46, 95%CI = 1.04-2.04, p < 0.028), TGFB1 rs1800470, OR = 1.26 95%CI = 0.97-1.63; p = 0.075), as well as the comorbidity, independence in activities of the daily life and general functional status (adjusted R2 = 0.2015). CONCLUSION: The model generated for this study showed that adults with older age, diabetes, greater dependency in activities of daily living, and decreased functional status were more frail and that genetic markers conferred a greater risk of presenting frailty.", "sentences": [], "annotations": [{"id": "34", "in