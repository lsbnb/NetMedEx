": "ncbi_gene", "normalized_id": 2670, "biotype": "gene", "name": "GFAP", "accession": "@GENE_GFAP"}, "type": "Association"}, "nodes": []}, {"id": "R17", "infons": {"score": "0.9601", "role1": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "role2": {"identifier": "2670", "type": "Gene", "valid": true, "normalized": [2670], "database": "ncbi_gene", "normalized_id": 2670, "biotype": "gene", "name": "GFAP", "accession": "@GENE_GFAP"}, "type": "Association"}, "nodes": []}, {"id": "R18", "infons": {"score": "0.8367", "role1": {"identifier": "MESH:D010842", "type": "Disease", "valid": true, "normalized": ["D010842"], "database": "ncbi_mesh", "normalized_id": "D010842", "biotype": "disease", "name": "Pica", "accession": "@DISEASE_Pica"}, "role2": {"identifier": "2670", "type": "Gene", "valid": true, "normalized": [2670], "database": "ncbi_gene", "normalized_id": 2670, "biotype": "gene", "name": "GFAP", "accession": "@GENE_GFAP"}, "type": "Association"}, "nodes": []}], "pmid": 41024483, "pmcid": null, "meta": {}, "date": "2025-09-29T00:00:00Z", "journal": "Ann Clin Transl Neurol", "authors": ["Hagemann TL", "Sonsalla MM", "Luzinski C", "Zacahua F", "Harris DA", "Lamming DW", "Messing A"], "relations_display": [{"name": "associate|@DISEASE_Anorexia|@VARIANT_p.R237H_GFAP_human"}, {"name": "associate|@DISEASE_Muscular_Atrophy|@VARIANT_p.R237H_GFAP_human"}, {"name": "positive_correlate|@GENE_GDF15|@GENE_GFRAL"}, {"name": "associate|@DISEASE_Pica|@VARIANT_p.R237H_GFAP_human"}, {"name": "associate|@DISEASE_Anorexia|@GENE_GDF15"}, {"name": "negative_correlate|@CHEMICAL_Oligonucleotides|@GENE_GFAP"}, {"name": "associate|@DISEASE_Alexander_Disease|@GENE_GDF15"}, {"name": "associate|@DISEASE_Weight_Gain|@GENE_GFAP"}, {"name": "associate|@GENE_GFAP|@GENE_GDF15"}, {"name": "associate|@DISEASE_Feeding_and_Eating_Disorders|@GENE_GDF15"}, {"name": "associate|@CHEMICAL_Oligonucleotides|@DISEASE_Weight_Gain"}, {"name": "associate|@DISEASE_Alexander_Disease|@GENE_GFAP"}, {"name": "associate|@DISEASE_Frailty|@GENE_GFAP"}, {"name": "associate|@DISEASE_Failure_to_Thrive|@GENE_GDF15"}, {"name": "associate|@DISEASE_Feeding_and_Eating_Disorders|@GENE_GFRAL"}, {"name": "associate|@DISEASE_Anorexia|@GENE_GFAP"}, {"name": "associate|@DISEASE_Muscular_Atrophy|@GENE_GFAP"}, {"name": "associate|@DISEASE_Pica|@GENE_GFAP"}]}, {"_id": "41044866|None", "id": "41044866", "infons": {}, "passages": [{"infons": {"journal": "Lipids;2025Oct03. doi:10.1002/lipd.70011", "year": "2025", "type": "title", "authors": "Klievik BJ, Metherel AH, Valenzuela R, Bazinet RP, "}, "offset": 0, "text": "Measuring Peripheral Tissue DHA Turnover Using a Novel 13C Enrichment Technique.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D004281", "type": "Chemical", "valid": true, "normalized": ["D004281"], "database": "ncbi_mesh", "normalized_id": "D004281", "biotype": "chemical", "name": "Docosahexaenoic Acids", "accession": "@CHEMICAL_Docosahexaenoic_Acids"}, "text": "DHA", "locations": [{"offset": 28, "length": 3}]}, {"id": "3", "infons": {"identifier": "MESH:C000615229", "type": "Chemical", "valid": true, "normalized": ["C000615229"], "database": "ncbi_mesh", "normalized_id": "C000615229", "biotype": "chemical", "name": "Carbon-13", "accession": "@CHEMICAL_Carbon_13"}, "text": "13C", "locations": [{"offset": 55, "length": 3}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 81, "text": "Recently, through the use of compound-specific isotope analysis (CSIA), our lab validated the utility of 13C enrichment (delta13C) of docosahexaenoic acid (DHA) by using a very high delta13C in a diet switch study by measuring brain, liver, and plasma DHA turnover and half-lives via high-precision gas chromatography combustion isotope ratio mass spectrometry (GC/C/IRMS). Using this novel enrichment technique, the present study extends measures of DHA turnover in the peripheral tissues, including red blood cells (RBC), perirenal adipose tissue (PRAT), muscle, heart, and skin. Mice were fed a low delta13C diet (fish-DHA control) for 3 months, then switched to either a high delta13C treatment diet (algal-DHA) or a very high delta13C treatment diet (13C enriched-DHA), while some remained on the fish-DHA control diet as a reference group for the remainder of the study time course. In mice fed the algal and 13C enriched-DHA diets, the RBC DHA half-life was 22.8 and 19.5 days, the PRAT DHA half-life was 6.0 and 8.2 days, the muscle DHA half-life was 38.2 and 42.2 days, the heart DHA half-life was 12.4 and 10.5 days, and the skin DHA half-life was 13.6 and 13.0 days, respectively. Future studies could employ the 13C enrichment method to examine how DHA metabolism is altered in peripheral tissues according to genetics, stress, and development.", "sentences": [], "annotations": [{"id": "30", "infons": {"identifier": "MESH:C000615229", "type": "Chemical", "valid": true, "normalized": ["C000615229"], "database": "ncbi_mesh", "normalized_id": "C000615229", "biotype": "chemical", "name": "Carbon-13", "accession": "@CHEMICAL_Carbon_13"}, "text": "13C", "locations": [{"offset": 186, "length": 3}]}, {"id": "31", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "delta13C", "locations": [{"offset": 202, "length": 8}]}, {"id": "32", "infons": {"identifier": "MESH:D004281", "type": "Chemical", "valid": true, "normalized": ["D004281"], "database": "ncbi_mesh", "normalized_id": "D004281", "biotype": "chemical", "name": "Docosahexaenoic Acids", "accession": "@CHEMICAL_Docosahexaenoic_Acids"}, "text": "docosahexaenoic acid", "locations": [{"offset": 215, "length": 20}]}, {"id": "33", "infons": {"identifier": "MESH:D004281", "type": "Chemical", "valid": true, "normalized": ["D004281"], "databa