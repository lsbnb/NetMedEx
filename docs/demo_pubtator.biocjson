D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 1760, "length": 10}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.998", "role1": {"identifier": "MESH:D010195", "type": "Disease", "valid": true, "normalized": ["D010195"], "database": "ncbi_mesh", "normalized_id": "D010195", "biotype": "disease", "name": "Pancreatitis", "accession": "@DISEASE_Pancreatitis"}, "role2": {"identifier": "713", "type": "Gene", "valid": true, "normalized": [713], "database": "ncbi_gene", "normalized_id": 713, "biotype": "gene", "name": "C1QB", "accession": "@GENE_C1QB"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "13,17"}]}, {"id": "R2", "infons": {"score": "0.9448", "role1": {"identifier": "MESH:D010195", "type": "Disease", "valid": true, "normalized": ["D010195"], "database": "ncbi_mesh", "normalized_id": "D010195", "biotype": "disease", "name": "Pancreatitis", "accession": "@DISEASE_Pancreatitis"}, "role2": {"identifier": "53405", "type": "Gene", "valid": true, "normalized": [53405], "database": "ncbi_gene", "normalized_id": 53405, "biotype": "gene", "name": "CLIC5", "accession": "@GENE_CLIC5"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "13,22"}]}, {"id": "R3", "infons": {"score": "0.9356", "role1": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "role2": {"identifier": "53405", "type": "Gene", "valid": true, "normalized": [53405], "database": "ncbi_gene", "normalized_id": 53405, "biotype": "gene", "name": "CLIC5", "accession": "@GENE_CLIC5"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "2", "role": "25,22"}]}, {"id": "R4", "infons": {"score": "0.7258", "role1": {"identifier": "MESH:D010195", "type": "Disease", "valid": true, "normalized": ["D010195"], "database": "ncbi_mesh", "normalized_id": "D010195", "biotype": "disease", "name": "Pancreatitis", "accession": "@DISEASE_Pancreatitis"}, "role2": {"identifier": "81539", "type": "Gene", "valid": true, "normalized": [81539], "database": "ncbi_gene", "normalized_id": 81539, "biotype": "gene", "name": "SLC38A1", "accession": "@GENE_SLC38A1"}, "type": "Association"}, "nodes": [{"refid": "3", "role": "13,23"}]}, {"id": "R5", "infons": {"score": "0.8214", "role1": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "role2": {"identifier": "81539", "type": "Gene", "valid": true, "normalized": [81539], "database": "ncbi_gene", "normalized_id": 81539, "biotype": "gene", "name": "SLC38A1", "accession": "@GENE_SLC38A1"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "4", "role": "25,23"}]}], "pmid": 40785039, "pmcid": null, "meta": {}, "date": "2025-08-01T00:00:00Z", "journal": "J Cell Mol Med", "authors": ["Zhang S", "Hu C", "Wang X", "Huang Z", "Xia Q", "Deng L"], "relations_display": [{"name": "associate|@DISEASE_Pancreatitis|@GENE_C1QB"}, {"name": "associate|@DISEASE_Pancreatitis|@GENE_CLIC5"}, {"name": "inhibit|@DISEASE_Sarcopenia|@GENE_CLIC5"}, {"name": "associate|@DISEASE_Pancreatitis|@GENE_SLC38A1"}, {"name": "inhibit|@DISEASE_Sarcopenia|@GENE_SLC38A1"}]}, {"_id": "40787751|None", "id": "40787751", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Cell Surface Thiol Engineering Mechanoregulates Myogenic Differentiation via the FAK-PI3K-AKT Axis.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "MESH:D013438", "type": "Chemical", "valid": true, "normalized": ["D013438"], "database": "ncbi_mesh", "normalized_id": "D013438", "biotype": "chemical", "name": "Sulfhydryl Compounds", "accession": "@CHEMICAL_Sulfhydryl_Compounds"}, "text": "Thiol", "locations": [{"offset": 13, "length": 5}]}, {"id": "5", "infons": {"identifier": "5747", "type": "Gene", "ncbi_homologene": "7314", "valid": true, "normalized": [5747], "database": "ncbi_gene", "normalized_id": 5747, "biotype": "gene", "name": "PTK2", "accession": "@GENE_PTK2"}, "text": "FAK", "locations": [{"offset": 81, "length": 3}]}, {"id": "6", "infons": {"identifier": "5291", "type": "Gene", "ncbi_homologene": "21250", "valid": true, "normalized": [5291], "database": "ncbi_gene", "normalized_id": 5291, "biotype": "gene", "name": "PIK3CB", "accession": "@GENE_PIK3CB"}, "text": "PI3K", "locations": [{"offset": 85, "length": 4}]}, {"id": "7", "infons": {"identifier": "207", "type": "Gene", "ncbi_homologene": "3785", "valid": true, "normalized": [207], "database": "ncbi_gene", "normalized_id": 207, "biotype": "gene", "name": "AKT1", "accession": "@GENE_AKT1"}, "text": "AKT", "locations": [{"offset": 90, "length": 3}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 100, "text": "Skeletal muscle regeneration is essential in conditions like muscle injury and muscular dystrophy, primarily relying on the activation and differentiation of myogenic progenitors. This study explores the role of redox-modulated surface thiol modification in myogenesis, using tris(2-carboxyethyl)phosphine hydrochloride (TCEP) to reduce disulfide bonds and generate free thiol groups on the cell surface. The findings show that TCEP treatment significantly increases cell surface thiols, activating the focal adhesion kinase (FAK)-phosphoinositide 3-kinase (PI3K)-protein kinase B (AKT) signaling pathway, and promoting cell spreading, adhesion, and actin cytoskeleton remodeling. This biochemical modulation upregulates myogenic and fusion-related markers, facilitating multinucleated myotube formation. Biophysical analysis using traction force microscopy (TFM), intracellular force microscopy (IFM), and monolayer stress microscopy (MSM) demonstrates that TCEP-treated cells, particularly at muscle-relevant stiffness (20 kPa), exhibit increased traction, intracellular, and monolayer stresses compared to untreated cells. These results suggest that redox-modulated surface thiol modification, combined with specific stiffness conditions, enhances myogenic differentiation and myotube maturation through biomechanical signaling. This proof-of-concept study advances the understanding of how redox-modulated surface engineering and substrate stiffness regulate myogenesis, offering novel therapeutic strategies for muscle regeneration and optimization of stem cell-based therapies for muscle tissue repair.", "sentences": [], "annotations": [{"id": "24", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle injury", "locations": [{"offset": 161, "length": 13}]}, {"id": "25", "infons": {"identifier": "MESH:D009136", "type": "Disease", "valid": true, "normalized": ["D009136"], "database": "ncbi_mesh", "normalized_id": "D009136", "biotype": "disease", "name": "Muscular Dystrophies", "accession": "@DISEASE_Muscular_Dystrophies"}, "text": "muscular dystrophy", "locations": [{"offset": 179, "length": 18}]}, {"id": "26", "infons": {"identifier": "MESH:D013438", "type": "Chemical", "valid": true, "normalized": ["D013438"], "database": "ncbi_mesh", "normalized_id": "D013438", "biotype": "chemical", "name": "Sulfhydryl Compounds", "accession": "@CHEMICAL_Sulfhydryl_Compounds"}, "text": "thiol", "locations": [{"offset": 336, "length": 5}]}, {"id": "27", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "tris(2-carboxyethyl)phosphine hydrochloride", "locations": [{"offset": 376, "length": 43}]}, {"id": "28", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "TCEP", "locations": [{"offset": 421, "length": 4}]}, {"id": "29", "infons": {"identifier": "MESH:D004220", "type": "Chemical", "valid": true, "normalized": ["D004220"], "database": "ncbi_mesh", "normalized_id": "D004220", "biotype": "chemical", "name": "Disulfides", "accession": "@CHEMICAL_Disulfides"}, "text": "disulfide", "locations": [{"offset": 437, "length": 9}]}, {"id": "30", "infons": {"identifier": "MESH:D013438", "type": "Chemical", "valid": true, "normalized": ["D013438"], "database": "ncbi_mesh", "normalized_id": "D013438", "biotype": "chemical", "name": "Sulfhydryl Compounds", "accession": "@CHEMICAL_Sulfhydryl_Compounds"}, "text": "thiol", "locations": [{"offset": 471, "length": 5}]}, {"id": "31", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "TCEP", "locations": [{"offset": 528, "length": 4}]}, {"id": "32", "infons": {"identifier": "MESH:D013438", "type": "Chemical", "valid": true, "normalized": ["D013438"], "database": "ncbi_mesh", "normalized_id": "D013438", "biotype": "chemical", "name": "Sulfhydryl Compounds", "accession": "@CHEMICAL_Sulfhydryl_Compounds"}, "text": "thiols", "locations": [{"offset": 580, "length": 6}]}, {"id": "33", "infons": {"identifier": "5747", "type": "Gene", "ncbi_homologene": "7314", "valid": true, "normalized": [5747], "database": "ncbi_gene", "normalized_id": 5747, "biotype": "gene", "name": "PTK2", "accession": "@GENE_PTK2"}, "text": "focal adhesion kinase", "locations": [{"offset": 603, "length": 21}]}, {"id": "34", "infons": {"identifier": "5747", "type": "Gene", "ncbi_homologene": "7314", "valid": true, "normalized": [5747], "database": "ncbi_gene", "normalized_id": 5747, "biotype": "gene", "name": "PTK2", "accession": "@GENE_PTK2"}, "text": "FAK", "locations": [{"offset": 626, "length": 3}]}, {"id": "35", "infons": {"identifier": "5291", "type": "Gene", "ncbi_homol