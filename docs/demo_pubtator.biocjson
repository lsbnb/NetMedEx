on": "@DISEASE_Muscular_Atrophy"}, "type": "Positive_Correlation"}, "nodes": []}, {"id": "R2", "infons": {"score": "0.9979", "role1": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "role2": {"identifier": "16337", "type": "Gene", "valid": true, "normalized": [16337], "database": "ncbi_gene", "normalized_id": 16337, "biotype": "gene", "name": "Insr", "accession": "@GENE_INSR"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "47,45"}]}, {"id": "R3", "infons": {"score": "0.6528", "role1": {"identifier": "MESH:C038892", "type": "Chemical", "valid": true, "normalized": ["C038892"], "database": "ncbi_mesh", "normalized_id": "C038892", "biotype": "chemical", "name": "methyl anthranilate", "accession": "@CHEMICAL_methyl_anthranilate"}, "role2": {"identifier": "MESH:C413246", "type": "Chemical", "valid": true, "normalized": ["C413246"], "database": "ncbi_mesh", "normalized_id": "C413246", "biotype": "chemical", "name": "oleanane", "accession": "@CHEMICAL_oleanane"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "19,20"}]}, {"id": "R4", "infons": {"score": "0.9972", "role1": {"identifier": "MESH:D003907", "type": "Chemical", "valid": true, "normalized": ["D003907"], "database": "ncbi_mesh", "normalized_id": "D003907", "biotype": "chemical", "name": "Dexamethasone", "accession": "@CHEMICAL_Dexamethasone"}, "role2": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "2", "role": "41,47"}]}, {"id": "R5", "infons": {"score": "0.848", "role1": {"identifier": "MESH:D013256", "type": "Chemical", "valid": true, "normalized": ["D013256"], "database": "ncbi_mesh", "normalized_id": "D013256", "biotype": "chemical", "name": "Steroids", "accession": "@CHEMICAL_Steroids"}, "role2": {"identifier": "16337", "type": "Gene", "valid": true, "normalized": [16337], "database": "ncbi_gene", "normalized_id": 16337, "biotype": "gene", "name": "Insr", "accession": "@GENE_INSR"}, "type": "Association"}, "nodes": []}], "pmid": 41290519, "pmcid": null, "meta": {}, "date": "2025-12-01T00:00:00Z", "journal": "J Cachexia Sarcopenia Muscle", "authors": ["Park EJ", "Kim HJ", "Lee SH", "Choi S", "Doan TP", "Joo KH", "An JP", "Jung DW", "Williams DR", "Oh WK"], "relations_display": [{"name": "cause|@CHEMICAL_Steroids|@DISEASE_Muscular_Atrophy"}, {"name": "associate|@DISEASE_Muscular_Atrophy|@GENE_INSR"}, {"name": "associate|@CHEMICAL_methyl_anthranilate|@CHEMICAL_oleanane"}, {"name": "cause|@CHEMICAL_Dexamethasone|@DISEASE_Muscular_Atrophy"}, {"name": "associate|@CHEMICAL_Steroids|@GENE_INSR"}]}, {"_id": "41290705|None", "id": "41290705", "infons": {}, "passages": [{"infons": {"journal": "NPJ Aging;2025Nov25; 11 (1) 94. doi:10.1038/s41514-025-00285-2", "year": "2025", "article-id_pmc": "PMC12647874", "type": "title", "authors": "Nagaoka N, Eguchi A, Ma N, Kawanokuchi J, Yamamoto T, Tempaku M, Izuoka K, Okabe J, Iwasa M, Nakagawa H, Kobayashi Y, "}, "offset": 0, "text": "Stimulation at the frontal cortex influences the exercise activity and skeletal muscle status in senescence-accelerating mice.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 121, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 127, "text": "Senescence-associated frailty and sarcopenia are global challenges. We here investigated neuronal activity and skeletal muscle biology in senescence-accelerated mouse prone 8 (SAMP8) mice with scalp acupuncture stimulation (SAPS). Excise activity was assessed using rotarod test in the three groups: SAMP8 mice receiving SAPS (SP8-Ap), SAMP8 controls (SP8-C), and senescence-accelerated mouse resistant 1 controls (SR1). SP8-Ap exhibited significantly improved exercise activity compared to SP8-C. SAPS increased brain-derived neurotrophic factor (BDNF) and nerve growth factor (NGF) levels in the frontal cortex of SP8-Ap. Monocyte/macrophage infiltration was significantly reduced in the gastrocnemius of SP8-Ap mice, which was associated with reduced expression of various glycogen synthase kinase-3beta (GSK3beta)-mediated inflammatory genes and increased insulin-like growth factor (IGF)-1 mRNA and phosphorylated AKT. These results indicate that elevation of neurotropic factors in the frontal cortex by SAPS can improve the exercise activity and skeletal muscle status. SAPS may represent a novel therapeutic approach to improve senescence-related frailty.", "sentences": [], "annotations": [{"id": "24", "infons": {"identifier": "MESH:D000073496", "type": "Disease", "valid": true, "normalized": ["D000073496"], "database": "ncbi_mesh", "normalized_id": "D000073496", "biotype": "disease", "name": "Frailty", "accession": "@DISEASE_Frailty"}, "text": "frailty", "locations": [{"offset": 149, "length": 7}]}, {"id": "25", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 161, "length": 10}]}, {"id": "26", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 288, "length": 5}]}, {"id": "27", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 310, "length": 4}]}, {"id": "28", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 433, "length": 4}]}, {"id": "29", "infons": {"identifier": "320145", "type": "Gene", "ncbi_homologene": "18548", "valid": true, "normalized": [320145], "database": "ncbi_gene", "normalized_id": 320145, "biotype": "gene", "name": "Sp8", "accession": "@GENE_SP8"}, "text": "SP8", "locations": [{"offset": 454, "length": 3}]}, {"id": "30", "infons": {"identifier": "320145", "type": "Gene", "ncbi_homologene": "18548", "valid": true, "normalized": [320145], "database": "ncbi_gene", "normalized_id": 320145, "biotype": "gene", "name": "Sp8", "accession": "@GENE_SP8"}, "text": "SP8", "locations": [{"offset": 479, "length": 3}]}, {"id": "31", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 514, "length": 5}]}, {"id": "32", "infons": {"identifier": "320145", "type": "Gene", "ncbi_homologene": "18548", "valid": true, "normalized": [320145], "database": "ncbi_gene", "normalized_id": 320145, "biotype": "gene", "name": "Sp8", "accession": "@GENE_SP8"}, "text": "SP8", "locations": [{"offset": 548, "length": 3}]}, {"id": "33", "infons": {"identifier": "320145", "type": "Gene", "ncbi_homologene": "18548", "valid": true, "normalized": [320145], "database": "ncbi_gene", "normalized_id": 320145, "biotype": "gene", "name": "Sp8", "accession": "@GENE_SP8"}, "text": "SP8", "locations": [{"offset": 618, "length": 3