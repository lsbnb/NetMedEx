63", "type": "Gene", "valid": true, "normalized": [20463], "database": "ncbi_gene", "normalized_id": 20463, "biotype": "gene", "name": "Cox7a2l", "accession": "@GENE_COX7A2L"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "9,22"}]}, {"id": "R4", "infons": {"score": "0.9942", "role1": {"identifier": "MESH:D014280", "type": "Chemical", "valid": true, "normalized": ["D014280"], "database": "ncbi_mesh", "normalized_id": "D014280", "biotype": "chemical", "name": "Triglycerides", "accession": "@CHEMICAL_Triglycerides"}, "role2": {"identifier": "20463", "type": "Gene", "valid": true, "normalized": [20463], "database": "ncbi_gene", "normalized_id": 20463, "biotype": "gene", "name": "Cox7a2l", "accession": "@GENE_COX7A2L"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "3", "role": "12,22"}]}], "pmid": 41253741, "pmcid": null, "meta": {}, "date": "2025-11-18T00:00:00Z", "journal": "Aging Cell", "authors": ["Ikeda K", "Shiba S", "Yokoyama M", "Fujimoto M", "Horie K", "Tanaka T", "Inoue S"], "relations_display": [{"name": "associate|@CHEMICAL_Adenosine_Triphosphate|@GENE_COX7A2L"}, {"name": "positive_correlate|@GENE_GLB1|@GENE_COX7A2L"}, {"name": "associate|@CHEMICAL_Blood_Glucose|@GENE_COX7A2L"}, {"name": "negative_correlate|@CHEMICAL_Triglycerides|@GENE_COX7A2L"}]}, {"_id": "41253787|None", "id": "41253787", "infons": {}, "passages": [{"infons": {"journal": "Nat Commun;2025Nov18; 16 (1) 10091. doi:10.1038/s41467-025-65141-z", "year": "2025", "article-id_pmc": "PMC12627490", "type": "title", "authors": "Yang X, Cao Y, Mu Y, Zhou Y, Zhang L, Ai H, Zhu D, Chen S, Wang HY, "}, "offset": 0, "text": "TBC1D1 functions as a negative regulator of satellite cells for muscle regeneration.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "23216", "type": "Gene", "ncbi_homologene": "56856", "valid": true, "normalized": [23216], "database": "ncbi_gene", "normalized_id": 23216, "biotype": "gene", "name": "TBC1D1", "accession": "@GENE_TBC1D1"}, "text": "TBC1D1", "locations": [{"offset": 0, "length": 6}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 85, "text": "The Rab GTPase activating protein (RabGAP) AS160 translocates from the cytosol into the nucleus acting as a transcriptional co-activator of Signal Transducer and Activator of Transcription 3 (STAT3) to regulate proliferation of muscle satellite cells (MuSCs). How this AS160-STAT3 complex is regulated remains largely unclear yet. Here, we show that TBC1D1, a RabGAP related to AS160, forms a super-complex with AS160 and STAT3 to retain the AS160-STAT3 complex in the cytosol. Phosphorylation of TBC1D1-Thr596 by protein kinase B dissociates TBC1D1 from AS160 thus releasing the cytosolic retention of the AS160-STAT3 complex. A non-phosphorylatable alanine substitution of Thr596 inhibits MuSC proliferation and impairs repair of injured muscle. In contrast, TBC1D1 deficiency, but not its GAP-inactive mutation, promotes MuSC proliferation and muscle regeneration. Thus, TBC1D1 is a negative regulator of MuSC proliferation through cytosolic retention of the AS160-STAT3 complex and might be a valuable therapeutic target for muscle regeneration.", "sentences": [], "annotations": [{"id": "25", "infons": {"identifier": "6774", "type": "Gene", "ncbi_homologene": "7960", "valid": true, "normalized": [6774], "database": "ncbi_gene", "normalized_id": 6774, "biotype": "gene", "name": "STAT3", "accession": "@GENE_STAT3"}, "text": "Signal Transducer and Activator of Transcription 3", "locations": [{"offset": 225, "length": 50}]}, {"id": "26", "infons": {"identifier": "6774", "type": "Gene", "ncbi_homologene": "7960", "valid": true, "normalized": [6774], "database": "ncbi_gene", "normalized_id": 6774, "biotype": "gene", "name": "STAT3", "accession": "@GENE_STAT3"}, "text": "STAT3", "locations": [{"offset": 277, "length": 5}]}, {"id": "27", "infons": {"identifier": "9882", "type": "Gene", "ncbi_homologene": "45451", "valid": true, "normalized": [9882], "database": "ncbi_gene", "normalized_id": 9882, "biotype": "gene", "name": "TBC1D4", "accession": "@GENE_TBC1D4"}, "text": "AS160", "locations": [{"offset": 354, "length": 5}]}, {"id": "28", "infons": {"identifier": "6774", "type": "Gene", "ncbi_homologene": "7960", "valid": true, "normalized": [6774], "database": "ncbi_gene", "normalized_id": 6774, "biotype": "gene", "name": "STAT3", "accession": "@GENE_STAT3"}, "text": "STAT3", "locations": [{"offset": 360, "length": 5}]}, {"id": "29", "infons": {"identifier": "23216", "type": "Gene", "ncbi_homologene": "56856", "valid": true, "normalized": [23216], "database": "ncbi_gene", "normalized_id": 23216, "biotype": "gene", "name": "TBC1D1", "accession": "@GENE_TBC1D1"}, "text": "TBC1D1", "locations": [{"offset": 435, "length": 6}]}, {"id": "30", "infons": {"identifier": "9882", "type": "Gene", "ncbi_homologene": "45451", "valid": true, "normalized": [9882], "database": "ncbi_gene", "normalized_id": 9882, "biotype": "gene", "name": "TBC1D4", "accession": "@GENE_TBC1D4"}, "text": "AS160", "locations": [{"offset": 463, "length": 5}]}, {"id": "31", "infons": {"identifier": "9882", "type": "Gene", "ncbi_homologene": "45451", "valid": true, "normalized": [9882], "database": "ncbi_gene", "normalized_id": 9882, "biotype": "gene", "name": "TBC1D4", "accession": "@GENE_TBC1D4"}, "text": "AS160", "locations": [{"offset": 497, "length": 5}]}, {"id": "32", "infons": {"identifier": "6774", "type": "Gene", "ncbi_homologene": "7960", "valid": true, "normalized": [6774], "database": "ncbi_gene", "normalized_id": 6774, "biotype": "gene", "name": "STAT3", "accession": "@GENE_STAT3"}, "text": "STAT3", "locations": [{"offset": 507, "length": 5}]}, {"id": "33", "infons": {"identifier": "9882", "type": "Gene", "ncbi_homologene": "45451", "valid": true, "normalized": [9882], "database": "ncbi_gene", "normalized_id": 9882, "biotype": "gene", "name": "TBC1D4", "accession": "@GENE_TBC1D4"}, "text": "AS160", "locations": [{"offset": 527, "length": 5}]},