C000615229", "type": "Chemical", "valid": true, "normalized": ["C000615229"], "database": "ncbi_mesh", "normalized_id": "C000615229", "biotype": "chemical", "name": "Carbon-13", "accession": "@CHEMICAL_Carbon_13"}, "text": "13C", "locations": [{"offset": 1305, "length": 3}]}, {"id": "55", "infons": {"identifier": "MESH:D004281", "type": "Chemical", "valid": true, "normalized": ["D004281"], "database": "ncbi_mesh", "normalized_id": "D004281", "biotype": "chemical", "name": "Docosahexaenoic Acids", "accession": "@CHEMICAL_Docosahexaenoic_Acids"}, "text": "DHA", "locations": [{"offset": 1342, "length": 3}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.997", "role1": {"identifier": "MESH:C000615229", "type": "Chemical", "valid": true, "normalized": ["C000615229"], "database": "ncbi_mesh", "normalized_id": "C000615229", "biotype": "chemical", "name": "Carbon-13", "accession": "@CHEMICAL_Carbon_13"}, "role2": {"identifier": "MESH:D004281", "type": "Chemical", "valid": true, "normalized": ["D004281"], "database": "ncbi_mesh", "normalized_id": "D004281", "biotype": "chemical", "name": "Docosahexaenoic Acids", "accession": "@CHEMICAL_Docosahexaenoic_Acids"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "26,27"}]}], "pmid": 41044866, "pmcid": null, "meta": {}, "date": "2025-10-03T00:00:00Z", "journal": "Lipids", "authors": ["Klievik BJ", "Metherel AH", "Valenzuela R", "Bazinet RP"], "relations_display": [{"name": "associate|@CHEMICAL_Carbon_13|@CHEMICAL_Docosahexaenoic_Acids"}]}, {"_id": "41058014|None", "id": "41058014", "infons": {}, "passages": [{"infons": {"journal": "Adv Sci (Weinh);2025Oct07 05989. doi:10.1002/advs.202505989", "year": "2025", "type": "title", "authors": "Yao Z, Jiang Z, Liu X, Zhang L, Guo S, Chen Y, Luo L, Ma S, Wang P, Shyh-Chang N, "}, "offset": 0, "text": "Muscle Organoids Reveal Exercise-Like Contractions Rapidly Promote Muscle Health Via Lamtor1's Signaling to Both AMPK and mTOR.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "55004", "type": "Gene", "ncbi_homologene": "9909", "valid": true, "normalized": [55004], "database": "ncbi_gene", "normalized_id": 55004, "biotype": "gene", "name": "LAMTOR1", "accession": "@GENE_LAMTOR1"}, "text": "Lamtor1", "locations": [{"offset": 85, "length": 7}]}, {"id": "4", "infons": {"identifier": "5562", "type": "Gene", "ncbi_homologene": "49590", "valid": true, "normalized": [5562], "database": "ncbi_gene", "normalized_id": 5562, "biotype": "gene", "name": "PRKAA1", "accession": "@GENE_PRKAA1"}, "text": "AMPK", "locations": [{"offset": 113, "length": 4}]}, {"id": "5", "infons": {"identifier": "2475", "type": "Gene", "ncbi_homologene": "3637", "valid": true, "normalized": [2475], "database": "ncbi_gene", "normalized_id": 2475, "biotype": "gene", "name": "MTOR", "accession": "@GENE_MTOR"}, "text": "mTOR", "locations": [{"offset": 122, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 128, "text": "Exercise triggers molecular changes in skeletal muscles, but distinguishing immediate responses from secondary inter-organ interactions in muscle biopsies remains challenging. Here, this study differentiates human embryonic stem cells (hESCs) into induced skeletal muscle (iMusc) cells to identify hypertrophic factors and generates a novel 3D human iMusc organoid model for studying the direct effects of exercise-like contractions. Transcriptomics profiling reveals iMusc organoids rapidly induced genes associated with calcium signaling, p38/MAPK, EGF/ErbB, and NGF pathways within 1 h, mimicking exercise responses in vivo. Proteomics profiling and in vivo validation reveal rapid activation of both AMPK and mTORC1 signaling, partly through increased Lamtor1 levels, resolving a paradox in exercise biology. Human muscle biopsy analyses reveal Lamtor1 decreases with aging, and increases with exercise. In vivo and organoid experiments both confirm Lamtor1's role in mTORC1-induced strength and AMPK-induced lipid metabolism. Overall, this 3D iMusc organoid model provides insights into primary contraction-induced changes and identifies Lamtor1 as a novel therapeutic target for exercise mimicry.", "sentences": [], "annotations": [{"id": "22", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 336, "length": 5}]}, {"id": "23", "infons": {"identifier": "MESH:D002312", "type": "Disease", "valid": true, "normalized": ["D002312"], "database": "ncbi_mesh", "normalized_id": "D002312", "biotype": "disease", "name": "Cardiomyopathy Hypertrophic", "accession": "@DISEASE_Cardiomyopathy_Hypertrophic"}, "text": "hypertrophic", "locations": [{"offset": 426, "length": 12}]}, {"id": "24", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 472, "length": 5}]}, {"id": "25", "infons": {"identifier": "MESH:D002118", "type": "Chemical", "valid": true, "normalized": ["D002118"], "database": "ncbi_mesh", "normalized_id": "D002118", "biotype": "chemical", "name": "Calcium", "accession": "@CHEMICAL_Calcium"}, "text": "calcium", "locations": [{"offset": 650, "length": 7}]}, {"id": "26", "infons": {"identifier": "1432", "type": "Gene", "ncbi_homologene": "31777", "valid": true, "normalized": [1432], "database": "ncbi_gene", "normalized_id": 1432, "biotype": "gene", "name": "MAPK14", "accession": "@GENE_MAPK14"}, "text": "p38", "locations": [{"offset": 669, "length": 3}]}, {"id": "27", "infons": {"identifier": "1950", "type": "Gene", "ncbi_homologene": "1483", "valid": true, "normalized": [1950], "database": "ncbi_gene", "normalized_id": 1950, "biotype": "gene", "name": "EGF", "accession": "@GENE_EGF"}, "text": "EGF", "locations": [{"offset": 679, "length": 3}]}, {"id": "28", "infons": {"identifier": "1956", "type": "Gene", "ncbi_homologene": "74545", "valid": true, "normalized": [1956], "database": "ncbi_gene", "normalized_id": 1956, "biotype": "gene", "name": "EGFR", "accession": "@GENE_EGFR"}, "text": "ErbB", "locations": [{"offset": 683, "length": 4}]}, {"id": "29", "infons": {"identifier": "4803", "type": "Gene", "ncbi_homologene": "1876", "valid": true, "normalized": [4803], "database": "ncbi_gene", "normalized_id": 4803, "biotype": "gene", "name": "NGF", "accession": "@GENE_NGF"}, "text": "NGF", "locations": [{"offset": 693, "length": 3}]}, {"id": "30", "infons": {"identifier": "5562", "type": "Gene", "ncbi_homologene": "49590", "valid": true, "normalized": [5562], "database": "ncbi_gene", "normalized_id": 5562, "biotype": "gene", "name": "PRKAA1", "accession": "@GENE_PRKAA1"}, "text": "AMPK", "locations": [{"offset": 832, "length": 4}]}, {"id": "31", "infons": {"identifier": "55004", "type": "Gene", "ncbi_homologene": "9909", "valid": true, "normalized": [55004], "database": "ncbi_gene", "normalized_id": 55004, "biotype": "gene", "name": "LAMTOR1", "accession": "@GENE_LAMTOR1"}, "text": "Lamtor1", "locations": [{"offset": 884, "length": 7}]}, {"id": "32", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "Human", "locations": [{"offset": 941, "length": 5}]}, {"id": "33", "infons": {"identifier": "55004", "type": "Gene", "ncbi_homologene": "9909", "valid": true, "normalized": [55004], "database": "ncbi_gene", "normalized_id": 55004, "biotype": "gene", "name": "LAMTOR1", "accession": "@GENE_LAMTOR1"}, "text": "Lamtor1", "locations": [{"offset": 977, "length": 7}]}, {"id": "34", "infons": {"identifier": "55004", "type": "Gene", "ncbi_homologene": "9909", "valid": true, "normalized": [55004], "database": "ncbi_gene", "normalized_id": 55004, "biotype": "gene", "name": "LAMTOR1", "accession": "@GENE_LAMTOR1"}, "text": "Lamtor1", "locations": [{"offset": 1082, "length": 7}]}, {"id": "35", "infons": {"identifier": "5562", "type": "Gene", "ncbi_homologene": "49590", "valid": true, "normalized": [5562], "database": "ncbi_gene", "normalized_id": 5562, "biotype": "gene", "name": "PRKAA1", "accession": "@GENE_PRKAA1"}, "text": "AMPK", "locations": [{"offset": 1128, "length": 4}]}, {"id": "36", "infons": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "text": "lipid", "locations": [{"offset": 1141, "length": 5}]}, {"id": "37", "infons": {"identifier": "55004", "type": "Gene", "ncbi_homologene": "9909", "valid": true, "normalized": [55004], "database": "ncbi_gene", "normalized_id": 55004, "biotype": "gene", "name": "LAMTOR1", "accession": "@GENE_LAMTOR1"}, "text": "Lamtor1", "locations": [{"offset": 1271, "length": 7}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9986", "role1": {"identifier": "2475", "type": "Gene", "valid": true, "normalized": [2475], "database": "ncbi_gene", "normalized_id": 2475, "biotype": "gene", "name": "MTOR", "accession": "@GENE_MTOR"}, "role2": {"identifier": "55004", "type": "Gene", "valid": true, "normalized": [55004], "database": "ncbi_gene", "normalized_id": 55004, "biotype": "gene", "name": "LAMTOR1", "accession": "@GENE_LAMTOR1"}, "type": "Association"}, "nodes": []}, {"id": "R2", "infons": {"score": "0.9978", "role1": {"identifier": "55004", "type": "Gene", "valid": true, "normalized": [55004], "database": "ncbi_gene", "normalized_id": 55004, "biotype": "gene", "name": "LAMTOR1", "accession": "@GENE_LAMTOR1"}, "role2": {"identifier": "5562", "type": "Gene", "valid": true, "normalized": [5562], "database": "ncbi_gene", "normalized_id": 5562, "biotype": "gene", "name": "PRKAA1", "accession": "@GENE_PRKAA1"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "0", "role": "18,16"}]}, {"id": "R3", "infons": {"score": "0.9993", "role1": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "role2": {"identifier": "55004", "type": "Gene", "valid": true, "normalized": [55004], "database": "ncbi_gene", "normalized_id": 55004, "biotype": "gene", "name": "LAMTOR1", "accession": "@GENE_LAMTOR1"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "17,18"}]}, {"id": "R4", "infons": {"score": "0.7537", "role1": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "role2": {"identifier": "5562", "type": "Gene", "valid": true, "normalized": [5562], "database": "ncbi_gene", "normalized_id": 5562, "biotype": "gene", "name": "PRKAA1", "accession": "@GENE_PRKAA1"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "17,16"}]}], "pmid": 41058014, "pmcid": null, "meta": {}, "date": "2025-10-07T00:00:00Z", "journal": "Adv Sci (Weinh)", "authors": ["Yao Z", "Jiang Z", "Liu X", "Zhang L", "Guo S", "Chen Y", "Luo L", "Ma S", "Wang P", "Shyh-Chang N"], "relations_display": [{"name": "associate|@GENE_MTOR|@GENE_LAMTOR1"}, {"name": "positive_correlate|@GENE_LAMTOR1|@GENE_PRKAA1"}, {"name": "associate|@CHEMICAL_Lipids|@GENE_LAMTOR1"}, {"name": "associate|@CHEMICAL_Lipids|@GENE_PRKAA1"}]}, {"_id": "41074427|None", "id": "41074427", "infons": {}, "passages": [{"infons": {"journal": "Front Biosci (Landmark Ed);2025Sep28; 30 (9) 38730. doi:10.31083/FBL38730", "year": "2025", "type": "title", "authors": "Kuo CJ, Manastireanu DM, Nieto-Torres JL, Kumsta C, "}, "offset": 0, "text": "Transcriptional Dysregulation of Autophagy in Aging and Potential Interventions: Insights Into TFEB and FOXOs.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "7942", "type": "Gene", "ncbi_homologene": "5182", "valid": true, "normalized": [7942], "database": "ncbi_gene", "normalized_id": 7942, "biotype": "gene", "name": "TFEB", "accession": "@GENE_TFEB"}, "text": "TFEB", "locations": [{"offset": 95, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 111, "text": "Autophagy is a highly conserved cellular degradation and recycling process essential for maintaining cellular homeostasis. However, autophagic activity declines with age, contributing to the accumulation of damaged organelles and protein aggregates. The decline in autophagic activity is considered a primary hallmark of aging, as it contributes to cellular dysfunction and the onset of age-associated diseases, including neurodegenerative disorders and metabolic dysfunction. Sustaining autophagy with age requires transcriptional regulation, which may become impaired with age. In this review, we summarize current understanding of transcriptional regulation of autophagy during aging, with a specific focus on transcription factor EB (TFEB) and forkhead box O (FOXO) transcription factors. We integrate mechanistic insights from both mammalian systems and model organisms to highlight how their regulatory activity declines with age through changes in expression, post-translational modifications, nuclear transport, and transcriptional efficiency. We further explore pharmacological and lifestyle interventions aimed at restoring autophagic function to mitigate cellular decline. Given the pivotal role of autophagy in promoting cellular resilience and disease prevention, targeting autophagy-regulating transcription factors holds promise as a therapeutic strategy to counteract age-related functional decline and extend healthspan.", "sentences": [], "annotations": [{"id": "6", "infons": {"identifier": "MESH:D019636", "type": "Disease", "valid": true, "normalized": ["D019636"], "database": "ncbi_mesh", "normalized_id": "D019636", "biotype": "disease", "name": "Neurodegenerative Diseases", "accession": "@DISEASE_Neurodegenerative_Diseases"}, "text": "neurodegenerative disorders", "locations": [{"offset": 533, "length": 27}]}, {"id": "7", "infons": {"identifier": "MESH:D008659", "type": "Disease", "valid": true, "normalized": ["D008659"], "database": "ncbi_mesh", "normalized_id": "D008659", "biotype": "disease", "name": "Metabolic Diseases", "accession": "@DISEASE_Metabolic_Diseases"}, "text": "metabolic dysfunction", "locations": [{"offset": 565, "length": 21}]}, {"id": "8", "infons": {"identifier": "7942", "type": "Gene", "ncbi_homologene": "5182", "valid": true, "normalized": [7942], "database": "ncbi_gene", "normalized_id": 7942, "biotype": "gene", "name": "TFEB", "accession": "@GENE_TFEB"}, "text": "transcription factor EB", "locations": [{"offset": 824, "length": 23}]}, {"id": "9", "infons": {"identifier": "7942", "type": "Gene", "ncbi_homologene": "5182", "valid": true, "normalized": [7942], "database": "ncbi_gene", "normalized_id": 7942, "biotype": "gene", "name": "TFEB", "accession": "@GENE_TFEB"}, "text": "TFEB", "locations": [{"offset": 849, "length": 4}]}], "relations": []}], "relations": [], "pmid": 41074427, "pmcid": null, "meta": {}, "date": "2025-09-28T00:00:00Z", "journal": "Front Biosci (Landmark Ed)", "authors": ["Kuo CJ", "Manastireanu DM", "Nieto-Torres JL", "Kumsta C"], "relations_display": []}, {"_id": "41075017|None", "id": "41075017", "infons": {}, "passages": [{"infons": {"journal": "Aging Clin Exp Res;2025Oct11; 37 (1) 295. doi:10.1007/s40520-025-03199-x", "year": "2025", "article-id_pmc": "PMC12515119", "type": "title", "authors": "Maggi S, Ecarnot F, Gianfredi V, Nucci D, Veronese N, Lei L, Hu M, Avart C, Capurso A, Chen L, Hachem F, Yang H, Logrieco AF, Magli M, Mai Q, Palla F, Predieri S, Rizzoli R, Rogoli D, Santino A, Silano M, Simeoni M, Trichopoulou A, Volpe R, Wang Y, Wu J, Xiaohui M, Chen X, Zhang X, Yujie L, Zanetti M, Picci G, "}, "offset": 0, "text": "Mediterranean diet and Cantonese cuisine for human health: report from a Sino-Italian bilateral meeting.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 45, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 105, "text": "This article explores the traditional Mediterranean and Cantonese diets through historical, cultural, and scientific lenses. Drawing from expert presentations delivered during a multi-day international symposium, we examine the culinary practices, nutritional components, and health implications of both dietary traditions. The comparative analysis addresses cardiovascular and metabolic health, cancer prevention, functional foods, public policy, and the emerging role of traditional foods in modern preventive medicine. By analyzing the synergy between dietary elements and lifestyle factors, we highlight how these long-standing traditions can inform contemporary strategies for health promotion and chronic disease prevention.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 501, "length": 6}]}, {"id": "5", "infons": {"identifier": "MESH:D004194", "type": "Disease", "valid": true, "normalized": ["D004194"], "database": "ncbi_mesh", "normalized_id": "D004194", "biotype": "disease", "name": "Disease", "accession": "@DISEASE_Disease"}, "text": "disease", "locations": [{"offset": 816, "length": 7}]}], "relations": []}], "relations": [], "pmid": 41075017, "pmcid": null, "meta": {}, "date": "2025-10-11T00:00:00Z", "journal": "Aging Clin Exp Res", "authors": ["Maggi S", "Ecarnot F", "Gianfredi V", "Nucci D", "Veronese N", "Lei L", "Hu M", "Avart C", "Capurso A", "Chen L", "Hachem F", "Yang H", "Logrieco AF", "Magli M", "Mai Q", "Palla F", "Predieri S", "Rizzoli R", "Rogoli D", "Santino A", "Silano M", "Simeoni M", "Trichopoulou A", "Volpe R", "Wang Y", "Wu J", "Xiaohui M", "Chen X", "Zhang X", "Yujie L", "Zanetti M", "Picci G"], "relations_display": []}, {"_id": "41085056|None", "id": "41085056", "infons": {}, "passages": [{"infons": {"journal": "Br J Clin Pharmacol;2025Oct14 70311. doi:10.1002/bcp.70311", "year": "2025", "type": "title", "authors": "Lee S, Kim HC, Yoon YR, Jang IJ, Yoo SK, Yu KS, "}, "offset": 0, "text": "Pharmacokinetics, pharmacodynamics and safety of vutiglabridin after multiple oral administrations in healthy female and obese subjects.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "vutiglabridin", "locations": [{"offset": 49, "length": 13}]}, {"id": "3", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obese", "locations": [{"offset": 121, "length": 5}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 137, "text": "AIMS: Vutiglabridin (HSG4112) is a novel drug under clinical development for antiobesity treatment. This study aimed to evaluate the pharmacokinetics (PKs) and safety of vutiglabridin after multiple oral administrations in healthy Korean female and obese subjects and explore short-term pharmacodynamic (PD) responses. METHODS: Two separate randomized, double-blind, placebo-controlled studies were conducted in healthy female and obese subjects. The subjects in each dose group (480 or 720 mg) received vutiglabridin or placebo once daily for 14 days under fed conditions at an 8:2 ratio. Serial blood samples were collected on days 1 and 14 for PK analysis. PD biomarkers related to obesity and inflammation were assessed, and safety and tolerability were evaluated throughout the study. RESULTS: At steady state, obese subjects exhibited a 9%-13% higher maximum concentration (Cmax,ss) and a 17%-19% lower area under the plasma concentration-time curve for a dosing interval at steady state (AUCtau,ss). This profile reflects altered absorption and distribution due to obesity-related physiological changes. After 14 days of treatment, compared with healthy females, obese subjects had greater decreases in baseline-corrected body weights in the 480 mg, 720 mg and placebo groups. Vutiglabridin was safe and well tolerated in both groups. CONCLUSIONS: Vutiglabridin presented higher peak plasma concentrations but lower systemic exposure in obese subjects than in healthy females. Additionally, a modest downward trend in body weight was observed in obese subjects relative to healthy female subjects. These findings support further long-term phase II clinical trials.", "sentences": [], "annotations": [{"id": "19", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Vutiglabridin", "locations": [{"offset": 143, "length": 13}]}, {"id": "20", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "HSG4112", "locations": [{"offset": 158, "length": 7}]}, {"id": "21", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "vutiglabridin", "locations": [{"offset": 307, "length": 13}]}, {"id": "22", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obese", "locations": [{"offset": 386, "length": 5}]}, {"id": "23", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obese", "locations": [{"offset": 568, "length": 5}]}, {"id": "24", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "vutiglabridin", "locations": [{"offset": 641, "length": 13}]}, {"id": "25", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 822, "length": 7}]}, {"id": "26", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 834, "length": 12}]}, {"id": "27", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obese", "locations": [{"offset": 953, "length": 5}]}, {"id": "28", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 1209, "length": 7}]}, {"id": "29", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obese", "locations": [{"offset": 1307, "length": 5}]}, {"id": "30", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Vutiglabridin", "locations": [{"offset": 1421, "length": 13}]}, {"id": "31", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Vutiglabridin", "locations": [{"offset": 1492, "length": 13}]}, {"id": "32", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obese", "locations": [{"offset": 1581, "length": 5}]}, {"id": "33", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obese", "locations": [{"offset": 1690, "length": 5}]}], "relations": []}], "relations": [], "pmid": 41085056, "pmcid": null, "meta": {}, "date": "2025-10-14T00:00:00Z", "journal": "Br J Clin Pharmacol", "authors": ["Lee S", "Kim HC", "Yoon YR", "Jang IJ", "Yoo SK", "Yu KS"], "relations_display": []}, {"_id": "41090781|None", "id": "41090781", "infons": {}, "passages": [{"infons": {"journal": "Cells;2025Oct06; 14 (19) . doi:10.3390/cells14191553", "year": "2025", "article-id_pmc": "PMC12523528", "type": "title", "authors": "Williams A, Wadsworth DD, Geetha T, "}, "offset": 0, "text": "Exercise, Epigenetics, and Body Composition: Molecular Connections.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 68, "text": "Exercise plays a crucial role in promoting overall health by activating molecular pathways that contribute to the prevention and management of chronic diseases, slowing epigenetic aging, improving body composition, and reducing the risk of obesity. In skeletal muscle, these benefits are largely mediated by exercise-induced transcriptional and epigenetic responses. Recent advances in epigenetics have intensified interest in understanding how physical activity influences long-term health and body composition at the molecular level. Epigenetic modifications, which regulate gene expression without altering the DNA sequence, are key mechanisms in this process. Emerging research has provided deeper insights into the processes such as DNA methylation, histone modification, and non-coding RNAs, and their connection to exercise. While numerous studies have demonstrated the influence of exercise on the epigenome, fewer have directly examined how these molecular changes relate to alterations in fat mass, lean body mass, and other components of body composition. This comprehensive review synthesizes the current evidence on the interplay between exercise, epigenetic regulation, and body composition, with a focus on adolescents and adults. We highlight key genes involved in metabolism, fat storage, muscle development, and epigenetic aging, and explore how their regulation may contribute to individual variability in exercise response. Understanding these molecular pathways may provide valuable insights for optimizing exercise interventions aimed at improving health outcomes across the lifespan.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D002908", "type": "Disease", "valid": true, "normalized": ["D002908"], "database": "ncbi_mesh", "normalized_id": "D002908", "biotype": "disease", "name": "Chronic Disease", "accession": "@DISEASE_Chronic_Disease"}, "text": "chronic diseases", "locations": [{"offset": 211, "length": 16}]}, {"id": "3", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 308, "length": 7}]}], "relations": []}], "relations": [], "pmid": 41090781, "pmcid": null, "meta": {}, "date": "2025-10-06T00:00:00Z", "journal": "Cells", "authors": ["Williams A", "Wadsworth DD", "Geetha T"], "relations_display": []}, {"_id": "41100656|None", "id": "41100656", "infons": {}, "passages": [{"infons": {"journal": "Indian J Med Res;2025Aug; 162 (2) 211. doi:10.25259/IJMR_529_2025", "year": "2025", "type": "title", "authors": "Nagaraju M, Kalahasti KK, Suryavanshi U, Reddy SS, Reddy GB, "}, "offset": 0, "text": "Vitamin B12 modulates D-galactose-induced renal dysfunction.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:D014805", "type": "Chemical", "valid": true, "normalized": ["D014805"], "database": "ncbi_mesh", "normalized_id": "D014805", "biotype": "chemical", "name": "Vitamin B 12", "accession": "@CHEMICAL_Vitamin_B_12"}, "text": "Vitamin B12", "locations": [{"offset": 0, "length": 11}]}, {"id": "4", "infons": {"identifier": "MESH:D005690", "type": "Chemical", "valid": true, "normalized": ["D005690"], "database": "ncbi_mesh", "normalized_id": "D005690", "biotype": "chemical", "name": "Galactose", "accession": "@CHEMICAL_Galactose"}, "text": "D-galactose", "locations": [{"offset": 22, "length": 11}]}, {"id": "5", "infons": {"identifier": "MESH:D007674", "type": "Disease", "valid": true, "normalized": ["D007674"], "database": "ncbi_mesh", "normalized_id": "D007674", "biotype": "disease", "name": "Kidney Diseases", "accession": "@DISEASE_Kidney_Diseases"}, "text": "renal dysfunction", "locations": [{"offset": 42, "length": 17}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 61, "text": "Background & objectives Age-related renal impairment presents a significant challenge in contemporary clinical practice. Cellular senescence and oxidative stress are the key contributors to chronic kidney disease (CKD) during aging. Senescence is triggered by advanced glycation end products (AGEs), hyperphosphatemia, and higher glucose levels, which lead to renal dysfunction by inducing inflammation, endoplasmic reticulum (ER) stress, fibrosis, and apoptosis. Further, vitamin B12 is known to influence biological ageing and has been suggested to improve kidney function in the elderly; however, the underlying mechanisms require further investigation. In this study, we investigated the potential of vitamin B12 in mitigating renal dysfunction using a D-galactose-induced aging rat model. Methods Twelve-month-old male Wistar rats were grouped into Control, D-galactose (300 mg/kg/day), and D-galactose + vitamin B12 supplementation groups (n=6). Renal dysfunction was evaluated by kidney function markers (creatinine, albumin, urea, and BUN), renal damage markers (kidney injury molecule-1 [KIM-1], lipocalin-2 [LCN-2], fatty-acid binding protein-1 [FABP-1], and tissue inhibitor of metalloproteinase-1 [TIMP-1]), and histopathology (glomerular changes). Signalling mechanisms of cellular senescence, phosphate metabolism, inflammation, fibrosis, and renal apoptosis were analysed by qRT-PCR and immunoblotting. Results Vitamin B12 supplementation attenuated renal dysfunction by alleviating the senescence-induced accumulation of AGEs and hyperphosphatemia. Furthermore, vitamin B12 administration conferred renal protection by subsiding inflammation, fibrosis, and apoptosis through modulation of the RAGE-NFkB, pPERK-GSK3beta, and JNK signalling pathways. Vitamin B12 supplementation mitigated hyperphosphatemia by mediating the Klotho-FGF23 axis. Interpretation & conclusions The findings provide evidence for vitamin B12 supplementation in managing renal aging.", "sentences": [], "annotations": [{"id": "58", "infons": {"identifier": "MESH:D007674", "type": "Disease", "valid": true, "normalized": ["D007674"], "database": "ncbi_mesh", "normalized_id": "D007674", "biotype": "disease", "name": "Kidney Diseases", "accession": "@DISEASE_Kidney_Diseases"}, "text": "renal impairment", "locations": [{"offset": 97, "length": 16}]}, {"id": "59", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "chronic kidney disease", "locations": [{"offset": 251, "length": 22}]}, {"id": "60", "infons": {"identifier": "MESH:D051436", "type": "Disease", "valid": true, "normalized": ["D051436"], "database": "ncbi_mesh", "normalized_id": "D051436", "biotype": "disease", "name": "Renal Insufficiency Chronic", "accession": "@DISEASE_Renal_Insufficiency_Chronic"}, "text": "CKD", "locations": [{"offset": 275, "length": 3}]}, {"id": "61", "infons": {"identifier": "MESH:D017127", "type": "Chemical", "valid": true, "normalized": ["D017127"], "database": "ncbi_mesh", "normalized_id": "D017127", "biotype": "chemical", "name": "Glycation End Products Advanced", "accession": "@CHEMICAL_Glycation_End_Products_Advanced"}, "text": "advanced glycation end products", "locations": [{"offset": 321, "length": 31}]}, {"id": "62", "infons": {"identifier": "MESH:D017127", "type": "Chemical", "valid": true, "normalized": ["D017127"], "database": "ncbi_mesh", "normalized_id": "D017127", "biotype": "chemical", "name": "Glycation End Products Advanced", "accession": "@CHEMICAL_Glycation_End_Products_Advanced"}, "text": "AGEs", "locations": [{"offset": 354, "length": 4}]}, {"id": "63", "infons": {"identifier": "MESH:D054559", "type": "Disease", "valid": true, "normalized": ["D054559"], "database": "ncbi_mesh", "normalized_id": "D054559", "biotype": "disease", "name": "Hyperphosphatemia", "accession": "@DISEASE_Hyperphosphatemia"}, "text": "hyperphosphatemia", "locations": [{"offse