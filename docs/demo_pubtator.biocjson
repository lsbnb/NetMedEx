bi_gene", "normalized_id": 2099, "biotype": "gene", "name": "ESR1", "accession": "@GENE_ESR1"}, "type": "Association"}, "nodes": [{"refid": "7", "role": "18,17"}]}, {"id": "R9", "infons": {"score": "0.9988", "role1": {"identifier": "MESH:D010024", "type": "Disease", "valid": true, "normalized": ["D010024"], "database": "ncbi_mesh", "normalized_id": "D010024", "biotype": "disease", "name": "Osteoporosis", "accession": "@DISEASE_Osteoporosis"}, "role2": {"identifier": "2064", "type": "Gene", "valid": true, "normalized": [2064], "database": "ncbi_gene", "normalized_id": 2064, "biotype": "gene", "name": "ERBB2", "accession": "@GENE_ERBB2"}, "type": "Association"}, "nodes": [{"refid": "8", "role": "18,15"}]}, {"id": "R10", "infons": {"score": "0.999", "role1": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "role2": {"identifier": "558", "type": "Gene", "valid": true, "normalized": [558], "database": "ncbi_gene", "normalized_id": 558, "biotype": "gene", "name": "AXL", "accession": "@GENE_AXL"}, "type": "Association"}, "nodes": [{"refid": "9", "role": "19,13"}]}], "pmid": 40660573, "pmcid": null, "meta": {}, "date": "2025-07-11T00:00:00Z", "journal": "Medicine (Baltimore)", "authors": ["Chen Z", "Lin J", "Wang Z"], "relations_display": [{"name": "associate|@DISEASE_Sarcopenia|@GENE_ERBB2"}, {"name": "associate|@DISEASE_Osteoporosis|@GENE_AXL"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_GAB1"}, {"name": "associate|@DISEASE_Osteoporosis|@GENE_GAB1"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_NRP2"}, {"name": "associate|@DISEASE_Osteoporosis|@GENE_NRP2"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_ESR1"}, {"name": "associate|@DISEASE_Osteoporosis|@GENE_ESR1"}, {"name": "associate|@DISEASE_Osteoporosis|@GENE_ERBB2"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_AXL"}]}, {"_id": "40663393|None", "id": "40663393", "infons": {}, "passages": [{"infons": {"journal": "JCI Insight;2025Jul15. doi:10.1172/jci.insight.192047", "year": "2025", "type": "title", "authors": "Yu K, Vyavahare S, Alhamad DW, Bensreti H, Ruan L, Tuladhar A, Dai C, Shaver JC, Tripathi A, Ding K, Pacholczyk R, Cooley MA, Zhong R, Johnson MH, Chen J, Bollag WB, Isales CM, Hill WD, Hamrick MW, Fulzele S, McGee-Lawrence ME, "}, "offset": 0, "text": "Inhibition of AhR improves cortical bone and skeletal muscle function via preservation of neuromuscular junctions.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "11622", "type": "Gene", "ncbi_homologene": "1224", "valid": true, "normalized": [11622], "database": "ncbi_gene", "normalized_id": 11622, "biotype": "gene", "name": "Ahr", "accession": "@GENE_AHR"}, "text": "AhR", "locations": [{"offset": 14, "length": 3}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 115, "text": "The aryl hydrocarbon receptor (AhR) is proposed to mediate the frailty-promoting effects of the tryptophan metabolite kynurenine (Kyn), which increases with age in mice and humans. The goal of the current study was to test whether administration of pharmacological AhR inhibitors, BAY2416964 and CH-223191, could abrogate musculoskeletal decline in aging mice. Female C57BL/6 mice (18 months old) were treated with vehicle (VEH) or BAY2416964 (30 mg/kg) via daily oral gavage 5 days/week for 8 weeks. A second AhR antagonist, CH-223191, was administered to 16-month-old male and female C57BL/6 mice via intraperitoneal injections (3.3 mg/kg) 3 days/week for 12 weeks. While grip strength declined over time in VEH-treated mice, BAY2416964 preserved grip strength in part by improving integrity of neuromuscular junctions, an effect replicated during in vitro studies with siRNA against AhR. Cortical bone mass was also greater in BAY2416964- than VEH-treated mice. Similarly, CH-223191 treatment improved cortical bone and showed beneficial effects in skeletal muscle, including reducing oxidative stress as compared to VEH-treated animals. Transcriptomic and proteomic data from BAY2416964-treated mice supported a positive impact of BAY2416964 on molecular targets that affect neuromuscular junction function. Taken together, these data support AhR as a therapeutic target for improving musculoskeletal health during aging.", "sentences": [], "annotations": [{"id": "29", "infons": {"identifier": "11622", "type": "Gene", "ncbi_homologene": "1224", "valid": true, "normalized": [11622], "database": "ncbi_gene", "normalized_id": 11622, "biotype": "gene", "name": "Ahr", "accession": "@GENE_AHR"}, "text": "aryl hydrocarbon receptor", "locations": [{"offset": 119, "length": 25}]}, {"id": "30", "infons": {"identifier": "11622", "type": "Gene", "ncbi_homologene": "1224", "valid": true, "normalized": [11622], "database": "ncbi_gene", "normalized_id": 11622, "biotype": "gene", "name": "Ahr", "accession": "@GENE_AHR"}, "text": "AhR", "locations": [{"offset": 146, "length": 3}]}, {"id": "31", "infons": {"identifier": "MESH:D014364", "type": "Chemical", "valid": true, "normalized": ["D014364"], "database": "ncbi_mesh", "normalized_id": "D014364", "biotype": "chemical", "name": "Tryptophan", "accession": "@CHEMICAL_Tryptophan"}, "text": "tryptophan", "locations": [{"offset": 211, "length": 10}]}, {"id": "32", "infons": {"identifier": "MESH:D007737", "type": "Chemical", "valid": true, "normalized": ["D007737"], "database": "ncbi_mesh", "normalized_id": "D007737", "biotype": "chemical", "name": "Kynurenine", "accession": "@CHEMICAL_Kynurenine"}, "text": "kynurenine", "locations": [{"offset": 233, "length": 10}]}, {"id": "33", "infons": {"identifier": "MESH:D007737", "type": "Chemical", "valid": true, "normalized": ["D007737"], "database": "ncbi_mesh", "normalized_id": "D007737", "biotype": "chemical", "name": "Kynurenine", "accession": "@CHEMICAL_Kynurenine"}, "text": "Kyn", "locations": [{"offset": 245, "length": 3}]}, {"id": "34", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 279, "length": 4}]}, {"id": "35", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "humans", "locations": [{"offset": 288, "length": 6}]}, {"id": "36", "infons": {"identifier": "11622", "type": "Gene", "ncbi_homologene": "1224", "valid": true, "normalized": [11622], "database": "ncbi_gene", "normalized_id": 11622, "biotype": "gene", "name": "Ahr", "accession": "@GENE_AHR"}, "text": "AhR", "locations": [{"offset": 380, "length": 3}]}, {"id": "37", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "BAY2416964", "locations": [{"offset": 396, "length": 10}]}, {"id": "38", "infons": {"identifier": "MESH:C511621", "type": "Chemical", "valid": true, "normalized": ["C511621"], "database": "ncbi_mesh", "normalized_id": "C511621", "biotype": "chemical", "name": "2-methyl-2H-pyrazole-3-carboxylic acid (2-methyl-4-o-tolylazophenyl)amide", "accession": "@CHEMICAL_2_methyl_2H_pyrazole_3_carboxylic_acid_(2_methyl_4_o_tolylazophenyl)amide"}, "text": "CH-223191", "locations": [{"offset": 411, "length": 9}]}, {"id": "39", "infons": {"identifier": "MESH:D009140", "type": "Disease", "valid": true, "normalized": ["D009140"], "database": "ncbi_mesh", "normalized_id": "D009140", "biotype": "disease", "name": "Musculoskeletal Diseases", "accession": "@DISEASE_Musculoskeletal_Diseases"}, "text": "musculoskeletal decline", "locations": [{"offset": 437, "length": 23}]}, {"id": "40", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "