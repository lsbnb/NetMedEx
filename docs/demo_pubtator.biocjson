EMICAL_Vitamin_K_1"}, "type": "Association"}, "nodes": [{"refid": "7", "role": "10,9"}]}, {"id": "R9", "infons": {"score": "0.9988", "role1": {"identifier": "MESH:D001778", "type": "Disease", "valid": true, "normalized": ["D001778"], "database": "ncbi_mesh", "normalized_id": "D001778", "biotype": "disease", "name": "Blood Coagulation Disorders", "accession": "@DISEASE_Blood_Coagulation_Disorders"}, "role2": {"identifier": "5627", "type": "Gene", "valid": true, "normalized": [5627], "database": "ncbi_gene", "normalized_id": 5627, "biotype": "gene", "name": "PROS1", "accession": "@GENE_PROS1"}, "type": "Association"}, "nodes": [{"refid": "8", "role": "18,25"}]}, {"id": "R10", "infons": {"score": "0.9873", "role1": {"identifier": "MESH:D014812", "type": "Chemical", "valid": true, "normalized": ["D014812"], "database": "ncbi_mesh", "normalized_id": "D014812", "biotype": "chemical", "name": "Vitamin K", "accession": "@CHEMICAL_Vitamin_K"}, "role2": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "type": "Association"}, "nodes": [{"refid": "9", "role": "32,29"}]}], "pmid": 40535915, "pmcid": null, "meta": {}, "date": "2025-06-17T00:00:00Z", "journal": "Food Sci Nutr", "authors": ["Dupuy M", "Bondonno NP", "Pokharel P", "Linneberg A", "Levinger I", "Schultz C", "Hodgson JM", "Sim M"], "relations_display": [{"name": "associate|@CHEMICAL_Vitamin_K|@DISEASE_Inflammation"}, {"name": "associate|@CHEMICAL_Calcium|@CHEMICAL_Vitamin_K"}, {"name": "associate|@CHEMICAL_Vitamin_K|@DISEASE_Neoplasms"}, {"name": "associate|@CHEMICAL_Vitamin_K|@DISEASE_Cardiovascular_Diseases"}, {"name": "associate|@CHEMICAL_Vitamin_K|@DISEASE_Blood_Coagulation_Disorders"}, {"name": "associate|@CHEMICAL_Vitamin_K|@GENE_PROS1"}, {"name": "associate|@DISEASE_Inflammation|@GENE_PROS1"}, {"name": "associate|@CHEMICAL_Oils|@CHEMICAL_Vitamin_K_1"}, {"name": "associate|@DISEASE_Blood_Coagulation_Disorders|@GENE_PROS1"}, {"name": "associate|@CHEMICAL_Vitamin_K|@DISEASE_Diabetes_Mellitus_Type_2"}]}, {"_id": "40542935|None", "id": "40542935", "infons": {}, "passages": [{"infons": {"journal": "Curr Urol Rep;2025Jun21; 26 (1) 50. doi:10.1007/s11934-025-01272-6", "year": "2025", "article-id_pmc": "PMC12182509", "type": "title", "authors": "Troy SP, Jakubowski CD, Gartrell BA, "}, "offset": 0, "text": "Packing the Punch: Current and Emerging Treatment Strategies in Metastatic Castration-Sensitive Prostate Cancer.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D064129", "type": "Disease", "valid": true, "normalized": ["D064129"], "database": "ncbi_mesh", "normalized_id": "D064129", "biotype": "disease", "name": "Prostatic Neoplasms Castration-Resistant", "accession": "@DISEASE_Prostatic_Neoplasms_Castration_Resistant"}, "text": "Metastatic Castration", "locations": [{"offset": 64, "length": 21}]}, {"id": "3", "infons": {"identifier": "MESH:D011471", "type": "Disease", "valid": true, "normalized": ["D011471"], "database": "ncbi_mesh", "normalized_id": "D011471", "biotype": "disease", "name": "Prostatic Neoplasms", "accession": "@DISEASE_Prostatic_Neoplasms"}, "text": "Prostate Cancer", "locations": [{"offset": 96, "length": 15}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 113, "text": "PURPOSE OF REVIEW: Prostate cancer remains a significant source of morbidity and mortality worldwide, with metastatic castration-sensitive disease (mCSPC) representing a complex therapeutic challenge. This review explores how a deeper understanding of the androgen receptor axis has shifted mCSPC management from monotherapy to more intense treatment. We discuss emerging data on triplet regimens, targeted therapies, and the role of local treatment. RECENT FINDINGS: Randomized trials have shown that adding docetaxel or androgen receptor signaling inhibitors (ARSIs) to androgen deprivation therapy (ADT) improves survival. Triplet therapy (ADT, docetaxel, and an ARSI) improves outcomes in patients with high-volume disease compared to ADT and docetaxel alone, although comparisons to ADT plus ARSI doublet therapy are ongoing. The early use of targeted radionuclides, biomarker-driven therapies, and metastasis-directed radiotherapy has also emerged, potentially refining treatment personalization in clinical practice. SUMMARY: Current guidelines recommend ADT combined with an ARSI, with the addition of docetaxel reserved for high-volume disease. Future research aims to optimize intensity, inform biomarker-driven strategies, and reduce toxicity. Advancements in management of mCSPC underscore the importance of a multimodal, personalized approach to improve outcomes. SUPPLEMENTARY INFORMATION: The online version contains supplementary material available at 10.1007/s11934-025-01272-6.", "sentences": [], "annotations": [{"id": "22", "infons": {"identifier": "MESH:D011471", "type": "Disease", "valid": true, "normalized": ["D011471"], "database": "ncbi_mesh", "normalized_id": "D011471", "biotype": "disease", "name": "Prostatic Neoplasms", "accession": "@DISEASE_Prostatic_Neoplasms"}, "text": "Prostate cancer", "locations": [{"offset": 132, "length": 15}]}, {"id": "23", "infons": {"identifier": "MESH:D064129", "type": "Disease", "valid": true, "normalized": ["D064129"], "database": "ncbi_mesh", "normalized_id": "D064129", "biotype": "disease", "name": "Prostatic Neoplasms Castration-Resistant", "accession": "@DISEASE_Prostatic_Neoplasms_Castration_Resistant"}, "text": "metastatic castration", "locations": [{"offset": 220, "length": 21}]}, {"id": "24", "infons": {"identifier": "MESH:D004194", "type": "Disease", "valid": true, "normalized": ["D004194"], "database": "ncbi_mesh", "normalized_id": "D004194", "biotype": "disease", "name": "Disease", "accession": "@DISEASE_Disease"}, "text": "sensitive disease", "locations": [{"offset": 242, "length": 17}]}, {"id": "25", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "mCSPC", "locations": [{"offset": 261, "length": 5}]}, {"id": "26", "infons": {"identifier": "367", "type": "Gene", "ncbi_homologene": "28", "valid": true, "normalized": [367], "database": "ncbi_gene", "normalized_id": 367, "biotype": "gene", "name": "AR", "accession": "@GENE_AR"}, "text": "androgen receptor", "locations": [{"offset": 369, "length": 17}]}, {"id": "27", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "mCSPC", "locations": [{"offset": 404, "length": 5}]}, {"id": "28", "infons": {"identifier": "MESH:D000077143", "type": "Chemical", "valid": true, "normalized": ["D000077143"], "database": "ncbi_mesh", "normalized_id": "D000077143", "biotype": "chemical", "name": "Docetaxel", "accession": "@CHEMICAL_Docetaxel"}, "text": "docetaxel", "locations": [{"offset": 622, "length": 9}]}, {"id": "29", "infons": {"identifier": "367", "type": "Gene", "ncbi_homologene": "28", "valid": true, "normalized": [367], "database": "ncbi_gene", "normalized_id": 367, "biotype": "gene", "name": "AR", "accession": "@GENE_AR"}, "text": "androgen receptor", "locations": [{"offset": 635, "length": 17}]}, {"id": "30", "infons": {"identifier": "MESH:D000077143", "type": "Chemical", "valid": true, "normalized": ["D000077143"], "database": "ncbi_mesh", "normalized_id": "D000077143", "biotype": "chemical", "name": "Docetaxel", "accession": "@CHEMICAL_Docetaxel"}, "text": "docetaxel", "locations": [{"offset": 761, "length": 9}]}, {"id": "31", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "ARSI", "locations": [{"offset": 779, "length": 4}]}, {"id": "32", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "960