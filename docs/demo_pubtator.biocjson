"id": "75", "infons": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "text": "diabetes", "locations": [{"offset": 2214, "length": 8}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.9962", "role1": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "role2": {"identifier": "16847", "type": "Gene", "valid": true, "normalized": [16847], "database": "ncbi_gene", "normalized_id": 16847, "biotype": "gene", "name": "Lepr", "accession": "@GENE_LEPR"}, "type": "Association"}, "nodes": [{"refid": "0", "role": "11,9"}]}], "pmid": 40636148, "pmcid": null, "meta": {}, "date": "2025-06-25T00:00:00Z", "journal": "Front Physiol", "authors": ["Yang J", "Wang Y", "Xu Y", "Jia X", "Lu F"], "relations_display": [{"name": "associate|@DISEASE_Diabetes_Mellitus_Type_2|@GENE_LEPR"}]}, {"_id": "40637132|None", "id": "40637132", "infons": {}, "passages": [{"infons": {"journal": "Br J Nutr;2025Jul10 1. doi:10.1017/S0007114525103875", "year": "2025", "type": "title", "authors": "Mao H, Lu G, Zheng L, Zhuang M, Liang L, Zhou S, Li J, Sun X, Liu Y, Ma M, Hu J, Yu J, Zhu L, "}, "offset": 0, "text": "The Research Progress and Potential Applications of Omega-3 Fatty Acids in Orthopedics: A Narrative Review.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D015525", "type": "Chemical", "valid": true, "normalized": ["D015525"], "database": "ncbi_mesh", "normalized_id": "D015525", "biotype": "chemical", "name": "Fatty Acids Omega-3", "accession": "@CHEMICAL_Fatty_Acids_Omega_3"}, "text": "Omega-3 Fatty Acids", "locations": [{"offset": 52, "length": 19}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 108, "text": "Omega-3 Polyunsaturated Fatty Acids (n-3 PUFAs), including alpha-linolenic acid (ALA), eicosapentaenoic acid (EPA), and docosahexaenoic acid (DHA), are widely found in plant oils and marine organisms. These fatty acids demonstrate significant biological effects, and their adequate intake is essential for maintaining health. However, modern diets often lack sufficient n-3 PUFAs, especially among populations that consume little fish or seafood,leading to a growing interest in n-3 PUFAs supplementation in nutrition and health research. In recent decades, the role of n-3 PUFAs in preventing and treating various diseases has gained increasing attention, particularly in cardiovascular, neurological, ophthalmic, allergic, hepatic, and oncological fields.In orthopedics, n-3 PUFAs exert beneficial effects through several mechanisms, including modulation of inflammatory responses, enhancement of cartilage repair, and regulation of bone metabolism. These effects demonstrate potential for the treatment of conditions such as osteoarthritis (OA), rheumatoid arthritis (RA), gout, osteoporosis (OP), fractures, sarcopenia, and spinal degenerative diseases (SDD). This review summarizes the clinical applications of n-3 PUFAs, with a focus on their research progress in the field of orthopedics, and explores their potential in the treatment of orthopedic diseases.", "sentences": [], "annotations": [{"id": "30", "infons": {"identifier": "MESH:D015525", "type": "Chemical", "valid": true, "normalized": ["D015525"], "database": "ncbi_mesh", "normalized_id": "D015525", "biotype": "chemical", "name": "Fatty Acids Omega-3", "accession": "@CHEMICAL_Fatty_Acids_Omega_3"}, "text": "Omega-3 Polyunsaturated Fatty Acids", "locations": [{"offset": 108, "length": 35}]}, {"id": "31", "infons": {"identifier": "MESH:D015525", "type": "Chemical", "valid": true, "normalized": ["D015525"], "database": "ncbi_mesh", "normalized_id": "D015525", "biotype": "chemical", "name": "Fatty Acids Omega-3", "accession": "@CHEMICAL_Fatty_Acids_Omega_3"}, "text": "n-3 PUFAs", "locations": [{"offset": 145, "length": 9}]}, {"id": "32", "infons": {"identifier": "MESH:D017962", "type": "Chemical", "valid": true, "normalized": ["D017962"], "database": "ncbi_mesh", "normalized_id": "D017962", "biotype": "chemical", "name": "alpha-Linolenic Acid", "accession": "@CHEMICAL_alpha_Linolenic_Acid"}, "text": "alpha-linolenic acid", "locations": [{"offset": 167, "length": 20}]}, {"id": "33", "infons": {"identifier": "MESH:D017962", "type": "Chemical", "valid": true, "normalized": ["D017962"], "database": "ncbi_mesh", "normalized_id": "D017962", "biotype": "chemical", "name": "alpha-Linolenic Acid", "accession": "@CHEMICAL_alpha_Linolenic_Acid"}, "text": "ALA", "locations": [{"offset": 189, "length": 3}]}, {"id": "34", "infons": {"identifier": "MESH:D015118", "type": "Chemical", "valid": true, "normalized": ["D015118"], "database": "ncbi_mesh", "normalized_id": "D015118", "biotype": "chemical", "name": "Eicosapentaenoic Acid", "accession": "@CHEMICAL_Eicosapentaenoic_Acid"}, "text": "eicosapentaenoic acid", "locations": [{"offset": 195, "length": 21}]}, {"id": "35", "infons": {"identifier": "MESH:D015118", "type": "Chemical", "valid": true, "normalized": ["D015118"], "database": "ncbi_mesh", "normalized_id": "D015118", "biotype": "chemical", "name": "Eicosapentaenoic Acid", "accession": "@CHEMICAL_Eicosapentaenoic_Acid"}, "text": "EPA", "locations": [{"offset": 218, "length": 3}]}, {"id": "36", "infons": {"identifier": "MESH:D004281", "type": "Chemical", "valid": true, "normalized": ["D004281"], "database": "ncbi_mesh", "normalized_id": "D004281", "biotype": "chemical", "name": "Docosahexaenoic Acids", "accession": "@CHEMICAL_Docosahexaenoic_Acids"}, "text": "docosahexaenoic acid", "locations": [{"offset": 228, "length": 20}]}, {"id": "37", "infons": {"identifier": "MESH:D004281", "type": "Chemical", "valid": true, "normalized"