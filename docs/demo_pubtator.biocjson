e": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 1941, "length": 6}]}], "relations": []}], "relations": [], "pmid": 41915085, "pmcid": null, "meta": {}, "date": "2026-03-31T00:00:00Z", "journal": "Mol Biomed", "authors": ["Liang J", "Zang S", "Wang Z", "Zhang R"], "relations_display": []}, {"_id": "41923173|None", "id": "41923173", "infons": {}, "passages": [{"infons": {"journal": "J Cachexia Sarcopenia Muscle;2026Apr; 17 (2) 70277. doi:10.1002/jcsm.70277", "year": "2026", "type": "title", "authors": "Yoon HJ, Han WH, Kim SB, Lee WG, Choi SY, Choi BJ, Pang M, Choi MK, Lee J, Song IS, Park MH, Jin HK, Bae JS, "}, "offset": 0, "text": "KARIs, Ghrelin Receptor Agonists With Excellent Brain Permeability, Increase Food Intake and Attenuate the Muscle Loss in Mice.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "KARIs", "locations": [{"offset": 0, "length": 5}]}, {"id": "5", "infons": {"identifier": "208188", "type": "Gene", "ncbi_homologene": "57161", "valid": true, "normalized": [208188], "database": "ncbi_gene", "normalized_id": 208188, "biotype": "gene", "name": "Ghsr", "accession": "@GENE_GHSR"}, "text": "Ghrelin Receptor", "locations": [{"offset": 7, "length": 16}]}, {"id": "6", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "Muscle Loss", "locations": [{"offset": 107, "length": 11}]}, {"id": "7", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "Mice", "locations": [{"offset": 122, "length": 4}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 128, "text": "BACKGROUND: Ghrelin regulates appetite, gastrointestinal motility and growth hormone (GH) secretion through activation of the growth hormone secretagogue receptor (GHSR-1a) in hypothalamic neurons, with downstream effects on adipose tissue and skeletal muscle. Although ghrelin and synthetic GHSR-1a agonists have been investigated for the treatment of anorexia, sarcopenia and cancer cachexia, their clinical utility has been limited by unfavourable pharmacokinetics. We recently discovered a novel class of small-molecule compounds, termed KARIs, which act as potent GHSR-1a agonists with excellent brain permeability. Here, we evaluated their efficacy as GHSR-1a agonists in vitro and in vivo. METHOD: GHSR-1a agonistic effects of KARIs were assessed using calcium influx and competitive binding assays in human GHSR-1a-expressing cells, and molecular docking simulations were conducted. Pharmacokinetic properties of KARIs (1 mg/kg i.v, 10 mg/kg p.o) were compared with anamorelin (3 mg/kg i.v., 30 mg/kg p.o.). In vivo efficacy was evaluated in mouse models of postoperative ileus (POI; 10, 20 or 30 mg/kg), age-related sarcopenia (10 mg/kg/day for 4 weeks) and cancer cachexia (10 or 30 mg/kg/day from Days 9 to 24 after CT26 tumour induction). RESULTS: KARIs directly interacted with key GHSR-1a residues (Phe279) and increased calcium influx (EC50: KARI 101 = 1.83 +- 1.05 muM; KARI 201 = 3.36 +- 1.09 muM). KARIs showed higher oral bioavailability (BA: KARI 101 = 63%; KARI 201 = 68%) and brain distribution (KARI 101 = 2.2; KARI 201 = 3.7) than anamorelin (BA = 45%, brain distribution = 0.1). KARIs significantly activated hypothalamic neurons (KARI 101 p = 0.029, KARI 201 p = 0.0152), resulting in increased food intake and improved gastric emptying and colonic transit in POI mice. In aged mice, KARIs markedly elevated plasma GH levels and restored gastrocnemius muscle mass (KARI 101 p = 0.0018, KARI 201 p = 0.0006) and improved rota-rod performance (p < 0.0001) by downregulating expression of atrophic genes and upregulating myogenic genes. In cancer cachexia mice, KARIs improved food intake and preserved skeletal muscle mass at lower doses (gastrocnemius, 10 mg/kg; p < 0.0001) than synthetic GHSR - 1a agonist (anamorelin, 30 mg/kg) and enhanced functional recovery (rota-rod test, 10 mg/kg; KARI 101 p = 0.045, KARI 201 p = 0.003) without affecting tumour growth. CONCLUSIONS: KARIs are potent, brain-penetrant GHSR-1a agonists with favourable pharmacokinetics compared to anamorelin. They enhance appetite, preserve skeletal muscle mass and improve physical performance in models of aging and cancer cachexia, supporting their potential as next-generation therapies for anorexia and muscle wasting.", "sentences": [], "annotations": [{"id": "70", "infons": {"identifier": "58991", "type": "Gene", "ncbi_homologene": "9487", "valid": true, "normalized": [58991], "database": "ncbi_gene", "normalized_id": 58991, "biotype": "gene", "name": "Ghrl", "accession": "@GENE_GHRL"}, "text": "Ghrelin", "locations": [{"offset": 140, "length": 7}]}, {"id": "71", "infons": {"identifier": "14599", "type": "Gene", "ncbi_homologene": "47932", "valid": true, "normalized": [14599], "database": "ncbi_gene", "normalized_id": 14599, "biotype": "gene", "name": "Gh", "accession": "@GENE_GH"}, "text": "growth hormone", "locations": [{"offset": 198, "length": 14}]}, {"id": "72", "infons": {"identifier": "14599", "type": "Gene", "ncbi_homologene": "47932", "valid": true, "normalized": [14599], "database": "ncbi_gene", "normalized_id": 14599, "biotype": "gene", "name": "Gh", "accession": "@GENE_GH"}, "text": "GH", "locations": [{"offset": 214, "length": 2}]}, {"id": "73", "infons": {"identifier": "208188", "type": "Gene", "ncbi_homologene": "57161", "valid": true, "normalized": [208188], "database": "ncbi_gene", "normalized_id": 208188, "biotype": "gene", "name": "Ghsr", "accession": "@GENE_GHSR"}, "text": "growth hormone secretagogue receptor", "locations": [{"offset": 254, "length": 36}]}, {"id": "74", "infons": {"identifier": "208188", "type": "Gene", "ncbi_homologene": "57161", "valid": true, "normalized": [208188], "database": "ncbi_gene", "normalized_id": 208188, "biotype": "gene", "name": "Ghsr", "accession": "@GENE_GHSR"}, "text": "GHSR-1a", "locations": [{"offset": 292, "length": 7}]}, {"id": "75", "infons": {"identifier": "58991", "type": "Gene", "ncbi_homologene": "9487", "valid": true, "normalized": [58991], "database": "ncbi_gene", "normalized_id": 58991, "biotype": "gene", "name": "Ghrl", "accession": "@GENE_GHRL"}, "text": "ghrelin", "locations": [{"offset": 398, "length": 7}]}, {"id": "76", "infons": {"identifier": "208188", "type": "Gene", "ncbi_homologene": "57161", "valid": true, "normalized": [208188], "database": "ncbi_gene", "normalized_id": 208188, "biotype": "gene", "name": "Ghsr", "accession": "@GENE_GHSR"}, "text": "GHSR-1a", "locations": [{"offset": 420, "length": 7}]}, {"id": "77", "infons": {"identifier": "MESH:D000855", "type": "Disease", "valid": true, "normalized": ["D000855"], "database": "ncbi_mesh", "normalized_id": "D000855", "biotype": "disease", "name": "Anorexia", "accession": "@DISEASE_Anorexia"}, "text": "anorexia", "locations": [{"offset": 481, "length": 8}]}, {"id": "78", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 491, "length": 10}]}, {"id": "79", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer cachexia", "locations": [{"offset": 506, "length": 15}]}, {"id": 