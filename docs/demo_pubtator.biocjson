d": true, "normalized": ["D005207"], "database": "ncbi_mesh", "normalized_id": "D005207", "biotype": "disease", "name": "Fasciculation", "accession": "@DISEASE_Fasciculation"}, "text": "skeletal muscle diseases", "locations": [{"offset": 1418, "length": 24}]}, {"id": "43", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 1481, "length": 10}]}], "relations": []}], "relations": [], "pmid": 40987776, "pmcid": null, "meta": {}, "date": "2025-09-23T00:00:00Z", "journal": "Bone Res", "authors": ["Mao X", "Lv K", "Qi W", "Cheng W", "Li T", "Sun Y", "Jin H", "Pan H", "Wang D"], "relations_display": []}, {"_id": "40995852|None", "id": "40995852", "infons": {}, "passages": [{"infons": {"journal": "Aging Cell;2025Sep25 70238. doi:10.1111/acel.70238", "year": "2025", "type": "title", "authors": "Yuan Y, Dyer C, Knight RD, "}, "offset": 0, "text": "Muscle Regeneration Can Be Rescued in a Telomerase Deficient Zebrafish Model of Ageing by MMP Inhibition.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "7955", "type": "Species", "valid": true, "normalized": [7955], "database": "ncbi_taxonomy", "normalized_id": 7955, "biotype": "species", "name": "7955", "accession": null}, "text": "Zebrafish", "locations": [{"offset": 61, "length": 9}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 106, "text": "Ageing progressively impairs skeletal muscle regeneration, contributing to reduced mobility and quality of life. While the molecular changes underlying muscle ageing have been well characterised, their impact on muscle stem cell (muSC) behaviour during regeneration remains poorly understood. Here, we leverage telomerase-deficient tert mutant zebrafish larvae as an in vivo model of accelerated ageing to perform real-time analysis of muSC dynamics following muscle injury. We demonstrate that the ageing-like inflammatory environment in tert mutant disrupts muSC migration, impairs activation and proliferation, and compromises regenerative capacity. We further show that sustained inflammation, mediated by persistent macrophage presence and elevated matrix metalloproteinase (MMP) activity, limits muSC recruitment and migration efficiency. Pharmacological inhibition of MMP9/13 activity and genetic depletion of macrophages partially restore muSC migratory behaviour and regenerative outcomes. Notably, we demonstrate that muSC migration dynamics correlate with regenerative success, providing a functional readout for therapeutic screening. Our findings reveal zebrafish tert mutants offer a tractable system for dissecting age-associated changes to cell behaviour and for identifying rejuvenation interventions.", "sentences": [], "annotations": [{"id": "10", "infons": {"identifier": "796551", "type": "Gene", "ncbi_homologene": "31141", "valid": true, "normalized": [796551], "database": "ncbi_gene", "normalized_id": 796551, "biotype": "gene", "name": "tert", "accession": "@GENE_TERT"}, "text": "tert", "locations": [{"offset": 438, "length": 4}]}, {"id": "11", "infons": {"identifier": "7955", "type": "Species", "valid": true, "normalized": [7955], "database": "ncbi_taxonomy", "normalized_id": 7955, "biotype": "species", "name": "7955", "accession": null}, "text": "zebrafish", "locations": [{"offset": 450, "length": 9}]}, {"id": "12", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle injury", "locations": [{"offset": 566, "length": 13}]}, {"id": "13", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 617, "length": 12}]}, {"id": "14", "infons": {"identifier": "796551", "type": "Gene", "ncbi_homologene": "31141", "valid": true, "normalized": [796551], "database": "ncbi_gene", "normalized_id": 796551, "biotype": "gene", "name": "tert", "accession": "@GENE_TERT"}, "text": "tert", "locations": [{"offset": 645, "length": 4}]}, {"id": "15", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 790, "length": 12}]}, {"id": "16", "infons": {"identifier": "7955", "type": "Species", "valid": true, "normalized": [7955], "database": "ncbi_taxonomy", "normalized_id": 7955, "biotype": "species", "name": "7955", "accession": null}, "text": "zebrafish", "locations": [{"offset": 1273, "length": 9}]}, {"id": "17", "infons": {"identifier": "796551", "type": "Gene", "ncbi_homologene": "31141", "valid": true, "normalized": [796551], "database": "ncbi_gene", "normalized_id": 796551, "biotype": "gene", "name": "tert", "accession": "@GENE_TERT"}, "text": "tert", "locations": [{"offset": 1283, "length": 4}]}], "relations": []}], "relations": [], "pmid": 40995852, "pmcid": null, "meta": {}, "date": "2025-09-25T00:00:00Z", "journal": "Aging Cell", "authors": ["Yuan Y", "Dyer C", "Knight RD"], "relations_display": []}, {"_id": "41000743|None", "id": "41000743", "infons": {}, "passages": [{"infons": {"journal": "bioRxiv;2025Sep18. doi:10.1101/2025.09.17.676776", "year": "2025", "article-id_pmc": "PMC12458469", "type": "title", "authors": "Tanaka H, McCauley BS, Guida C, Lei X, Li S, Moreno TM, Guillotte K, Chua ZM, Abele A, Lamba A, Arnold R, Rajesh A, Teneche MG, Haddadin L, Deshpande A, Deshpande AJ, Colas A, Kumsta C, Petrascheck M, Bodmer R, Dang W, Adams PD, "}, "offset": 0, "text": "Nucleosome stability safeguards cell identity, stress resilience and healthy aging.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 84, "text": "Nucleosomes are the minimal repeating units of chromatin. Their dynamic assembly and disassembly underpins chromatin organization and genome regulation. However, it remains unclear how intrinsic nucleosome stability contributes to higher-level yet fundamental cellular and organismal properties-such as preservation of cell identity, lineage specification, stress resilience and ultimately healthy aging. To address this, we tested the impact of decreased intrinsic nucleosome stability across multiple cell, tissue and organismal models by introducing histone mutants that weaken histone-histone interactions. While nucleosome instability did not broadly alter global chromatin accessibility, DNA damage, cell proliferation or viability, it impaired lineage-specific gene expression programs, altered lineage specification and activated intrinsic inflammatory and stress pathways in a manner reminiscent of aging in mouse tissues and human cells. Consistently, nucleosome instability accelerated the onset of age-associated transcriptional alterations and functional decline in Caenorhabditis elegans and Drosophila melanogaster , and reduced cellular resilience to exogenous perturbations- including environmental, epigenetic and mitotic stress-in human cells and Saccharomyces cerevisiae . These cross-species findings identify nucleosome stability as an evolutionarily conserved epigenetic safeguard that preserves cell identity and stress resilience and supports organismal function and healthy aging.", "sentences": [], "annotations": [{"id": "7", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 932, "length": 12}]}, {"id": "8", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mouse", "locations": [{"offset": 1001, "length": 5}]}, {"id": "9", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 1019, "length": 5}]}, {"id": "10", "infons": {"identifier": "6239", "type": "Species", "valid": true, "normalized": [6239], "database": "ncbi_taxonomy", "normalized_id": 6239, "biotype": "species", "name": "6239", "accession": null}, "text": "Caenorhabditis elegans", "locations": [{"offset": 1163, "length": 22}]}, {"id": "11", "infons": {"identifier": "7227", "type": "Species", "valid": true, "normalized": [7227], "database": "ncbi_taxonomy", "normalized_id": 7227, "biotype": "species", "name": "7227", "accession": null}, "text": "Drosophila melanogaster", "locations": [{"offset": 1190, "length": 23}]}, {"id": "12", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 1334, "length": 5}]}, {"id": "13", "infons": {"identifier": "4932", "type": "Species", "valid": true, "normalized": [4932], "database": "ncbi_taxonomy", "normalized_id": 4932, "biotype": "species", "name": "4932", "accession": null}, "text": "Saccharomyces cerevisiae", "locations": [{"offset": 1350, "length": 24}]}], "relations": []}], "relations": [], "pmid": 41000743, "pmcid": null, "meta": {}, "date": "2025-09-18T00:00:00Z", "journal": "bioRxiv", "authors": ["Tanaka H", "McCauley BS", "Guida C", "Lei X", "Li S", "Moreno TM", "Guillotte K", "Chua ZM", "Abele A", "Lamba A", "Arnold R", "Rajesh A", "Teneche MG", "Haddadin L", "Deshpande A", "Deshpande AJ", "Colas A", "Kumsta C", "Petrascheck M", "Bodmer R", "Dang W", "Adams PD"], "relations_display": []}, {"_id": "41002997|None", "id": "41002997", "infons": {}, "passages": [{"infons": {"journal": "Metabolites;2025Sep15; 15 (9) . doi:10.3390/metabo15090613", "year": "2025", "article-id_pmc": "PMC12471849", "type": "title", "authors": "Hao X, Tu S, Pan D, Liao W, Yang L, Wang S, Sun G, "}, "offset": 0, "text": "Relationship of Ageing to Insulin Resistance and Atherosclerosis.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "Insulin Resistance", "locations": [{"offset": 26, "length": 18}]}, {"id": "3", "infons": {"identifier": "MESH:D050197", "type": "Disease", "valid": true, "normalized": ["D050197"], "database": "ncbi_mesh", "normalized_id": "D050197", "biotype": "disease", "name": "Atherosclerosis", "accession": "@DISEASE_Atherosclerosis"}, "text": "Atherosclerosis", "locations": [{"offset": 49, "length": 15}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 66, "text": "Ageing drives a vicious cycle of insulin resistance (IR) and atherosclerosis through shared pathological pathways. This review aims to synthesise the current understanding of the molecular mechanisms that connect ageing, IR, and atherosclerosis, with a particular focus on oxidative stress, chronic inflammation, and metabolic disturbances. We systematically summarise evidence demonstrating how age-related mitochondrial dysfunction promotes IR, which in turn accelerates atherosclerotic progression. Based on this integration, we conclude that the intertwined nature of these processes reveals promising therapeutic targets. Targeting these shared pathways, such as with senolytic agents or anti-inflammatory agents, may offer novel strategic insights for concurrently mitigating IR and atherosclerosis in the ageing population.", "sentences": [], "annotations": [{"id": "17", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "insulin resistance", "locations": [{"offset": 99, "length": 18}]}, {"id": "18", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 119, "length": 2}]}, {"id": "19", "infons": {"identifier": "MESH:D050197", "type": "Disease", "valid": true, "normalized": ["D050197"], "database": "ncbi_mesh", "normalized_id": "D050197", "biotype": "disease", "name": "Atherosclerosis", "accession": "@DISEASE_Atherosclerosis"}, "text": "atherosclerosis", "locations": [{"offset": 127, "length": 15}]}, {"id": "20", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 287, "length": 2}]}, {"id": "21", "infons": {"identifier": "MESH:D050197", "type": "Disease", "valid": true, "normalized": ["D050197"], "database": "ncbi_mesh", "normalized_id": "D050197", "biotype": "disease", "name": "Atherosclerosis", "accession": "@DISEASE_Atherosclerosis"}, "text": "atherosclerosis", "locations": [{"offset": 295, "length": 15}]}, {"id": "22", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "chronic inflammation", "locations": [{"offset": 357, "length": 20}]}, {"id": "23", "infons": {"identifier": "MESH:D024821", "type": "Disease", "valid": true, "normalized": ["D024821"], "database": "ncbi_mesh", "normalized_id": "D024821", "biotype": "disease", "name": "Metabolic Syndrome", "accession": "@DISEASE_Metabolic_Syndrome"}, "text": "metabolic disturbances", "locations": [{"offset": 383, "length": 22}]}, {"id": "24", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial dysfunction", "locations": [{"offset": 474, "length": 25}]}, {"id": "25", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 509, "length": 2}]}, {"id": "26", "infons": {"identifier": "MESH:D050197", "type": "Disease", "valid": true, "normalized": ["D050197"], "database": "ncbi_mesh", "normalized_id": "D050197", "biotype": "disease", "name": "Atherosclerosis", "accession": "@DISEASE_Atherosclerosis"}, "text": "atherosclerotic", "locations": [{"offset": 539, "length": 15}]}, {"id": "27", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 764, "length": 12}]}, {"id": "28", "infons": {"identifier": "MESH:D007333", "type": "Disease", "valid": true, "normalized": ["D007333"], "database": "ncbi_mesh", "normalized_id": "D007333", "biotype": "disease", "name": "Insulin Resistance", "accession": "@DISEASE_Insulin_Resistance"}, "text": "IR", "locations": [{"offset": 848, "length": 2}]}, {"id": "29", "infons": {"identifier": "MESH:D050197", "type": "Disease", "valid": true, "normalized": ["D050197"], "database": "ncbi_mesh", "normalized_id": "D050197", "biotype": "disease", "name": "Atherosclerosis", "accession": "@DISEASE_Atherosclerosis"}, "text": "atherosclerosis", "locations": [{"offset": 855, "length": 15}]}], "relations": []}], "relations": [], "pmid": 41002997, "pmcid": null, "meta": {}, "date": "2025-09-15T00:00:00Z", "journal": "Metabolites", "authors": ["Hao X", "Tu S", "Pan D", "Liao W", "Yang L", "Wang S", "Sun G"], "relations_display": []}, {"_id": "41003013|None", "id": "41003013", "infons": {}, "passages": [{"infons": {"journal": "Metabolites;2025Sep22; 15 (9) . doi:10.3390/metabo15090629", "year": "2025", "article-id_pmc": "PMC12471871", "type": "title", "authors": "Balderrama-G&#xf3;mez A, Mu&#xf1;oz-P&#xe9;rez VM, Ortiz MI, Cari&#xf1;o-Cort&#xe9;s R, Castro-Rosas J, Betanzos A, Fern&#xe1;ndez-Mart&#xed;nez E, Castillo-Ju&#xe1;rez I, "}, "offset": 0, "text": "Using Caprylic Acid for the Prevention and Treatment of Helicobacter pylori Infection and Gastric Cancer: A Review.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "MESH:C031492", "type": "Chemical", "valid": true, "normalized": ["C031492"], "database": "ncbi_mesh", "normalized_id": "C031492", "biotype": "chemical", "name": "octanoic acid", "accession": "@CHEMICAL_octanoic_acid"}, "text": "Caprylic Acid", "locations": [{"offset": 6, "length": 13}]}, {"id": "4", "infons": {"identifier": "MESH:D016481", "type": "Disease", "valid": true, "normalized": ["D016481"], "database": "ncbi_mesh", "normalized_id": "D016481", "biotype": "disease", "name": "Helicobacter Infections", "accession": "@DISEASE_Helicobacter_Infections"}, "text": "Helicobacter pylori Infection", "locations": [{"offset": 56, "length": 29}]}, {"id": "5", "infons": {"identifier": "MESH:D013274", "type": "Disease", "valid": true, "normalized": ["D013274"], "database": "ncbi_mesh", "normalized_id": "D013274", "biotype": "disease", "name": "Stomach Neoplasms", "accession": "@DISEASE_Stomach_Neoplasms"}, "text": "Gastric Cancer", "locations": [{"offset": 90, "length": 14}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 116, "text": "The present study investigates the bactericidal and anticancer potential of caprylic acid (CA) against Helicobacter pylori infection, a major global risk factor for gastric cancer. Several chronic inflammatory processes, bacterial virulence factors, and carcinogenic mechanisms-capable of inducing DNA damage in gastric epithelial cells, promoting genomic instability, and contributing to the development of gastritis or peptic ulcer disease in susceptible individuals-remain incompletely understood. CA, a medium-chain fatty acid naturally found in plant and animal sources such as coconut oil and goat's milk, possesses notable biological properties that may confer gastroprotective effects against gastric cancer induced by H. pylori. Despite advances in medical management, no universally effective strategy currently exists for the treatment or prevention of H. pylori-associated gastric cancer. Conventional therapies, including surgery, radiotherapy, and chemotherapy, often entail long-term complications that may affect patients' nutritional status. In brief, further elucidation of the mechanisms underlying medium-chain fatty acid metabolism, particularly that of CA in gastric cancer cells, may yield valuable insights for the development of innovative therapeutic approaches. Consequently, the integration of CA into therapeutic dietary regimens and the formulation of nutraceuticals targeting H. pylori infection and related gastric pathologies warrant consideration. Therefore, CA could be considered a potential adjuvant in the preventive treatment of H. pylori-induced gastritis and its associated complications. However, further in vitro and in vivo studies are needed to confirm its beneficial use for this pathology.", "sentences": [], "annotations": [{"id": "31", "infons": {"identifier": "MESH:C031492", "type": "Chemical", "valid": true, "normalized": ["C031492"], "database": "ncbi_mesh", "normalized_id": "C031492", "biotype": "chemical", "name": "octanoic acid", "accession": "@CHEMICAL_octanoic_acid"}, "text": "caprylic acid", "locations": [{"offset": 192, "length": 13}]}, {"id": "32", "infons": {"identifier": "MESH:C031492", "type": "Chemical", "valid": true, "normalized": ["C031492"], "database": "ncbi_mesh", "normalized_id": "C031492", "biotype": "chemical", "name": "octanoic acid", "accession": "@CHEMICAL_octanoic_acid"}, "text": "CA", "locations": [{"offset": 207, "length": 2}]}, {"id": "33", "infons": {"identifier": "MESH:D016481", "type": "Disease", "valid": true, "normalized": ["D016481"], "database": "ncbi_mesh", "normalized_id": "D016481", "biotype": "disease", "name": "Helicobacter Infections", "accession": "@DISEASE_Helicobacter_Infections"}, "text": "Helicobacter pylori infection", "locations": [{"offset": 219, "length": 29}]}, {"id": "34", "infons": {"identifier": "MESH:D013274", "type": "Disease", "valid": true, "normalized": ["D013274"], "database": "ncbi_mesh", "normalized_id": "D013274", "biotype": "disease", "name": "Stomach Neoplasms", "accession": "@DISEASE_Stomach_Neoplasms"}, "text": "gastric cancer", "locations": [{"offset": 281, "length": 14}]}, {"id": "35", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 313, "length": 12}]}, {"id": "36", "infons": {"identifier": "MESH:D011230", "type": "Disease", "valid": true, "normalized": ["D011230"], "database": "ncbi_mesh", "normalized_id": "D011230", "biotype": "disease", "name": "Precancerous Conditions", "accession": "@DISEASE_Precancerous_Conditions"}, "text": "carcinogenic", "locations": [{"offset": 370, "length": 12}]}, {"id": "37", "infons": {"identifier": "MESH:D005756", "type": "Disease", "valid": true, "normalized": ["D005756"], "database": "ncbi_mesh", "normalized_id": "D005756", "biotype": "disease", "name": "Gastritis", "accession": "@DISEASE_Gastritis"}, "text": "gastritis", "locations": [{"offset": 524, "length": 9}]}, {"id": "38", "infons": {"identifier": "MESH:D010437", "type": "Disease", "valid": true, "normalized": ["D010437"], "database": "ncbi_mesh", "normalized_id": "D010437", "biotype": "disease", "name": "Peptic Ulcer", "accession": "@DISEASE_Peptic_Ulcer"}, "text": "peptic ulcer disease", "locations": [{"offset": 537, "length": 20}]}, {"id": "39", "infons": {"identifier": "MESH:C031492", "type": "Chemical", "valid": true, "normalized": ["C031492"], "database": "ncbi_mesh", "normalized_id": "C031492", "biotype": "chemical", "name": "octanoic acid", "accession": "@CHEMICAL_octanoic_acid"}, "text": "CA", "locations": [{"offset": 617, "length": 2}]}, {"id": "40", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "medium-chain fatty acid", "locations": [{"offset": 623, "length": 23}]}, {"id": "41", "infons": {"identifier": "MESH:D000074263", "type": "Chemical", "valid": true, "normalized": ["D000074263"], "database": "ncbi_mesh", "normalized_id": "D000074263", "biotype": "chemical", "name": "Coconut Oil", "accession": "@CHEMICAL_Coconut_Oil"}, "text": "coconut oil", "locations": [{"offset": 699, "length": 11}]}, {"id": "42", "infons": {"identifier": "MESH:D013274", "type": "Disease", "valid": true, "normalized": ["D013274"], "database": "ncbi_mesh", "normalized_id": "D013274", "biotype": "disease", "name": "Stomach Neoplasms", "accession": "@DISEASE_Stomach_Neoplasms"}, "text": "gastric cancer", "locations": [{"offset": 817, "length": 14}]}, {"id": "43", "infons": {"identifier": "210", "type": "Species", "valid": true, "normalized": [210], "database": "ncbi_taxonomy", "normalized_id": 210, "biotype": "species", "name": "210", "accession": null}, "text": "H. pylori", "locations": [{"offset": 843, "length": 9}]}, {"id": "44", "infons": {"identifier": "210", "type": "Species", "valid": true, "normalized": [210], "database": "ncbi_taxonomy", "normalized_id": 210, "biotype": "species", "name": "210", "accession": null}, "text": "H. pylori", "locations": [{"offset": 980, "length": 9}]}, {"id": "45", "infons": {"identifier": "MESH:D013274", "type": "Disease", "valid": true, "normalized": ["D013274"], "database": "ncbi_mesh", "normalized_id": "D013274", "biotype": "disease", "name": "Stomach Neoplasms", "accession": "@DISEASE_Stomach_Neoplasms"}, "text": "gastric cancer", "locations": [{"offset": 1001, "length": 14}]}, {"id": "46", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 1145, "length": 8}]}, {"id": "47", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "medium-chain fatty acid", "locations": [{"offset": 1234, "length": 23}]}, {"id": "48", "infons": {"identifier": "MESH:C031492", "type": "Chemical", "valid": true, "normalized": ["C031492"], "database": "ncbi_mesh", "normalized_id": "C031492", "biotype": "chemical", "name": "octanoic acid", "accession": "@CHEMICAL_octanoic_acid"}, "text": "CA", "locations": [{"offset": 1291, "length": 2}]}, {"id": "49", "infons": {"identifier": "MESH:D013274", "type": "Disease", "valid": true, "norm