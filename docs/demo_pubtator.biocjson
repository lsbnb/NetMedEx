e": "Negative_Correlation"}, "nodes": [{"refid": "3", "role": "29,8"}]}, {"id": "R5", "infons": {"score": "0.5896", "role1": {"identifier": "MESH:D000077333", "type": "Chemical", "valid": true, "normalized": ["D000077333"], "database": "ncbi_mesh", "normalized_id": "D000077333", "biotype": "chemical", "name": "Telmisartan", "accession": "@CHEMICAL_Telmisartan"}, "role2": {"identifier": "MESH:D003520", "type": "Chemical", "valid": true, "normalized": ["D003520"], "database": "ncbi_mesh", "normalized_id": "D003520", "biotype": "chemical", "name": "Cyclophosphamide", "accession": "@CHEMICAL_Cyclophosphamide"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "4", "role": "29,30"}]}, {"id": "R6", "infons": {"score": "0.9978", "role1": {"identifier": "MESH:D000077333", "type": "Chemical", "valid": true, "normalized": ["D000077333"], "database": "ncbi_mesh", "normalized_id": "D000077333", "biotype": "chemical", "name": "Telmisartan", "accession": "@CHEMICAL_Telmisartan"}, "role2": {"identifier": "MESH:D013733", "type": "Disease", "valid": true, "normalized": ["D013733"], "database": "ncbi_mesh", "normalized_id": "D013733", "biotype": "disease", "name": "Testicular Diseases", "accession": "@DISEASE_Testicular_Diseases"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "5", "role": "29,31"}]}, {"id": "R7", "infons": {"score": "0.9987", "role1": {"identifier": "MESH:D000077333", "type": "Chemical", "valid": true, "normalized": ["D000077333"], "database": "ncbi_mesh", "normalized_id": "D000077333", "biotype": "chemical", "name": "Telmisartan", "accession": "@CHEMICAL_Telmisartan"}, "role2": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "6", "role": "29,32"}]}, {"id": "R8", "infons": {"score": "0.9979", "role1": {"identifier": "MESH:D003520", "type": "Chemical", "valid": true, "normalized": ["D003520"], "database": "ncbi_mesh", "normalized_id": "D003520", "biotype": "chemical", "name": "Cyclophosphamide", "accession": "@CHEMICAL_Cyclophosphamide"}, "role2": {"identifier": "MESH:D013733", "type": "Disease", "valid": true, "normalized": ["D013733"], "database": "ncbi_mesh", "normalized_id": "D013733", "biotype": "disease", "name": "Testicular Diseases", "accession": "@DISEASE_Testicular_Diseases"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "7", "role": "30,31"}]}], "pmid": 41732548, "pmcid": null, "meta": {}, "date": "2026-02-15T00:00:00Z", "journal": "Toxicol Rep", "authors": ["Kassid AA", "Mahmood AM", "Obaid KA", "Philip Rahmani MH"], "relations_display": [{"name": "cause|@CHEMICAL_Cyclophosphamide|@DISEASE_Inflammation"}, {"name": "associate|@CHEMICAL_Telmisartan|@GENE_PPARG"}, {"name": "negative_correlate|@CHEMICAL_Cyclophosphamide|@CHEMICAL_Testosterone"}, {"name": "negative_correlate|@CHEMICAL_Telmisartan|@GENE_AGTR1B"}, {"name": "negative_correlate|@CHEMICAL_Telmisartan|@CHEMICAL_Cyclophosphamide"}, {"name": "treat|@CHEMICAL_Telmisartan|@DISEASE_Testicular_Diseases"}, {"name": "treat|@CHEMICAL_Telmisartan|@DISEASE_Inflammation"}, {"name": "cause|@CHEMICAL_Cyclophosphamide|@DISEASE_Testicular_Diseases"}]}, {"_id": "41743109|None", "id": "41743109", "infons": {}, "passages": [{"infons": {"type": "title"}, "offset": 0, "text": "Ribosome heterogeneity and specialization in musculoskeletal physiology and pathology.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 87, "text": "Musculoskeletal (MSK) tissues are highly dynamic systems that rely on tightly regulated protein synthesis to maintain homeostasis and structural integrity, adapt to physiological stimuli, and respond to injury. The deregulation of protein synthesis is implicated in a wide range of MSK pathologies. At the core of protein synthesis are ribosomes, complex molecular nanomachines that translate mRNAs and generate proteins. Once considered uniform entities passively exerting their function, ribosomes are now recognized to be heterogeneous in their composition and capable of specialized functions. These emerging concepts of ribosome heterogeneity and specialization are increasingly recognized as key regulators of physiological and pathological cellular processes across fields. Although the MSK field has yet to fully embrace and integrate ribosome-centered research, accumulating evidence suggests that ribosome heterogeneity and specialization might have profound implications for MSK (patho)biology. In this review, we summarize the emerging data across MSK tissues (bone, skeletal muscle, articular cartilage, tendons, and ligaments), highlighting the roles of ribosomes in supporting development, maintaining homeostasis, and facilitating cellular and tissue functions and adaptations, but also driving pathological changes and disease progression. Furthermore, we also outline recent key technological and methodological advances that are critical for uncovering the full scope, significance, and dynamic regulation of ribosome heterogeneity and specialization in MSK (patho)biology. As the field moves forward, ribosome-centered research holds great promise in revealing new mechanisms underlying MSK biology and identifying novel therapeutic targets.", "sentences": [], "annotations": [], "relations": []}], "relations": [], "pmid": 41743109, "pmcid": null, "meta": {}, "date": "2026-02-02T00:00:00Z", "journal": "JBMR Plus", "authors": ["Chabronova A", "van den Akker GGH", "Welting TJM", "Peffers MJ"], "relations_display": []}, {"_id": "41751201|None", "id": "41751201", "infons": {}, "passages": [{"infons": {"journal": "Biomedicines;2026Jan29; 14 (2) . doi:10.3390/biomedicines14020302", "year": "2026", "type": "title", "authors": "Ghanemi A, Yoshioka M, Guimar&#xe3;es RF, St-Amand J, "}, "offset": 0, "text": "Exploring SPARC over Other Exerkines/Myokines: A Strategic Approach Towards Novel Exercise-Mimicking Therapies.", "sentences": [], "annotations": [{"id": "3", "infons": {"identifier": "6678", "type": "Gene", "ncbi_homologene": "31132", "valid": true, "normalized": [6678], "database": "ncbi_gene", "normalized_id": 6678, "biotype": "gene", "name": "SPARC", "accession": "@GENE_SPARC"}, "text": "SPARC", "locations": [{"offset": 10, "length": 5}]}, {"id": "4", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "Exerkines", "locations": [{"offset": 27, "length": 9}]}, {"id": "5", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "Myokines", "locations": [{"offset": 37, "length": 8}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 112, "text": "Identifying novel therapeutic targets for diseases and health conditions represents an important step towards new therapies. Functional genomics and proteomics represent promising tools in identifying such pharmacological targets. Within this context, numerous biomolecules have been characterized as exercise-induced (exerkines) in muscles (myokines). In this article, we present illustrative examples of why secreted protein acidic and rich in cysteine (SPARC) would be a \"leading candidate\" myokine/exerkine for exploring exercise-induced genes/proteins to develop therapies, clarify mechanisms, and improve various aspects of biomedical research, including population health.", "sentences": [], "annotations": [{"id": "9", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "exerkines", "locations": [{"offset": 431, "length": 9}]}, {"id": "10", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "myokines", "locations": [{"offset": 454, "length": 8}]}, {"id": "11", "infons": {"identifier": "6678", "type": "Gene", "ncbi_homologene": "31132", "valid": true, "normalized": [6678], "database": "ncbi_gene", "normalized_id": 6678, "biotype": "gene", "name": "SPARC", "accession": "@GENE_SPARC"}, "text": "SPARC", "locations": [{"offset": 568, "length": 5}]}], "relations": []}], "relations": [], "pmid": 41751201, "pmcid": null, "meta": {}, "date": "2026-01-29T00:00:00Z", "journal": "Biomedicines", "authors": ["Ghanemi A", "Yoshioka M", "Guimarães RF", "St-Amand J"], "relations_display": []}, {"_id": "41759582|None", "id": "41759582", "infons": {}, "passages": [{"infons": {"journal": "J Lipid Res;2026Feb25 101009. doi:10.1016/j.jlr.2026.101009", "year": "2026", "type": "title", "authors": "Verdaguer IB, Hern&#xe1;ndez A, Torres S, Rodr&#xed;guez-Peiris M, Arenas F, Martinez DE, L&#xf3;pez MB, Crispim M, Tabata Y, Garcia-Ruiz C, Fernandez-Checa JC, "}, "offset": 0, "text": "Prenols and Prenoic Acids in Metabolism, Disease, and Aging.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:C009034", "type": "Chemical", "valid": true, "normalized": ["C009034"], "database": "ncbi_mesh", "normalized_id": "C009034", "biotype": "chemical", "name": "prenol", "accession": "@CHEMICAL_prenol"}, "text": "Prenols", "locations": [{"offset": 0, "length": 7}]}, {"id": "3", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Prenoic Acids", "locations": [{"offset": 12, "length": 13}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 61, "text": "Acyclic terpene derivatives are well known as components of plant essential oils and insect hormones, yet their active biosynthesis also occurs in mammals. The terpenic alcohols-or prenols-geranylgeraniol (GGOH) and farnesol (FOH), together with their prenoic acids and derivatives, were identified in mammalian cells over sixty years ago but remain largely overlooked. These metabolites display diverse biological functions: they induce autophagy, inhibit tumor growth and inflammation, suppress cholesterol synthesis, enhance insulin sensitivity and cognition, regulate sexual characteristics, and promote healthy aging. In mammals, prenols arise from an age-dependent, bidirectional pathway that interconverts polyprenyl diphosphates, prenols, and prenoic acids. They can be oxidized into aldehydes and carboxylic acids or reconverted into diphosphate forms for use in protein prenylation and in the biosynthesis of ubiquinone, cholesterol, and dolichol. While enzymes catalyzing polyprenyl diphosphate dephosphorylation and oxidation steps have been partly characterized, the kinases mediating their reverse phosphorylation remain unidentified. This review summarizes current advances in the understanding of prenol metabolism in mammals, emphasizing its role in metabolic regulation, disease prevention, and longevity. By integrating biochemical and physiological evidence, we highlight the emerging view that these small terpenes constitute a fundamental yet underexplored layer of metabolic control. Greater attention to this pathway may reveal novel strategies for maintaining metabolic health and mitigating age-related disorders.", "sentences": [], "annotations": [{"id": "32", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "Acyclic terpene derivatives", "locations": [{"offset": 61, "length": 27}]}, {"id": "33", "infons": {"identifier": "MESH:D009822", "type": "Chemical", "valid": true, "normalized": ["D009822"], "database": "ncbi_mesh", "normalized_id": "D009822", "biotype": "chemical", "name": "Oils Volatile", "accession": "@CHEMICAL_Oils_Volatile"}, "text": "essential oils", "locations": [{"offset": 127, "length": 14}]}, {"id": "34", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "terpenic alcohols", "locations": [{"offset": 221, "length": 17}]}, {"id": "35", "infons": {"identifier": "MESH:C009034", "type": "Chemical", "valid": true, "normalized": ["C009034"], "database": "ncbi_mesh", "normalized_id": "C009034", "biotype": "chemical", "name": "prenol", "accession": "@CHEMICAL_prenol"}, "text": "prenols", "locations": [{"offset": 242, "length": 7}]}, {"id": "36", "infons": {"identifier": "MESH:C017338", "type": "Chemical", "valid": true, "normalized": ["C017338"], "database": "ncbi_mesh", "normalized_id": "C017338", "biotype": "chemical", "name": "geranylgeraniol", "accession": "@CHEMICAL_geranylgeraniol"}, "text": "geranylgeraniol", "locations": [{"offset": 250, "length": 15}]}, {"id": "37", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "GGOH", "locations": [{"offset": 267, "length": 4}]}, {"id": "38", "infons": {"identifier": "MESH:D005204", "type": "Chemical", "valid": true, "normalized": ["D005204"], "database": "ncbi_mesh", "normalized_id": "D005204", "biotype": "chemical", "name": "Farnesol", "accession": "@CHEMICAL_Farnesol"}, "text": "farnesol", "locations": [{"offset": 277, "length": 8}]}, {"id": "39", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "FOH", "locations": [{"offset": 287, "length": 3}]}, {"id": "40", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "prenoic acids", "locations": [{"offset": 313, "length": 13}]}, {"id": "41", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "tumor", "locations": [{"offset": 518, "length": 5}]}, {"id": "42", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 535, "length": 12}]}, {"id": "43", "infons": {"identifier": "MESH:D002784", "type": "Chemical", "valid": true, "normalized": ["D002784"], "database": "ncbi_mesh", "normalized_id": "D002784", "biotype": "chemical", "name": "Cholesterol", "accession": "@CHEMICAL_Cholesterol"}, "text": "cholesterol", "locations": [{"offset": 558, "length": 11}]}, {"id": "44", "infons": {"identifier": "3630", "type": "Gene", "ncbi_homologene": "173", "valid": true, "normalized": [3630], "database": "ncbi_gene", "normalized_id": 3630, "biotype": "gene", "name": "INS", "accession": "@GENE_INS"}, "text": "insulin", "locations": [{"offset": 589, "length": 7}]}, {"id": "45", "infons": {"identifier": "MESH:C009034", "type": "Chemical", "valid": true, "normalized": ["C009034"], "database": "ncbi_mesh", "normalized_id": "C009034", "biotype": "chemical", "name": "prenol", "accession": "@CHEMICAL_prenol"}, "text": "prenols", "locations": [{"offset": 696, "length": 7}]}, {"id": "46", "infons": {"identifier": "MESH:D019588", "type": "Disease", "valid": true, "normalized": ["D019588"], "database": "ncbi_mesh", "normalized_id": "D019588", "biotype": "disease", "name": "Aging Premature", "accession": "@DISEASE_Aging_Premature"}, "text": "age", "locations": [{"offset": 718, "length": 3}]}, {"id": "47", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "polyprenyl diphosphates", "locations": [{"offset": 774, "length": 23}]}, {"id": "48", "infons": {"identifier": "MESH:C009034", "type": "Chemical", "valid": true, "normalized": ["C009034"], "database": "ncbi_mesh", "normalized_id": "C009034", "biotype": "chemical", "name": "prenol", "accession": "@CHEMICAL_prenol"}, "text": "prenols", "locations": [{"offset": 799, "length": 7}]}, {"id": "49", "infons": {"identifier": "-", "type": "Chemical", "valid": false, "normalized_id": null, "biotype": "chemical"}, "text": "prenoic acids", "location