{"score": "0.8006", "role1": {"identifier": "MESH:C045651", "type": "Chemical", "valid": true, "normalized": ["C045651"], "database": "ncbi_mesh", "normalized_id": "C045651", "biotype": "chemical", "name": "epigallocatechin gallate", "accession": "@CHEMICAL_epigallocatechin_gallate"}, "role2": {"identifier": "MESH:D007501", "type": "Chemical", "valid": true, "normalized": ["D007501"], "database": "ncbi_mesh", "normalized_id": "D007501", "biotype": "chemical", "name": "Iron", "accession": "@CHEMICAL_Iron"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "8", "role": "20,24"}]}, {"id": "R10", "infons": {"score": "0.9861", "role1": {"identifier": "MESH:D003474", "type": "Chemical", "valid": true, "normalized": ["D003474"], "database": "ncbi_mesh", "normalized_id": "D003474", "biotype": "chemical", "name": "Curcumin", "accession": "@CHEMICAL_Curcumin"}, "role2": {"identifier": "MESH:D007501", "type": "Chemical", "valid": true, "normalized": ["D007501"], "database": "ncbi_mesh", "normalized_id": "D007501", "biotype": "chemical", "name": "Iron", "accession": "@CHEMICAL_Iron"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "9", "role": "18,24"}]}, {"id": "R11", "infons": {"score": "0.9601", "role1": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "role2": {"identifier": "MESH:D019588", "type": "Disease", "valid": true, "normalized": ["D019588"], "database": "ncbi_mesh", "normalized_id": "D019588", "biotype": "disease", "name": "Aging Premature", "accession": "@DISEASE_Aging_Premature"}, "type": "Association"}, "nodes": [{"refid": "10", "role": "23,26"}]}, {"id": "R12", "infons": {"score": "0.7647", "role1": {"identifier": "MESH:D007501", "type": "Chemical", "valid": true, "normalized": ["D007501"], "database": "ncbi_mesh", "normalized_id": "D007501", "biotype": "chemical", "name": "Iron", "accession": "@CHEMICAL_Iron"}, "role2": {"identifier": "MESH:D019588", "type": "Disease", "valid": true, "normalized": ["D019588"], "database": "ncbi_mesh", "normalized_id": "D019588", "biotype": "disease", "name": "Aging Premature", "accession": "@DISEASE_Aging_Premature"}, "type": "Association"}, "nodes": [{"refid": "11", "role": "24,26"}]}, {"id": "R13", "infons": {"score": "0.9961", "role1": {"identifier": "MESH:D019588", "type": "Disease", "valid": true, "normalized": ["D019588"], "database": "ncbi_mesh", "normalized_id": "D019588", "biotype": "disease", "name": "Aging Premature", "accession": "@DISEASE_Aging_Premature"}, "role2": {"identifier": "2879", "type": "Gene", "valid": true, "normalized": [2879], "database": "ncbi_gene", "normalized_id": 2879, "biotype": "gene", "name": "GPX4", "accession": "@GENE_GPX4"}, "type": "Association"}, "nodes": [{"refid": "12", "role": "26,13"}]}, {"id": "R14", "infons": {"score": "0.9982", "role1": {"identifier": "MESH:C045651", "type": "Chemical", "valid": true, "normalized": ["C045651"], "database": "ncbi_mesh", "normalized_id": "C045651", "biotype": "chemical", "name": "epigallocatechin gallate", "accession": "@CHEMICAL_epigallocatechin_gallate"}, "role2": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "13", "role": "20,23"}]}], "pmid": 40642182, "pmcid": null, "meta": {}, "date": "2025-07-03T00:00:00Z", "journal": "J Aging Res", "authors": ["Hamidu S", "Amponsah SK", "Aning A", "Adams L", "Kumi J", "Ampem-Danso E", "Hamidu F", "Mumin Mohammed MA", "Ador GT", "Khatun S"], "relations_display": [{"name": "negative_correlate|@CHEMICAL_Curcumin|@CHEMICAL_Reactive_Oxygen_Species"}, {"name": "positive_correlate|@CHEMICAL_Iron|@CHEMICAL_Reactive_Oxygen_Species"}, {"name": "negative_correlate|@CHEMICAL_Resveratrol|@CHEMICAL_Lipids"}, {"name": "negative_correlate|@CHEMICAL_Resveratrol|@CHEMICAL_Reactive_Oxygen_Species"}, {"name": "associate|@CHEMICAL_Iron|@CHEMICAL_Lipids"}, {"name": "associate|@CHEMICAL_Lipids|@DISEASE_Nerve_Degeneration"}, {"name": "negative_correlate|@CHEMICAL_Curcumin|@CHEMICAL_Lipids"}, {"name": "negative_correlate|@CHEMICAL_epigallocatechin_gallate|@CHEMICAL_Reactive_Oxygen_Species"}, {"name": "negative_correlate|@CHEMICAL_epigallocatechin_gallate|@CHEMICAL_Iron"}, {"name": "negative_correlate|@CHEMICAL_Curcumin|@CHEMICAL_Iron"}, {"name": "associate|@CHEMICAL_Lipids|@DISEASE_Aging_Premature"}, {"name": "associate|@CHEMICAL_Iron|@DISEASE_Aging_Premature"}, {"name": "associate|@DISEASE_Aging_Premature|@GENE_GPX4"}, {"name": "negative_correlate|@CHEMICAL_epigallocatechin_gallate|@CHEMICAL_Lipids"}]}, {"_id": "40643502|None", "id": "40643502", "infons": {}, "passages": [{"infons": {"journal": "Cells;2025Jun26; 14 (13) . doi:10.3390/cells14130981", "year": "2025", "article-id_pmc": "PMC12249023", "type": "title", "authors": "Yushkov B, Chereshnev V, Korneva E, Yushkova V, Sarapultsev A, "}, "offset": 0, "text": "Stem-Cell Niches in Health and Disease: Microenvironmental Determinants of Regeneration and Pathology.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 103, "text": "Stem-cell behavior is governed not solely by intrinsic genetic programs but by highly specialized microenvironments-or niches-that integrate structural, biochemical, and mechanical cues to regulate quiescence, self-renewal, and differentiation. This review traces the evolution of stem-cell niche biology from foundational embryological discoveries to its current role as a central determinant in tissue regeneration and disease. We describe the cellular and extracellular matrix architectures that define adult stem-cell niches across diverse organs and dissect conserved signaling axes-including Wnt, BMP, and Notch-that orchestrate lineage commitment. Emphasis is placed on how aging, inflammation, fibrosis, and metabolic stress disrupt niche function, converting supportive environments into autonomous drivers of pathology. We then examine emerging therapeutic strategies that shift the regenerative paradigm from a stem-cell-centric to a niche-centric model. These include stromal targeting (e.g., FAP inhibition), which are engineered scaffolds that replicate native niche mechanics, extracellular vesicles that deliver paracrine cues, and composite constructs that preserve endogenous cell-matrix interactions. Particular attention is given to cardiac, hematopoietic, reproductive, and neurogenic niches, where clinical failures often reflect niche misalignment rather than intrinsic stem-cell deficits. We argue that successful regenerative interventions must treat stem cells and their microenvironment as an inseparable therapeutic unit. Future advances will depend on high-resolution niche mapping, mechanobiologically informed scaffold design, and niche-targeted clinical trials. Re-programming pathological niches may unlock regenerative outcomes that surpass classical cell therapies, marking a new era of microenvironmentally integrated medicine.", "sentences": [], "annotations": [{"id": "4", "infons": {"identifier": "649", "type": "Gene", "ncbi_homologene": "55955", "valid": true, "normalized": [649], "database": "ncbi_gene", "normalized_id": 649, "biotype": "gene", "name": "BMP1", "accession": "@GENE_BMP1"}, "text": "BMP", "locations": [{"offset": 706, "length": 3}]}, {"id": "5", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 791, "length": 12}]}, {"id": "6", "infons": {"identifier": "MESH:D005355", "type": "Disease", "valid": true, "normalized": ["D005355"], "database": "ncbi_mesh", "normalized_id": "D005355", "biotype": "disease", "name": "Fibrosis", "accession": "@DISEASE_Fibrosis"}, "text": "fibrosis", "locations": [{"offset": 805, "length": 8}]}, {"id": "7", "infons": {"identifier": "2191", "type": "Gene", "ncbi_homologene": "48282", "valid": true, "normalized": [2191], "database": "ncbi_gene", "normalized_id": 2191, "biotype": "gene", "name": "FAP", "accession": "@GENE_FAP"}, "text": "FAP", "locations": [{"offset": 1108, "length": 3}]}], "relations": []}], "relations": [], "pmid": 40643502, "pmcid": null, "meta": {}, "date": "2025-06-26T00:00:00Z", "journal": "Cells", "authors": ["Yushkov B", "Chereshnev V", "Korneva E", "Yushkova V", "Sarapultsev A"], "relations_display": []}, {"_id": "40650709|None", "id": "40650709", "infons": {}, "passages": [{"infons": {"journal": "Adv Sci (Weinh);2025Jul12 02831. doi:10.1002/advs.202502831", "year": "2025", "type": "title", "authors": "Zhang S, Tan R, Meng S, Zhang K, Hu J, "}, "offset": 0, "text": "Wearable Bioelectronics for Home-Based Monitoring and Treatment of Muscle Atrophy.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "Muscle Atrophy", "locations": [{"offset": 67, "length": 14}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 83, "text": "Muscle atrophy is a chronic disease caused by multiple factors, and there is currently no effective treatment or reliable diagnostic method. Similar review articles focus on the induction and summary of the pathogenic mechanism and traditional treatment of muscle atrophy. However, soft, portable, and efficient bioelectronic devices that are expected to achieve home diagnosis and treatment of the disease are more concerned, hoping to realize complete home care as soon as possible. The article includes: 1) Classification and summary of muscle atrophy-related diseases and pathways; 2) Mechanical sensors, electromyography (EMG), electrochemical sensors, bioelectrical impedance analysis (BIA), and ultrasonic patches for monitoring muscle atrophy; 3) Transcutaneous electrotherapy, bioelectronic implants, bioelectronic drug delivery devices, and ExoMuscles for treating muscle atrophy; 4) Electrode-tissue interface problems in muscle atrophy bioelectronics and feasible solutions. 5) Recommendations and prospects for integrated bioelectronic systems for home diagnosis and treatment of muscle atrophy in the future.", "sentences": [], "annotations": [{"id": "9", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "Muscle atrophy", "locations": [{"offset": 83, "length": 14}]}, {"id": "10", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 340, "length": 14}]}, {"id": "11", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 623, "length": 14}]}, {"id": "12", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 819, "length": 14}]}, {"id": "13", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 958, "length": 14}]}, {"id": "14", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 1016, "length": 14}]}, {"id": "15", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle atrophy", "locations": [{"offset": 1176, "length": 14}]}], "relations": []}], "relations": [], "pmid": 40650709, "pmcid": null, "meta": {}, "date": "2025-07-12T00:00:00Z", "journal": "Adv Sci (Weinh)", "authors": ["Zhang S", "Tan R", "Meng S", "Zhang K", "Hu J"], "relations_display": []}, {"_id": "40653208|None", "id": "40653208", "infons": {}, "passages": [{"infons": {"journal": "Exp Gerontol;2025Jul11; 209 112831. doi:10.1016/j.exger.2025.112831", "year": "2025", "type": "title", "authors": "Toth MJ, Savage PD, Snoke DB, Bellefleur ER, DeSarno M, Tourville TW, Blankstein M, Keeble AR, Gonzalez-Velez S, Fry CS, Stevens-Lapsley J, Nelms NJ, "}, "offset": 0, "text": "Sustaining neuromuscular activation after total knee arthroplasty preserves skeletal muscle fiber size, contractility, and innervation in older adults.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 152, "text": "Knee osteoarthritis (OA) is the leading cause of physical disability in older adults. Total knee arthroplasty (TKA) is a common treatment for advanced stage knee OA that alleviates knee pain, but it is associated with precipitous reductions in physical function early after surgery that can take months or years to recover. Sustaining neuromuscular activation after surgery with neuromuscular electrical stimulation (NMES) can improve recovery of physical function, but the mechanisms underlying its benefits are unclear. To examine the unique effects of NMES on skeletal muscle, we randomized older adult patients (70 % female) to early NMES (n = 11) or no intervention (n = 12) for 5 weeks after surgery. We measured skeletal muscle (vastus lateralis) fiber size, contractility, mitochondrial content, and mRNA abundance pre-surgery and 5 weeks post-surgery. NMES diminished TKA-induced muscle fiber atrophy in fast-twitch, myosin heavy chain (MHC) IIA fibers and improved or preserved single muscle fiber contractility in MHC I and MHC IIA fibers, respectively. In MHC IIA fibers, the beneficial effects of NMES to sustain fiber force production were explained at the molecular level by preservation of strongly bound, myosin-actin crossbridges. Additionally, TKA-induced increases in markers of denervation (CHRNA1 and MYOG) in controls were prevented by NMES. Our results identify beneficial effects of sustaining neuromuscular activation early, post-TKA with NMES on skeletal muscle fiber size and function and potential molecular mechanisms underlying these effects.", "sentences": [], "annotations": [{"id": "10", "infons": {"identifier": "MESH:D020370", "type": "Disease", "valid": true, "normalized": ["D020370"], "database": "ncbi_mesh", "normalized_id": "D020370", "biotype": "disease", "name": "Osteoarthritis Knee", "accession": "@DISEASE_Osteoarthritis_Knee"}, "text": "Knee osteoarthritis", "locations": [{"offset": 152, "length": 19}]}, {"id": "11", "infons": {"identifier": "MESH:D010003", "type": "Disease", "valid": true, "normalized": ["D010003"], "database": "ncbi_mesh", "normalized_id": "D010003", "biotype": "disease", "name": "Osteoarthritis", "accession": "@DISEASE_Osteoarthritis"}, "text": "OA", "locations": [{"offset": 173, "length": 2}]}, {"id": "12", "infons": {"identifier": "MESH:D059445", "type": "Disease", "valid": true, "normalized": ["D059445"], "database": "ncbi_mesh", "normalized_id": "D059445", "biotype": "disease", "name": "Anhedonia", "accession": "@DISEASE_Anhedonia"}, "text": "physical disability", "locations": [{"offset": 201, "length": 19}]}, {"id": "13", "infons": {"identifier": "MESH:D020370", "type": "Disease", "valid": true, "normalized": ["D020370"], "database": "ncbi_mesh", "normalized_id": "D020370", "biotype": "disease", "name": "Osteoarthritis Knee", "accession": "@DISEASE_Osteoarthritis_Knee"}, "text": "knee OA", "locations": [{"offset": 309, "length": 7}]}, {"id": "14", "infons": {"identifier": "MESH:D046788", "type": "Disease", "valid": true, "normalized": ["D046788"], "database": "ncbi_mesh", "normalized_id": "D046788", "biotype": "disease", "name": "Patellofemoral Pain Syndrome", "accession": "@DISEASE_Patellofemoral_Pain_Syndrome"}, "text": "knee pain", "locations": [{"offset": 333, "length": 9}]}, {"id": "15", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "patients", "locations": [{"offset": 758, "length": 8}]}, {"id": "16", "infons": {"identifier": "MESH:D001284", "type": "Disease", "valid": true, "normalized": ["D001284"], "database": "ncbi_mesh", "normalized_id": "D001284", "biotype": "disease", "name": "Atrophy", "accession": "@DISEASE_Atrophy"}, "text": "atrophy", "locations": [{"offset": 1054, "length": 7}]}, {"id": "17", "infons": {"identifier": "79784", "type": "Gene", "ncbi_homologene": "23480", "valid": true, "normalized": [79784], "database": "ncbi_gene", "normalized_id": 79784, "biotype": "gene", "name": "MYH14", "accession": "@GENE_MYH14"}, "text": "myosin", "locations": [{"offset": 1374, "length": 6}]}, {"id": "18", "infons": {"identifier": "1134", "type": "Gene", "ncbi_homologene": "59", "valid": true, "normalized": [1134], "database": "ncbi_gene", "normalized_id": 1134, "biotype": "gene", "name": "CHRNA1", "accession": "@GENE_CHRNA1"}, "text": "CHRNA1", "locations": [{"offset": 1464, "length": 6}]}, {"id": "19", "infons": {"identifier": "4656", "type": "Gene", "ncbi_homologene": "1854", "valid": true, "normalized": [4656], "database": "ncbi_gene", "normalized_id": 4656, "biotype": "gene", "name": "MYOG", "accession": "@GENE_MYOG"}, "text": "MYOG", "locations": [{"offset": 1475, "length": 4}]}], "relations": []}], "relations": [], "pmid": 40653208, "pmcid": null, "meta": {}, "date": "2025-07-11T00:00:00Z", "journal": "Exp Gerontol", "authors": ["Toth MJ", "Savage PD", "Snoke DB", "Bellefleur ER", "DeSarno M", "Tourville TW", "Blankstein M", "Keeble AR", "Gonzalez-Velez S", "Fry CS", "Stevens-Lapsley J", "Nelms NJ"], "relations_display": []}, {"_id": "40659717|None", "id": "40659717", "infons": {}, "passages": [{"infons": {"journal": "Sci Rep;2025Jul15; 15 (1) 25439. doi:10.1038/s41598-025-10200-0", "year": "2025", "article-id_pmc": "PMC12259881", "type": "title", "authors": "Zhang P, Du Y, Zhong X, Wang Y, Pan T, "}, "offset": 0, "text": "Identification of potential shared core biomarkers in type 2 diabetes and sarcopenia.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes", "locations": [{"offset": 54, "length": 15}]}, {"id": "3", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 74, "length": 10}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 86, "text": "Type 2 diabetes (T2D) and sarcopenia (SA) commonly co-occur in clinical settings. This study aims to identify overlapping biomarkers for T2D and SA, thereby advancing the understanding of shared pathophysiological mechanisms. Gene expression data from the NCBI GEO database were analyzed to detect differentially expressed genes (DEGs) in T2D and SA using the limma package. Weighted Gene Co-expression Network Analysis (WGCNA) was applied to identify significant gene modules in each condition, followed by functional enrichment analysis. A risk assessment model was established and evaluated through Support Vector Machine (SVM) analysis. Additionally, regulatory networks, including miRNAs and transcription factors, were constructed to investigate gene regulation. qRT-PCR and western blotting were employed to validate the expression of these biomarkers in the muscle tissues of db/db mice. A total of 330 DEGs were identified in the T2D dataset, while 1054 were found in the SA dataset, with 50 overlapping genes. Key modules in each condition highlighted 30 shared genes, which were enriched in biological processes and pathways related to metabolic and immune functions. Fourteen intersecting hub genes exhibited significant differential expression across the disease datasets, supporting the development of a robust risk classification model. This model demonstrated strong predictive performance, with AUC values of 0.944 for T2D and 0.940 for SA. BDH1, FGF9, and LDHA were identified as key biomarkers through bioinformatics analysis and experimental validation. The identification of BDH1, FGF9, and LDHA offers both diagnostic value and potential therapeutic targets for T2D and SA, thus clarifying the shared pathogenesis of these diseases.", "sentences": [], "annotations": [{"id": "25", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "Type 2 diabetes", "locations": [{"offset": 86, "length": 15}]}, {"id": "26", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "T2D", "locations": [{"offset": 103, "length": 3}]}, {"id": "27", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 112, "length": 10}]}, {"id": "28", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "SA", "locations": [{"offset": 124, "length": 2}]}, {"id": "29", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "T2D", "locations": [{"offset": 223, "length": 3}]}, {"id": "30", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "SA", "locations": [{"offset": 231, "length": 2}]}, {"id": "31", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "T2D", "locations": [{"offset": 425, "length": 3}]}, {"id": "32", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "SA", "locations": [{"offset": 433, "length": 2}]}, {"id": "33", "infons": {"identifier": "10090", "type": "Species", "valid": true, "normalized": [10090], "database": "ncbi_taxonomy", "normalized_id": 10090, "biotype": "species", "name": "10090", "accession": null}, "text": "mice", "locations": [{"offset": 976, "length": 4}]}, {"id": "34", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "T2D", "locations": [{"offset": 1025, "length": 3}]}, {"id": "35", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "SA", "locations": [{"offset": 1067, "length": 2}]}, {"id": "36", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "T2D", "locations": [{"offset": 1522, "length": 3}]}, {"id": "37", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh"