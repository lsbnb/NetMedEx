": [{"offset": 1197, "length": 3}]}, {"id": "51", "infons": {"identifier": "MESH:D028361", "type": "Disease", "valid": true, "normalized": ["D028361"], "database": "ncbi_mesh", "normalized_id": "D028361", "biotype": "disease", "name": "Mitochondrial Diseases", "accession": "@DISEASE_Mitochondrial_Diseases"}, "text": "mitochondrial deficits", "locations": [{"offset": 1239, "length": 22}]}, {"id": "52", "infons": {"identifier": "MESH:D010300", "type": "Disease", "valid": true, "normalized": ["D010300"], "database": "ncbi_mesh", "normalized_id": "D010300", "biotype": "disease", "name": "Parkinson Disease", "accession": "@DISEASE_Parkinson_Disease"}, "text": "PD", "locations": [{"offset": 1274, "length": 2}]}, {"id": "53", "infons": {"identifier": "MESH:D007657", "type": "Chemical", "valid": true, "normalized": ["D007657"], "database": "ncbi_mesh", "normalized_id": "D007657", "biotype": "chemical", "name": "Ketone Bodies", "accession": "@CHEMICAL_Ketone_Bodies"}, "text": "KBs", "locations": [{"offset": 1291, "length": 3}]}, {"id": "54", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "glucose", "locations": [{"offset": 1495, "length": 7}]}, {"id": "55", "infons": {"identifier": "627", "type": "Gene", "ncbi_homologene": "7245", "valid": true, "normalized": [627], "database": "ncbi_gene", "normalized_id": 627, "biotype": "gene", "name": "BDNF", "accession": "@GENE_BDNF"}, "text": "brain-derived neurotrophic factor", "locations": [{"offset": 1582, "length": 33}]}, {"id": "56", "infons": {"identifier": "627", "type": "Gene", "ncbi_homologene": "7245", "valid": true, "normalized": [627], "database": "ncbi_gene", "normalized_id": 627, "biotype": "gene", "name": "BDNF", "accession": "@GENE_BDNF"}, "text": "BDNF", "locations": [{"offset": 1617, "length": 4}]}, {"id": "57", "infons": {"ide