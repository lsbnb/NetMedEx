": "6", "role": "39,41"}]}, {"id": "R8", "infons": {"score": "0.9828", "role1": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "role2": {"identifier": "5970", "type": "Gene", "valid": true, "normalized": [5970], "database": "ncbi_gene", "normalized_id": 5970, "biotype": "gene", "name": "RELA", "accession": "@GENE_RELA"}, "type": "Association"}, "nodes": [{"refid": "7", "role": "41,28"}]}, {"id": "R9", "infons": {"score": "0.9938", "role1": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "role2": {"identifier": "7124", "type": "Gene", "valid": true, "normalized": [7124], "database": "ncbi_gene", "normalized_id": 7124, "biotype": "gene", "name": "TNF", "accession": "@GENE_TNF"}, "type": "Positive_Correlation"}, "nodes": [{"refid": "8", "role": "41,40"}]}], "pmid": 40810394, "pmcid": null, "meta": {}, "date": "2025-08-01T00:00:00Z", "journal": "J Cachexia Sarcopenia Muscle", "authors": ["Park S", "Shin MK", "Jeong DS", "Yeo XY", "Kim YJ", "Muhammad J", "Kim M", "Gu S", "Lee JE", "Park Y", "Lim SB", "Mun JY", "Jung S", "Lee DR", "Jo J"], "relations_display": [{"name": "associate|@GENE_NFKB1|@GENE_NFKBIA"}, {"name": "associate|@GENE_AKT1|@GENE_NFKB1"}, {"name": "associate|@GENE_MYOD1|@GENE_PAX7"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_PAX7"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_MYOD1"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_NFKB1"}, {"name": "treat|@CHEMICAL_Testosterone|@DISEASE_Sarcopenia"}, {"name": "associate|@DISEASE_Sarcopenia|@GENE_RELA"}, {"name": "stimulate|@DISEASE_Sarcopenia|@GENE_TNF"}]}, {"_id": "40814109|None", "id": "40814109", "infons": {}, "passages": [{"infons": {"journal": "J Transl Med;2025Aug14; 23 (1) 910. doi:10.1186/s12967-025-06892-7", "year": "2025", "article-id_pmc": "PMC12355846", "type": "title", "authors": "Xiao J, Qin X, Chen W, Que X, Ma Y, Huang W, Ou H, Bao Y, Qu L, Shan S, "}, "offset": 0, "text": "Immunoinflammation and post-translational modifications in the aging process.", "sentences": [], "annotations": [], "relations": []}, {"infons": {"type": "abstract"}, "offset": 78, "text": "Aging is an intrinsic biological decline marked by multidimensional alterations spanning molecular, cellular, tissue, and organ levels. One hallmark of aging is the progressive deterioration of immune function, a condition referred to as immunosenescence. This process often involves a persistent, mild, and non-infectious inflammatory state across the body, commonly described as inflammaging. The regulation of age-related immune and inflammatory processes is critically influenced by epigenetic mechanisms, such as alterations in DNA methylation patterns, histone modifications, chromatin structure reorganization, and the regulatory actions of non-coding RNAs. Recent research has increasingly focused on the regulatory roles of post-translational modifications (PTMs), including histone methylation, acetylation, ubiquitination, and O-GlcNAcylation, have been widely recognized as fundamental modulators of immunoinflammatory processes in aging. In this review, we provide a comprehensive overview of histone modification-mediated mechanisms involved in the regulation of immunosenescence. We further highlight their functional roles from the perspective of immune inflammation and explore potential therapeutic strategies targeting histone modifications to mitigate immunosenescence.", "sentences": [], "annotations": [{"id": "5", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 401, "length": 12}]}, {"id": "6", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "inflammaging", "locations": [{"offset": 459, "length": 12}]}, {"id": "7", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammatory", "locations": [{"offset": 514, "length": 12}]}, {"id": "8", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "immunoinflammatory", "locations": [{"offset": 990, "length": 18}]}, {"id": "9", "infons": {"identifier": "MESH:D007249", "type": "Disease", "valid": true, "normalized": ["D007249"], "database": "ncbi_mesh", "normalized_id": "D007249", "biotype": "disease", "name": "Inflammation", "accession": "@DISEASE_Inflammation"}, "text": "inflammation", "locations": [{"offset": 1248, "length": 12}]}], "relations": []}], "relations": [], "pmid": 40814109, "pmcid": null, "meta": {}, "date": "2025-08-14T00:00:00Z", "journal": "J Transl Med", "authors": ["Xiao J", "Qin X", "Chen W", "Que X", "Ma Y", "Huang W", "Ou H", "Bao Y", "Qu L", "Shan S"], "relations_display": []}, {"_id": "40843857|None", "id": "40843857", "infons": {}, "passages": [{"infons": {"journal": "Medicines (Basel);2025Jul28; 12 (3) . doi:10.3390/medicines12030019", "year": "2025", "article-id_pmc": "PMC12372088", "type": "title", "authors": "Ullah MI, Tamanna S, "}, "offset": 0, "text": "Obesity: Clinical Impact, Pathophysiology, Complications, and Modern Innovations in Therapeutic Strategies.", "sentences": [], "annotations": [{"id": "1", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "Obesity", "locations": [{"offset": 0, "length": 7}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 108, "text": "Obesity is a growing global health concern with widespread impacts on physical, psychological, and social well-being. Clinically, it is a major driver of type 2 diabetes (T2D), cardiovascular disease (CVD), non-alcoholic fatty liver disease (NAFLD), and cancer, reducing life expectancy by 5-20 years and imposing a staggering economic burden of USD 2 trillion annually (2.8% of global GDP). Despite its significant health and socioeconomic impact, earlier obesity medications, such as fenfluramine, sibutramine, and orlistat, fell short of expectations due to limited effectiveness, serious side effects including valvular heart disease and gastrointestinal issues, and high rates of treatment discontinuation. The advent of glucagon-like peptide-1 (GLP-1) receptor agonists (e.g., semaglutide, tirzepatide) has revolutionized obesity management. These agents demonstrate unprecedented efficacy, achieving 15-25% mean weight loss in clinical trials, alongside reducing major adverse cardiovascular events by 20% and T2D incidence by 72%. Emerging therapies, including oral GLP-1 agonists and triple-receptor agonists (e.g., retatrutide), promise enhanced tolerability and muscle preservation, potentially bridging the efficacy gap with bariatric surgery. However, challenges persist. High costs, supply shortages, and unequal access pose significant barriers to the widespread implementation of obesity treatment, particularly in low-resource settings. Gastrointestinal side effects and long-term safety concerns require close monitoring, while weight regain after medication discontinuation emphasizes the need for ongoing adherence and lifestyle support. This review highlights the transformative potential of incretin-based therapies while advocating for policy reforms to address cost barriers, equitable access, and preventive strategies. Future research must prioritize long-term cardiovascular outcome trials and mitigate emerging risks, such as sarcopenia and joint degeneration. A multidisciplinary approach combining pharmacotherapy, behavioral interventions, and systemic policy changes is critical to curbing the obesity epidemic and its downstream consequences.", "sentences": [], "annotations": [{"id": "25", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "Obesity", "locations": [{"offset": 108, "length": 7}]}, {"id": "26", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "type 2 diabetes", "locations": [{"offset": 262, "length": 15}]}, {"id": "27", "infons": {"identifier": "MESH:D003924", "type": "Disease", "valid": true, "normalized": ["D003924"], "database": "ncbi_mesh", "normalized_id": "D003924", "biotype": "disease", "name": "Diabetes Mellitus Type 2", "accession": "@DISEASE_Diabetes_Mellitus_Type_2"}, "text": "T2D", "locations": [{"offset": 279, "length": 3}]}, {"id": "28", "infons": {"identifier": "MESH:D002318", "type": "Disease", "valid": true, "normalized": ["D002318"], "database": "ncbi_mesh", "normalized_id": "D002318", "biotype": "disease", "name": "Cardiovascular Diseases", "accession": "@DISEASE_Cardiovascular_Diseases"}, "text": "cardiovascular disease", "locations": [{"offset": 285, "length": 22}]}, {"id": "29", "infons": {"identifier": "MESH:D002318", "type": "Disease", "valid": true, "normalized": ["D002318"], "database": "ncbi_mesh", "normalized_id": "D002318", "biotype": "disease", "name": "Cardiovascular Diseases", "accession": "@DISEASE_Cardiovascular_Diseases"}, "text": "CVD", "locations": [{"offset": 309, "length": 3}]}, {"id": "30", "infons": {"identifier": "MESH:D065626", "type": "Disease", "valid": true, "normalized": ["D065626"], "database": "ncbi_mesh", "normalized_id": "D065626", "biotype": "disease", "name": "Non-alcoholic Fatty Liver Disease", "accession": "@DISEASE_Non_alcoholic_Fatty_Liver_Disease"}, "text": "non-alcoholic fatty liver disease", "locations": [{"offset": 315, "length": 33}]}, {"id": "31", "infons": {"identifier": "MESH:D065626", "type": "Disease", "valid": true, "normalized": ["D065626"], "database": "ncbi_mesh", "normalized_id": "D065626", "biotype": "disease", "name": "Non-alcoholic Fatty Liver Disease", "accession": "@DISEASE_Non_alcoholic_Fatty_Liver_Disease"}, "text": "NAFLD", "locations": [{"offset": 350, "length": 5}]}, {"id": "32", "infons": {"identifier": "MESH:D009369", "type": "Disease", "valid": true, "normalized": ["D009369"], "database": "ncbi_mesh", "normalized_id": "D009369", "biotype": "disease", "name": "Neoplasms", "accession": "@DISEASE_Neoplasms"}, "text": "cancer", "locations": [{"offset": 362, "length": 6}]}, {"id": "33", "infons": {"identifier": "MESH:D009765", "type": "Disease", "valid": true, "normalized": ["D009765"], "database": "ncbi_mesh", "normalized_id": "D009765", "biotype": "disease", "name": "Obesity", "accession": "@DISEASE_Obesity"}, "text": "obesity", "locations": [{"offset": 565, "length": 7}]}, {"id": "34", "infons": {"identifier": "MESH:D005277", "type": "Chemical", "valid": true, "normalized": ["D005277"], "database": "ncbi_mesh", "normalized_id": "D005277", "biotype": "chemical", "name": "Fenfluramine", "accession": "@CHEMICAL_Fenfluramine"}, "text": "fenfluramine", "locations": [{"offset": 594, "length": 12}]}, {"id": "35", "infons": {"identifier": "MESH:C058254", "type": "Chemical", "valid": true, "normalized": ["C058254"], "database": "ncbi_mesh", "normalized_id": "C058254", "biotype": "chemical", "name": "sibutramine", "accession": "@CHEMICAL_s