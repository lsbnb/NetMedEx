"103", "infons": {"identifier": "MESH:D009135", "type": "Disease", "valid": true, "normalized": ["D009135"], "database": "ncbi_mesh", "normalized_id": "D009135", "biotype": "disease", "name": "Muscular Diseases", "accession": "@DISEASE_Muscular_Diseases"}, "text": "muscle dysfunction", "locations": [{"offset": 1939, "length": 18}]}], "relations": []}], "relations": [{"id": "R1", "infons": {"score": "0.8325", "role1": {"identifier": "MESH:C477224", "type": "Chemical", "valid": true, "normalized": ["C477224"], "database": "ncbi_mesh", "normalized_id": "C477224", "biotype": "chemical", "name": "erastin", "accession": "@CHEMICAL_erastin"}, "role2": {"identifier": "MESH:D017962", "type": "Chemical", "valid": true, "normalized": ["D017962"], "database": "ncbi_mesh", "normalized_id": "D017962", "biotype": "chemical", "name": "alpha-Linolenic Acid", "accession": "@CHEMICAL_alpha_Linolenic_Acid"}, "type": "Negative_Correlation"}, "nodes": [{"refid": "0", "role": "48,41"}]}, {"id": "R2", "infons": {"score": "0.8311", "role1": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "role2": {"identifier": "MESH:D017382", "type": "Chemical", "valid": true, "normalized": ["D017382"], "database": "ncbi_mesh", "normalized_id": "D017382", "biotype": "chemical", "name": "Reactive Oxygen Species", "accession": "@CHEMICAL_Reactive_Oxygen_Species"}, "type": "Association"}, "nodes": [{"refid": "1", "role": "37,36"}]}, {"id": "R3", "infons": {"score": "0.9415", "role1": {"identifier": "MESH:D008055", "type": "Chemical", "valid": true, "normalized": ["D008055"], "database": "ncbi_mesh", "normalized_id": "D008055", "biotype": "chemical", "name": "Lipids", "accession": "@CHEMICAL_Lipids"}, "role2": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "type": "Association"}, "nodes": [{"refid": "2", "role": "37,9"}]}], "pmid": 41509286, "pmcid": null, "meta": {}, "date": "2025-12-29T00:00:00Z", "journal": "bioRxiv", "authors": ["Lu X", "Sharko OL", "Shmanai VV", "Shchepinov MS", "Markworth JF"], "relations_display": [{"name": "negative_correlate|@CHEMICAL_erastin|@CHEMICAL_alpha_Linolenic_Acid"}, {"name": "associate|@CHEMICAL_Lipids|@CHEMICAL_Reactive_Oxygen_Species"}, {"name": "associate|@CHEMICAL_Lipids|@DISEASE_Muscular_Atrophy"}]}, {"_id": "41511097|None", "id": "41511097", "infons": {}, "passages": [{"infons": {"journal": "Physiol Res;2025Dec31; 74 (Suppl 1) 37", "year": "2025", "type": "title", "authors": "Horv&#xe1;th L, Peka&#x159; M, &#x160;vagera Z, Hork&#xe1; V, Mr&#xe1;z M, Bu&#x17e;ga M, "}, "offset": 0, "text": "Skeletal Muscle as an Auto-, Para- and Endocrine Organ: The Role of Myokines in Muscle Metabolism and Other Metabolic Organs.", "sentences": [], "annotations": [{"id": "1", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "Myokines", "locations": [{"offset": 68, "length": 8}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 126, "text": "Skeletal musculature represents the largest organ in the human body, playing a vital role in systemic metabolism, physiological functions, and glucose homeostasis. Skeletal muscles are also a significant source of multiple humoral factors, including myokines, which are, as part of the muscular secretome, involved in cellular signaling within and outside of the muscle. Myokines are a group of cytokines that exert a major influence on muscle metabolism through autocrine mechanisms and are involved in para- or endocrine regulation in organs outside of muscle tissue, such as the pancreas, adipose tissue, liver, heart, bone, gastrointestinal tract, and brain. In the future, these findings could be crucial for the identification of important biomarkers used for the monitoring of physical activity in the treatment of pathologies such as intensive care-associated muscle wasting, sarcopenia, diabetes, neurodegenerative diseases, etc. As skeletal muscle tissue is intrinsically linked to multiple types of tissues and organs metabolically, functionally, and most importantly, regionally, there can be a significant overlap between the auto- and paracrine effects of myokines, depending on the presence of that myokine. The following section will discuss the auto-, para-, and endocrine effects of some of the myo-inducible cytokines on skeletal muscles and adjacent tissue types. Key words Skeletal muscle cells \" Myokines \" Secretome \" Autocrine effect \" Paracrine effect.", "sentences": [], "annotations": [{"id": "9", "infons": {"identifier": "9606", "type": "Species", "valid": true, "normalized": [9606], "database": "ncbi_taxonomy", "normalized_id": 9606, "biotype": "species", "name": "9606", "accession": null}, "text": "human", "locations": [{"offset": 183, "length": 5}]}, {"id": "10", "infons": {"identifier": "MESH:D005947", "type": "Chemical", "valid": true, "normalized": ["D005947"], "database": "ncbi_mesh", "normalized_id": "D005947", "biotype": "chemical", "name": "Glucose", "accession": "@CHEMICAL_Glucose"}, "text": "glucose", "locations": [{"offset": 269, "length": 7}]}, {"id": "11", "infons": {"identifier": "MESH:D009133", "type": "Disease", "valid": true, "normalized": ["D009133"], "database": "ncbi_mesh", "normalized_id": "D009133", "biotype": "disease", "name": "Muscular Atrophy", "accession": "@DISEASE_Muscular_Atrophy"}, "text": "muscle wasting", "locations": [{"offset": 994, "length": 14}]}, {"id": "12", "infons": {"identifier": "MESH:D055948", "type": "Disease", "valid": true, "normalized": ["D055948"], "database": "ncbi_mesh", "normalized_id": "D055948", "biotype": "disease", "name": "Sarcopenia", "accession": "@DISEASE_Sarcopenia"}, "text": "sarcopenia", "locations": [{"offset": 1010, "length": 10}]}, {"id": "13", "infons": {"identifier": "MESH:D003920", "type": "Disease", "valid": true, "normalized": ["D003920"], "database": "ncbi_mesh", "normalized_id": "D003920", "biotype": "disease", "name": "Diabetes Mellitus", "accession": "@DISEASE_Diabetes_Mellitus"}, "text": "diabetes", "locations": [{"offset": 1022, "length": 8}]}, {"id": "14", "infons": {"identifier": "MESH:D019636", "type": "Disease", "valid": true, "normalized": ["D019636"], "database": "ncbi_mesh", "normalized_id": "D019636", "biotype": "disease", "name": "Neurodegenerative Diseases", "accession": "@DISEASE_Neurodegenerative_Diseases"}, "text": "neurodegenerative diseases", "locations": [{"offset": 1032, "length": 26}]}, {"id": "15", "infons": {"type": "Disease", "valid": false, "normalized_id": null, "biotype": "disease"}, "text": "Myokines", "locations": [{"offset": 1544, "length": 8}]}], "relations": []}], "relations": [], "pmid": 41511097, "pmcid": null, "meta": {}, "date": "2025-12-31T00:00:00Z", "journal": "Physiol Res", "authors": ["Horváth L", "Pekař M", "Švagera Z", "Horká V", "Mráz M", "Bužga M"], "relations_display": []}, {"_id": "41512056|None", "id": "41512056", "infons": {}, "passages": [{"infons": {"journal": "Sci Adv;2026Jan09; 12 (2) 0766. doi:10.1126/sciadv.aec0766", "year": "2026", "article-id_pmc": "PMC12787525", "type": "title", "authors": "Han X, Shen J, Yan J, Tacke R, Dai W, Mao Q, Queen Daguplo H, Liu S, Islam A, Liu T, Koch MC, Lin RZ, Li H, Anthony T, Xie P, Zhang L, Gao S, Simon MC, Chen X, Yang J, Su X, Zong WX, "}, "offset": 0, "text": "Impaired nitrogenous waste clearance promotes hepatocellular carcinoma.", "sentences": [], "annotations": [{"id": "2", "infons": {"identifier": "MESH:D007222", "type": "Disease", "valid": true, "normalized": ["D007222"], "database": "ncbi_mesh", "normalized_id": "D007222", "biotype": "disease", "name": "Inert Gas Narcosis", "accession": "@DISEASE_Inert_Gas_Narcosis"}, "text": "nitrogenous waste", "locations": [{"offset": 9, "length": 17}]}, {"id": "3", "infons": {"identifier": "MESH:D006528", "type": "Disease", "valid": true, "normalized": ["D006528"], "database": "ncbi_mesh", "normalized_id": "D006528", "biotype": "disease", "name": "Carcinoma Hepatocellular", "accession": "@DISEASE_Carcinoma_Hepatocellular"}, "text": "hepatocellular carcinoma", "locations": [{"offset": 46, "length": 24}]}], "relations": []}, {"infons": {"type": "abstract"}, "offset": 72, "text": "In mammals, hepatic urea cycle enzymes (UCEs) convert ammonia, the toxic nitrogenous waste, into urea for excretion. In hepatocellular carcinoma (HCC), UCE expression is often heterogeneously repressed, but its role in tumorigenesis is unclear. We show that, as in patients, UCE expression is markedly reduced in multiple HCC mouse models, including those driven by oncogenic c-MET/beta-catenin, leading to impaired ammonia clearance, altered amino acid metabolism, and increased pyrimidine synthesis. In contrast, UCE expression is largely preserved in c-MET/sgAxin1 tumors, allowing assessment of the consequences of UCE loss. Silencing individual UCEs increases ammonia burden and accelerates HCC with reprogrammed amino acid and pyrimidine metabolism, supporting a causal role for defective ammonia detoxification in oncogenesis. Notably, dietary protein restriction lowers hepatic ammonia and slows tumor growth. These findings establish a mechanistic link between nitrogen overload and hepatocarcinogenesis and highlight protein restriction as a feasible therapeutic strategy for patients with impaired nitrogenous waste handling.", "sentences": [], "annotations": [{"id": "37", "infons": {"identifier": "MESH:D014508", "type": "Chemical", "valid": true, "normalized": ["D014508"], "database": "ncbi_mesh", "normalized_id": "D014508", "biotype": "chemical", "name": "Urea", "accession": "@CHEMICAL_Urea"}, "text": "urea", "locations": [{"offset": 92, "length": 4}]}, {"id": "38", "infons": {"identifier": "MESH:D000641", "type": "Chemical", "valid": true, "normalized": ["D000641"], "database": "ncbi_mesh", "normalized_id": "D000641", "biotype": "chemical", "name": "Ammonia", "accession": "@CHEMICAL_Ammonia"}, "text": "ammonia", "locations": [{"offset": 126, "length": 7}]}, {"id": "39", "infons": {"identifier": "MESH:D007222", "type": "Disease", "valid": true, "normalized": ["D007222"], "database": "ncbi_mesh", "normalized_id": "D007222", "biotype": "disease", "name": "Inert Gas Narcosis", "accession": "@DISEASE_Inert_Gas_Narcosis"}, "text": "nitrogenous waste", "locations": [{"offset": 145, "length": 17}]}, {"id": "40", "infons": {"identifier": "MESH:D014508", "type": "Chemical", "valid": true, "normalized": ["D014508"], "database": "ncbi_mesh", "normalized_id": "D014508", "biotype": "chemical", "name": "Urea", "accession": "@CHEMICAL_Urea"}, "text": "urea", "locations": [{"offset": 169, "length": 4}]}, {"id": "41", "infons": {"identifier": "MESH:D006528", "type": "Disease", "valid": true, "normalized": ["D006528"], "database": "ncbi_mesh", "normalized_id": "D006528", "biotype": "disease", "name": "Carcinoma Hepatocellular", "accession": "@DISEASE_Carcinoma_Hepatocellular"}, "text": "hepatocellular carcinoma", "locations": [{"offset": 192, "length": 24}]}, {"id": "42", "infons": {"identifier": "MESH:D006528", "type": "Disease", "valid": true, "normalized": ["D006528"], "database": "ncbi_mesh", "normalized_id": "D006528", "biotype": "disease", "name": "Carcinoma Hepatocellular", "accession": "@DISEASE_Carcinoma_Hepatocellular"}, "text": "HCC", "locations": [{"offset": 218, "length": 3}]}, {"id": "43", "infons": {"identifier": "51172", "type": "Gene", "ncbi_homologene": "8466", "valid": true, "normalized": [51172], "database": "ncbi_gene", "normalized_id": 51172, "biotype": "gene", "name": "NAGPA", "accession": "@GENE_NAGPA"}, "text": "UCE", "locations": [{"offset": 224, "length": 3}]}, {"id": "44", "infons": {"identifier": "MESH:D063646", "type": "Disease", "vali