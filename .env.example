# NetMedEx Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── LLM Provider Selection ─────────────────────────────────────────────────────
# Options: openai | google | openrouter | anthropic | groq | nvidia | local
LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key: https://aistudio.google.com/
# GEMINI_API_KEY=your-gemini-key-here
# GOOGLE_MODEL=gemini-2.0-flash
# GOOGLE_SAFETY_SETTING=medium

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Get your key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get your key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Groq ──────────────────────────────────────────────────────────────────────
# Get your key: https://console.groq.com/
# GROQ_API_KEY=your-groq-key-here
# GROQ_MODEL=llama-3.3-70b-versatile

# ── NVIDIA NIM ────────────────────────────────────────────────────────────────
# Get your key: https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-your-nvidia-key-here
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# ── Local / Ollama ────────────────────────────────────────────────────────────
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3.1
# LOCAL_LLM_API_KEY=local-dummy-key

# ── Web Application ───────────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8050
# LOGGING_DEBUG=false
# FLASK_DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# Auto-generated by start_webapp.sh if not set. Override to share across processes.
# NETMEDEX_SESSION_SECRET=your-random-secret-here

# Allow writing .env from the web UI (disabled by default for security)
# NETMEDEX_ALLOW_WEB_ENV_WRITE=false

# Allow uploading graph pickle files (disabled by default)
# ALLOW_UNSAFE_GRAPH_PICKLE_UPLOAD=false
